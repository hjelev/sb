${logo_block}

Usage: sb [--export-path FILE] [--update] [--version] [--help]

Options:
  --export-path FILE  Write final working directory to FILE on exit.
  --update            Update Shell Buddy in its current install directory using install.sh.
  --version           Show script version and exit.
  --help              Show this help text and exit.
EOF
    }

    parse_args() {
      while (($# > 0)); do
        case "$1" in
          --export-path)
            if [[ -z "${2-}" ]]; then
              echo "Error: --export-path requires a file path." >&2
              exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
          --help)
            usage
            exit 0
            ;;
          --update)
            self_update
            exit 0
            ;;
          --version)
            sb_name_with_version
            printf '\n'
            exit 0
            ;;
          *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
        esac
      done
    }

    init_runtime_config() {
      local split_value
      local idle_ms

      if [[ "$SB_SHOW_DEBUG_FOOTER" == "1" ]]; then
        SHOW_DEBUG_FOOTER=1
      else
        SHOW_DEBUG_FOOTER=0
      fi

      if [[ "$SB_PREVIEW_SPLIT_PCT" =~ ^[0-9]+$ ]]; then
        split_value=$SB_PREVIEW_SPLIT_PCT
      else
        split_value=30
      fi
      (( split_value < 20 )) && split_value=20
      (( split_value > 70 )) && split_value=70
      PREVIEW_SPLIT_PCT=$split_value

      if [[ -n "$SB_PREVIEW_SEPARATOR_CHAR" ]]; then
        PREVIEW_SEPARATOR_CHAR="${SB_PREVIEW_SEPARATOR_CHAR:0:1}"
      else
        PREVIEW_SEPARATOR_CHAR="│"
      fi

      if [[ "$SB_PREVIEW_COLORS" == "0" ]]; then
        PREVIEW_COLORS=0
      else
        PREVIEW_COLORS=1
      fi

      if [[ "$SB_PREVIEW_RELEASE_IDLE_MS" =~ ^[0-9]+$ ]]; then
        idle_ms=$SB_PREVIEW_RELEASE_IDLE_MS
      elif [[ "$SB_PREVIEW_IDLE_MS" =~ ^[0-9]+$ ]]; then
        idle_ms=$SB_PREVIEW_IDLE_MS
      else
        idle_ms=700
      fi
      (( idle_ms < 100 )) && idle_ms=100
      (( idle_ms > 5000 )) && idle_ms=5000
      PREVIEW_RELEASE_IDLE_MS=$idle_ms
    }

    detect_runtime_capabilities() {
      local uname_s now_value

      uname_s="$(uname -s 2>/dev/null || printf '')"
      [[ "$uname_s" == "Darwin" ]] && IS_DARWIN=1 || IS_DARWIN=0

      if ls --version >/dev/null 2>&1; then
        HAS_GNU_LS=1
      else
        HAS_GNU_LS=0
      fi

      now_value="$(date +%s%N 2>/dev/null || printf '')"
      if [[ "$now_value" =~ ^[0-9]+$ && "$now_value" != *N* ]]; then
        HAS_DATE_NANOSECONDS=1
      else
        HAS_DATE_NANOSECONDS=0
      fi
    }

    append_array_value() {
      local array_name="$1"
      local value="$2"
      eval "$array_name+=(\"\$value\")"
    }

    read_stdin_into_array() {
      local array_name="$1"
      local line

      eval "$array_name=()"
      while IFS= read -r line || [[ -n "$line" ]]; do
        append_array_value "$array_name" "$line"
      done
    }

    lowercase_string() {
      printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
