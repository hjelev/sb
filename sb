        upload_url=${upload_url//$'\r'/}
        upload_url=${upload_url%%$'\n'*}

        if (( upload_rc == 0 )) && [[ -n "$upload_url" ]] && [[ "$upload_url" =~ ^https?:// ]]; then
            # Success - URL was returned
            LAST_UPLOAD_URL="$upload_url"
            
            # Copy URL to clipboard
            if string_to_clipboard "$upload_url"; then
                cb_status="${STATUS_LABEL}✓ copied${NC}"
            else
                cb_status="${AMBER}(no clipboard tool)${NC}"
            fi

            draw_ui
            printf "\033[$((max_rows + 3));1H\033[K%b" "${CYAN}${upload_url}${NC} ${cb_status}"
            redraw_cursor
            sleep 3
        else
            # Error - show what went wrong
            draw_ui
            printf "\033[$((max_rows + 3));1H\033[K%b" "${AMBER}✗ Upload error (code: $upload_rc)${NC}\n"
