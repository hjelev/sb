#!/usr/bin/env bash
VERSION=""

usage() {
    cat <<'EOF'
Usage: sb [--export-path FILE] [-w WIDTH] [--update] [-i|--int] [--version] [--help]

Options:
    --export-path FILE  Write the final working directory to FILE on exit.
        -w, --width WIDTH   Set initial name column width (10-60).
  -i, --int           Show status of available integrations and exit.
  --update            Reinstall/update sb using the installer script.
  --version           Print the sb version and exit.
  --help              Show this help text and exit.
EOF
}

update_self() { curl -fsSL "${SB_INSTALLER_URL:-https://raw.githubusercontent.com/hjelev/sb/master/install.sh}" | bash -s -- --install-dir "$(cd "$(dirname "$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")")" && pwd -P)";}
show_integrations() {
    local -a integrations=("git" "chafa" "glow" "csvlens" "jnv" "ouch" "fuse-zip" "age" "pdftotext" "sox" "bat" "fzf" "rg" "delta" "dust" "vidir" "sshfs")

    get_moreutils_version() {
        local ver=""

        if command -v dpkg-query >/dev/null 2>&1; then
            ver=$(dpkg-query -W -f='${Version}' moreutils 2>/dev/null | head -n 1)
        fi
        if [[ -z "$ver" ]] && command -v pacman >/dev/null 2>&1; then
            ver=$(pacman -Q moreutils 2>/dev/null | awk '{print $2; exit}')
        fi
        if [[ -z "$ver" ]] && command -v rpm >/dev/null 2>&1; then
            ver=$(rpm -q --qf '%{VERSION}-%{RELEASE}' moreutils 2>/dev/null | head -n 1)
        fi
        if [[ -z "$ver" ]] && command -v brew >/dev/null 2>&1; then
            ver=$(brew list --versions moreutils 2>/dev/null | awk '{print $2; exit}')
        fi

        printf "%s" "$ver"
    }

    get_tool_version_line() {
        local tool="$1"
        local out=""
        case "$tool" in
            pdftotext)
                out=$("$tool" -v 2>&1 | head -n 1)
                ;;
            sshfs)
                out=$("$tool" -V 2>&1 | head -n 1)
                ;;
            vidir)
                local mu_ver
                mu_ver=$(get_moreutils_version)
                [[ -n "$mu_ver" ]] && out="moreutils $mu_ver" || out=""
                ;;
            *)
                out=$("$tool" --version 2>&1 | head -n 1)
                [[ -z "$out" ]] && out=$("$tool" -V 2>&1 | head -n 1)
                ;;
        esac
        if [[ "$out" =~ [Uu]nknown[[:space:]]+option|[Ii]nvalid[[:space:]]+option|[Uu]nrecognized[[:space:]]+option ]]; then
            out=""
        fi
        [[ -z "$out" ]] && out="version info unavailable"
        printf "%s" "$out"
    }

    get_tool_version_short() {
        local version_line="$1"
        local short=""
        if [[ "$version_line" == "version info unavailable" ]]; then
            printf "%s" "version unavailable"
            return
        fi
        short=$(printf "%s" "$version_line" | grep -oE '[0-9]+(\.[0-9]+){1,}' | head -n 1)
        [[ -z "$short" ]] && short="$version_line"
        printf "%s" "$short"
    }

    get_tool_description() {
        local tool="$1"
        case "$tool" in
            git) printf "Show current branch in header; add * for unstaged changes" ;;
            chafa) printf "Image preview in terminal" ;;
            glow) printf "Markdown preview" ;;
            csvlens) printf "Delimited file preview (.csv, .tsv, .tab, .psv, .dsv)" ;;
            jnv) printf "JSON preview (.json, .jsonl, .ndjson, .geojson)" ;;
            ouch) printf "Archive content preview via 'ouch list'" ;;
            fuse-zip) printf "Browse ZIP-based archives as folders (.zip, .jar, .apk, .docx, .xlsx, .pptx, .odt, .ods, .odp, .epub, .cbz, .xpi, etc.)" ;;
            age) printf "Encrypt/decrypt files with passphrase (toggle using p)" ;;
            pdftotext) printf "PDF text preview (uses 'bat' when available, otherwise 'less')" ;;
            sox) printf "Audio preview/playback for sound files" ;;
            bat) printf "Syntax highlighting for code files" ;;
            fzf) printf "Fuzzy finder for directory/file jumping" ;;
            rg) printf "Ripgrep for fast text search" ;;
            delta) printf "Enhanced diff viewer for file comparison" ;;
            dust) printf "Disk usage analyzer (shows folder sizes and percentages)" ;;
            vidir) printf "Batch rename (moreutils): selected items, or all visible if none selected" ;;
            sshfs) printf "SSH filesystem: browse remote hosts via sshfs (press S for picker)" ;;
            *) printf "" ;;
        esac
    }

    printf "%b" "${CYAN}Available Integrations:\n\n${NC}"
    for tool in "${integrations[@]}"; do
        local description
        description=$(get_tool_description "$tool")
        if command -v "$tool" &>/dev/null; then
            local version version_short
            version=$(get_tool_version_line "$tool")
            version_short=$(get_tool_version_short "$version")
            printf "  ${GREEN}✓${NC} %-32s ${STATUS_LABEL}-${NC} %s\n" "${tool} (${version_short})" "$description"
        else
            printf "  ${RED}✗${NC} ${AMBER}%-32s${NC} ${STATUS_LABEL}-${NC} %s\n" "${tool} (not installed)" "$description"
        fi
    done
}
