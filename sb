    is_binary_file_quick() {
      local item="$1"
      local sample_bytes=0 nontext_bytes=0 mime="" desc="" mime_lc="" desc_lc=""

      [[ -f "$item" ]] || return 1

      # Shebang files are text scripts even without extensions.
      if [[ "$(LC_ALL=C head -c 2 -- "$item" 2>/dev/null)" == '#!' ]]; then
        return 1
      fi

      # Fast path: a NUL byte in the first 4KiB is a strong binary signal.
      if LC_ALL=C head -c 4096 -- "$item" 2>/dev/null | grep -qU $'\x00'; then
        return 0
      fi

      if command -v file >/dev/null 2>&1; then
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        desc="$(file --brief -- "$item" 2>/dev/null || true)"
        mime_lc="$(lowercase_string "$mime")"
        desc_lc="$(lowercase_string "$desc")"

        case "$mime_lc" in
          text/*|application/json|application/xml|application/x-sh|application/javascript|application/x-empty|application/x-shellscript|application/x-python|application/x-perl|application/x-ruby)
            return 1
            ;;
          image/*|audio/*|video/*|font/*|application/pdf|application/zip|application/x-7z-compressed|application/x-tar|application/gzip|application/x-executable|application/x-pie-executable|application/x-sharedlib|application/x-object)
            return 0
            ;;
          *)
            ;;
        esac

        if [[ "$desc_lc" == *text* || "$desc_lc" == *script* || "$desc_lc" == *source* || "$desc_lc" == *utf-* || "$desc_lc" == *unicode* ]]; then
          return 1
        fi

        if [[ "$desc_lc" == *executable* || "$desc_lc" == *"shared object"* || "$desc_lc" == *archive* || "$desc_lc" == *"image data"* || "$desc_lc" == *audio* || "$desc_lc" == *video* || "$desc_lc" == *pdf* || "$desc_lc" == *font* ]]; then
          return 0
        fi
      fi

      # Heuristic: treat mostly-printable samples as text, even without extension.
      sample_bytes="$(LC_ALL=C head -c 4096 -- "$item" 2>/dev/null | wc -c | tr -d '[:space:]')"
      nontext_bytes="$(LC_ALL=C head -c 4096 -- "$item" 2>/dev/null | tr -d '\11\12\15\40-\176' | wc -c | tr -d '[:space:]')"
      [[ -z "$sample_bytes" ]] && sample_bytes=0
      [[ -z "$nontext_bytes" ]] && nontext_bytes=0

      if (( sample_bytes == 0 )); then
        return 1
      fi

      # <= 20% non-printable bytes in sample: likely text/source/script.
      if (( nontext_bytes * 100 <= sample_bytes * 20 )); then
        return 1
      fi

      if [[ -n "$mime_lc" && "$mime_lc" != "application/octet-stream" ]]; then
        return 0
      fi

      # Fallback for ambiguous files: require stronger non-text signal before binary.
      if (( nontext_bytes * 100 >= sample_bytes * 35 )); then
        return 0
      fi

      return 1
    }

    should_use_hex_fallback_file() {
      local item="$1"
      local mime_probe=""
      local desc_probe=""
      local desc_probe_lc=""

      is_binary_file_quick "$item" || return 1

      if command -v file >/dev/null 2>&1; then
        mime_probe="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        desc_probe="$(file --brief -- "$item" 2>/dev/null || true)"
        desc_probe_lc="$(lowercase_string "$desc_probe")"

        if [[ "$mime_probe" == text/* || "$desc_probe_lc" == *text* || "$desc_probe_lc" == *script* || "$desc_probe_lc" == *source* ]]; then
          return 1
        fi
      fi

      return 0
    }

