                *.md|*.markdown) file_icons+=("$ICON_MARKDOWN") ;;
                *.xml) file_icons+=("$ICON_XML") ;;
                *.csv) file_icons+=("$ICON_CSV") ;;
                *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg|*.heic|*.avif) file_icons+=("$ICON_IMAGE") ;;
                *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v|*.ogv|*.wmv) file_icons+=("$ICON_VIDEO") ;;
                *.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a|*.opus|*.wma) file_icons+=("$ICON_AUDIO") ;;
                *.zip|*.tar|*.tar.gz|*.tgz|*.bz2|*.xz|*.rar|*.7z|*.gz|*.zst) file_icons+=("$ICON_ARCHIVE") ;;
                *.pdf|*.doc|*.docx|*.odt|*.rtf|*.xls|*.xlsx|*.ppt|*.pptx) file_icons+=("$ICON_DOCUMENT") ;;
                *.sh|*.bash|*.zsh|*.fish|*.rb|*.pl|*.php|*.lua|*.ps1) file_icons+=("$ICON_SCRIPT") ;;
