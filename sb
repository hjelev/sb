      fi
    }

    zip_mount_for_archive() {
      local archive="$1"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        printf '%s' "${ZIP_MOUNT_BY_ARCHIVE[$archive]-}"
        return 0
      fi

      for i in "${!ZIP_MOUNT_ARCHIVES[@]}"; do
        if [[ "${ZIP_MOUNT_ARCHIVES[$i]}" == "$archive" ]]; then
          printf '%s' "${ZIP_MOUNT_POINTS[$i]}"
          return 0
        fi
      done
      return 0
    }

    zip_archive_for_mount() {
      local mountpoint="$1"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        printf '%s' "${ZIP_ARCHIVE_BY_MOUNT[$mountpoint]-}"
        return 0
      fi

      for i in "${!ZIP_ARCHIVE_MOUNTS[@]}"; do
        if [[ "${ZIP_ARCHIVE_MOUNTS[$i]}" == "$mountpoint" ]]; then
          printf '%s' "${ZIP_ARCHIVE_ARCHIVES[$i]}"
