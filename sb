    path_is_image_file() {
      local item="$1"
      local mime=""
      local lower=""

      [[ -f "$item" ]] || return 1

      if command -v file >/dev/null 2>&1; then
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        [[ "$mime" == image/* ]] && return 0
      fi

      lower="$(printf '%s' "$item" | tr '[:upper:]' '[:lower:]')"
      case "$lower" in
        *.png|*.jpg|*.jpeg|*.gif|*.bmp|*.webp|*.tif|*.tiff|*.svg|*.avif|*.heic|*.heif|*.ico)
          return 0
          ;;
      esac
      return 1
    }

    run_chafa_image_gallery() {
      local current_item="$1"
      shift
      local -a chafa_args=("$@")
      local current_abs current_dir
      local key item rc=0 i cursor_idx
      local -a all_files=()
      local -a images=()

      if [[ "$current_item" == /* ]]; then
        current_abs="$current_item"
      else
        current_abs="$(pwd -P 2>/dev/null || pwd)/${current_item#./}"
      fi
      current_dir="$(path_dirname "$current_abs")"

      while IFS= read -r -d '' item; do
        all_files+=("$item")
      done < <(find "$current_dir" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)

      for item in "${all_files[@]}"; do
        if path_is_image_file "$item"; then
          images+=("$item")
        fi
      done

      if (( ${#images[@]} == 0 )); then
        run_interactive_preview_command chafa "${chafa_args[@]}" -- "$current_item"
        return $?
      fi

      cursor_idx=0
      for i in "${!images[@]}"; do
        if [[ "${images[$i]}" == "$current_abs" ]]; then
          cursor_idx=$i
          break
        fi
      done

      disable_mouse_tracking
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true

      while true; do
        clear
        chafa "${chafa_args[@]}" -- "${images[$cursor_idx]}"
        rc=$?
        if (( rc != 0 )); then
          break
        fi

        printf "\n\033[2m[%d/%d] ← previous  → next  any other key return\033[0m" "$((cursor_idx + 1))" "${#images[@]}"

        stty -echo cbreak -ixon intr undef
        key="$(read_key || true)"
        stty "$orig_stty" 2>/dev/null || true

        case "$key" in
          "$KEY_RIGHT")
            if (( cursor_idx + 1 < ${#images[@]} )); then
              ((cursor_idx++))
              continue
            fi
            ;;
          "$KEY_LEFT")
            if (( cursor_idx > 0 )); then
              ((cursor_idx--))
              continue
            fi
            ;;
        esac
        break
      done

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      enable_mouse_tracking
      on_resize
      PREVIEW_FOCUS_PATH="${images[$cursor_idx]}"
      return $rc
    }

    run_audio_preview_command() {
      local rc=0
      local key=""
      local pid=0
      local paused=0

      disable_mouse_tracking
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear

      "$@" &
      pid=$!

      # Poll keys while playback runs; q/Esc/Ctrl+C stop, Space toggles pause/resume.
      stty -echo -icanon -ixon intr undef min 0 time 1
      while kill -0 "$pid" 2>/dev/null; do
        IFS= read -rsn1 key || true
        case "$key" in
          q|$'\e'|$'\003')
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            rc=130
            break
            ;;
          ' ')
            if (( paused )); then
              kill -CONT "$pid" 2>/dev/null || true
              paused=0
            else
              kill -STOP "$pid" 2>/dev/null || true
              paused=1
            fi
            ;;
        esac
      done

      if (( rc == 0 )); then
        wait "$pid" 2>/dev/null || rc=$?
      fi

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      enable_mouse_tracking
      on_resize
      return $rc
    }

    read_yes_no_prompt() {
      local prompt="$1"
      local key
      local tty="/dev/tty"

      [[ -w "$tty" ]] || tty="/proc/self/fd/2"

      # Flush any queued key bytes so the confirm prompt doesn't auto-consume stale input.
      while IFS= read -rsn1 -t 0.001 key; do :; done

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"

      key="$(read_key || true)"
      printf "\033[?25l" >"$tty"
      case "$key" in
        y|Y) return 0 ;;
        *) return 1 ;;
      esac
    }

    read_line_prompt() {
      local prompt="$1"
      local initial_value="$2"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty echo <"$tty"
      if (( HAS_READLINE_DEFAULTS )); then
        IFS= read -r -e -i "$initial_value" -p "$prompt" value <"$tty" >"$tty" 2>&1
      else
        printf "%s" "$prompt" >"$tty"
        if [[ -n "$initial_value" ]]; then
          printf "%s" "$initial_value" >"$tty"
        fi
        IFS= read -r value <"$tty"
        [[ -z "$value" ]] && value="$initial_value"
      fi
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    read_secret_prompt() {
      local prompt="$1"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"
      IFS= read -r -s value <"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    run_user_command_prompt() {
      local user_cmd=""
      local rc=0

      user_cmd="$(read_line_prompt "Command: " "")"
      user_cmd="$(trim_whitespace "$user_cmd")"
      [[ -n "$user_cmd" ]] || {
        draw_status
        footer_message_auto "Command cancelled."
        return 1
      }

      if [[ "$user_cmd" == "logo" ]]; then
        disable_mouse_tracking
        printf "\033[?25h"
        stty "$orig_stty" 2>/dev/null || true
        clear
        render_help_logo
        printf "\n\033[2mPress any key to return...\033[0m"
        IFS= read -rsn1 || true
        stty -echo cbreak -ixon intr undef
        printf "\033[?25l"
        enable_mouse_tracking
        on_resize
        return 0
      fi

      disable_mouse_tracking
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
