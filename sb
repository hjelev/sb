    integration_is_disabled() {
      local tool="$1"
      local entry

      if (( HAS_ASSOC_ARRAYS )); then
        [[ -n "${DISABLED_INTEGRATIONS[$tool]+x}" ]]
        return
      fi

      for entry in "${DISABLED_INTEGRATIONS[@]}"; do
        [[ "$entry" == "$tool" ]] && return 0
      done
      return 1
    }

    disable_integration() {
      local tool="$1"

      integration_is_disabled "$tool" && return 0
      if (( HAS_ASSOC_ARRAYS )); then
        DISABLED_INTEGRATIONS[$tool]=1
      else
        DISABLED_INTEGRATIONS+=("$tool")
      fi
    }

    enable_integration() {
      local tool="$1"
      local i
      local -a remaining=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'DISABLED_INTEGRATIONS[$tool]'
        return 0
      fi

      for i in "${!DISABLED_INTEGRATIONS[@]}"; do
        [[ "${DISABLED_INTEGRATIONS[$i]}" == "$tool" ]] && continue
        remaining+=("${DISABLED_INTEGRATIONS[$i]}")
      done
      DISABLED_INTEGRATIONS=("${remaining[@]}")
    }

    selected_path_is_marked() {
      local path="$1"
      local entry

      if (( HAS_ASSOC_ARRAYS )); then
        [[ -n "${SELECTED_PATHS[$path]+x}" ]]
        return
      fi

      for entry in "${SELECTED_PATHS[@]}"; do
        [[ "$entry" == "$path" ]] && return 0
      done
      return 1
    }

    mark_selected_path() {
      local path="$1"

      selected_path_is_marked "$path" && return 0
      if (( HAS_ASSOC_ARRAYS )); then
        SELECTED_PATHS[$path]=1
      else
        SELECTED_PATHS+=("$path")
      fi
    }

    unmark_selected_path() {
      local path="$1"
      local i
      local -a remaining=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'SELECTED_PATHS[$path]'
        return 0
      fi

      for i in "${!SELECTED_PATHS[@]}"; do
        [[ "${SELECTED_PATHS[$i]}" == "$path" ]] && continue
        remaining+=("${SELECTED_PATHS[$i]}")
      done
      SELECTED_PATHS=("${remaining[@]}")
    }

    update_selected_count() {
      SELECTED_COUNT=${#SELECTED_PATHS[@]}
    }

    print_selected_paths() {
      local path

      if (( HAS_ASSOC_ARRAYS )); then
        for path in "${!SELECTED_PATHS[@]}"; do
          printf '%s\n' "$path"
        done
        return 0
      fi

      if (( ${#SELECTED_PATHS[@]} > 0 )); then
