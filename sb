"$KEY_PASTE") if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then echo -ne "\033[?25h"; printf "\033[$((max_rows + 3));1H\033[K"; stty echo; read -r -p "Paste ${#CLIPBOARD_MULTI[@]} item(s) here? [y/N]: " confirm; stty -echo cbreak -ixon intr undef; echo -ne "\033[?25l"; if [[ "$confirm" =~ ^[Yy]$ ]]; then for src in "${CLIPBOARD_MULTI[@]}"; do bname=$(basename "$src"); dest="$bname"; if [[ -e "$dest" ]]; then echo -ne "\033[?25h"; printf "\033[$((max_rows + 3));1H\033[K"; stty echo; read -e -i "$dest" -p "Paste '$bname' as: " dest; stty -echo cbreak -ixon intr undef; echo -ne "\033[?25l"; fi; if (( CLIPBOARD_MOVE )); then mv -- "$src" "$dest" 2>/dev/null; else cp -r -- "$src" "$dest" 2>/dev/null; fi; done; if (( CLIPBOARD_MOVE )); then CLIPBOARD_MULTI=(); CLIPBOARD_MOVE=0; CLIPBOARD_NAME=""; clear_selection; fi; update_files; draw_ui; fi; elif [[ -n "$CLIPBOARD_PATH" ]]; then dest="$CLIPBOARD_NAME"; [[ -e "$dest" ]] && { echo -ne "\033[?25h"; printf "\033[$((max_rows + 3));1H\033[K"; stty echo; read -e -i "$dest" -p "New name: " dest; stty -echo cbreak -ixon intr undef; echo -ne "\033[?25l"; }; cp -r "$CLIPBOARD_PATH" "$dest" 2>/dev/null && { update_files; draw_ui; }; fi ;;
"$KEY_SORT_NAME") SORT_MODE="name"; SORT_NAME_DESC=$((1 - SORT_NAME_DESC)); clear_selection; show_loading_status; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
"$KEY_SORT_DATE") SORT_MODE="date"; SORT_DATE_DESC=$((1 - SORT_DATE_DESC)); clear_selection; show_loading_status; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
"$KEY_SORT_SIZE") SORT_MODE="size"; SORT_SIZE_DESC=$((1 - SORT_SIZE_DESC)); clear_selection; show_loading_status; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
"$KEY_SORT_EXT") SORT_MODE="ext"; SORT_EXT_DESC=$((1 - SORT_EXT_DESC)); clear_selection; show_loading_status; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
"$KEY_MOVE") if (( ${#selected[@]} > 0 )); then move_selected; else move_clipboard_item; fi ;;
"$KEY_LESS") item=$(get_item); if [[ -f "$item" && "${item,,}" == *.age ]]; then open_protected_file_with_less "$item"; else open_with_less "$item"; fi ;;
"$KEY_EDIT") item=$(get_item); if [[ -f "$item" && "${item,,}" == *.age ]]; then open_protected_file_with_editor "$item"; else open_in_editor "$item"; fi ;;
"$KEY_OPEN_GUI") item=$(get_item); if [[ -f "$item" && "${item,,}" == *.age ]]; then open_protected_file_with_gui "$item"; else open_in_gui "$item"; fi ;;
"$KEY_RENAME") rename_dispatch ;;
"$KEY_FZF_JUMP") fzf_jump ;;
"$KEY_INTEGRATIONS") show_integrations_screen ;;
"$KEY_SSH_PICKER") show_ssh_picker ;;
"$KEY_RIPGREP") rg_search ;;
"$KEY_JUMP_PATH") jump_to_path ;;
"$KEY_CREATE_FILE") create_file_item ;;
"$KEY_CREATE_DIR") create_dir_item ;;
"$KEY_DOWNLOAD") download_from_url ;;
"$KEY_UPLOAD") upload_to_catbox ;;
"$KEY_PROTECT") age_toggle_protection ;;
"$KEY_CREATE_ARCHIVE") create_archive_item ;;
"$KEY_EXTRACT_ARCHIVE") extract_archive_item ;;
"$KEY_HELP"|$'\eOP'|$'\e[11~') show_help ;;
"$KEY_BOOKMARKS") show_bookmarks ;;
"$KEY_SELECT_ALL") toggle_select_all ;;
"$KEY_TOGGLE_HIDDEN"|'.') SHOW_HIDDEN=$((1 - SHOW_HIDDEN)); clear_selection; show_loading_status; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
"$KEY_DUST_MODE")
    if command -v dust &>/dev/null; then
        DUST_MODE=$((1 - DUST_MODE))
        if (( DUST_MODE )); then
            show_loading_status
        fi
        update_dust_sizes
        draw_ui
        if (( DUST_MODE )); then
            printf "\033[$((max_rows + 3));1H\033[K%b" "${GREEN}Dust enabled${NC}"
        else
            printf "\033[$((max_rows + 3));1H\033[K%b" "${GREEN}Dust disabled${NC}"
        fi
        draw_status_line
    else
        printf "\033[$((max_rows + 3));1H\033[K%b" "${AMBER}dust is not installed${NC}"
    fi
    ;;
"$KEY_COLUMN_SHRINK") (( NAME_COL_WIDTH > NAME_COL_MIN )) && apply_name_col_resize_burst -1 ;;
"$KEY_COLUMN_GROW") (( NAME_COL_WIDTH < NAME_COL_MAX )) && apply_name_col_resize_burst 1 ;;
"$KEY_COLUMN_MIN") (( NAME_COL_WIDTH != NAME_COL_MIN )) && NAME_COL_WIDTH=$NAME_COL_MIN && draw_ui 1 ;;
"$KEY_COLUMN_MAX") (( NAME_COL_WIDTH != NAME_COL_MAX )) && NAME_COL_WIDTH=$NAME_COL_MAX && draw_ui 1 ;;
"$KEY_TOGGLE_EXEC") item=$(get_item); toggle_executable "$item" ;;
"$KEY_DELETE") if (( ${#selected[@]} > 0 )); then delete_selected; else item=$(get_item); delete_item "$item"; fi ;;
[0-9]) jump_to_bookmark "$key" ;;
"$KEY_QUIT") break ;;
esac
done
