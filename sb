    parse_dust_output_rows() {
      local input="$1"
      local line plain size depth path cwd_abs
      local -a parsed_rows=()
      local -a parsed_paths=()
      local -a fields=()
      local i token next_token

      DUST_TOTAL=""
      ROWS_COLOR=()
      DUST_ROW_PATHS=()
      cwd_abs="$(pwd -P 2>/dev/null || pwd)"

      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        plain="$(strip_ansi_for_display "$line")"
        size=""
        depth=""
        path=""

        # Preferred parser for dust -R without -p:
        # "<name> <depth> <size> <percent>" where <name> can contain spaces.
        if [[ "$plain" =~ ^(.*[^[:space:]])[[:space:]]+([0-9]+)[[:space:]]+([0-9]+([.][0-9]+)?([KMGTPE]i?B?|B|[KMGTPE]))[[:space:]]+([0-9]+%)$ ]]; then
          path="${BASH_REMATCH[1]}"
          depth="${BASH_REMATCH[2]}"
          size="${BASH_REMATCH[3]}"
        fi

        fields=()
        read -r -a fields <<< "$plain"

        # Extract depth (first small integer token).
        if [[ -z "$depth" ]]; then
          for token in "${fields[@]}"; do
            if [[ "$token" =~ ^[0-9]+$ ]] && (( token <= 64 )); then
              depth="$token"
              break
            fi
          done
        fi

        # Extract size token (human unit like 14G, 4.0K, 123M, 12KiB, etc.).
        if [[ -z "$size" ]]; then
          for token in "${fields[@]}"; do
            if [[ "$token" =~ ^[0-9]+([.][0-9]+)?([KMGTPE]i?B?|B|[KMGTPE])$ ]]; then
              size="$token"
              break
            fi
          done
        fi

        # Extract path token from any supported dust text layout.
        if [[ -z "$path" ]]; then
          for (( i=0; i<${#fields[@]}; i++ )); do
            token="${fields[$i]}"
            next_token="${fields[$((i + 1))]-}"
            case "$token" in
              .)
                if [[ "$next_token" == /* ]]; then
                  path=".${next_token}"
                else
                  path="."
                fi
                break
                ;;
              ./*|../*|/*|~/*)
                path="$token"
                break
                ;;
            esac
          done
        fi

        # Normalize a discovered path for later open/enter operations.
        # Fallback for no-full-path mode: remaining tokens after depth+size = bare name.
        if [[ -z "$path" && -n "$depth" && -n "$size" ]]; then
          local _d_used=0 _s_used=0 _tok
          local -a _rem=()
          for _tok in "${fields[@]}"; do
            if (( !_d_used )) && [[ "$_tok" == "$depth" ]]; then _d_used=1; continue; fi
            if (( !_s_used )) && [[ "$_tok" == "$size" ]]; then _s_used=1; continue; fi
            [[ "$_tok" =~ ^[0-9]+%$ ]] && continue
            _rem+=("$_tok")
          done
          path="${_rem[*]}"
        fi

        # Normalize path: expand ~, make bare names absolute.
        if [[ -n "$path" ]]; then
          path="${path/#\~/$HOME}"
          if [[ "$path" != "." && "$path" != /* && "$path" != ./* && "$path" != ../* && "$path" != ~/* ]]; then
            path="${cwd_abs}/${path}"
          fi
          # If parser assembled a non-existent path (e.g. included tree glyphs),
          # leave it empty so row path resolution falls back to plain-row peeling.
          if [[ "$path" != "." && "$path" != "./" && ! -e "$path" && ! -L "$path" ]]; then
            path=""
          fi
        fi

        # Root aggregate row should not be listed; show its size in header instead.
        if [[ -n "$path" ]] && [[ "$path" == "." || "$path" == "./" || "$path" == "$cwd_abs" ]] && [[ "$depth" == "0" || -z "$depth" ]]; then
          [[ -n "$size" ]] && DUST_TOTAL="$size"
          continue
        fi

        # Extra compatibility for variants that print an explicit "total" line.
        if [[ "$plain" =~ ^[[:space:]]*([^[:space:]]+)[[:space:]]+total([[:space:]]|$) ]]; then
          DUST_TOTAL="${BASH_REMATCH[1]}"
          continue
        fi

        parsed_rows+=("$line")
        parsed_paths+=("$path")
      done <<< "$input"

      if (( ${#parsed_rows[@]} > 0 )); then
        ROWS_COLOR=("${parsed_rows[@]}")
        DUST_ROW_PATHS=("${parsed_paths[@]}")
      fi
    }

    capture_directory_rows() {
      local requested_source="${1:-$LIST_SOURCE}"
      local source="$LIST_SOURCE"
      local output=""

      DUST_TOTAL=""
      DUST_ROW_PATHS=()

      LAST_SOURCE_REQUESTED="$requested_source"
      LAST_SOURCE_FALLBACK=0
      LAST_SOURCE_FALLBACK_TO="-"

      if (( PREVIEW_MODE )) && [[ "$source" == "dust" ]]; then
        source="$(best_non_dust_source)"
        LIST_SOURCE="$source"
        LAST_SOURCE_FALLBACK=1
        LAST_SOURCE_FALLBACK_TO="$source"
      fi

      while true; do
        case "$source" in
          ls)
            LAST_SOURCE_EXECUTED="ls"
            if (( HAS_GNU_LS )); then
              local -a ls_args=()
              if (( PREVIEW_MODE )); then
                ls_args=(-1 --group-directories-first --quoting-style=literal --color=always)
              else
                ls_args=(-lh --group-directories-first --time-style=long-iso --quoting-style=literal --color=always)
              fi
              (( show_hidden )) && ls_args+=(-A)
              LAST_SOURCE_ARGS="ls ${ls_args[*]}"
              if output="$(LC_ALL=C ls "${ls_args[@]}" 2>/dev/null | sed '1{/^total /d;}')"; then
                LAST_SOURCE_RC=0
                LIST_SOURCE="ls"
                break
              fi
            elif (( IS_DARWIN )); then
              if (( PREVIEW_MODE )); then
                local -a bsd_ls_args=()
                bsd_ls_args=(-1 -G)
                (( show_hidden )) && bsd_ls_args+=(-A)
                LAST_SOURCE_ARGS="ls ${bsd_ls_args[*]}"
                if output="$(LC_ALL=C ls "${bsd_ls_args[@]}" 2>/dev/null | sed '1{/^total /d;}')"; then
                  LAST_SOURCE_RC=0
                  LIST_SOURCE="ls"
                  break
                fi
              else
                LAST_SOURCE_ARGS="ls -ldh -D '%Y-%m-%d %H:%M' [-G] -- entries (fallback: stat -f '%Sp %Su %z %Sm %N' -t '%Y-%m-%d %H:%M')"
                if capture_directory_rows_bsd_ls; then
                  LAST_SOURCE_RC=0
                  LIST_SOURCE="ls"
                  return 0
                fi
              fi
            else
              local -a ls_args=()
              if (( PREVIEW_MODE )); then
                ls_args=(-1)
              else
                ls_args=(-lh)
              fi
              (( show_hidden )) && ls_args+=(-A)
              LAST_SOURCE_ARGS="ls ${ls_args[*]}"
              if output="$(LC_ALL=C ls "${ls_args[@]}" 2>/dev/null | sed '1{/^total /d;}')"; then
                LAST_SOURCE_RC=0
                LIST_SOURCE="ls"
                break
              fi
            fi
            if [[ -n "$output" ]]; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="ls"
              break
            fi
            LAST_SOURCE_RC=$?
            ROWS_COLOR=()
            return "$LAST_SOURCE_RC"
            ;;
          eza)
            if (( !HAS_EZA )); then
              LAST_SOURCE_EXECUTED="eza"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              if (( HAS_LSD )); then
                LAST_SOURCE_FALLBACK_TO=lsd
              elif (( HAS_DUST )); then
                LAST_SOURCE_FALLBACK_TO=dust
              elif (( HAS_LOGO_LS )); then
                LAST_SOURCE_FALLBACK_TO=logo-ls
              else
                LAST_SOURCE_FALLBACK_TO=ls
              fi
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a eza_args=() eza_extra_args=()
            if (( PREVIEW_MODE )); then
              eza_args=(-1 --group-directories-first --icons=never --color="$SB_EZA_COLOR")
            else
              eza_args=(--long --modified --group-directories-first --time-style=long-iso --icons="$SB_EZA_ICONS" --color="$SB_EZA_COLOR")
            fi
            case "$SB_EZA_HYPERLINK" in
