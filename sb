zip_do_mount() {
    local zip_file="$1" mp="$2"
    local abs_zip

    command -v fuse-zip &>/dev/null || return 1
    abs_zip="$(cd "$(dirname -- "$zip_file")" 2>/dev/null && pwd -P)/$(basename -- "$zip_file")"
    [[ -f "$abs_zip" ]] || return 1

    mkdir -p "$mp" 2>/dev/null || return 1
    zip_is_mounted "$mp" && return 0

    if fuse-zip -- "$abs_zip" "$mp" >/dev/null 2>&1; then
