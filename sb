#!/usr/bin/env bash
VERSION="0.4.0"

usage() {
    cat <<'EOF'
Usage: sb [--export-path FILE] [--update] [--version] [--help]

Options:
  --export-path FILE  Write the final working directory to FILE on exit.
  --update            Reinstall/update sb using the installer script.
  --version           Print the sb version and exit.
  --help              Show this help text and exit.
EOF
}

update_self() { curl -fsSL "${SB_INSTALLER_URL:-https://raw.githubusercontent.com/hjelev/sb/master/install.sh}" | bash -s -- --install-dir "$(cd "$(dirname "$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")")" && pwd -P)";}

if (( BASH_VERSINFO[0] < 4 )); then
    echo "Error: sb requires bash 4.0 or newer." >&2
    echo "macOS ships with bash 3.2. Install a newer version with: brew install bash" >&2
    exit 1
fi
EXPORT_FILE=""
while (($# > 0)); do
    case "$1" in
        --export-path)
            if [[ -z "${2-}" ]]; then
                echo "Error: --export-path requires a file path." >&2
                exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
        --version)
            printf "sb %s\n" "$VERSION"
            exit 0
            ;;
        --update)
            update_self
            exit 0
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
    esac
done
HIGHLIGHT='\033[1;44m'; BLUE='\033[1;34m'; YELLOW='\033[1;38;5;229m'; AMBER='\033[1;38;5;172m'; GREEN='\033[1;32m'; CYAN='\033[1;36m'; RED='\033[1;31m'; NC='\033[0m'; SELECT='\033[48;5;66m'
ICON_DIR='📁'; ICON_LINK='🔗'; ICON_FILE='📄'; ICON_EXEC='🛠'; ICON_IMAGE='🖼'; ICON_VIDEO='🎬'; ICON_AUDIO='🎵'; ICON_ARCHIVE='📦'; ICON_SCRIPT='📜'; ICON_CODE='💻'
cursor=1; old_cursor=0; old_scroll=-1; scroll_offset=0; files=(); metadata=(); file_icons=(); CLIPBOARD_PATH=""; CLIPBOARD_NAME=""; CLIPBOARD_MULTI=(); CLIPBOARD_MOVE=0; declare -A dir_positions; declare -A selected
SHOW_HIDDEN=0
init_platform() { OS_NAME=$(uname -s 2>/dev/null); OPEN_CMD="xdg-open"; LS_CMD="ls"; LS_GROUP_DIRS=0; (( BASH_VERSINFO[0] >= 4 )) && READ_TIMEOUT="0.001" || READ_TIMEOUT="1"; [[ "$OS_NAME" == "Darwin" ]] && OPEN_CMD="open" && command -v gls &>/dev/null && LS_CMD="gls"; "$LS_CMD" -F --group-directories-first -d . >/dev/null 2>&1 && LS_GROUP_DIRS=1; }
HELP_SECTION=''; HELP_KEY=''; HELP_ACCENT=''
init_platform
orig_stty=$(stty -g)
cleanup() { echo -ne "\033[?25h"; stty "$orig_stty"; [[ -n "$EXPORT_FILE" ]] && pwd > "$EXPORT_FILE"; clear; }
handle_resize() { get_terminal_size; old_cursor=-1; old_scroll=-1; stty -echo cbreak; printf "\033[2J\033[1;1H"; draw_ui; }
trap cleanup EXIT; trap handle_resize SIGWINCH; stty -echo cbreak
get_terminal_size() { term_rows=$(tput lines); term_cols=$(tput cols); max_rows=$((term_rows - 4)); }
get_color() { local f="$1"; [[ "$f" == */ ]] && echo -n "$BLUE" && return; [[ "$f" == *@ ]] && echo -n "$CYAN" && return; [[ "$f" == *\* ]] && echo -n "$GREEN" && return; [[ "$f" =~ \.(zip|tar|gz|rar|7z)$ ]] && echo -n "$RED" && return; echo -n "$NC"; }
list_entries() { local -a ls_args=(-F); (( SHOW_HIDDEN )) && ls_args+=(-A); (( LS_GROUP_DIRS )) && ls_args+=(--group-directories-first); "$LS_CMD" "${ls_args[@]}" 2>/dev/null; }
is_gui_session() { [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" || -n "${MIR_SOCKET:-}" || "$OS_NAME" == "Darwin" ]]; }
restore_browser_ui() { stty -echo cbreak; printf "\033[2J\033[1;1H\033[?25l"; get_terminal_size; update_files; draw_ui; }
run_interactive_command() { echo -ne "\033[?25h"; stty "$orig_stty"; clear; "$@"; local status=$?; restore_browser_ui; return $status; }
show_open_error() { local item="$1"; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K%b" "${RED}Unable to open '$item'. Set \$EDITOR or install xdg-open, nano, vim, vi, or less.${NC}"; IFS= read -rsN1; echo -ne "\033[?25l"; draw_ui; }
open_in_terminal_editor() { local item="$1" editor_name; local -a editors=(); [[ -n "${VISUAL:-}" ]] && editors+=("${VISUAL%% *}"); [[ -n "${EDITOR:-}" ]] && editors+=("${EDITOR%% *}"); editors+=(sensible-editor editor nano vim vi less more); for editor_name in "${editors[@]}"; do [[ -n "$editor_name" ]] || continue; command -v "$editor_name" >/dev/null 2>&1 || continue; run_interactive_command "$editor_name" "$item" && return 0; done; return 1; }
open_external() { local item="$1"; if is_gui_session; then command -v "$OPEN_CMD" &>/dev/null && "$OPEN_CMD" "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "xdg-open" ]] && command -v xdg-open &>/dev/null && xdg-open "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "open" ]] && command -v open &>/dev/null && open "$item" >/dev/null 2>&1 && return 0; fi; open_in_terminal_editor "$item" && return 0; show_open_error "$item"; return 1; }
icon_for_item() { local path="$1"; local lower_name="${2,,}"; if [[ -d "$path" ]]; then printf "%s" "$ICON_DIR"; elif [[ -L "$path" ]]; then printf "%s" "$ICON_LINK"; elif [[ -x "$path" && -f "$path" ]]; then printf "%s" "$ICON_EXEC"; else case "$lower_name" in *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg) printf "%s" "$ICON_IMAGE" ;; *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v) printf "%s" "$ICON_VIDEO" ;; *.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a) printf "%s" "$ICON_AUDIO" ;; *.zip|*.tar|*.tar.gz|*.tgz|*.bz2|*.xz|*.rar|*.7z|*.gz) printf "%s" "$ICON_ARCHIVE" ;; *.sh|*.bash|*.zsh|*.fish|*.py|*.js|*.ts|*.rb|*.pl|*.php) printf "%s" "$ICON_SCRIPT" ;; *.c|*.h|*.cpp|*.hpp|*.go|*.rs|*.java|*.kt|*.swift|*.cs|*.json|*.yaml|*.yml|*.toml|*.ini|*.conf|*.md|*.txt) printf "%s" "$ICON_CODE" ;; *) printf "%s" "$ICON_FILE" ;; esac; fi; }
update_files() { files=(); metadata=(); file_icons=(); mapfile -t files < <(list_entries); for f in "${files[@]}"; do clean_f=$(echo "$f" | sed 's/[$*@|=>]//g'); base_name="${clean_f##*/}"; icon="$(icon_for_item "$clean_f" "$base_name")"; [[ -e "$clean_f" || -L "$clean_f" ]] && meta=$(ls -ldh "$clean_f" 2>/dev/null | awk '{printf "%s|%s|%s|%3s %2s %5s", $3, $1, $5, $6, $7, $8}') || meta="----------|----------|-----|------------"; metadata+=("$meta"); file_icons+=("$icon"); done; if [[ ${#files[@]} -eq 0 ]]; then files=("(Empty Directory)"); metadata=("----------|----------|-----|------------"); file_icons=("$ICON_DIR"); fi; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; }
ensure_cursor_visible() { local total=${#files[@]}; local max_scroll=$(( total - max_rows )); (( max_scroll < 0 )) && max_scroll=0; if (( cursor < scroll_offset + 1 )); then scroll_offset=$(( cursor - 1 )); elif (( cursor > scroll_offset + max_rows )); then scroll_offset=$(( cursor - max_rows )); fi; (( scroll_offset < 0 )) && scroll_offset=0; (( scroll_offset > max_scroll )) && scroll_offset=$max_scroll; }
draw_line() { local idx=$1; local row=$2; local f_name="${files[$idx]}"; local display_name="${f_name:0:17}"; local file_icon="${file_icons[$idx]:-$ICON_FILE}"; local meta="${metadata[$idx]}"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; local sel_mark=" "; [[ -n "${selected[$idx]+x}" ]] && sel_mark="*"; printf "\033[${row};1H\033[K"; if (( idx + 1 == cursor )); then printf "%1s%s" "$sel_mark" "$file_icon"; printf "\033[5G${HIGHLIGHT}%-17s %-12s %-11s %8s  %12s${NC}" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod"; elif [[ -n "${selected[$idx]+x}" ]]; then printf "%1s%s" "$sel_mark" "$file_icon"; printf "\033[5G${SELECT}%-17s %-12s %-11s %8s  %12s${NC}" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod"; else printf "$(get_color "$f_name")%1s%s\033[5G%-17s${NC} %-12s %-11s %8s  %12s" "$sel_mark" "$file_icon" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod"; fi; }
draw_status_line() { local hidden_status="Off"; (( SHOW_HIDDEN )) && hidden_status="On"; local sel_count=${#selected[@]}; printf "\033[%d;1H\033[K" $((max_rows + 4)); printf "Item %d/%d │ Hidden: %-3s │ Sel: %-3s │ Clip: %-8s │ Path: %s" "$cursor" "${#files[@]}" "$hidden_status" "$sel_count" "${CLIPBOARD_NAME:-None}" "$(pwd)"; }
scroll_list_once() { local direction="$1"; local top=3; local bottom=$((max_rows + 2)); local old_idx=$((old_cursor - 1)); local new_idx=$((cursor - 1)); printf "\033[%d;%dr" "$top" "$bottom"; if [[ "$direction" == "down" ]]; then printf "\033[%d;1H\033[M" "$top"; if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then draw_line "$old_idx" $((bottom - 1)); fi; if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then draw_line "$new_idx" "$bottom"; fi; else printf "\033[%d;1H\033[L" "$top"; if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then draw_line "$new_idx" "$top"; fi; if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then draw_line "$old_idx" $((top + 1)); fi; fi; printf "\033[r"; draw_status_line; }
draw_ui() { local total=${#files[@]}; ensure_cursor_visible; local hidden_status="Off"; (( SHOW_HIDDEN )) && hidden_status="On"; local sel_count=${#selected[@]}; local buffer=""; buffer+=$'\e[H\e[?25l'; buffer+=$(printf "    %-17s %-12s %-11s %8s  %12s\n" "FILE NAME" "OWNER" "PERMS" "SIZE" "MODIFIED"); buffer+=$'\e[2;1H'; for (( i=0; i<term_cols-1; i++ )); do buffer+="─"; done; buffer+=$'\n'; for (( i=0; i<max_rows; i++ )); do local idx=$((scroll_offset + i)); local row=$((i + 3)); buffer+=$'\e['$row$';1H\e[K'; if (( idx < total )); then local f_name="${files[$idx]}"; local display_name="${f_name:0:17}"; local file_icon="${file_icons[$idx]:-$ICON_FILE}"; local meta="${metadata[$idx]}"; local sel_mark=" "; [[ -n "${selected[$idx]+x}" ]] && sel_mark="*"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; if (( idx + 1 == cursor )); then buffer+="$(printf "%1s%s" "$sel_mark" "$file_icon")\033[5G${HIGHLIGHT}$(printf "%-17s %-12s %-11s %8s  %12s" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod")${NC}"; elif [[ -n "${selected[$idx]+x}" ]]; then buffer+="$(printf "%1s%s" "$sel_mark" "$file_icon")\033[5G${SELECT}$(printf "%-17s %-12s %-11s %8s  %12s" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod")${NC}"; else buffer+="$(get_color "$f_name")$(printf "%1s%s\033[5G%-17s" "$sel_mark" "$file_icon" "$display_name")${NC}"; buffer+=$(printf " %-12s %-11s %8s  %12s" "$m_owner" "$m_perms" "$m_size" "$m_mod"); fi; fi; done; buffer+=$'\e['$((max_rows + 4))$';1H\e[K'; buffer+=$(printf "Item %d/%d │ Hidden: %-3s │ Sel: %-3s │ Clip: %-8s │ Path: %s" "$cursor" "$total" "$hidden_status" "$sel_count" "${CLIPBOARD_NAME:-None}" "$(pwd)"); printf "%b" "$buffer"; old_cursor=$cursor; old_scroll=$scroll_offset; }
redraw_cursor() { local previous_scroll=$scroll_offset; ensure_cursor_visible; if (( scroll_offset == previous_scroll + 1 && cursor == old_cursor + 1 )); then scroll_list_once down; old_cursor=$cursor; old_scroll=$scroll_offset; return; fi; if (( scroll_offset == previous_scroll - 1 && cursor == old_cursor - 1 )); then scroll_list_once up; old_cursor=$cursor; old_scroll=$scroll_offset; return; fi; if (( scroll_offset != previous_scroll )); then draw_ui; return; fi; if (( old_cursor > 0 && old_cursor != cursor )); then local old_idx=$(( old_cursor - 1 )); if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then draw_line "$old_idx" $((old_idx - scroll_offset + 3)); fi; fi; local new_idx=$(( cursor - 1 )); if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then draw_line "$new_idx" $((new_idx - scroll_offset + 3)); fi; draw_status_line; old_cursor=$cursor; old_scroll=$scroll_offset; }
get_item() { [[ $cursor -gt 0 && $cursor -le ${#files[@]} ]] && echo "${files[$((cursor-1))]}" | sed 's/[$*@|=>]//g'; }
open_file() { local item="$1"; if command -v chafa &>/dev/null && [[ "$item" =~ \.(jpg|jpeg|png|gif|bmp|webp|tiff|ico)$ ]]; then echo -ne "\033[?25h"; tput smcup; printf "\033[H"; chafa "$item" | head -n $((term_rows - 2)); printf "\033[$((term_rows));1H"; read -rsn1; tput rmcup; echo -ne "\033[?25l"; redraw_cursor; else open_external "$item"; fi; }
open_with_less() { local item="$1"; [[ -f "$item" ]] && run_interactive_command less -- "$item"; }
show_help() { echo -ne "\033[?25h"; clear; printf "%b" "${HELP_ACCENT}Shell Buddy${NC} "; printf "%b" "${VERSION}\n\n"; printf "%b" "${HELP_SECTION}Navigation${NC}\n"; printf "%b" "  ${HELP_KEY}Up/Down arrows${NC}   Move selection\n"; printf "%b" "  ${HELP_KEY}PgUp/PgDn${NC}        Jump by one page\n"; printf "%b" "  ${HELP_KEY}Home/End${NC}         Jump to top/bottom\n"; printf "%b" "  ${HELP_KEY}Right/Enter${NC}      Open directory/file\n"; printf "%b" "  ${HELP_KEY}Left${NC}             Go to parent directory\n"; printf "%b" "  ${HELP_KEY}~${NC}                Go to home directory\n\n"; printf "%b" "${HELP_SECTION}File Actions${NC}\n"; printf "%b" "  ${HELP_KEY}n${NC}                Create file\n"; printf "%b" "  ${HELP_KEY}N${NC}                Create folder\n"; printf "%b" "  ${HELP_KEY}Space${NC}            Toggle item selection\n"; printf "%b" "  ${HELP_KEY}c${NC}                Copy selected item(s)\n"; printf "%b" "  ${HELP_KEY}p${NC}                Paste copied item(s)\n"; printf "%b" "  ${HELP_KEY}m${NC}                Move selected item(s)\n"; printf "%b" "  ${HELP_KEY}l${NC}                Open selected file in less\n"; printf "%b" "  ${HELP_KEY}x${NC}                Toggle executable permission\n"; printf "%b" "  ${HELP_KEY}d${NC}                Delete selected item(s)\n\n"; printf "%b" "${HELP_SECTION}View${NC}\n"; printf "%b" "  ${HELP_KEY}.${NC}                Toggle hidden files\n"; printf "%b" "  ${HELP_KEY}h${NC}                Show this help\n"; printf "%b" "  ${HELP_KEY}q${NC}                Quit\n\n"; printf "%b" "${HELP_ACCENT}Press any key to return...${NC}"; read -rsn1; draw_ui; }
create_file_item() { local name=""; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -p "New file name: " name; stty -echo cbreak; echo -ne "\033[?25l"; [[ -z "$name" ]] && { redraw_cursor; return; }; touch -- "$name" 2>/dev/null && { update_files; draw_ui; } || redraw_cursor; }
create_dir_item() { local name=""; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -p "New folder name: " name; stty -echo cbreak; echo -ne "\033[?25l"; [[ -z "$name" ]] && { redraw_cursor; return; }; mkdir -p -- "$name" 2>/dev/null && { update_files; draw_ui; } || redraw_cursor; }
move_clipboard_item() { [[ -z "$CLIPBOARD_PATH" ]] && { redraw_cursor; return; }; local dest="$CLIPBOARD_NAME"; [[ -e "$dest" ]] && { echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -i "$dest" -p "Move as: " dest; stty -echo cbreak; echo -ne "\033[?25l"; }; [[ -z "$dest" ]] && { redraw_cursor; return; }; mv -- "$CLIPBOARD_PATH" "$dest" 2>/dev/null && { CLIPBOARD_PATH=""; CLIPBOARD_NAME=""; update_files; draw_ui; } || redraw_cursor; }
toggle_selection() { local idx=$(( cursor - 1 )); local item; item=$(get_item); [[ -z "$item" || "$item" == "(Empty Directory)" ]] && return; if [[ -n "${selected[$idx]+x}" ]]; then unset 'selected[$idx]'; else selected[$idx]=1; fi; }
clear_selection() { selected=(); }
toggle_executable() { local item="$1"; [[ -z "$item" || "$item" == "(Empty Directory)" ]] && return; if [[ -x "$item" ]]; then chmod a-x -- "$item" 2>/dev/null; else chmod u+x -- "$item" 2>/dev/null; fi; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui; }
delete_item() { local item="$1"; [[ -z "$item" || "$item" == "(Empty Directory)" ]] && return; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -r -p "Delete '$item'? [y/N]: " confirm; stty -echo cbreak; echo -ne "\033[?25l"; get_terminal_size; printf "\033[2J\033[H"; if [[ "$confirm" =~ ^[Yy]$ ]]; then rm -rf -- "$item" 2>/dev/null; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; fi; draw_ui; }
delete_selected() { local -a items=(); for idx in "${!selected[@]}"; do local f="${files[$idx]}"; f=$(echo "$f" | sed 's/[$*@|=>]//g'); [[ -n "$f" && "$f" != "(Empty Directory)" ]] && items+=("$f"); done; [[ ${#items[@]} -eq 0 ]] && return; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -r -p "Delete ${#items[@]} selected item(s)? [y/N]: " confirm; stty -echo cbreak; echo -ne "\033[?25l"; get_terminal_size; printf "\033[2J\033[H"; if [[ "$confirm" =~ ^[Yy]$ ]]; then for f in "${items[@]}"; do rm -rf -- "$f" 2>/dev/null; done; clear_selection; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; fi; draw_ui; }
copy_selected() { local -a items=(); for idx in "${!selected[@]}"; do local f="${files[$idx]}"; f=$(echo "$f" | sed 's/[$*@|=>]//g'); [[ -n "$f" && "$f" != "(Empty Directory)" ]] && items+=("$(pwd)/$f"); done; [[ ${#items[@]} -eq 0 ]] && return; CLIPBOARD_MULTI=("${items[@]}"); CLIPBOARD_PATH=""; CLIPBOARD_NAME="${#items[@]} items"; redraw_cursor; }
move_selected() { local -a items=(); for idx in "${!selected[@]}"; do local f="${files[$idx]}"; f=$(echo "$f" | sed 's/[$*@|=>]//g'); [[ -n "$f" && "$f" != "(Empty Directory)" ]] && items+=("$(pwd)/$f"); done; [[ ${#items[@]} -eq 0 ]] && return; CLIPBOARD_MULTI=("${items[@]}"); CLIPBOARD_MOVE=1; CLIPBOARD_PATH=""; CLIPBOARD_NAME="${#items[@]} items"; redraw_cursor; }
echo -ne "\033[?25l"; get_terminal_size; update_files; draw_ui
while true; do
IFS= read -rsN1 key
if [[ $key == $'\e' ]]; then while IFS= read -rsN1 -t $READ_TIMEOUT key_rest; do key+="$key_rest"; done; fi
case "$key" in
$'\e[A') ((cursor > 1)) && ((cursor--)) && redraw_cursor ;;
$'\e[B') ((cursor < ${#files[@]})) && ((cursor++)) && redraw_cursor ;;
$'\e[5~') old_cursor=$cursor; ((cursor -= max_rows)); (( cursor < 1 )) && cursor=1; (( cursor != old_cursor )) && redraw_cursor ;;
$'\e[6~') old_cursor=$cursor; ((cursor += max_rows)); (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor != old_cursor )) && redraw_cursor ;;
$'\e[H'|$'\e[1~'|$'\e[7~'|$'\eOH') ((cursor > 1)) && cursor=1 && redraw_cursor ;;
$'\e[F'|$'\e[4~'|$'\e[8~'|$'\eOF') ((cursor < ${#files[@]})) && cursor=${#files[@]} && redraw_cursor ;;
$'\e[C'|$'\n'|$'\r') item=$(get_item); if [ -d "$item" ]; then dir_positions["$(pwd)"]=$cursor; cd "$item" 2>/dev/null; clear_selection; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui; elif [ -f "$item" ]; then open_file "$item"; fi ;;
$'\e[D') dir_positions["$(pwd)"]=$cursor; cd .. 2>/dev/null; clear_selection; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui ;;
'~') dir_positions["$(pwd)"]=$cursor; cd "$HOME" 2>/dev/null; clear_selection; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui ;;
' ') toggle_selection; if ((cursor < ${#files[@]})); then ((cursor++)); fi; redraw_cursor ;;
'c') if (( ${#selected[@]} > 0 )); then copy_selected; else item=$(get_item); if [[ "$item" != "(Empty Directory)" ]]; then CLIPBOARD_MULTI=(); CLIPBOARD_MOVE=0; CLIPBOARD_PATH="$(pwd)/$item"; CLIPBOARD_NAME="$item"; redraw_cursor; fi; fi ;;
'p') if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -r -p "Paste ${#CLIPBOARD_MULTI[@]} item(s) here? [y/N]: " confirm; stty -echo cbreak; echo -ne "\033[?25l"; if [[ "$confirm" =~ ^[Yy]$ ]]; then for src in "${CLIPBOARD_MULTI[@]}"; do bname=$(basename "$src"); dest="$bname"; if [[ -e "$dest" ]]; then echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -i "$dest" -p "Paste '$bname' as: " dest; stty -echo cbreak; echo -ne "\033[?25l"; fi; if (( CLIPBOARD_MOVE )); then mv -- "$src" "$dest" 2>/dev/null; else cp -r -- "$src" "$dest" 2>/dev/null; fi; done; if (( CLIPBOARD_MOVE )); then CLIPBOARD_MULTI=(); CLIPBOARD_MOVE=0; CLIPBOARD_NAME=""; clear_selection; fi; update_files; draw_ui; fi; elif [[ -n "$CLIPBOARD_PATH" ]]; then dest="$CLIPBOARD_NAME"; [[ -e "$dest" ]] && { echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -i "$dest" -p "New name: " dest; stty -echo cbreak; echo -ne "\033[?25l"; }; cp -r "$CLIPBOARD_PATH" "$dest" 2>/dev/null && { update_files; draw_ui; }; fi ;;
'm') if (( ${#selected[@]} > 0 )); then move_selected; else move_clipboard_item; fi ;;
'l') item=$(get_item); open_with_less "$item" ;;
'n') create_file_item ;;
'N') create_dir_item ;;
'h') show_help ;;
'.') SHOW_HIDDEN=$((1 - SHOW_HIDDEN)); update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
'x') item=$(get_item); toggle_executable "$item" ;;
'd') if (( ${#selected[@]} > 0 )); then delete_selected; else item=$(get_item); delete_item "$item"; fi ;;
'q') break ;;
esac
done
