    sb_name_with_version() {
      if [[ -n "$VERSION" ]]; then
        if [[ "$VERSION" =~ ^[0-9] ]]; then
          printf 'Shell Buddy v%s' "$VERSION"
        else
          printf 'Shell Buddy %s' "$VERSION"
        fi
      else
        printf 'Shell Buddy'
      fi
    }

    current_slogan() {
      local -a slogans=()
      local idx=0

      # Backward-compatible override: when set, use one fixed slogan.
      if [[ -n "$SB_SLOGAN" ]]; then
        printf '%s' "$SB_SLOGAN"
        return 0
      fi

      # Keep one chosen slogan for this run to avoid changing between screens.
      if [[ -n "$SB_ACTIVE_SLOGAN" ]]; then
        printf '%s' "$SB_ACTIVE_SLOGAN"
        return 0
      fi

      IFS='|' read -r -a slogans <<< "$SB_SLOGANS"
      if ((${#slogans[@]} == 0)); then
        SB_ACTIVE_SLOGAN="Bringing your tools together"
        printf '%s' "$SB_ACTIVE_SLOGAN"
        return 0
      fi

      if [[ "$SB_SLOGAN_ROTATE_RANDOM" == "1" && ${#slogans[@]} -gt 1 ]]; then
        idx=$((RANDOM % ${#slogans[@]}))
      fi

      SB_ACTIVE_SLOGAN="${slogans[$idx]}"
      printf '%s' "$SB_ACTIVE_SLOGAN"
    }

    render_help_logo() {
      local c1 c2 c3 cr slogan
      c1=""
      c2=""
      c3=""
      cr=""
      slogan="$(current_slogan)"
      if command -v tput >/dev/null 2>&1 && [[ -n "${TERM:-}" && "${TERM}" != "dumb" ]]; then
        c1="$(tput setaf 15 2>/dev/null || true)"
        c2="$(tput setaf 250 2>/dev/null || true)"
        c3="$(tput setaf 245 2>/dev/null || true)"
        cr="$(tput sgr0 2>/dev/null || true)"
      fi

      printf '%s\n' "${c1} ┌─┐┬ ┬┌─┐┬  ┬    ┌┐ ┬ ┬┌┬┐┌┬┐┬ ┬${cr}"
      printf '%s\n' "${c2} └─┐├─┤├┤ │  │    ├┴┐│ │ ││ ││└┬┘${cr}"
      printf '%s\n' "${c3} └─┘┴ ┴└─┘┴─┘┴─┘  └─┘└─┘─┴┘─┴┘ ┴${cr}"
      printf '  %s\n' "$slogan"
      printf '%s\tversion (%s)%s\n' "$c3" "$VERSION" "$cr"
    }

    resolve_self_path() {
      local source_path="${BASH_SOURCE[0]}"
      local source_dir=""

      while [[ -L "$source_path" ]]; do
        source_dir="$(cd -P "$(dirname "$source_path")" 2>/dev/null && pwd)" || return 1
        source_path="$(readlink "$source_path")" || return 1
        [[ "$source_path" == /* ]] || source_path="$source_dir/$source_path"
      done

      source_dir="$(cd -P "$(dirname "$source_path")" 2>/dev/null && pwd)" || return 1
      printf '%s/%s' "$source_dir" "$(basename "$source_path")"
    }

    self_update() {
      local script_path install_dir latest_tag latest_version reply
      local tag_sha master_sha

      command -v curl >/dev/null 2>&1 || {
        echo "Error: curl is required for --update." >&2
        exit 1
      }
      command -v bash >/dev/null 2>&1 || {
        echo "Error: bash is required for --update." >&2
        exit 1
      }

      script_path="$(resolve_self_path)" || {
        echo "Error: unable to resolve the current Shell Buddy path for --update." >&2
        exit 1
      }
      install_dir="$(cd -P "$(dirname "$script_path")" 2>/dev/null && pwd)" || {
        echo "Error: unable to resolve the install directory for --update." >&2
        exit 1
      }

      printf 'Installed: %s (in %s)\n' "$(sb_name_with_version)" "$install_dir"
      printf 'Checking for latest release...\n'

      latest_tag="$(curl -fsSL "https://api.github.com/repos/hjelev/sb/releases/latest" 2>/dev/null \
          | awk -F '"' '/"tag_name"/ { print $4; exit }')"

      if [[ -n "$latest_tag" ]]; then
        latest_version="${latest_tag#v}"
        tag_sha="$(curl -fsSL "https://api.github.com/repos/hjelev/sb/commits/$latest_tag" 2>/dev/null \
          | awk -F '"' '/"sha":/ { print substr($4, 1, 7); exit }')"
        master_sha="$(curl -fsSL "https://api.github.com/repos/hjelev/sb/commits/master" 2>/dev/null \
          | awk -F '"' '/"sha":/ { print substr($4, 1, 7); exit }')"

        if [[ "$latest_version" == "$VERSION" ]]; then
          printf 'Already on the latest release (%s).\n' "$VERSION"
          if [[ -n "$tag_sha" && -n "$master_sha" && "$tag_sha" != "$master_sha" ]]; then
            printf 'Master has newer commits (%s vs %s).\n' "$master_sha" "$tag_sha"
            printf 'Install latest development version from master branch? [y/N] '
            read -r reply
            if [[ "$reply" =~ ^[Yy]$ ]]; then
              printf 'Installing from master branch...\n'
              curl -fsSL "$SB_INSTALLER_URL" | bash -s -- --install-dir "$install_dir" --ref master
            fi
          else
            printf 'Master is identical to latest release; no development update available.\n'
          fi
          return 0
        else
          printf 'Latest release: %s\n' "$latest_tag"
          printf 'Update to %s? [Y/n] ' "$latest_tag"
          read -r reply
          if [[ ! "$reply" =~ ^[Nn]$ ]]; then
            printf 'Updating to %s...\n' "$latest_tag"
            curl -fsSL "$SB_INSTALLER_URL" | bash -s -- --install-dir "$install_dir" --version "$latest_tag"
            return 0
          fi
        fi
      else
        printf 'No release found on GitHub.\n'
      fi

      printf 'Install latest development version from master branch? [y/N] '
      read -r reply
      if [[ "$reply" =~ ^[Yy]$ ]]; then
        printf 'Installing from master branch...\n'
        curl -fsSL "$SB_INSTALLER_URL" | bash -s -- --install-dir "$install_dir" --ref master
      fi
    }

    usage() {
      local logo_block
