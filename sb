    }

    store_zip_mount() {
      local archive="$1"
      local mountpoint="$2"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        ZIP_MOUNT_BY_ARCHIVE[$archive]="$mountpoint"
        ZIP_ARCHIVE_BY_MOUNT[$mountpoint]="$archive"
        return 0
      fi

      for i in "${!ZIP_MOUNT_ARCHIVES[@]}"; do
        if [[ "${ZIP_MOUNT_ARCHIVES[$i]}" == "$archive" ]]; then
          ZIP_MOUNT_POINTS[$i]="$mountpoint"
          return 0
        fi
      done

      ZIP_MOUNT_ARCHIVES+=("$archive")
      ZIP_MOUNT_POINTS+=("$mountpoint")
      ZIP_ARCHIVE_MOUNTS+=("$mountpoint")
      ZIP_ARCHIVE_ARCHIVES+=("$archive")
    }

    remove_zip_mount_by_archive() {
      local archive="$1"
      local i
      local -a archives=() mounts=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'ZIP_MOUNT_BY_ARCHIVE[$archive]'
        return 0
