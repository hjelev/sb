      existing_items+=("$item")
    fi
  done

  (( ${#existing_items[@]} > 0 )) || {
    draw_status
    footer_message_auto "Delete failed: selected sources do not exist."
    return 1
  }

  if (( ${#existing_items[@]} > 1 )); then
    label="Delete ${#existing_items[@]} selected item(s)? [y/N]: "
  else
    label="Delete '$(path_basename "${existing_items[0]}")'? [y/N]: "
  fi

  if ! read_yes_no_prompt "$label"; then
    draw_status
    footer_message_auto "Delete cancelled."
    return 1
  fi

  for item in "${existing_items[@]}"; do
    if err="$(run_rm_rf "$item" 2>&1)"; then
      ((ok_count++))
      unmark_selected_path "$item"
    else
      ((fail_count++))
      LAST_PASTE_ERR="$err"
    fi
  done

  skip_count=$(( ${#items[@]} - ${#existing_items[@]} ))
  update_selected_count
  LAST_PASTE_OP="rm"
  LAST_PASTE_RC=0
  LAST_PASTE_OK=$ok_count
  LAST_PASTE_FAIL=$fail_count
  LAST_PASTE_SKIP=$skip_count
  if (( fail_count > 0 )); then
    LAST_PASTE_RC=1
  fi

  if (( ok_count > 0 )); then
    load_data
    if (( cursor >= ${#ROWS_COLOR[@]} )); then
      cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
    fi
    if (( cursor < top )); then
      top=$cursor
    elif (( cursor >= top + visible_rows )); then
      top=$(( cursor - visible_rows + 1 ))
    fi
  fi

  draw_ui
  footer_message_auto "Delete: ok:%d fail:%d skip:%d" "$ok_count" "$fail_count" "$skip_count"
  return 0
}

    bulk_rename_selected_with_vidir() {
      local -a items=()
      local -a existing_items=()
      local -a old_names=()
      local -a new_for_old=()
      local -a mapped=()
      local -a phase_old=()
      local -a phase_new=()
      local -a phase_tmp=()
      local item old_name new_name tmp_name link_target target_base err
      local tmpdir old_count new_count=0 changed_count=0
      local i j idx found in_selected

      if (( !HAS_VIDIR )); then
        draw_status
        footer_message_auto "Bulk rename unavailable: vidir is not installed or disabled in integrations."
        return 1
      fi

      if (( SELECTED_COUNT < 2 )); then
        draw_status
        footer_message_auto "Bulk rename needs at least 2 selected items."
        return 1
      fi

      read_stdin_into_array items < <(collect_selected_paths_in_row_order)
      (( ${#items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Bulk rename failed: no valid selected paths."
        return 1
      }

      for item in "${items[@]}"; do
        if [[ -e "$item" || -L "$item" ]]; then
          existing_items+=("$item")
          old_names+=("$(path_basename "$item")")
        fi
      done

      (( ${#existing_items[@]} > 1 )) || {
        draw_status
        footer_message_auto "Bulk rename needs at least 2 existing selected items."
        return 1
      }

      old_count=${#old_names[@]}
      for (( i=0; i<old_count; i++ )); do
        new_for_old+=("${old_names[$i]}")
        mapped+=(0)
      done

      tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/sb-vidir-rename.XXXXXX")" || {
        draw_status
        footer_message_auto "Bulk rename failed: cannot create temporary workspace."
        return 1
      }

      for old_name in "${old_names[@]}"; do
        if ! ln -s -- "$(pwd -P)/$old_name" "$tmpdir/$old_name" 2>/dev/null; then
          run_rm_rf "$tmpdir" >/dev/null 2>&1 || true
          draw_status
          footer_message_auto "Bulk rename failed: cannot prepare temp entries for vidir."
          return 1
        fi
      done

      run_interactive_command vidir "$tmpdir"

      while IFS= read -r -d '' item; do
        new_name="${item##*/}"
        link_target="$(readlink "$item" 2>/dev/null || true)"
        [[ -n "$link_target" ]] || continue
        target_base="$(path_basename "$link_target")"
        found=-1
        for i in "${!old_names[@]}"; do
          if [[ "${old_names[$i]}" == "$target_base" ]]; then
            found=$i
            break
          fi
        done
        (( found >= 0 )) || continue
        new_for_old[$found]="$new_name"
        mapped[$found]=1
        ((new_count++))
      done < <(find "$tmpdir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null)

      run_rm_rf "$tmpdir" >/dev/null 2>&1 || true

      if (( new_count != old_count )); then
        draw_status
        footer_message_auto "Bulk rename cancelled: all selected items must remain listed in vidir."
        return 1
      fi

      for i in "${!mapped[@]}"; do
        if (( mapped[$i] == 0 )); then
          draw_status
          footer_message_auto "Bulk rename cancelled: selection mapping became invalid."
          return 1
        fi
      done

      for i in "${!new_for_old[@]}"; do
        new_name="$(sanitize_filename_input "${new_for_old[$i]}")"
        new_for_old[$i]="$new_name"
        if [[ -z "$new_name" || "$new_name" == */* ]]; then
          draw_status
          footer_message_auto "Bulk rename failed: names must be non-empty and cannot contain '/'."
          return 1
        fi
      done

      for i in "${!new_for_old[@]}"; do
        for j in "${!new_for_old[@]}"; do
          (( i == j )) && continue
          if [[ "${new_for_old[$i]}" == "${new_for_old[$j]}" ]]; then
            draw_status
            footer_message_auto "Bulk rename failed: duplicate target name '%s'." "${new_for_old[$i]}"
            return 1
          fi
        done
      done

      for i in "${!old_names[@]}"; do
        old_name="${old_names[$i]}"
        new_name="${new_for_old[$i]}"
        [[ "$new_name" == "$old_name" ]] && continue
        ((changed_count++))
        if [[ -e "$new_name" || -L "$new_name" ]]; then
          in_selected=0
          for item in "${old_names[@]}"; do
            if [[ "$item" == "$new_name" ]]; then
              in_selected=1
              break
            fi
          done
          if (( !in_selected )); then
            draw_status
            footer_message_auto "Bulk rename failed: target exists: %s" "$new_name"
            return 1
          fi
        fi
      done

      if (( changed_count == 0 )); then
        draw_status
        footer_message_auto "Bulk rename cancelled: no name changes."
        return 1
      fi

      for i in "${!old_names[@]}"; do
        old_name="${old_names[$i]}"
        new_name="${new_for_old[$i]}"
        [[ "$new_name" == "$old_name" ]] && continue
        tmp_name=".sb-vidir-tmp.$$.$RANDOM.$i"
        while [[ -e "$tmp_name" || -L "$tmp_name" ]]; do
          tmp_name=".sb-vidir-tmp.$$.$RANDOM.$i"
        done
        if ! err="$(run_mv_path "$old_name" "$tmp_name" 2>&1)"; then
          for (( idx=${#phase_tmp[@]}-1; idx>=0; idx-- )); do
            run_mv_path "${phase_tmp[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
          done
          draw_status
          footer_message_auto "Bulk rename failed during staging: %s" "$err"
          return 1
        fi
        phase_old+=("$old_name")
        phase_new+=("$new_name")
        phase_tmp+=("$tmp_name")
      done

      for i in "${!phase_tmp[@]}"; do
        if ! err="$(run_mv_path "${phase_tmp[$i]}" "${phase_new[$i]}" 2>&1)"; then
          for (( idx=i; idx<${#phase_tmp[@]}; idx++ )); do
            if [[ -e "${phase_tmp[$idx]}" || -L "${phase_tmp[$idx]}" ]]; then
              run_mv_path "${phase_tmp[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
            fi
          done
          for (( idx=i-1; idx>=0; idx-- )); do
            if [[ -e "${phase_new[$idx]}" || -L "${phase_new[$idx]}" ]]; then
              run_mv_path "${phase_new[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
            fi
          done
          draw_status
          footer_message_auto "Bulk rename failed during apply: %s" "$err"
          return 1
        fi
      done

      clear_selection
      load_data
      position_cursor_for_name "${new_for_old[0]}" >/dev/null 2>&1 || true
      draw_ui
      footer_message_auto "Bulk rename complete (vidir): renamed %d selected item(s)." "$changed_count"
      return 0
    }

    rename_current_or_selected() {
      if (( SELECTED_COUNT > 1 )); then
        bulk_rename_selected_with_vidir
        return $?
      fi

      rename_current_entry
      return $?
