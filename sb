PENDING_KEY=""
READ_KEY_RESULT=""

read_key_event() {
    local timeout="${1-}"
    local key="" key_rest=""

    if [[ -n "$PENDING_KEY" ]]; then
        READ_KEY_RESULT="$PENDING_KEY"
        PENDING_KEY=""
        return 0
    fi

    if [[ -n "$timeout" ]]; then
        IFS= read -rsN1 -t "$timeout" key || return 1
    else
        IFS= read -rsN1 key
    fi

    if [[ "$key" == $'\e' ]]; then
        while IFS= read -rsN1 -t "$READ_TIMEOUT" key_rest; do key+="$key_rest"; done
    fi

    READ_KEY_RESULT="$key"
    return 0
}

apply_name_col_resize_burst() {
    local delta="$1"
    local target next_key

    target=$((NAME_COL_WIDTH + delta))

    # Tiny debounce: coalesce rapid repeated [ / ] keypresses into one redraw.
    while read_key_event "0.015"; do
        next_key="$READ_KEY_RESULT"
        case "$next_key" in
            "$KEY_COLUMN_SHRINK") (( target-- )) ;;
            "$KEY_COLUMN_GROW") (( target++ )) ;;
            *)
                PENDING_KEY="$next_key"
                break
                ;;
        esac
    done

    (( target < NAME_COL_MIN )) && target=$NAME_COL_MIN
    (( target > NAME_COL_MAX )) && target=$NAME_COL_MAX

    if (( target != NAME_COL_WIDTH )); then
        NAME_COL_WIDTH=$target
        draw_ui 1
    fi
}

normalize_key() {
    local key="$1"
    # Check Home key (custom + defaults)
    if [[ "$key" == "$KEY_HOME" ]] || [[ "$key" == $'\e[H' ]] || [[ "$key" == $'\e[1~' ]] || [[ "$key" == $'\e[7~' ]] || [[ "$key" == $'\eOH' ]]; then
        echo "ACTION_HOME"
        return
    fi
    # Check End key (custom + defaults)
    if [[ "$key" == "$KEY_END" ]] || [[ "$key" == $'\e[F' ]] || [[ "$key" == $'\e[4~' ]] || [[ "$key" == $'\e[8~' ]] || [[ "$key" == $'\eOF' ]]; then
        echo "ACTION_END"
        return
    fi
    # Check Enter key (custom + defaults)
    if [[ "$key" == "$KEY_ENTER" ]] || [[ "$key" == $'\e[C' ]] || [[ "$key" == $'\n' ]] || [[ "$key" == $'\r' ]]; then
        echo "ACTION_ENTER"
        return
    fi
    # Check Exit key (custom + default)
    if [[ "$key" == "$KEY_EXIT" ]] || [[ "$key" == $'\e[D' ]]; then
        echo "ACTION_EXIT"
        return
    fi
    # Check Select Toggle key (custom + defaults)
    if [[ "$key" == "$KEY_SELECT_TOGGLE" ]] || [[ "$key" == $'\e[2~' ]] || [[ "$key" == $'\e[L' ]] || [[ "$key" == ' ' ]]; then
        echo "ACTION_SELECT_TOGGLE"
        return
    fi
