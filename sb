    rename_current_entry() {
      local src src_name parent_dir new_name dest err

      src="$(current_row_path)" || {
        draw_status
        footer_message_auto "Rename failed: no valid item on current row."
        return 1
      }

      if [[ ! -e "$src" && ! -L "$src" ]]; then
        draw_status
        footer_message_auto "Rename failed: selected item no longer exists."
        return 1
      fi

      src_name="$(path_basename "$src")"
      new_name="$(read_line_prompt "Rename '${src_name}' to: " "$src_name")"
      new_name="$(sanitize_filename_input "$new_name")"
      [[ -n "$new_name" ]] || {
        draw_status
        footer_message_auto "Rename cancelled."
        return 1
      }

      if [[ "$new_name" == "$src_name" ]]; then
        draw_status
        footer_message_auto "Rename unchanged: %s" "$src_name"
        return 0
      fi

      if [[ "$new_name" == */* ]]; then
        draw_status
        footer_message_auto "Rename failed: use a name only (no '/')."
        return 1
      fi

      parent_dir="$(path_dirname "$src")"
      dest="$parent_dir/$new_name"
      if [[ -e "$dest" || -L "$dest" ]]; then
        draw_status
        footer_message_auto "Rename failed: target exists: %s" "$new_name"
        return 1
      fi

      if ! err="$(run_mv_path "$src" "$dest" 2>&1)"; then
        draw_status
        if [[ -n "$err" ]]; then
          footer_message_auto "Rename failed: %s" "$err"
        else
          footer_message_auto "Rename failed: %s" "$src_name"
        fi
        return 1
      fi

      load_data
      position_cursor_for_name "$new_name" >/dev/null 2>&1 || true
      draw_ui
      footer_message_auto "Renamed: %s -> %s" "$src_name" "$new_name"
      return 0
    }

    create_entry_from_prompt() {
      local kind="$1"
      local prompt label name target display_name err

      if [[ "$kind" == "dir" ]]; then
        prompt="New folder name: "
        label="Folder"
      else
        prompt="New file name: "
        label="File"
      fi

      name="$(read_line_prompt "$prompt" "")"
      name="$(sanitize_filename_input "$name")"
      [[ -n "$name" ]] || {
        draw_status
        footer_message_auto "%s creation cancelled." "$label"
        return 1
      }

      target="${name/#\~/$HOME}"
      if [[ "$target" != /* ]]; then
        target="$(pwd -P)/$target"
      fi

      if [[ -e "$target" || -L "$target" ]]; then
        draw_status
        footer_message_auto "%s exists: %s" "$label" "$name"
        return 1
      fi

      if [[ "$kind" == "dir" ]]; then
        if ! err="$(run_mkdir "$target" 2>&1)"; then
          draw_status
          if [[ -n "$err" ]]; then
            footer_message_auto "Create folder failed: %s" "$err"
          else
            footer_message_auto "Create folder failed: %s" "$name"
          fi
          return 1
        fi
      else
        if ! err="$(run_touch_path "$target" 2>&1)"; then
          draw_status
          if [[ -n "$err" ]]; then
            footer_message_auto "Create file failed: %s" "$err"
          else
            footer_message_auto "Create file failed: %s" "$name"
          fi
          return 1
        fi
      fi

      display_name="$(path_basename "$target")"
      load_data
      position_cursor_for_name "$display_name" >/dev/null 2>&1 || true
      draw_ui
      footer_message_auto "%s created: %s" "$label" "$display_name"
      return 0
    }

    # Reorder long-list rows to `name metadata...` using awk+column alignment.
    # Minimal modification: split on date-time anchor, reorder, let column handle alignment.
    format_name_first_aligned() {
      local term_cols width_pct name_limit name_min_soft name_max_cap
      term_cols=$cols
      (( term_cols < 1 )) && term_cols=1

      if [[ "$SB_NAMEFIRST_WIDTH_PCT" =~ ^[0-9]+$ ]]; then
        width_pct=$SB_NAMEFIRST_WIDTH_PCT
      else
        width_pct=35
      fi

      if [[ "$SB_NAMEFIRST_NAME_MIN" =~ ^[0-9]+$ ]]; then
        name_min_soft=$SB_NAMEFIRST_NAME_MIN
      else
        name_min_soft=12
      fi

      if [[ "$SB_NAMEFIRST_NAME_MAX" =~ ^[0-9]+$ ]]; then
        name_max_cap=$SB_NAMEFIRST_NAME_MAX
      else
        name_max_cap=64
      fi

      (( width_pct < 1 )) && width_pct=1
      (( width_pct > 100 )) && width_pct=100
      (( name_min_soft < 1 )) && name_min_soft=1
      (( name_max_cap < 1 )) && name_max_cap=1
      (( name_max_cap < name_min_soft )) && name_max_cap=$name_min_soft

      name_limit=$(( (term_cols * width_pct) / 100 ))
      (( name_limit < name_min_soft )) && name_limit=$name_min_soft
      (( name_limit > name_max_cap )) && name_limit=$name_max_cap
      (( name_limit > term_cols )) && name_limit=$term_cols

      awk \
        -v name_limit="$name_limit" \
        -v list_source="$LIST_SOURCE" \
        -v debug_logo="$SB_DEBUG_LOGO_NAMEFIRST" \
        -v debug_file="$SB_DEBUG_LOGO_FILE" '
        BEGIN {
          esc = sprintf("%c", 27) "\\[[0-9;:]*m"
          dt_iso_plain = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9][[:space:]]+[0-9][0-9]:[0-9][0-9][[:space:]]+"
          dt_rfc3339_plain = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9][^ ]*[[:space:]]+"
          dt_stamp_plain = "[A-Za-z][A-Za-z][A-Za-z][[:space:]]+[0-9][0-9]?[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))[[:space:]]+"
          # Separate patterns for ISO, RFC3339, and Stamp (logo-ls default) timestamps.
          # Keeping them separate avoids complex nested alternation issues across awk implementations.
          dt_iso     = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*[[:space:]]+(" esc ")*[0-9][0-9]:[0-9][0-9](" esc ")*[[:space:]]+"
          # After the seconds, [^ ]* eats the timezone (+HH:MM, -HH:MM, Z) plus any trailing ANSI codes.
          dt_rfc3339 = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*T[0-9][0-9]:[0-9][0-9]:[0-9][0-9][^ ]*[[:space:]]+"
          dt_stamp   = "[A-Za-z][A-Za-z][A-Za-z](" esc ")*[[:space:]]+[0-9][0-9]?(" esc ")*[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))(" esc ")*[[:space:]]+"
          ellipsis = "..."
          row_count = 0
          logo_dt_mode = 0
          dbg_rows = 0
          if (debug_logo == "1") {
            print "--- logo-namefirst-debug ---" > debug_file
            print "name_limit=" name_limit > debug_file
          }
        }
        function strip_ansi(s, tmp) {
          tmp = s
          gsub(esc, "", tmp)
          return tmp
        }
        function pad_spaces(count, out, i) {
          out = ""
          for (i = 0; i < count; i++) {
            out = out " "
          }
          return out
        }
        function truncate_plain(plain, limit, keep) {
          if (limit <= 0 || length(plain) <= limit) {
            return plain
          }
          keep = limit - length(ellipsis)
          if (keep < 1) keep = 1
          return substr(plain, 1, keep) ellipsis
        }
        function truncate_colored(s, limit, plain, has_ansi, out, keep, i, ch, rest, mlen, m) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (!has_ansi) {
            return truncate_plain(plain, limit)
          }
          if (limit <= 0 || length(plain) <= limit) {
            return s
          }
          keep = limit - length(ellipsis)
          if (keep < 1) keep = 1
          out = ""
          i = 1
          while (i <= length(s) && keep > 0) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                out = out ch m
                i += RLENGTH + 1
                continue
              }
            }
            out = out ch
            i++
            keep--
          }
          return out ellipsis sprintf("%c[0m", 27)
        }
        function take_colored_prefix(s, limit, plain, has_ansi, out, i, ch, rest, m) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (limit <= 0) {
            return ""
          }
          if (!has_ansi) {
            return substr(plain, 1, limit)
          }
          out = ""
          i = 1
          while (i <= length(s) && limit > 0) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                out = out ch m
                i += RLENGTH + 1
                continue
              }
            }
            out = out ch
            i++
            limit--
          }
          return out sprintf("%c[0m", 27)
        }
        function drop_colored_prefix(s, skip, plain, has_ansi, out, i, ch, rest, m, visible) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (skip <= 0) {
            return s
          }
          if (!has_ansi) {
            return substr(plain, skip + 1)
          }
          out = ""
          i = 1
          visible = 0
          while (i <= length(s)) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                if (visible >= skip) {
                  out = out ch m
                }
                i += RLENGTH + 1
                continue
              }
            }
            visible++
            if (visible > skip) {
              out = out ch
            }
            i++
          }
          return out
        }
        {
          row_count++
          original[row_count] = $0
          parsed[row_count] = 0

          if (list_source == "logo-ls") {
            plain_row = strip_ansi($0)
            split_mode = "none"
            matched = 0
            if (logo_dt_mode == 1 && match(plain_row, dt_iso_plain)) {
              matched = 1
            } else if (logo_dt_mode == 2 && match(plain_row, dt_rfc3339_plain)) {
              matched = 1
            } else if (logo_dt_mode == 3 && match(plain_row, dt_stamp_plain)) {
              matched = 1
            } else if (match(plain_row, dt_iso_plain)) {
              logo_dt_mode = 1
              matched = 1
            } else if (match(plain_row, dt_rfc3339_plain)) {
              logo_dt_mode = 2
              matched = 1
            } else if (match(plain_row, dt_stamp_plain)) {
              logo_dt_mode = 3
              matched = 1
            }

            if (matched) {
              split_end = RSTART + RLENGTH - 1
              meta = take_colored_prefix($0, split_end)
              name = drop_colored_prefix($0, split_end)
              split_mode = "date"
            }

            if (split_mode != "none") {

              plain_name = strip_ansi(name)
              if (match(plain_name, /^[[:space:]]+/)) {
                lead_ws = RLENGTH
                name = drop_colored_prefix(name, lead_ws)
                plain_name = substr(plain_name, lead_ws + 1)
              }

              cleaned_plain = plain_name
              sub(/[[:space:]]+\.\.\.[[:space:]]*$/, "", cleaned_plain)
              sub(/[[:space:]]+$/, "", cleaned_plain)
              if (length(cleaned_plain) < length(plain_name)) {
                name = take_colored_prefix(name, length(cleaned_plain))
              }

              if (cleaned_plain == "" || cleaned_plain ~ /^[0-9][0-9]?[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))[[:space:]]*$/) {
                parsed[row_count] = 0
                next
              }

              if (debug_logo == "1" && dbg_rows < 12) {
                dbg_rows++
                print "row=" row_count " mode=" split_mode > debug_file
                print "plain=" plain_row > debug_file
                print "name=" cleaned_plain > debug_file
                print "meta=" strip_ansi(meta) > debug_file
              }
              name_col[row_count] = name
              meta_col[row_count] = meta
              parsed[row_count] = 1
            } else if (debug_logo == "1" && dbg_rows < 12) {
              dbg_rows++
              print "row=" row_count " mode=none" > debug_file
              print "plain=" plain_row > debug_file
            }
          } else if (match($0, dt_iso) || match($0, dt_rfc3339) || match($0, dt_stamp)) {
            name = substr($0, RSTART + RLENGTH)
            meta = substr($0, 1, RSTART + RLENGTH - 1)
            name_col[row_count] = name
            meta_col[row_count] = meta
            parsed[row_count] = 1
          }
        }
        END {
          for (i = 1; i <= row_count; i++) {
            if (!parsed[i]) {
              print original[i]
              continue
            }

            disp_name = truncate_colored(name_col[i], name_limit)
            plain_name = strip_ansi(disp_name)
            spacing = name_limit - length(plain_name) + 1
            if (spacing < 1) spacing = 1
            printf "%s%s%s\n", disp_name, pad_spaces(spacing), meta_col[i]
          }
        }
    '
    }

    load_data() {
      local t0 t1 t2

      PREVIEW_RENDER_DEFERRED=0
      PREVIEW_LAST_NAV_NS=0
      invalidate_preview_cache

      ROWS_COLOR=()
      ROWS_PLAIN=()
      ROWS_PATH=()
      ROWS_SELECTED=()
      DUST_ROW_PATHS=()

      t0=$(now_epoch_ns)
      capture_directory_rows || true
      t1=$(now_epoch_ns)
      LAST_LS_MS=$(( (t1 - t0) / 1000000 ))
      LAST_PARSE_MS=0
      LAST_LOAD_MS=$LAST_LS_MS
      ENTRY_COUNT=${#ROWS_COLOR[@]}

      if (( ${#ROWS_COLOR[@]} == 0 )); then
        ROWS_COLOR=("\033[2m(empty directory)\033[0m")
        ROWS_PLAIN=("(empty directory)")
        ROWS_SELECT_PLAIN=("(empty directory)")
        update_git_header_suffix
        cursor=0
        top=0
        return
      fi

      # Keep a stable plain array for path extraction before any display reformatting.
      read_stdin_into_array ROWS_SELECT_PLAIN < <(printf '%s\n' "${ROWS_COLOR[@]}" | sed -E $'s/\x1B\[[0-9;:]*m//g')

      if (( NAME_FIRST_VIEW )); then
        # Reformat only the display rows; selection rows stay in original capture order.
        read_stdin_into_array ROWS_COLOR < <(printf '%s\n' "${ROWS_COLOR[@]}" | format_name_first_aligned)
      fi
      t2=$(now_epoch_ns)
      LAST_PARSE_MS=$(( (t2 - t1) / 1000000 ))
      LAST_LOAD_MS=$(( (t2 - t0) / 1000000 ))

      (( cursor >= ${#ROWS_COLOR[@]} )) && cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
      (( top < 0 )) && top=0

      update_git_header_suffix
    }

    update_git_header_suffix() {
      local current_dir branch dirty="" status_output git_enabled=1
      current_dir="$(pwd -P 2>/dev/null || pwd)"
      integration_is_disabled git && git_enabled=0

      if [[ "$GIT_HEADER_CACHE_PWD" == "$current_dir" && "$GIT_HEADER_CACHE_ENABLED" == "$git_enabled" ]]; then
        GIT_HEADER_SUFFIX="$GIT_HEADER_CACHE_SUFFIX"
        return
      fi

      GIT_HEADER_SUFFIX=""
      if (( !git_enabled )); then
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      fi

      command -v git >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      branch="$(git branch --show-current 2>/dev/null)"
      [[ -z "$branch" ]] && branch="$(git rev-parse --short HEAD 2>/dev/null)"
      if [[ -n "$branch" && "$SB_GIT_DIRTY_CHECK" == "1" ]]; then
        status_output="$(git status --porcelain=v1 --untracked-files=normal 2>/dev/null)"
        [[ -n "$status_output" ]] && dirty="*"
      fi

      if [[ -n "$branch" ]]; then
        if [[ -n "$dirty" ]]; then
          printf -v GIT_HEADER_SUFFIX " \033[0;36m(%s\033[1;37m%s\033[0;36m)\033[0m" "$branch" "$dirty"
        else
          printf -v GIT_HEADER_SUFFIX " \033[0;36m(%s)\033[0m" "$branch"
        fi
      fi
      GIT_HEADER_CACHE_PWD="$current_dir"
      GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
      GIT_HEADER_CACHE_ENABLED="$git_enabled"
    }

    draw_header() {
      local user host cwd dust_segment=""
      local separator_width
      local separator
      user="${USER:-$(id -un 2>/dev/null || printf 'user')}"
      host="${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'host')}"
      cwd="$(pwd -P 2>/dev/null || pwd)"
      if [[ "$LIST_SOURCE" == "dust" && -n "$DUST_TOTAL" ]]; then
        printf -v dust_segment " \033[2m[dust:%s]\033[0m" "$DUST_TOTAL"
      fi
      separator_width=$cols
      (( separator_width < 1 )) && separator_width=1

      printf "\033[0;36m%s@%s\033[0m \033[2m»\033[0m \033[1;37m%s\033[0m%s%s\n" \
        "$user" "$host" "$cwd" "$GIT_HEADER_SUFFIX" "$dust_segment"
      printf -v separator '%*s' "$separator_width" ''
      separator=${separator// /─}
      printf '%s\033[K\n' "$separator"
    }

    ensure_cursor_hidden() {
      printf "\033[?25l"
    }

    draw_row() {
      local i="$1"
      local selected="$2"
      local row
      local row_plain

      if (( i < 0 || i >= ${#ROWS_COLOR[@]} )); then
        printf "\033[K\n"
        return
      fi

      row="${ROWS_COLOR[$i]}"
      row_plain="${ROWS_PLAIN[$i]-}"
      if [[ -z "$row_plain" ]]; then
        row_plain="$(strip_ansi_for_display "$row")"
        ROWS_PLAIN[$i]="$row_plain"
      fi

      if (( selected )); then
        printf "\033[7m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      if [[ "${ROWS_SELECTED[$i]-0}" == "1" ]]; then
        printf "\033[48;5;24m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      printf "%s\033[K\n" "$row"
    }

    strip_ansi_for_display() {
      local text="$1"
      local esc=$'\033'
      local ansi_re

      ansi_re="${esc}\\[[0-9:;]*m"

      while [[ "$text" =~ $ansi_re ]]; do
        text="${text//${BASH_REMATCH[0]}/}"
      done

      printf '%s' "$text"
    }

    draw_status() {
      local total="$ENTRY_COUNT"
      local status_row=$rows
      local separator_row=$(( rows - 1 ))
      local separator_width
      local separator
      local debug_line=""
      local hidden_state="off"
      local source_state="$LIST_SOURCE"
      local layout_state="meta-first"
      local preview_state="off"
      local debug_state=""
      local selection_state="$SELECTED_COUNT"
      local clipboard_state="$CLIPBOARD_LABEL"
      (( show_hidden )) && hidden_state="on"
      (( NAME_FIRST_VIEW )) && layout_state="name-first"
      (( PREVIEW_MODE )) && preview_state="on"

      if (( SHOW_DEBUG_FOOTER )); then
        debug_state=" renderer:${source_state} layout:${layout_state} hidden:${hidden_state} load:${LAST_LOAD_MS}ms (ls:${LAST_LS_MS} parse:${LAST_PARSE_MS})"

        if [[ "$SB_DEBUG_SOURCE" == "1" ]]; then
          debug_state+=" dbg:req:${LAST_SOURCE_REQUESTED} run:${LAST_SOURCE_EXECUTED} rc:${LAST_SOURCE_RC}"
          if (( LAST_SOURCE_FALLBACK )); then
            debug_state+=" fb:${LAST_SOURCE_FALLBACK_TO}"
          fi
          if [[ "$SB_DEBUG_SHOW_CMD" == "1" ]]; then
            debug_state+=" cmd:${LAST_SOURCE_ARGS}"
          fi
        fi

        if [[ "$SB_DEBUG_PASTE" == "1" ]]; then
          debug_state+=" clip:${LAST_CLIP_MODE} req:${LAST_CLIP_REQUESTED} ok:${LAST_CLIP_RESOLVED} drop:${LAST_CLIP_DROPPED}"
          debug_state+=" paste:${LAST_PASTE_OP} rc:${LAST_PASTE_RC} ok:${LAST_PASTE_OK} fail:${LAST_PASTE_FAIL} skip:${LAST_PASTE_SKIP}"
          if [[ -n "$LAST_PASTE_ERR" && "$LAST_PASTE_ERR" != "-" ]]; then
            local err_preview="$LAST_PASTE_ERR"
            if (( ${#err_preview} > 72 )); then
              err_preview="${err_preview:0:69}..."
            fi
            debug_state+=" err:${err_preview}"
          fi
        fi

        debug_line="$debug_state"
      fi

      # Keep footer anchored regardless of current cursor location.
      # Disable autowrap for the status line so long text never scrolls the screen.
      printf "\033[?7l"

      separator_width=$cols
      (( separator_width < 1 )) && separator_width=1
      if (( SHOW_DEBUG_FOOTER )); then
        printf "\033[%d;1H\033[K\033[2m%s\033[0m\033[K" "$separator_row" "$debug_line"
      else
        printf -v separator '%*s' "$separator_width" ''
        separator=${separator// /─}
        printf "\033[%d;1H\033[K%s\033[K" "$separator_row" "$separator"
      fi

      printf "\033[%d;1H\033[K" "$status_row"
      printf "\033[2m[total:\033[22;97m%s\033[2m sel:\033[22;97m%s\033[2m clip:\033[22;97m%s\033[2m preview:\033[22;97m%s\033[2m] F1:\033[22;97mhelp\033[2m %s:\033[22;97mrename\033[2m %s:\033[22;97mview\033[2m %s:\033[22;97medit\033[2m %s:\033[22;97mcopy\033[2m %s:\033[22;97mreload\033[2m %s:\033[22;97mpreview\033[2m%s\033[0m\033[K" \
        "$total" "$selection_state" "$clipboard_state" \
        "$preview_state" \
        "$KEY_RENAME_F2_LABEL" "$KEY_OPEN_LESS_F3_LABEL" "$KEY_OPEN_EDITOR_F4_LABEL" "$KEY_COPY_F5_LABEL" "$KEY_RELOAD_LABEL" "$KEY_TOGGLE_PREVIEW_LABEL" \
        ""
      printf "\033[?7h"
    }

    footer_message_auto() {
      local fmt="$1"
      shift
      local rendered=""
      local category="info"
      local icon=""
      local lower_msg=""
      local git_prefix=""
      local color_success=""
      local color_warning=""
      local color_error=""
      local color_info=""
      local color_reset=""
      local color_dim=$'\033[2m'

      printf -v rendered "$fmt" "$@"
      lower_msg="$(printf '%s' "$rendered" | tr '[:upper:]' '[:lower:]')"

      if [[ "$lower_msg" == *"cancel"* ]]; then
        category="info"
      elif [[ "$lower_msg" == *"failed"* || "$lower_msg" == *"error"* || "$lower_msg" == *"cannot"* || "$lower_msg" == *"unavailable"* ]]; then
        category="error"
      elif [[ "$lower_msg" == *"warn"* || "$lower_msg" == *"requires"* || "$lower_msg" == *"needs at least"* || "$lower_msg" == *"unchanged"* || "$lower_msg" == *"skipped"* ]]; then
        category="warning"
      elif [[ "$lower_msg" == *" complete"* || "$lower_msg" == *" completed"* || "$lower_msg" == *" created"* || "$lower_msg" == *" downloaded"* || "$lower_msg" == *" copied"* || "$lower_msg" == *" renamed"* || "$lower_msg" == *" protected"* || "$lower_msg" == *" unprotected"* || "$lower_msg" == *" ok:"* ]]; then
        category="success"
      fi

      if [[ "${NERD_FONT_ACTIVE:-0}" == "1" ]]; then
        if command -v tput >/dev/null 2>&1 && [[ -n "${TERM:-}" && "${TERM}" != "dumb" ]]; then
          color_success="$(tput setaf 2 2>/dev/null || true)"
          color_warning="$(tput setaf 3 2>/dev/null || true)"
          color_error="$(tput setaf 1 2>/dev/null || true)"
          color_info="$(tput setaf 6 2>/dev/null || true)"
          color_reset="$(tput sgr0 2>/dev/null || true)"
          color_dim="$(tput dim 2>/dev/null || printf $'\033[2m')"
        fi
        if [[ "$lower_msg" == *"git workflow"* ]]; then
          git_prefix=" "
        fi
        case "$category" in
          success) icon="${color_success}${git_prefix}󰄬 ${color_reset}${color_dim}" ;;
          warning) icon="${color_warning}${git_prefix}󰀪 ${color_reset}${color_dim}" ;;
          error) icon="${color_error}${git_prefix}󰄶 ${color_reset}${color_dim}" ;;
          *) icon="${color_info}${git_prefix}󰋽 ${color_reset}${color_dim}" ;;
        esac
      fi

      printf "\033[%d;1H\033[K\033[2m%s%s\033[0m" "$rows" "$icon" "$rendered"
    }

    invalidate_preview_cache() {
      PREVIEW_CACHE_PATH=""
      PREVIEW_CACHE_WIDTH=0
      PREVIEW_CACHE_HEIGHT=0
      PREVIEW_LINES_HAS_ANSI=0
      PREVIEW_LINES=()
    }

    fit_plain_cell() {
      local text="$1"
      local width="$2"
      local ellipsis="..."

      (( width < 1 )) && {
        printf ''
        return
      }

      if (( ${#text} > width )); then
        if (( width <= ${#ellipsis} )); then
          text="${text:0:width}"
        else
          text="${text:0:$((width - ${#ellipsis}))}${ellipsis}"
        fi
      fi

      printf '%-*s' "$width" "$text"
    }

    preview_collect_lines() {
      local height="$1"
      local raw_text="$2"
      local preserve_ansi="${3:-0}"

      if [[ -z "$raw_text" ]]; then
        PREVIEW_LINES_HAS_ANSI=0
        PREVIEW_LINES=("(no preview output)")
        return 0
      fi

      if [[ "$preserve_ansi" == "1" ]]; then
        PREVIEW_LINES_HAS_ANSI=1
        read_stdin_into_array PREVIEW_LINES < <(
          printf '%s\n' "$raw_text" \
            | sed 's/\t/  /g' \
            | head -n "$height"
        )
      else
        PREVIEW_LINES_HAS_ANSI=0
        read_stdin_into_array PREVIEW_LINES < <(
          printf '%s\n' "$raw_text" \
            | sed -E $'s/\x1B\[[0-9;:]*m//g' \
            | sed 's/\t/  /g' \
            | head -n "$height"
        )
      fi

      if (( ${#PREVIEW_LINES[@]} == 0 )); then
        PREVIEW_LINES_HAS_ANSI=0
        PREVIEW_LINES=("(no preview output)")
      fi
    }

    set_preview_pane_color_kind() {
      local kind="$1"

      case "$kind" in
        directory)
          PREVIEW_PANE_COLOR=$'\033[0;36m'
          ;;
        archive)
          PREVIEW_PANE_COLOR=$'\033[0;33m'
          ;;
        image)
          PREVIEW_PANE_COLOR=$'\033[0;35m'
          ;;
        pdf)
          PREVIEW_PANE_COLOR=$'\033[0;32m'
          ;;
        markdown)
          PREVIEW_PANE_COLOR=$'\033[1;36m'
          ;;
        data)
          PREVIEW_PANE_COLOR=$'\033[0;96m'
          ;;
        binary)
          PREVIEW_PANE_COLOR=$'\033[0;31m'
          ;;
        *)
          PREVIEW_PANE_COLOR=$'\033[0;37m'
          ;;
      esac
    }

    build_inline_preview_for_path() {
      local path="$1"
      local width="$2"
      local height="$3"
      local output=""

      PREVIEW_LINES=()

      if [[ -z "$path" ]]; then
        set_preview_pane_color_kind text
        PREVIEW_LINES=("(no selection)")
        return 0
      fi

      if [[ -d "$path" ]]; then
        set_preview_pane_color_kind directory
        output="$(LC_ALL=C ls -1A -- "$path" 2>/dev/null | head -n "$height")"
        if [[ -z "$output" ]]; then
          PREVIEW_LINES=("(directory is empty)")
          return 0
        fi
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if is_archive_file "$path"; then
        set_preview_pane_color_kind archive
        local lower
        lower="$(lowercase_string "$path")"
        case "$lower" in
          *.zip|*.jar|*.apk|*.war|*.ear|*.aar|*.cbz|*.epub|*.xpi|*.docx|*.xlsx|*.pptx|*.odt|*.ods|*.odp)
            if command -v unzip >/dev/null 2>&1; then
              output="$(unzip -l -- "$path" 2>/dev/null | head -n "$height")"
            fi
            ;;
          *.tar|*.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.tar.lz4|*.tar.zst|*.tzst|*.tar.lz)
            if command -v tar >/dev/null 2>&1; then
              output="$(tar tvf "$path" 2>/dev/null | head -n "$height")"
            fi
            ;;
          *.7z)
            if command -v 7z >/dev/null 2>&1; then
              output="$(7z l -- "$path" 2>/dev/null | head -n "$height")"
            fi
            ;;
          *.rar)
            if command -v unrar >/dev/null 2>&1; then
              output="$(unrar l -- "$path" 2>/dev/null | head -n "$height")"
            elif command -v rar >/dev/null 2>&1; then
              output="$(rar l -- "$path" 2>/dev/null | head -n "$height")"
            fi
            ;;
        esac
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if (( HAS_CHAFA )) && ! integration_is_disabled chafa && path_is_image_file "$path"; then
        set_preview_pane_color_kind image
        output="$(chafa --animate=off --symbols vhalf --size "${width}x${height}" -- "$path" 2>/dev/null)"
        preview_collect_lines "$height" "$output" 1
        return 0
      fi

      if (( HAS_PDFTOTEXT )) && ! integration_is_disabled pdftotext && is_pdf_file "$path"; then
        set_preview_pane_color_kind pdf
        output="$(pdftotext ${SB_PDFTOTEXT_ARGS:-} -- "$path" - 2>/dev/null | head -n "$height")"
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if (( HAS_GLOW )) && ! integration_is_disabled glow && is_markdown_file "$path"; then
        set_preview_pane_color_kind markdown
        output="$(glow -w "$width" ${SB_GLOW_ARGS:-} -- "$path" 2>/dev/null | head -n "$height")"
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if is_jnv_file "$path"; then
        set_preview_pane_color_kind data
        if (( HAS_JNV )) && ! integration_is_disabled jnv; then
          if command -v jq >/dev/null 2>&1; then
            output="$(jq -C . -- "$path" 2>/dev/null | head -n "$height")"
          else
            output="$(printf 'jnv integration available (interactive). Showing plain excerpt.\n\n'; head -n "$height" -- "$path" 2>/dev/null)"
          fi
        else
          output="$(head -n "$height" -- "$path" 2>/dev/null)"
        fi
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if is_csvlens_file "$path"; then
        set_preview_pane_color_kind data
        if (( HAS_CSVLENS )) && ! integration_is_disabled csvlens; then
          if command -v column >/dev/null 2>&1; then
            output="$(head -n "$height" -- "$path" 2>/dev/null | column -s, -t 2>/dev/null)"
          else
            output="$(printf 'csvlens integration available (interactive). Showing plain excerpt.\n\n'; head -n "$height" -- "$path" 2>/dev/null)"
          fi
        else
          output="$(head -n "$height" -- "$path" 2>/dev/null)"
        fi
        preview_collect_lines "$height" "$output"
        return 0
      fi

      if (( HAS_HEXYL )) && ! integration_is_disabled hexyl && should_use_hex_fallback_file "$path"; then
        set_preview_pane_color_kind binary
        output="$(hexyl ${SB_HEXYL_ARGS:-} -- "$path" 2>/dev/null | head -n "$height")"
        preview_collect_lines "$height" "$output"
        return 0
      fi

      set_preview_pane_color_kind text
      if (( HAS_BAT )); then
        output="$(bat --paging=never --terminal-width "$width" --line-range ":$height" -- "$path" 2>/dev/null)"
      elif (( HAS_BATCAT )); then
        output="$(batcat --paging=never --terminal-width "$width" --line-range ":$height" -- "$path" 2>/dev/null)"
      else
        output="$(head -n "$height" -- "$path" 2>/dev/null)"
      fi
      preview_collect_lines "$height" "$output"
    }

    ensure_preview_cache() {
      local width="$1"
      local height="$2"
      local path=""

      if (( cursor >= 0 && cursor < ${#ROWS_SELECT_PLAIN[@]} )); then
        path="$(ensure_row_path "$cursor" 2>/dev/null || true)"
      fi

      if [[ "$PREVIEW_CACHE_PATH" == "$path" && "$PREVIEW_CACHE_WIDTH" == "$width" && "$PREVIEW_CACHE_HEIGHT" == "$height" ]]; then
        return 0
      fi

      build_inline_preview_for_path "$path" "$width" "$height"
      PREVIEW_CACHE_PATH="$path"
      PREVIEW_CACHE_WIDTH=$width
      PREVIEW_CACHE_HEIGHT=$height
    }

    draw_ui_preview_split() {
      local split_pct left_width right_width line idx

      split_pct=$PREVIEW_SPLIT_PCT
      (( split_pct < 20 )) && split_pct=20
      (( split_pct > 70 )) && split_pct=70

      left_width=$(( (cols * split_pct) / 100 ))
      (( left_width < 12 )) && left_width=12
      (( left_width > cols - 10 )) && left_width=$(( cols - 10 ))
      right_width=$(( cols - left_width - 1 ))
      (( right_width < 8 )) && right_width=8

      ensure_preview_cache "$right_width" "$visible_rows"

      printf "\033[?7l"
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        draw_preview_split_row "$idx" "$line" "$left_width" "$right_width"
      done
      printf "\033[?7h"
    }

    draw_preview_split_row() {
      local idx="$1"
      local line="$2"
      local left_width="$3"
      local right_width="$4"
      local row_plain=""
      local left_cell right_cell preview_line separator_cell color_dim color_reset preview_color preview_reset
      local screen_line=$((3 + line))

      printf "\033[%d;1H" "$screen_line"

      if (( idx >= 0 && idx < ${#ROWS_COLOR[@]} )); then
        row_plain="${ROWS_PLAIN[$idx]-}"
        if [[ -z "$row_plain" ]]; then
          row_plain="$(strip_ansi_for_display "${ROWS_COLOR[$idx]}")"
          ROWS_PLAIN[$idx]="$row_plain"
        fi
      fi

      left_cell="$(fit_plain_cell "$row_plain" "$left_width")"
      preview_line="${PREVIEW_LINES[$line]-}"
      if (( PREVIEW_LINES_HAS_ANSI )); then
        right_cell="$preview_line"
      else
        right_cell="$(fit_plain_cell "$preview_line" "$right_width")"
      fi
      color_dim=$'\033[2m'
      color_reset=$'\033[0m'
      separator_cell="${color_dim}${PREVIEW_SEPARATOR_CHAR}${color_reset}"
      preview_color=""
      preview_reset=""
      if (( PREVIEW_COLORS )) && (( !PREVIEW_LINES_HAS_ANSI )); then
        preview_color="$PREVIEW_PANE_COLOR"
        preview_reset=$'\033[0m'
      fi

      if (( idx == cursor )); then
        printf "\033[7m%s\033[0m%s%s%s\033[K" "$left_cell" "$separator_cell" "$preview_color" "$right_cell$preview_reset"
      elif (( idx >= 0 && idx < ${#ROWS_SELECTED[@]} )) && [[ "${ROWS_SELECTED[$idx]-0}" == "1" ]]; then
        printf "\033[48;5;24m%s\033[0m%s%s%s\033[K" "$left_cell" "$separator_cell" "$preview_color" "$right_cell$preview_reset"
      else
        printf "%s%s%s%s\033[K" "$left_cell" "$separator_cell" "$preview_color" "$right_cell$preview_reset"
      fi
    }

    redraw_preview_rows_and_status() {
      local refresh_preview="${1:-1}"
      local split_pct left_width right_width line idx

      ensure_cursor_hidden

      split_pct=$PREVIEW_SPLIT_PCT
      (( split_pct < 20 )) && split_pct=20
      (( split_pct > 70 )) && split_pct=70

      left_width=$(( (cols * split_pct) / 100 ))
      (( left_width < 12 )) && left_width=12
      (( left_width > cols - 10 )) && left_width=$(( cols - 10 ))
      right_width=$(( cols - left_width - 1 ))
      (( right_width < 8 )) && right_width=8

      if [[ "$refresh_preview" == "1" ]]; then
        ensure_preview_cache "$right_width" "$visible_rows"
      fi

      printf "\033[?7l"
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        draw_preview_split_row "$idx" "$line" "$left_width" "$right_width"
      done
      printf "\033[?7h"

      draw_status
    }

    # Fast navigation redraw: updates ONLY the left file-list pane and separator.
    # The right preview pane is left completely untouched, keeping it visually
    # stable while the user holds Up/Down.  The deferred-idle timer handles the
    # single preview rebuild once the user stops navigating.
    redraw_preview_left_and_status() {
      local split_pct left_width line idx row_plain left_cell screen_line
      local color_dim color_reset sep

      ensure_cursor_hidden

      split_pct=$PREVIEW_SPLIT_PCT
      (( split_pct < 20 )) && split_pct=20
      (( split_pct > 70 )) && split_pct=70
      left_width=$(( (cols * split_pct) / 100 ))
      (( left_width < 12 )) && left_width=12
      (( left_width > cols - 10 )) && left_width=$(( cols - 10 ))

      color_dim=$'\033[2m'
      color_reset=$'\033[0m'
      sep="${color_dim}${PREVIEW_SEPARATOR_CHAR}${color_reset}"

      printf "\033[?7l"
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        screen_line=$((3 + line))
        row_plain=""
        if (( idx >= 0 && idx < ${#ROWS_COLOR[@]} )); then
          row_plain="${ROWS_PLAIN[$idx]-}"
          if [[ -z "$row_plain" ]]; then
            row_plain="$(strip_ansi_for_display "${ROWS_COLOR[$idx]}")"
            ROWS_PLAIN[$idx]="$row_plain"
          fi
        fi
        left_cell="$(fit_plain_cell "$row_plain" "$left_width")"
        printf "\033[%d;1H" "$screen_line"
        if (( idx == cursor )); then
          printf "\033[7m%s\033[0m%s" "$left_cell" "$sep"
        elif (( idx >= 0 && idx < ${#ROWS_SELECTED[@]} )) && [[ "${ROWS_SELECTED[$idx]-0}" == "1" ]]; then
          printf "\033[48;5;24m%s\033[0m%s" "$left_cell" "$sep"
        else
          printf "%s%s" "$left_cell" "$sep"
        fi
      done
      printf "\033[?7h"

      draw_status
    }

    scroll_list_once() {
      local direction="$1"
      local top_row=3
      local bottom_row=$((2 + visible_rows))

      printf "\033[%d;%dr" "$top_row" "$bottom_row"
      if [[ "$direction" == "down" ]]; then
        printf "\033[%d;1H\033[M" "$top_row"
      else
        printf "\033[%d;1H\033[L" "$top_row"
      fi
      printf "\033[r"
    }

    redraw_row_at_index() {
      local i="$1"
      local screen_line

      (( i >= top && i < top + visible_rows )) || return
      screen_line=$((3 + i - top))
      printf "\033[%d;1H" "$screen_line"
      if (( i == cursor )); then
        draw_row "$i" 1
      else
        draw_row "$i" 0
      fi
    }

    redraw_visible_rows_and_status() {
      local i
      ensure_cursor_hidden
      for (( i=top; i<top + visible_rows; i++ )); do
        redraw_row_at_index "$i"
      done
      draw_status
    }

    draw_ui() {
      ensure_cursor_hidden
      printf "\033[H\033[2J"
      draw_header

      if (( PREVIEW_MODE )); then
        draw_ui_preview_split
        draw_status
        return
      fi

      local line idx
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        if (( idx == cursor )); then
          draw_row "$idx" 1
        else
          draw_row "$idx" 0
        fi
      done

      draw_status
    }

    normalize_function_key_sequence() {
      local seq="$1"

      case "$seq" in
        # Alternate arrow-key sequences (application cursor mode).
        $'\eOA')
          printf '%s' "$KEY_UP"
          return 0
          ;;
        $'\eOB')
          printf '%s' "$KEY_DOWN"
          return 0
          ;;
        $'\eOC')
          printf '%s' "$KEY_RIGHT"
          return 0
          ;;
        $'\eOD')
          printf '%s' "$KEY_LEFT"
          return 0
          ;;
        # CSI arrow-key variants (including modifier forms like Esc [ 1 ; n A/B/C/D).
        $'\e[A'|$'\e['*'A')
          printf '%s' "$KEY_UP"
          return 0
          ;;
        $'\e[B'|$'\e['*'B')
          printf '%s' "$KEY_DOWN"
          return 0
          ;;
        $'\e[C'|$'\e['*'C')
          printf '%s' "$KEY_RIGHT"
          return 0
          ;;
        $'\e[D'|$'\e['*'D')
          printf '%s' "$KEY_LEFT"
          return 0
          ;;
        # Mouse clicks (SGR 1006 mode): left click opens/enters, right click goes parent.
        $'\e[<0;'*'M')
          printf '%s' "$KEY_RIGHT"
          return 0
          ;;
        $'\e[<2;'*'M')
          printf '%s' "$KEY_LEFT"
          return 0
          ;;
        # Mouse wheel up/down (SGR 1006 mode) -> map to existing cursor keys.
        $'\e[<64;'*'M'|$'\e[<64;'*'m')
          printf '%s' "$KEY_UP"
          return 0
          ;;
        $'\e[<65;'*'M'|$'\e[<65;'*'m')
          printf '%s' "$KEY_DOWN"
          return 0
          ;;
        $'\eOP'|$'\e[11~'|$'\e[11;'*'~'|$'\e[1;'*P)
          printf '%s' "$KEY_HELP_F1"
          return 0
          ;;
        $'\eOQ'|$'\e[12~'|$'\e[12;'*'~'|$'\e[1;'*Q)
          printf '%s' "$KEY_RENAME_F2"
          return 0
          ;;
        $'\eOR'|$'\e[13~'|$'\e[13;'*'~'|$'\e[1;'*R)
          printf '%s' "$KEY_OPEN_LESS_F3"
          return 0
          ;;
        $'\eOS'|$'\e[14~'|$'\e[14;'*'~'|$'\e[1;'*S)
          printf '%s' "$KEY_OPEN_EDITOR_F4"
          return 0
          ;;
        # Enter variants seen across terminals/key protocols.
        $'\eOM'|$'\e[27;13~'|$'\e[27;13;'*'~'|$'\e[13u'|$'\e[13;'*'u'|$'\e[27;13u'|$'\e[27;13;'*'u')
          printf '%s' "$KEY_ENTER"
          return 0
          ;;
        $'\e[15~'|$'\e[15;'*'~')
          printf '%s' "$KEY_COPY_F5"
          return 0
          ;;
        $'\e[17~'|$'\e[17;'*'~')
          printf '%s' "$KEY_RELOAD"
          return 0
          ;;
        $'\e[18~'|$'\e[18;'*'~')
          printf '%s' $'\e[18~'
          return 0
          ;;
        $'\e[19~'|$'\e[19;'*'~')
          printf '%s' "$KEY_TOGGLE_DEBUG"
          return 0
          ;;
        $'\e[20~'|$'\e[20;'*'~')
          printf '%s' "$KEY_TOGGLE_NAME_FIRST"
          return 0
          ;;
        $'\e[21~'|$'\e[21;'*'~')
          printf '%s' $'\e[21~'
          return 0
          ;;
        $'\e[23~'|$'\e[23;'*'~')
          printf '%s' $'\e[23~'
          return 0
          ;;
        $'\e[24~'|$'\e[24;'*'~')
          printf '%s' "$KEY_TOGGLE_SOURCE"
          return 0
          ;;
      esac

      printf '%s' "$seq"
      return 0
    }

    read_key() {
      local timeout="${1:-}"
      local k k2 ch seq normalized
      local mouse_complete=0
      if [[ -n "$timeout" ]]; then
        IFS= read -rsn1 -t "$timeout" k || return 1
      else
        IFS= read -rsn1 k || return 1
      fi
      # In some terminal modes, Enter may arrive as an empty read token.
      # Canonicalize it so dispatch paths consistently receive KEY_ENTER.
      if [[ -z "$k" ]]; then
        LAST_KEY_RAW=$'\n'
        printf '%s' "$KEY_ENTER"
        return 0
      fi
      if [[ "$k" != $'\e' ]]; then
        LAST_KEY_RAW="$k"
        printf '%s' "$k"
        return 0
      fi

      seq="$k"
      IFS= read -rsn1 -t 0.005 k2 || {
        LAST_KEY_RAW="$seq"
        printf '%s' "$seq"
        return 0
      }
      seq+="$k2"

      # SS3 sequence (e.g. F1..F4 as Esc O P/Q/R/S) is exactly one more byte.
      if [[ "$k2" == 'O' ]]; then
        IFS= read -rsn1 -t 0.005 ch || {
          LAST_KEY_RAW="$seq"
          printf '%s' "$seq"
          return 0
        }
        seq+="$ch"
        LAST_KEY_RAW="$seq"
        normalized="$(normalize_function_key_sequence "$seq")"
        printf '%s' "$normalized"
        return 0
      fi

      # CSI sequence: read until final byte in 0x40..0x7E range.
      if [[ "$k2" == '[' ]]; then
        # SGR mouse report starts with ESC [ < ... and must end with M/m.
        # If a partial sequence leaks through (timeouts), swallow it so delimiters like ';'
        # do not get interpreted as standalone keys (e.g. run-command key).
        if IFS= read -rsn1 -t 0.005 ch; then
          seq+="$ch"
          if [[ "$ch" == '<' ]]; then
            mouse_complete=0
            while IFS= read -rsn1 -t 0.02 ch; do
              seq+="$ch"
              if [[ "$ch" == 'M' || "$ch" == 'm' ]]; then
                mouse_complete=1
                break
              fi
              (( ${#seq} >= 64 )) && break
            done
            if (( !mouse_complete )); then
              while IFS= read -rsn1 -t 0.001 ch; do
                [[ "$ch" == 'M' || "$ch" == 'm' ]] && break
              done
              LAST_KEY_RAW="$seq"
              printf '%s' ""
              return 0
            fi
            LAST_KEY_RAW="$seq"
            normalized="$(normalize_function_key_sequence "$seq")"
            printf '%s' "$normalized"
            return 0
          fi
          [[ "$ch" =~ [@-~] ]] || {
            while IFS= read -rsn1 -t 0.005 ch; do
              seq+="$ch"
              [[ "$ch" =~ [@-~] ]] && break
              (( ${#seq} >= 32 )) && break
            done
          }
          LAST_KEY_RAW="$seq"
          normalized="$(normalize_function_key_sequence "$seq")"
          printf '%s' "$normalized"
          return 0
        fi

        while IFS= read -rsn1 -t 0.005 ch; do
          seq+="$ch"
          [[ "$ch" =~ [@-~] ]] && break
          (( ${#seq} >= 32 )) && break
        done
        LAST_KEY_RAW="$seq"
        normalized="$(normalize_function_key_sequence "$seq")"
        printf '%s' "$normalized"
        return 0
      fi

      # Non-CSI escape combinations (e.g. Alt+key): return as-is.
      LAST_KEY_RAW="$seq"
      printf '%s' "$seq"
      return 0
    }

    move_up() {
      (( cursor > 0 )) || return
      ((cursor--))
      (( cursor < top )) && top=$cursor
    }

    move_down() {
      (( cursor + 1 < ${#ROWS_COLOR[@]} )) || return
      ((cursor++))
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    # Strip symlink target from a name string if the row represents a symlink (l*).
    strip_symlink_target() {
      local plain="$1" name="$2"
      if [[ "$plain" == l* || "$plain" == L* ]]; then
        name="${name%% -> *}"
        name="${name%% ⇒ *}"
        name="${name%% ~> *}"
      fi
      printf '%s' "$name"
    }

    parse_name_from_plain_row() {
      local plain="$1" name
      case "$LIST_SOURCE" in
        ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        lsd|eza)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        dust)
          # Dust output prefixes rows with size and tree glyphs; resolve_row_path_from_plain
          # token-peeling logic will reduce this to an existing path candidate.
          name="$plain"
          ;;
        logo-ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9:]+|Z)[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[2]}"
          elif [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          elif [[ "$plain" =~ [A-Za-z][A-Za-z][A-Za-z][[:space:]]+[[:digit:]]{1,2}[[:space:]]+(([0-9]{2}:[0-9]{2}(:[0-9]{2})?)|([0-9]{4}))[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[5]}"
          elif [[ "$plain" =~ [A-Za-z][A-Za-z][A-Za-z][[:space:]]+[[:digit:]]{1,2}[[:space:]]+[0-9]{4}[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          if [[ "$name" =~ ^(.*[^[:space:]])[[:space:]]+\.\.\.[[:space:]]*$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          if ! path_exists "$name" && [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          # logo-ls appends -F classify suffixes: / (dir), @ (symlink), * (exe), = (socket), | (fifo).
          # Strip them so path resolution works; display is unaffected (drawn from ROWS_COLOR/PLAIN).
          name="${name%/}"
          name="${name%@}"
          name="${name%\*}"
          name="${name%=}"
          name="${name%|}"
          ;;
        *)
          return 1
          ;;
      esac

      printf '%s' "$name"
      return 0
    }

    path_exists() {
      local p="$1"
      [[ -e "$p" || -L "$p" ]]
    }

    normalize_candidate_path() {
      local value="$1"

      # Trim leading/trailing whitespace.
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"

      # Remove renderer symlink target tails.
      value="${value%% -> *}"
      value="${value%% ⇒ *}"
      value="${value%% ~> *}"

      # Remove logo-ls classify suffixes.
      value="${value%/}"
      value="${value%@}"
      value="${value%\*}"
      value="${value%=}"
      value="${value%|}"

      # Some icon themes glue glyphs directly to names; peel non-path glyphs.
      while [[ "$value" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+(.*)$ ]]; do
        value="${BASH_REMATCH[1]}"
      done

      # Trim again after normalization.
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"

      printf '%s' "$value"
    }

    resolve_row_path_from_plain() {
      local plain="$1" name candidate

      if (( PREVIEW_MODE )); then
        candidate="$(normalize_candidate_path "$plain")"
        if path_exists "$candidate"; then
          printf '%s' "$candidate"
          return 0
        fi
        while [[ "$candidate" =~ ^[[:space:]]*[^[:space:]]+[[:space:]]+(.*)$ ]]; do
          candidate="${BASH_REMATCH[1]}"
          candidate="$(normalize_candidate_path "$candidate")"
          [[ -n "$candidate" ]] || break
          if path_exists "$candidate"; then
            printf '%s' "$candidate"
            return 0
          fi
        done
        return 1
      fi

      name="$(parse_name_from_plain_row "$plain" 2>/dev/null || true)"

      if [[ -n "$name" ]]; then
        candidate="$name"
      elif [[ "$LIST_SOURCE" == "logo-ls" ]]; then
        # For logo-ls, fall back to scanning from the full row when parser patterns miss.
        candidate="$plain"
      else
        return 1
      fi

      candidate="$(normalize_candidate_path "$candidate")"
      if path_exists "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi

      # Some renderers can leave icon tokens in plain text; peel leading tokens until path resolves.
      while [[ "$candidate" =~ ^[[:space:]]*[^[:space:]]+[[:space:]]+(.*)$ ]]; do
        candidate="${BASH_REMATCH[1]}"
        candidate="$(normalize_candidate_path "$candidate")"
        [[ -n "$candidate" ]] || break
        if path_exists "$candidate"; then
          printf '%s' "$candidate"
          return 0
        fi
      done

      return 1
    }

    build_row_paths() {
      local plain path i
      ROWS_PATH=()
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        plain="${ROWS_SELECT_PLAIN[$i]}"
        if [[ "$plain" == "(empty directory)" ]]; then
          ROWS_PATH+=("")
          continue
        fi
        if [[ "$LIST_SOURCE" == "dust" && -n "${DUST_ROW_PATHS[$i]-}" ]]; then
          ROWS_PATH+=("${DUST_ROW_PATHS[$i]}")
          continue
        fi
        path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
        ROWS_PATH+=("$path")
      done
    }

    ensure_row_path() {
      local idx="$1"
      local plain path

      if (( idx < 0 || idx >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi

      if [[ -n "${ROWS_PATH[$idx]-}" ]]; then
        printf '%s' "${ROWS_PATH[$idx]}"
        return 0
      fi

      plain="${ROWS_SELECT_PLAIN[$idx]}"
      [[ "$plain" == "(empty directory)" ]] && return 1

      if [[ "$LIST_SOURCE" == "dust" && -n "${DUST_ROW_PATHS[$idx]-}" ]]; then
        ROWS_PATH[$idx]="${DUST_ROW_PATHS[$idx]}"
        printf '%s' "${ROWS_PATH[$idx]}"
        return 0
      fi

      path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
      [[ -n "$path" ]] || return 1
      ROWS_PATH[$idx]="$path"
      printf '%s' "$path"
      return 0
    }

    ensure_all_row_paths() {
      local i
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        ensure_row_path "$i" >/dev/null 2>&1 || true
      done
    }

    clear_selection() {
      SELECTED_PATHS=()
      update_selected_count
      ROWS_SELECTED=()
    }

    rebuild_row_selection_flags() {
      local i path selected_path still_visible
      local -a current_selected=()

      ensure_all_row_paths
      read_stdin_into_array current_selected < <(print_selected_paths)

      ROWS_SELECTED=()
      for selected_path in "${current_selected[@]}"; do
        still_visible=0
        for i in "${!ROWS_SELECT_PLAIN[@]}"; do
          path="${ROWS_PATH[$i]-}"
          if [[ "$path" == "$selected_path" ]]; then
            still_visible=1
            break
          fi
        done
        (( still_visible )) || unmark_selected_path "$selected_path"
      done

      update_selected_count
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        if [[ -n "$path" ]] && selected_path_is_marked "$path"; then
          ROWS_SELECTED+=(1)
        else
          ROWS_SELECTED+=(0)
        fi
      done
    }

    current_row_path() {
      if (( cursor < 0 || cursor >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi
      ensure_row_path "$cursor"
    }

    toggle_selection_current() {
      local path idx
      idx=$cursor
      path="$(current_row_path)" || return 1

      if selected_path_is_marked "$path"; then
        unmark_selected_path "$path"
        ROWS_SELECTED[$idx]=0
      else
        mark_selected_path "$path"
        ROWS_SELECTED[$idx]=1
      fi

      update_selected_count
      return 0
    }

    toggle_select_all() {
      local i all_selected=1 path
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        if ! selected_path_is_marked "$path"; then
          all_selected=0
          break
        fi
      done

      if (( all_selected )); then
        clear_selection
      else
        for i in "${!ROWS_SELECT_PLAIN[@]}"; do
          [[ -n "${ROWS_PATH[$i]-}" ]] || continue
          mark_selected_path "${ROWS_PATH[$i]}"
        done
        rebuild_row_selection_flags
      fi
    }

    collect_selected_paths_in_row_order() {
      local i path
      local -a collected=()
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        selected_path_is_marked "$path" || continue
        collected+=("$path")
      done
      if (( ${#collected[@]} > 0 )); then
        printf '%s\n' "${collected[@]}"
      fi
    }

    update_clipboard_label() {
      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        CLIPBOARD_LABEL="${#CLIPBOARD_MULTI[@]} items"
      elif [[ -n "$CLIPBOARD_NAME" ]]; then
        CLIPBOARD_LABEL="$CLIPBOARD_NAME"
      else
        CLIPBOARD_LABEL="none"
      fi
    }

    set_clipboard_from_current_or_selection() {
      local mode="$1"
      local path
      local abs_path
      local requested_count=0
      local -a items=()
      local -a abs_items=()

      LAST_CLIP_MODE="$mode"
      LAST_CLIP_REQUESTED=0
      LAST_CLIP_RESOLVED=0
      LAST_CLIP_DROPPED=0

      if (( SELECTED_COUNT > 0 )); then
        read_stdin_into_array items < <(collect_selected_paths_in_row_order)
      else
        path="$(current_row_path)" || return 1
        items=("$path")
      fi

      (( ${#items[@]} > 0 )) || return 1
      requested_count=${#items[@]}
      LAST_CLIP_REQUESTED=$requested_count
      for path in "${items[@]}"; do
        [[ -n "$path" ]] || continue
        abs_path="$(pwd -P)/$path"
        if path_exists "$path" || path_exists "$abs_path"; then
          abs_items+=("$abs_path")
        fi
      done
      LAST_CLIP_RESOLVED=${#abs_items[@]}
      LAST_CLIP_DROPPED=$(( requested_count - LAST_CLIP_RESOLVED ))
      (( ${#abs_items[@]} > 0 )) || return 1

      if (( ${#abs_items[@]} > 1 )) || [[ "$mode" == "move" ]]; then
        CLIPBOARD_MULTI=("${abs_items[@]}")
        CLIPBOARD_PATH=""
        CLIPBOARD_MOVE=0
        [[ "$mode" == "move" ]] && CLIPBOARD_MOVE=1
        CLIPBOARD_NAME="${#abs_items[@]} items"
      else
        CLIPBOARD_MULTI=()
        CLIPBOARD_MOVE=0
        CLIPBOARD_PATH="${abs_items[0]}"
        CLIPBOARD_NAME="$(path_basename "${abs_items[0]}")"
      fi

      CLIPBOARD_ITEMS=("${abs_items[@]}")
      CLIPBOARD_MODE="$mode"
      update_clipboard_label
      return 0
    }

    copy_full_paths_to_system_clipboard() {
      local path abs_path cwd_abs payload
      local -a items=()
      local -a abs_items=()

      cwd_abs="$(pwd -P 2>/dev/null || pwd)"

      read_stdin_into_array items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Copy full path failed: no valid source paths in current selection."
        return 1
      }

      for path in "${items[@]}"; do
        [[ -n "$path" ]] || continue
        if [[ "$path" == /* ]]; then
          abs_path="$path"
        else
          abs_path="$cwd_abs/$path"
        fi
        if [[ -e "$abs_path" || -L "$abs_path" ]]; then
          abs_items+=("$abs_path")
        fi
      done

      (( ${#abs_items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Copy full path failed: selected sources do not exist."
        return 1
      }

      printf -v payload '%s\n' "${abs_items[@]}"

      if ! integration_is_disabled wl-copy && command -v wl-copy >/dev/null 2>&1; then
        printf '%s' "$payload" | wl-copy
      elif ! integration_is_disabled xclip && command -v xclip >/dev/null 2>&1; then
        printf '%s' "$payload" | xclip -selection clipboard
      elif ! integration_is_disabled xsel && command -v xsel >/dev/null 2>&1; then
        printf '%s' "$payload" | xsel --clipboard --input
      elif ! integration_is_disabled pbcopy && command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$payload" | pbcopy
      else
        draw_status
        footer_message_auto "Copy full path failed: no enabled clipboard tool found (wl-copy/xclip/xsel/pbcopy)."
        return 1
      fi

      draw_status
      if (( ${#abs_items[@]} == 1 )); then
        footer_message_auto "Copied full path to clipboard."
      else
        footer_message_auto "Copied %d full paths to clipboard." "${#abs_items[@]}"
      fi
      return 0
    }

    paste_clipboard_items() {
      local src dest bname err
      local ok_count=0 fail_count=0 skip_count=0

      LAST_PASTE_OP="-"
      LAST_PASTE_RC=0
      LAST_PASTE_ERR="-"
      LAST_PASTE_OK=0
      LAST_PASTE_FAIL=0
      LAST_PASTE_SKIP=0

      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        if read_yes_no_prompt "Paste ${#CLIPBOARD_MULTI[@]} item(s) here? [y/N]: "; then
          for src in "${CLIPBOARD_MULTI[@]}"; do
            bname="$(path_basename "$src")"
            dest="$bname"
            if [[ -e "$dest" ]]; then
              bname="$(sanitize_filename_input "$bname")"
              dest="$(read_line_prompt "Paste '$bname' as: " "$dest")"
            fi
            dest="$(sanitize_filename_input "$dest")"
            if [[ -z "$dest" ]]; then
              ((skip_count++))
              continue
            fi

            if (( CLIPBOARD_MOVE )); then
              LAST_PASTE_OP="mv"
              if [[ "$SB_DEBUG_PASTE" == "1" ]]; then
                if err="$(run_mv_path "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif run_mv_path "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            else
              LAST_PASTE_OP="cp"
              if [[ "$SB_DEBUG_PASTE" == "1" ]]; then
                if err="$(run_cp_recursive "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif run_cp_recursive "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            fi
          done

          LAST_PASTE_OK=$ok_count
          LAST_PASTE_FAIL=$fail_count
          LAST_PASTE_SKIP=$skip_count

          if (( CLIPBOARD_MOVE )); then
            CLIPBOARD_MULTI=()
            CLIPBOARD_MOVE=0
            CLIPBOARD_NAME=""
            clear_selection
          fi

          CLIPBOARD_ITEMS=()
          update_clipboard_label
          load_data
          draw_ui
          footer_message_auto "Paste: ok:%d fail:%d skip:%d" "$ok_count" "$fail_count" "$skip_count"
        else
          LAST_PASTE_OP="cancel"
          draw_ui
        fi
        return 0
      fi

      if [[ -n "$CLIPBOARD_PATH" ]]; then
        dest="$CLIPBOARD_NAME"
        if [[ -e "$dest" ]]; then
          dest="$(read_line_prompt "New name: " "$dest")"
        fi
        dest="$(sanitize_filename_input "$dest")"

        LAST_PASTE_OP="cp"
        if [[ "$SB_DEBUG_PASTE" == "1" ]]; then
          if err="$(run_cp_recursive "$CLIPBOARD_PATH" "$dest" 2>&1)"; then
            LAST_PASTE_RC=0
            LAST_PASTE_ERR="-"
            LAST_PASTE_OK=1
            LAST_PASTE_FAIL=0
            LAST_PASTE_SKIP=0
            load_data
            draw_ui
            footer_message_auto "Paste: ok:1 fail:0 skip:0"
          else
            LAST_PASTE_RC=$?
            LAST_PASTE_ERR="$err"
            LAST_PASTE_OK=0
            LAST_PASTE_FAIL=1
            LAST_PASTE_SKIP=0
            draw_ui
            footer_message_auto "Paste failed for: %s" "$dest"
          fi
          return 0
        fi

        if run_cp_recursive "$CLIPBOARD_PATH" "$dest" 2>/dev/null; then
          LAST_PASTE_RC=0
          LAST_PASTE_OK=1
          LAST_PASTE_FAIL=0
          LAST_PASTE_SKIP=0
          load_data
          draw_ui
          footer_message_auto "Paste: ok:1 fail:0 skip:0"
        else
          LAST_PASTE_RC=$?
          LAST_PASTE_OK=0
          LAST_PASTE_FAIL=1
          LAST_PASTE_SKIP=0
          draw_ui
          footer_message_auto "Paste failed for: %s" "$dest"
        fi
        return 0
      fi

      draw_ui
      footer_message_auto "Clipboard is empty. Copy or move items first."
      return 1
    }

    selected_path() {
      current_row_path
    }

    integration_version_label() {
      local tool="$1"
      local out version

      case "$tool" in
        eza)
          out="$(eza -v 2>&1 || eza --version 2>&1 || true)"
          version="$(printf '%s\n' "$out" | awk '/^v[0-9]/{print; exit}')"
          if [[ -n "$version" ]]; then
            printf 'eza %s' "$version"
          else
            printf '%s\n' "$out" | head -1
          fi
          ;;
        pbcopy)
          # pbcopy has no --version and can block waiting for stdin on macOS.
          printf 'macOS clipboard'
          ;;
        *)
          "$tool" --version </dev/null 2>&1 | head -1
          ;;
      esac
    }

    sanitize_integration_label() {
      local name="$1"
      local version_raw="$2"
      local clean_name clean_version version_token

      clean_name="$(printf '%s' "$name" | sed -E $'s/\x1B\[[0-9;]*m//g; s/[[:cntrl:]]//g; s/[[:space:]]+/ /g; s/^ //; s/ $//')"
      clean_version="$(printf '%s' "$version_raw" | sed -E $'s/\x1B\[[0-9;]*m//g; s/[[:cntrl:]]//g; s/[[:space:]]+/ /g; s/^ //; s/ $//')"

      case "$clean_version" in
        ""|"not installed")
          printf '%s' "$clean_name"
          return 0
          ;;
        "built-in toggle")
          printf '%s (built-in)' "$clean_name"
          return 0
          ;;
      esac

      version_token="$(printf '%s\n' "$clean_version" | grep -oE 'v?[0-9]+([.][0-9A-Za-z_-]+)+' | head -1 || true)"
      if [[ -n "$version_token" ]]; then
        version_token="${version_token#v}"
        printf '%s (%s)' "$clean_name" "$version_token"
        return 0
      fi

      printf '%s' "$clean_name"
    }

