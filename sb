      fi
      rc=$?

      printf "\n\033[2mCommand exited with code %d. Press any key to return...\033[0m" "$rc"
      IFS= read -rsn1 || true

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      enable_mouse_tracking
      on_resize
      return $rc
    }

    run_git_add_commit_push() {
      local commit_msg=""
      local branch_name=""
      local branch_second_part=""
      local branch_prefix=""
      local rc=0
      local tmp_log=""

      if integration_is_disabled git; then
        draw_status
        footer_message_auto "Git workflow unavailable: git integration is disabled."
        return 1
      fi

      if ! command -v git >/dev/null 2>&1; then
        draw_status
        footer_message_auto "Git workflow unavailable: git is not installed."
        return 1
      fi

      if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        draw_status
        footer_message_auto "Git workflow unavailable: current directory is not a git repository."
        return 1
      fi

      commit_msg="$(read_line_prompt "Commit message: " "")"
      commit_msg="$(trim_whitespace "$commit_msg")"
      if [[ -z "$commit_msg" ]]; then
        draw_status
        footer_message_auto "Git workflow cancelled: commit message is empty."
        return 1
      fi

      branch_name="$(git branch --show-current 2>/dev/null || true)"
      if [[ "$branch_name" == */* ]]; then
        branch_second_part="${branch_name#*/}"
        if [[ "$branch_second_part" == *-* ]]; then
          branch_prefix="$branch_second_part"
          if [[ "$branch_second_part" =~ ^([[:alpha:]][[:alnum:]]*-[0-9]+)([-_].*)?$ ]]; then
            branch_prefix="${BASH_REMATCH[1]}"
          fi
          if [[ "$commit_msg" != "$branch_prefix:"* ]]; then
            commit_msg="${branch_prefix}: $commit_msg"
          fi
        fi
      fi

      tmp_log="$(mktemp "${TMPDIR:-/tmp}/sb-git-workflow.XXXXXX")" || {
        draw_status
        footer_message_auto "Git workflow failed: unable to create temporary log file."
        return 1
      }

      {
        printf '==> git add --all\n'
        git add --all
      } >>"$tmp_log" 2>&1 || rc=$?

      if (( rc == 0 )); then
        {
          printf '\n==> git commit -m %q\n' "$commit_msg"
          git commit -m "$commit_msg"
        } >>"$tmp_log" 2>&1 || rc=$?
      fi

      if (( rc == 0 )); then
        {
          printf '\n==> git push origin HEAD\n'
          git push origin HEAD
        } >>"$tmp_log" 2>&1 || rc=$?
      fi

      if (( rc == 0 )); then
        rm -f -- "$tmp_log"
        GIT_HEADER_CACHE_PWD=""
        GIT_HEADER_CACHE_SUFFIX=""
        load_data
        draw_ui
        footer_message_auto "Git workflow complete: add, commit, push succeeded."
        return 0
      fi

      disable_mouse_tracking
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      printf 'Git workflow failed (exit %d) in %s\n\n' "$rc" "$(pwd -P 2>/dev/null || pwd)"
      cat -- "$tmp_log"
      printf "\n\033[2mPress any key to return...\033[0m"
      IFS= read -rsn1 || true
      rm -f -- "$tmp_log"

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      enable_mouse_tracking
      on_resize
      draw_ui
      footer_message_auto "Git workflow failed."
      return $rc
    }

    sanitize_filename_input() {
      local value="$1"
      # Remove non-printable control bytes that can be accidentally captured from terminal control output.
      value="$(printf '%s' "$value" | tr -d '\000-\037\177')"
      printf '%s' "$value"
    }

    trim_whitespace() {
      local value="$1"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      printf '%s' "$value"
    }

    infer_download_name_from_url() {
      local url="$1"
      local stripped host_port host path name

      _download_name=""
      _download_used_host=0

      stripped="${url%%#*}"
      stripped="${stripped%%\?*}"

      if [[ "$stripped" == *://* ]]; then
        host_port="${stripped#*://}"
      else
        host_port="$stripped"
      fi

      host_port="${host_port%%/*}"
      host="${host_port%%:*}"

      path="${stripped#*://}"
      path="/${path#*/}"
      if [[ "$stripped" != *://* ]]; then
        path="/${stripped#*/}"
      fi

      if [[ "$path" == "/" || "$stripped" == */ ]]; then
        name=""
      else
        name="${stripped##*/}"
        [[ "$name" == "$host" ]] && name=""
      fi

      name="$(sanitize_filename_input "$name")"
      if [[ -z "$name" ]]; then
        name="$(sanitize_filename_input "$host")"
        _download_used_host=1
      fi

      if [[ -z "$name" ]]; then
        name="download"
        _download_used_host=1
      fi

      _download_name="$name"
    }

    download_file_from_url() {
      local url suggested_name target_name rc

      if (( !HAS_WGET && !HAS_CURL )); then
        draw_status
        footer_message_auto "Download unavailable: install/enable wget or curl in integrations."
        return 1
      fi

      url="$(read_line_prompt "Download URL: " "")"
      url="$(trim_whitespace "$url")"
      [[ -n "$url" ]] || {
        draw_status
        footer_message_auto "Download cancelled."
        return 1
      }

      infer_download_name_from_url "$url"
      suggested_name="$_download_name"
      target_name="$suggested_name"

      if (( _download_used_host )); then
        target_name="$(read_line_prompt "Save as: " "$suggested_name")"
        target_name="$(sanitize_filename_input "$target_name")"
      fi

      target_name="$(trim_whitespace "$target_name")"
      [[ -n "$target_name" ]] || {
        draw_status
        footer_message_auto "Download cancelled."
        return 1
      }

      if [[ "$target_name" == */* ]]; then
        draw_status
        footer_message_auto "Download failed: use a file name only (no '/')."
        return 1
      fi

      if [[ -e "$target_name" || -L "$target_name" ]]; then
        target_name="$(read_line_prompt "Target exists, save as: " "$target_name")"
        target_name="$(sanitize_filename_input "$target_name")"
        target_name="$(trim_whitespace "$target_name")"
        [[ -n "$target_name" ]] || {
          draw_status
          footer_message_auto "Download cancelled."
          return 1
        }
        if [[ "$target_name" == */* ]]; then
          draw_status
          footer_message_auto "Download failed: use a file name only (no '/')."
          return 1
        fi
        if [[ -e "$target_name" || -L "$target_name" ]]; then
          draw_status
          footer_message_auto "Download failed: target exists: %s" "$target_name"
          return 1
        fi
      fi

      if (( HAS_WGET )); then
        run_interactive_command_with_status wget -O "$target_name" -- "$url"
        rc=$?
      else
        run_interactive_command_with_status curl -fL --output "$target_name" -- "$url"
        rc=$?
      fi

      if (( rc != 0 )); then
        [[ -f "$target_name" && ! -s "$target_name" ]] && rm -f -- "$target_name"
        draw_status
        footer_message_auto "Download failed (exit %d)." "$rc"
        return 1
      fi

      load_data
      position_cursor_for_name "$target_name" >/dev/null 2>&1 || true
      draw_ui
      footer_message_auto "Downloaded: %s" "$target_name"
      return 0
    }

    is_age_file() {
      local item="$1"
      [[ "$item" == *.age ]]
    }

    run_age_encrypt_with_passphrase() {
      local input_file="$1"
      local output_file="$2"
      local passphrase="$3"
      local q_input q_output

      if command -v script >/dev/null 2>&1; then
        printf -v q_input '%q' "$input_file"
        printf -v q_output '%q' "$output_file"
        printf '%s\n%s\n' "$passphrase" "$passphrase" | script -q -c "age -p -o $q_output -- $q_input" /dev/null >/dev/null 2>&1
        return $?
      fi

      AGE_PASSPHRASE="$passphrase" age -p -o "$output_file" -- "$input_file" >/dev/null 2>&1
      return $?
    }

    run_age_decrypt_with_passphrase() {
      local input_file="$1"
      local output_file="$2"
      local passphrase="$3"
      local q_input q_output

      if command -v script >/dev/null 2>&1; then
        printf -v q_input '%q' "$input_file"
        printf -v q_output '%q' "$output_file"
        printf '%s\n' "$passphrase" | script -q -c "age -d -o $q_output -- $q_input" /dev/null >/dev/null 2>&1
        return $?
      fi

      AGE_PASSPHRASE="$passphrase" age -d -o "$output_file" -- "$input_file" >/dev/null 2>&1
      return $?
    }

    toggle_age_protection_current() {
      local item output_name rc passphrase passphrase_confirm

      if (( !HAS_AGE )); then
        draw_status
        footer_message_auto "Age unavailable: install/enable age in integrations."
        return 1
      fi

      item="$(selected_path)" || {
        draw_status
        footer_message_auto "Age action failed: no current file."
        return 1
      }

      if [[ ! -f "$item" ]]; then
        draw_status
        footer_message_auto "Age action requires a regular file."
        return 1
      fi

      if is_age_file "$item"; then
        output_name="${item%.age}"
        [[ -n "$output_name" ]] || output_name="decrypted"

        if [[ -e "$output_name" || -L "$output_name" ]]; then
          output_name="$(read_line_prompt "Decrypt as: " "$output_name")"
          output_name="$(sanitize_filename_input "$output_name")"
          output_name="$(trim_whitespace "$output_name")"
          [[ -n "$output_name" ]] || {
            draw_status
            footer_message_auto "Decrypt cancelled."
            return 1
          }
          if [[ "$output_name" == */* ]]; then
            draw_status
            footer_message_auto "Decrypt failed: use a name only (no '/')."
            return 1
          fi
          if [[ -e "$output_name" || -L "$output_name" ]]; then
            draw_status
            footer_message_auto "Decrypt failed: target exists: %s" "$output_name"
            return 1
          fi
        fi

        passphrase="$(read_secret_prompt "Age passphrase (decrypt): ")"
        [[ -n "$passphrase" ]] || {
          draw_status
          footer_message_auto "Decrypt cancelled."
          return 1
        }

        run_age_decrypt_with_passphrase "$item" "$output_name" "$passphrase"
        rc=$?
        passphrase=""

        if (( rc != 0 )); then
          [[ -f "$output_name" && ! -s "$output_name" ]] && rm -f -- "$output_name"
          draw_status
          footer_message_auto "Decrypt failed (exit %d)." "$rc"
          return 1
        fi

        rm -f -- "$item"
        load_data
        position_cursor_for_name "$output_name" >/dev/null 2>&1 || true
        draw_ui
        footer_message_auto "Unprotected with age: %s" "$output_name"
        return 0
      fi

      output_name="${item}.age"
      if [[ -e "$output_name" || -L "$output_name" ]]; then
        output_name="$(read_line_prompt "Encrypt as: " "$output_name")"
        output_name="$(sanitize_filename_input "$output_name")"
        output_name="$(trim_whitespace "$output_name")"
        [[ -n "$output_name" ]] || {
          draw_status
          footer_message_auto "Encrypt cancelled."
          return 1
        }
        if [[ "$output_name" != *.age ]]; then
          output_name="${output_name}.age"
        fi
        if [[ "$output_name" == */* ]]; then
          draw_status
          footer_message_auto "Encrypt failed: use a name only (no '/')."
          return 1
        fi
        if [[ -e "$output_name" || -L "$output_name" ]]; then
          draw_status
          footer_message_auto "Encrypt failed: target exists: %s" "$output_name"
          return 1
        fi
      fi

      passphrase="$(read_secret_prompt "Age passphrase (encrypt): ")"
      [[ -n "$passphrase" ]] || {
        draw_status
        footer_message_auto "Encrypt cancelled."
        return 1
      }

      passphrase_confirm="$(read_secret_prompt "Confirm passphrase: ")"
      if [[ "$passphrase" != "$passphrase_confirm" ]]; then
        passphrase=""
        passphrase_confirm=""
        draw_status
        footer_message_auto "Encrypt cancelled: passphrases did not match."
        return 1
      fi
      passphrase_confirm=""

      run_age_encrypt_with_passphrase "$item" "$output_name" "$passphrase"
      rc=$?
      passphrase=""

      if (( rc != 0 )); then
        [[ -f "$output_name" && ! -s "$output_name" ]] && rm -f -- "$output_name"
        draw_status
        footer_message_auto "Encrypt failed (exit %d)." "$rc"
        return 1
      fi

      rm -f -- "$item"
      load_data
      position_cursor_for_name "$output_name" >/dev/null 2>&1 || true
      draw_ui
      footer_message_auto "Protected with age: %s" "$output_name"
      return 0
    }

    preview_age_file_with_pass() {
      local item="$1"
      local base plain_name tmp_dir tmp_file rc passphrase

      if (( !HAS_AGE )); then
        draw_status
        footer_message_auto "Open failed: age is not installed or disabled."
        return 1
      fi

      base="$(path_basename "$item")"
      plain_name="${base%.age}"
      [[ -n "$plain_name" ]] || plain_name="decrypted"
