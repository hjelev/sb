        draw_ui
        printf "\033[$((max_rows + 3));1H\033[K%b" "${STATUS_LABEL}Uploading: ${base_name}${NC}"
        redraw_cursor
        
        # catbox.moe returns a plain text URL on success.
        upload_url=$(curl -fsS -F "reqtype=fileupload" -F "fileToUpload=@${file}" "https://catbox.moe/user/api.php" 2>&1)
