            ;;
          lsd)
            if (( !HAS_LSD )); then
              LAST_SOURCE_EXECUTED="lsd"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              if (( HAS_EZA )); then
                LAST_SOURCE_FALLBACK_TO=eza
              elif (( HAS_DUST )); then
                LAST_SOURCE_FALLBACK_TO=dust
              else
                LAST_SOURCE_FALLBACK_TO=ls
              fi
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a lsd_args=() lsd_extra_args=()
            local lsd_blocks
            lsd_blocks="$(lsd_blocks_with_required_date "$SB_LSD_BLOCKS")"
            if (( PREVIEW_MODE )); then
              lsd_args=(-1 --group-dirs first --icon never --icon-theme "$SB_LSD_ICON_THEME" --color "$SB_LSD_COLOR" --hyperlink "$SB_LSD_HYPERLINK")
