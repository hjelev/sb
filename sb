NAME_COL_MAX=60
BASE_MIN_COLS=56
if [[ -n "$NAME_COL_WIDTH_OVERRIDE" ]]; then
    if [[ "$NAME_COL_WIDTH_OVERRIDE" =~ ^[0-9]+$ ]] && (( NAME_COL_WIDTH_OVERRIDE >= NAME_COL_MIN && NAME_COL_WIDTH_OVERRIDE <= NAME_COL_MAX )); then
        NAME_COL_WIDTH=$NAME_COL_WIDTH_OVERRIDE
    else
        echo "Error: width must be an integer between ${NAME_COL_MIN} and ${NAME_COL_MAX}." >&2
        exit 1
    fi
fi
init_platform() { OS_NAME=$(uname -s 2>/dev/null); OPEN_CMD="xdg-open"; LS_CMD="ls"; LS_GROUP_DIRS=0; STAT_FMT_MTIME="-c %Y"; STAT_FMT_SIZE="-c %s"; (( BASH_VERSINFO[0] >= 4 )) && READ_TIMEOUT="0.001" || READ_TIMEOUT="1"; [[ "$OS_NAME" == "Darwin" ]] && OPEN_CMD="open" && command -v gls &>/dev/null && LS_CMD="gls"; [[ "$OS_NAME" == "Darwin" && "$LS_CMD" == "ls" ]] && STAT_FMT_MTIME="-f %m" && STAT_FMT_SIZE="-f %z"; "$LS_CMD" -F --group-directories-first -d . >/dev/null 2>&1 && LS_GROUP_DIRS=1; }
HELP_SECTION=''; HELP_KEY="$STATUS_VALUE"; HELP_ACCENT="$STATUS_VALUE"
init_platform
USER_HOST="${USER:-$(id -un 2>/dev/null)}@$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'unknown')"
orig_stty=$(stty -g)
cleanup() { echo -ne "\033[?25h"; stty "$orig_stty"; [[ -n "$EXPORT_FILE" ]] && pwd > "$EXPORT_FILE"; clear; }
handle_resize() { get_terminal_size; old_cursor=-1; old_scroll=-1; stty -echo cbreak -ixon; printf "\033[2J\033[1;1H"; draw_ui; }
trap cleanup EXIT; trap handle_resize SIGWINCH; stty -echo cbreak -ixon
get_terminal_size() { term_rows=$(tput lines); term_cols=$(tput cols); max_rows=$((term_rows - 4)); }
update_git_header_suffix() {
    GIT_HEADER_SUFFIX=""
    command -v git &>/dev/null || return
    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return

    local branch dirty="" status_output
    branch=$(git branch --show-current 2>/dev/null)
    [[ -z "$branch" ]] && branch=$(git rev-parse --short HEAD 2>/dev/null)
    [[ -z "$branch" ]] && return

    status_output=$(git status --porcelain=v1 --untracked-files=normal 2>/dev/null)
    [[ -n "$status_output" ]] && dirty="*"
    GIT_HEADER_SUFFIX=" (${branch}${dirty})"
}
extra_meta_cols() { (( DUST_MODE )) && echo 7 || echo 0; }
required_term_cols() { local extra_cols; extra_cols=$(extra_meta_cols); echo $((BASE_MIN_COLS + NAME_COL_WIDTH + extra_cols)); }
is_terminal_too_narrow() { local extra_cols; extra_cols=$(extra_meta_cols); (( term_cols < BASE_MIN_COLS + NAME_COL_WIDTH + extra_cols )); }
draw_too_narrow_message() { local required_cols; required_cols=$(required_term_cols); local msg="Terminal too narrow: need at least ${required_cols} columns (current: ${term_cols}). Resize terminal to continue."; printf "\033[H\033[2J\033[?25l"; printf "\033[1;1H%b\n\n" "${AMBER}$msg${NC}"; printf "Use [ and ] to shrink/grow name column. Press q to quit.\n"; }
strip_ls_suffix() {
    local item="$1"
    local last_char
    [[ "$item" == "(Empty Directory)" ]] && { printf "%s" "$item"; return; }
    last_char="${item: -1}"
    case "$last_char" in
        '/'|'@'|'*'|'|'|'='|'>') printf "%s" "${item:0:${#item}-1}" ;;
        *) printf "%s" "$item" ;;
    esac
}
get_color() {
    local f="$1"
    local clean_f clean_no_suffix base_name
    clean_f="$f"
    case "${clean_f: -1}" in
        '/'|'@'|'*'|'|'|'='|'>') clean_f="${clean_f:0:${#clean_f}-1}" ;;
    esac
    clean_no_suffix="${clean_f%/}"
    base_name="${clean_no_suffix##*/}"
    if [[ "$base_name" == .* ]]; then
        [[ "$f" == */ ]] && echo -n "$HIDDEN_DIR" && return
        echo -n "$HIDDEN_FILE" && return
    fi
    [[ "$f" == */ ]] && echo -n "$BLUE" && return
    [[ "$f" == *@ ]] && echo -n "$CYAN" && return
    [[ "$f" == *\* ]] && echo -n "$GREEN" && return
    [[ "$f" =~ \.(zip|tar|gz|rar|7z)$ ]] && echo -n "$RED" && return
    echo -n "$STATUS_VALUE"
}
list_entries() { local -a ls_args=(-F); (( SHOW_HIDDEN )) && ls_args+=(-A); (( LS_GROUP_DIRS )) && ls_args+=(--group-directories-first); "$LS_CMD" "${ls_args[@]}" 2>/dev/null; }
is_gui_session() { [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" || -n "${MIR_SOCKET:-}" || "$OS_NAME" == "Darwin" ]]; }
restore_browser_ui() { stty -echo cbreak -ixon; printf "\033[2J\033[1;1H\033[?25l"; get_terminal_size; show_loading_status; update_files; draw_ui; }
run_interactive_command() { echo -ne "\033[?25h"; stty "$orig_stty"; clear; "$@"; local status=$?; restore_browser_ui; return $status; }
show_open_error() { local item="$1"; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K%b" "${RED}Unable to open '$item'. Set \$EDITOR or install xdg-open, nano, vim, vi, or less.${NC}"; IFS= read -rsN1; echo -ne "\033[?25l"; draw_ui; }
show_loading_status() { printf "\033[%d;1H\033[KLoading \033[5m...\033[0m" $((max_rows + 4)); }
open_in_terminal_editor() { local item="$1" editor_name; local -a editors=(); [[ -n "${VISUAL:-}" ]] && editors+=("${VISUAL%% *}"); [[ -n "${EDITOR:-}" ]] && editors+=("${EDITOR%% *}"); editors+=(sensible-editor editor nano vim vi less more); for editor_name in "${editors[@]}"; do [[ -n "$editor_name" ]] || continue; command -v "$editor_name" >/dev/null 2>&1 || continue; run_interactive_command "$editor_name" "$item" && return 0; done; return 1; }
open_external() { local item="$1"; if is_gui_session; then command -v "$OPEN_CMD" &>/dev/null && "$OPEN_CMD" "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "xdg-open" ]] && command -v xdg-open &>/dev/null && xdg-open "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "open" ]] && command -v open &>/dev/null && open "$item" >/dev/null 2>&1 && return 0; fi; open_in_terminal_editor "$item" && return 0; show_open_error "$item"; return 1; }
icon_for_item() { local path="$1"; local lower_name="${2,,}"; if [[ -d "$path" ]]; then printf "%s" "$ICON_DIR"; elif [[ -L "$path" ]]; then printf "%s" "$ICON_LINK"; elif [[ -x "$path" && -f "$path" ]]; then printf "%s" "$ICON_EXEC"; else case "$lower_name" in *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg) printf "%s" "$ICON_IMAGE" ;; *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v) printf "%s" "$ICON_VIDEO" ;; *.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a) printf "%s" "$ICON_AUDIO" ;; *.zip|*.tar|*.tar.gz|*.tgz|*.bz2|*.xz|*.rar|*.7z|*.gz) printf "%s" "$ICON_ARCHIVE" ;; *.sh|*.bash|*.zsh|*.fish|*.py|*.js|*.ts|*.rb|*.pl|*.php) printf "%s" "$ICON_SCRIPT" ;; *.c|*.h|*.cpp|*.hpp|*.go|*.rs|*.java|*.kt|*.swift|*.cs|*.json|*.yaml|*.yml|*.toml|*.ini|*.conf|*.md|*.txt) printf "%s" "$ICON_CODE" ;; *) printf "%s" "$ICON_FILE" ;; esac; fi; }
icon_for_list_item() {
    local item="$1"
    local clean_f lower_name
    clean_f="$item"
    case "${clean_f: -1}" in
        '/'|'@'|'*'|'|'|'='|'>') clean_f="${clean_f:0:${#clean_f}-1}" ;;
    esac
    lower_name="${clean_f##*/}"
    lower_name="${lower_name,,}"
    case "$item" in
        */) printf "%s" "$ICON_DIR" ;;
        *@) printf "%s" "$ICON_LINK" ;;
        *\*) printf "%s" "$ICON_EXEC" ;;
        *)
            case "$lower_name" in
                *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg) printf "%s" "$ICON_IMAGE" ;;
                *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v) printf "%s" "$ICON_VIDEO" ;;
                *.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a) printf "%s" "$ICON_AUDIO" ;;
                *.zip|*.tar|*.tar.gz|*.tgz|*.bz2|*.xz|*.rar|*.7z|*.gz) printf "%s" "$ICON_ARCHIVE" ;;
                *.sh|*.bash|*.zsh|*.fish|*.py|*.js|*.ts|*.rb|*.pl|*.php) printf "%s" "$ICON_SCRIPT" ;;
                *.c|*.h|*.cpp|*.hpp|*.go|*.rs|*.java|*.kt|*.swift|*.cs|*.json|*.yaml|*.yml|*.toml|*.ini|*.conf|*.md|*.txt) printf "%s" "$ICON_CODE" ;;
                *) printf "%s" "$ICON_FILE" ;;
            esac
            ;;
    esac
}
SORT_RESULT=()
sort_items_by_mode() {
    local -a keyed=()
    local item key base ext size mtime clean_item last_char
    SORT_RESULT=()
    (( $# == 0 )) && return

    # Build keyed array inline to avoid per-item command substitutions
    for item in "$@"; do
        case "$SORT_MODE" in
            name)
                base="${item##*/}"
                base="${base%/}"  # strip trailing slash for dirs
                key="${base,,}"
                ;;
            date)
                # Strip ls suffix from item before stat
                clean_item="$item"
                last_char="${clean_item: -1}"
                case "$last_char" in
                    '/'|'@'|'*'|'|'|'='|'>') clean_item="${clean_item:0:${#clean_item}-1}" ;;
                esac
                mtime=$(stat $STAT_FMT_MTIME -- "$clean_item" 2>/dev/null || echo 0)
                key=$(printf "%020d" "$mtime")
                ;;
            size)
                # Strip ls suffix from item before stat
                clean_item="$item"
                last_char="${clean_item: -1}"
                case "$last_char" in
                    '/'|'@'|'*'|'|'|'='|'>') clean_item="${clean_item:0:${#clean_item}-1}" ;;
                esac
                size=$(stat $STAT_FMT_SIZE -- "$clean_item" 2>/dev/null || echo 0)
                key=$(printf "%020d" "$size")
                ;;
            ext)
                base="${item##*/}"
                base="${base%/}"
                ext="${base##*.}"
                [[ "$base" == "$ext" ]] && ext=""
                key="${ext,,}|${base,,}"
                ;;
            *)
                base="${item##*/}"
                base="${base%/}"
                key="${base,,}"
                ;;
        esac
        keyed+=("$key"$'\t'"$item")
    done

    case "$SORT_MODE" in
        name) if (( SORT_NAME_DESC )); then mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1fr | cut -f2-); else mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1f | cut -f2-); fi ;;
        date) if (( SORT_DATE_DESC )); then mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1nr | cut -f2-); else mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1n | cut -f2-); fi ;;
        size) if (( SORT_SIZE_DESC )); then mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1nr | cut -f2-); else mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1n | cut -f2-); fi ;;
        ext) if (( SORT_EXT_DESC )); then mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1fr | cut -f2-); else mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1f | cut -f2-); fi ;;
        *) mapfile -t SORT_RESULT < <(printf '%s\n' "${keyed[@]}" | sort -t $'\t' -k1,1f | cut -f2-) ;;
    esac
}
sort_files_by_mode() {
    local -a dirs=() non_dirs=() sorted_dirs=() sorted_non_dirs=()
    local f clean_f
    for f in "${files[@]}"; do
        if [[ "$f" == */ ]]; then
            dirs+=("$f")
        else
            non_dirs+=("$f")
        fi
    done
    sort_items_by_mode "${dirs[@]}"
    sorted_dirs=("${SORT_RESULT[@]}")
    sort_items_by_mode "${non_dirs[@]}"
    sorted_non_dirs=("${SORT_RESULT[@]}")
    files=("${sorted_dirs[@]}" "${sorted_non_dirs[@]}")
}
get_sort_display() { local mode_label="Name"; local is_desc=0; case "$SORT_MODE" in name) mode_label="Name"; is_desc=$SORT_NAME_DESC ;; date) mode_label="Date"; is_desc=$SORT_DATE_DESC ;; size) mode_label="Size"; is_desc=$SORT_SIZE_DESC ;; ext) mode_label="Ext"; is_desc=$SORT_EXT_DESC ;; esac; if (( is_desc )); then printf "%s↓" "$mode_label"; else printf "%s↑" "$mode_label"; fi; }
build_item_meta() {
    local clean_f="$1"
    if [[ -e "$clean_f" || -L "$clean_f" ]]; then
        if [[ "$OS_NAME" == "Darwin" && "$LS_CMD" == "ls" ]]; then
            LC_TIME=C stat -f '%Su|%Sp|%z|%Sm' -t '%Y-%m-%d %H:%M' -- "$clean_f" 2>/dev/null && return
        fi
        LC_TIME=C ls -ldh --time-style=long-iso -- "$clean_f" 2>/dev/null | awk '{printf "%s|%s|%s|%s %s", $3, $1, $5, $6, $7}' && return
    fi
    printf "%s" "$DEFAULT_META"
}
populate_display_data_bulk() {
    local -a clean_items=()
    local f clean_f lower_name last_char
    local i idx
    local perms owner size date time
    local default_meta="$DEFAULT_META"
    local -A item_to_idx

    file_icons=()
    metadata=()

    for i in "${!files[@]}"; do
        f="${files[$i]}"
        metadata+=("$default_meta")
        if [[ "$f" == "(Empty Directory)" ]]; then
            file_icons+=("$ICON_DIR")
            continue
        fi

        clean_f="$f"
        last_char="${clean_f: -1}"
        case "$last_char" in
            '/')
                file_icons+=("$ICON_DIR")
                clean_f="${clean_f:0:${#clean_f}-1}"
                ;;
            '@')
                file_icons+=("$ICON_LINK")
                clean_f="${clean_f:0:${#clean_f}-1}"
                ;;
            '*')
                file_icons+=("$ICON_EXEC")
                clean_f="${clean_f:0:${#clean_f}-1}"
                ;;
            '|'|'='|'>')
                clean_f="${clean_f:0:${#clean_f}-1}"
                ;;
        esac

        if [[ "$last_char" != '/' && "$last_char" != '@' && "$last_char" != '*' ]]; then
            lower_name="${clean_f##*/}"
            lower_name="${lower_name,,}"
            case "$lower_name" in
                *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg) file_icons+=("$ICON_IMAGE") ;;
                *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v) file_icons+=("$ICON_VIDEO") ;;
                *.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a) file_icons+=("$ICON_AUDIO") ;;
                *.zip|*.tar|*.tar.gz|*.tgz|*.bz2|*.xz|*.rar|*.7z|*.gz) file_icons+=("$ICON_ARCHIVE") ;;
                *.sh|*.bash|*.zsh|*.fish|*.py|*.js|*.ts|*.rb|*.pl|*.php) file_icons+=("$ICON_SCRIPT") ;;
                *.c|*.h|*.cpp|*.hpp|*.go|*.rs|*.java|*.kt|*.swift|*.cs|*.json|*.yaml|*.yml|*.toml|*.ini|*.conf|*.md|*.txt) file_icons+=("$ICON_CODE") ;;
                *) file_icons+=("$ICON_FILE") ;;
            esac
        fi

        clean_items+=("$clean_f")
        item_to_idx["$clean_f"]=$i
    done

    (( ${#clean_items[@]} == 0 )) && return

    if [[ "$OS_NAME" == "Darwin" && "$LS_CMD" == "ls" ]]; then
        while IFS='|' read -r owner perms size date time filename; do
            [[ -z "$owner" || -z "$perms" || -z "$size" || -z "$date" || -z "$time" || -z "$filename" ]] && continue
            if [[ -n "${item_to_idx[$filename]}" ]]; then
                idx=${item_to_idx[$filename]}
                metadata[$idx]="${owner}|${perms}|${size}|${date} ${time}"
            fi
        done < <(LC_TIME=C stat -f '%Su|%Sp|%z|%Sm|%N' -t '%Y-%m-%d|%H:%M' -- "${clean_items[@]}" 2>/dev/null)
    else
        while IFS='|' read -r perms owner size date time filename; do
            [[ -z "$owner" || -z "$perms" || -z "$size" || -z "$date" || -z "$time" || -z "$filename" ]] && continue

            # Match by filename to handle ls output being in any order
            if [[ -n "${item_to_idx[$filename]}" ]]; then
                idx=${item_to_idx[$filename]}
                metadata[$idx]="${owner}|${perms}|${size}|${date} ${time}"
            fi
        done < <(LC_TIME=C "$LS_CMD" -ldh --time-style=long-iso -- "${clean_items[@]}" 2>/dev/null | awk '{
            perms=$1; owner=$3; size=$5; date=$6; time=$7
            filename=""
            for(i=8;i<=NF;i++) {
                if(i>8) filename=filename" "
                filename=filename$i
            }
            # Strip " -> target" part for symlinks
            idx=index(filename, " ->")
            if(idx>0) filename=substr(filename, 1, idx-1)
            printf "%s|%s|%s|%s|%s|%s\n", perms, owner, size, date, time, filename
        }')
    fi
}
ensure_row_data() {
    local idx="$1"
    local f_name
    f_name="${files[$idx]}"
    [[ -z "$f_name" ]] && return
    [[ "$f_name" == "(Empty Directory)" ]] && {
        file_icons[$idx]="$ICON_DIR"
        metadata[$idx]="$DEFAULT_META"
        return
    }
    if [[ -z "${file_icons[$idx]+x}" ]]; then
        file_icons[$idx]="$(icon_for_list_item "$f_name")"
    fi
    [[ -z "${metadata[$idx]+x}" ]] && metadata[$idx]="$DEFAULT_META"
}

format_bytes_human() {
    local bytes="$1"
    local -a units=(B K M G T P)
    local unit_index=0
    local whole remainder decimal

    [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0

    while (( bytes >= 1024 && unit_index < ${#units[@]} - 1 )); do
        remainder=$((bytes % 1024))
        bytes=$((bytes / 1024))
        ((unit_index++))
    done

    whole=$bytes
    if (( unit_index == 0 )); then
        printf "%d%s" "$whole" "${units[$unit_index]}"
        return
    fi

    decimal=$(( (remainder * 10) / 1024 ))
    if (( whole >= 10 )); then
        printf "%d%s" "$whole" "${units[$unit_index]}"
    else
        printf "%d.%d%s" "$whole" "$decimal" "${units[$unit_index]}"
    fi
