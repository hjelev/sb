            esac
            [[ -n "$SB_EZA_COLOR_SCALE" ]] && eza_args+=(--color-scale="$SB_EZA_COLOR_SCALE")
            [[ -n "$SB_EZA_COLOR_SCALE_MODE" ]] && eza_args+=(--color-scale-mode="$SB_EZA_COLOR_SCALE_MODE")
