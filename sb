      _sb_fmt_help_cell() {
        local cell="$1"
        local width="$2"
        local key_col=12 requested_key_col max_key_col
        (( width < 1 )) && return
        if [[ -z "$cell" ]]; then
          printf "%-*s" "$width" ""
          return
        fi
        if [[ "$cell" != *"  "* ]]; then
          printf "\033[1;36m%-*s\033[0m" "$width" "${cell:0:$width}"
          return
        fi
        local key="${cell%%  *}"
        local desc="${cell#"$key"}"
        while [[ "$desc" == ' '* ]]; do desc="${desc# }"; done
        requested_key_col=12
        if [[ "$key" == SB_* || "$key" == KEY_* ]]; then
          requested_key_col=24
        fi
        max_key_col=$(( width - 2 - 8 ))
        if (( max_key_col < 6 )); then
          key_col=6
        elif (( requested_key_col > max_key_col )); then
          key_col=$max_key_col
        else
          key_col=$requested_key_col
        fi
        local desc_col=$(( width - key_col - 2 ))
        (( desc_col < 0 )) && desc_col=0
        printf "\033[1;33m%-*s\033[0m  %-*s" "$key_col" "${key:0:$key_col}" "$desc_col" "${desc:0:$desc_col}"
      }

      local max_lines left_line right_line
      local content_rows top_line max_top line_idx needs_redraw
      local -a help_lines=()
      max_lines=${#left_col[@]}
      (( ${#right_col[@]} > max_lines )) && max_lines=${#right_col[@]}

      for (( i=0; i<max_lines; i++ )); do
        left_line="${left_col[$i]-}"
        right_line="${right_col[$i]-}"
        help_lines+=("$(printf "%s%s%s" \
          "$(_sb_fmt_help_cell "${left_line:0:$left_width}" "$left_width")" \
          "$divider" \
          "$(_sb_fmt_help_cell "${right_line:0:$right_width}" "$right_width")")")
      done

      content_rows=$(( _rows - 3 ))
      (( content_rows < 1 )) && content_rows=1
      top_line=0
      max_top=$(( max_lines - content_rows ))
      (( max_top < 0 )) && max_top=0
      needs_redraw=1

      while true; do
        if (( needs_redraw )); then
          printf "\033[H\033[2J"
          printf "\033[1;36m%s\033[0m  keyboard shortcuts\n" "$(sb_name_with_version)"
          junction=$(( left_width + 1 ))
          for (( i=0; i<total_width; i++ )); do
            if (( i == junction )); then printf "┬"; else printf "─"; fi
          done
          printf "\n"

          for (( i=0; i<content_rows; i++ )); do
            line_idx=$(( top_line + i ))
            if (( line_idx < max_lines )); then
              printf "%s\n" "${help_lines[$line_idx]}"
            else
              printf "\033[K\n"
            fi
          done

          if (( max_top > 0 )); then
            printf "\033[%s;1H\033[2m↑↓ scroll | PgUp/PgDn page | Home/End bounds | b bookmarks | S ssh | %s help | any other key return\033[0m\033[K" "$_rows" "$KEY_HELP_LABEL"
          else
            printf "\033[%s;1H\033[2mPress b bookmarks | S ssh | %s help | any other key to return...\033[0m\033[K" "$_rows" "$KEY_HELP_LABEL"
          fi
          needs_redraw=0
        fi

        local help_key
        help_key="$(read_key || true)"
        [[ -n "$help_key" ]] || continue
        case "$help_key" in
          "$KEY_BOOKMARKS")
            show_bookmarks
            return
            ;;
          "$KEY_SSH_PICKER")
            show_ssh_picker || true
            return
            ;;
          "$KEY_UP")
            if (( top_line > 0 )); then
              ((top_line--))
              needs_redraw=1
            fi
            continue
            ;;
          "$KEY_DOWN")
            if (( top_line < max_top )); then
              ((top_line++))
              needs_redraw=1
            fi
            continue
            ;;
          "$KEY_PGUP")
            if (( top_line > 0 )); then
              top_line=$(( top_line - content_rows ))
              (( top_line < 0 )) && top_line=0
              needs_redraw=1
              continue
            fi
            ;;
          "$KEY_PGDN")
            if (( top_line < max_top )); then
              top_line=$(( top_line + content_rows ))
              (( top_line > max_top )) && top_line=$max_top
              needs_redraw=1
              continue
            fi
            ;;
          "$KEY_HOME")
            if (( top_line != 0 )); then
              top_line=0
              needs_redraw=1
              continue
            fi
            ;;
          "$KEY_END")
            if (( top_line != max_top )); then
              top_line=$max_top
              needs_redraw=1
              continue
            fi
            ;;
          "$KEY_HELP"|"$KEY_HELP_F1"|"$KEY_LEFT"|"$KEY_QUIT")
            break
            ;;
          $'\e')
            if (( max_top > 0 )); then
              continue
            fi
            break
            ;;
          *)
            if (( max_top > 0 )); then
              continue
            fi
            break
            ;;
        esac
      done
      draw_ui
    }

    main() {
      parse_args "$@"
      init_runtime_config
      detect_runtime_capabilities
      detect_sources

      orig_stty=$(stty -g)
      trap cleanup EXIT
      trap on_resize SIGWINCH

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      enable_mouse_tracking

      on_resize
      load_data
      draw_ui

      while true; do
        local key
        local old_cursor old_top
        local now_ns elapsed_ms
        if (( PREVIEW_MODE && PREVIEW_RENDER_DEFERRED )); then
          key="$(read_key 0.03 || true)"
          if [[ -z "$key" ]]; then
            now_ns=$(now_epoch_ns)
            elapsed_ms=$(( (now_ns - PREVIEW_LAST_NAV_NS) / 1000000 ))
            if (( elapsed_ms >= PREVIEW_RELEASE_IDLE_MS )); then
              redraw_preview_rows_and_status 1
              PREVIEW_RENDER_DEFERRED=0
            fi
            continue
          fi
        else
          key="$(read_key || true)"
        fi
        [[ -z "$key" ]] && continue

        if (( PREVIEW_MODE && PREVIEW_RENDER_DEFERRED )); then
          if [[ "$key" != "$KEY_UP" && "$key" != "$KEY_DOWN" ]]; then
            redraw_preview_rows_and_status 1
            PREVIEW_RENDER_DEFERRED=0
          fi
        fi

        case "$key" in
          "$KEY_QUIT")
            break
            ;;
          "$KEY_RELOAD")
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_HIDDEN")
            if (( show_hidden )); then
              show_hidden=0
            else
              show_hidden=1
            fi
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_SOURCE")
            cycle_list_source
            [[ "$LIST_SOURCE" != "dust" ]] && LAST_NON_DUST_SOURCE="$LIST_SOURCE"
            load_data
            draw_ui
            ;;
          "$KEY_DUST_MODE")
            if toggle_dust_source_mode; then
              load_data
              draw_ui
            fi
            ;;
          "$KEY_TOGGLE_NAME_FIRST")
            if (( NAME_FIRST_VIEW )); then
              NAME_FIRST_VIEW=0
            else
              NAME_FIRST_VIEW=1
            fi
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_PREVIEW")
            if (( PREVIEW_MODE )); then
              PREVIEW_MODE=0
            else
              PREVIEW_MODE=1
            fi
            PREVIEW_RENDER_DEFERRED=0
            PREVIEW_LAST_NAV_NS=0
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_DEBUG")
            if (( SHOW_DEBUG_FOOTER )); then
              SHOW_DEBUG_FOOTER=0
            else
              SHOW_DEBUG_FOOTER=1
            fi
            draw_status
            ;;
          "$KEY_SELECT_TOGGLE"|$'\e[2~'|$'\e[L')
            if (( PREVIEW_MODE )); then
              toggle_selection_current || true
              if (( cursor + 1 < ${#ROWS_COLOR[@]} )); then
                ((cursor++))
                if (( cursor >= top + visible_rows )); then
                  top=$(( cursor - visible_rows + 1 ))
                fi
              fi
              redraw_preview_rows_and_status
              continue
            fi

            old_cursor=$cursor
            old_top=$top
            toggle_selection_current || true
            if (( cursor + 1 < ${#ROWS_COLOR[@]} )); then
              ((cursor++))
              if (( cursor >= top + visible_rows )); then
                top=$(( cursor - visible_rows + 1 ))
              fi
            fi

            if (( top == old_top + 1 && cursor == old_cursor + 1 )); then
              scroll_list_once down
              redraw_row_at_index "$old_cursor"
              redraw_row_at_index "$cursor"
              draw_status
            elif (( top != old_top || cursor != old_cursor )); then
              redraw_row_at_index "$old_cursor"
              redraw_row_at_index "$cursor"
              draw_status
            else
              redraw_row_at_index "$old_cursor"
              draw_status
            fi
            ;;
          "$KEY_SELECT_ALL")
            toggle_select_all
            if (( PREVIEW_MODE )); then
              redraw_preview_rows_and_status
            else
              redraw_visible_rows_and_status
            fi
            ;;
          "$KEY_COPY"|"$KEY_COPY_F5")
            if set_clipboard_from_current_or_selection copy; then
              draw_status
            else
              draw_status
              footer_message_auto "Copy failed: no valid source paths in current selection."
            fi
            ;;
          "$KEY_COPY_PATH")
            copy_full_paths_to_system_clipboard || true
            ;;
          "$KEY_MOVE")
            if set_clipboard_from_current_or_selection move; then
              draw_status
            else
              draw_status
              footer_message_auto "Move failed: no valid source paths in current selection."
            fi
            ;;
          "$KEY_DELETE")
            delete_current_or_selected
            ;;
          "$KEY_CHMOD_X")
            toggle_executable || true
            ;;
          "$KEY_RENAME"|"$KEY_RENAME_F2")
            rename_current_or_selected || true
            ;;
          "$KEY_PASTE")
            paste_clipboard_items || true
            ;;
          "$KEY_RUN_COMMAND")
            run_user_command_prompt || true
            ;;
          "$KEY_GIT_PUSH")
            run_git_add_commit_push || true
            ;;
          "$KEY_UP")
            if (( PREVIEW_MODE )); then
              move_up
              redraw_preview_left_and_status
              PREVIEW_RENDER_DEFERRED=1
              PREVIEW_LAST_NAV_NS=$(now_epoch_ns)
              continue
            fi

            old_cursor=$cursor
            old_top=$top
            move_up
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top - 1 && cursor == old_cursor - 1 )); then
                scroll_list_once up
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_DOWN")
            if (( PREVIEW_MODE )); then
              move_down
              redraw_preview_left_and_status
              PREVIEW_RENDER_DEFERRED=1
              PREVIEW_LAST_NAV_NS=$(now_epoch_ns)
              continue
            fi

            old_cursor=$cursor
            old_top=$top
            move_down
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top + 1 && cursor == old_cursor + 1 )); then
                scroll_list_once down
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_PGUP")
            page_up
            draw_ui
            ;;
          "$KEY_PGDN")
            page_down
            draw_ui
            ;;
          "$KEY_LEFT")
            go_parent_dir || true
            ;;
          "$KEY_RIGHT"|"$KEY_ENTER"|$'\n')
            if dust_row_is_root_total "$cursor"; then
              go_parent_dir || true
            else
              enter_or_open_selected || true
            fi
            ;;
          "$KEY_OPEN_LESS"|"$KEY_OPEN_LESS_F3")
            open_selected_with_less || true
            ;;
          "$KEY_OPEN_GUI")
            open_selected_with_gui || true
            ;;
          "$KEY_OPEN_EDITOR"|"$KEY_OPEN_EDITOR_F4")
            open_selected_with_editor || true
            ;;
          "$KEY_COMPARE")
            compare_two_selected_files || true
            ;;
          "$KEY_SEARCH")
            bulk_search_in_current_dir || true
            ;;
          "$KEY_FIND_FILE"|"$KEY_FIND_FILE_ALT")
            fuzzy_find_filename_in_current_dir || true
            ;;
          "$KEY_DOWNLOAD")
            download_file_from_url || true
            ;;
          "$KEY_AGE_TOGGLE")
            toggle_age_protection_current || true
            ;;
          "$KEY_EXTRACT_ZIP")
            handle_zip_action || true
            ;;
          "$KEY_NEW_FILE")
            create_entry_from_prompt file || true
            ;;
          "$KEY_NEW_DIR")
            create_entry_from_prompt dir || true
            ;;
          "$KEY_HOME"|$'\e[1~')
            cursor=0
            top=0
            draw_ui
            ;;
          "$KEY_INTEGRATIONS")
            show_integrations
            ;;
          "$KEY_SSH_PICKER")
            show_ssh_picker || true
            ;;
          "$KEY_BOOKMARKS")
            show_bookmarks
            ;;
          "$KEY_HELP"|"$KEY_HELP_F1")
            show_help
            ;;
          "$KEY_END"|$'\e[4~')
            if (( ${#ROWS_COLOR[@]} > 0 )); then
              cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
              top=$(( cursor - visible_rows + 1 ))
              (( top < 0 )) && top=0
            fi
            draw_ui
            ;;
          "$KEY_HOME_DIR")
            navigate_to_dir "$HOME"
            ;;
          '1'|'2'|'3'|'4'|'5'|'6'|'7'|'8'|'9')
            jump_to_bookmark "$key"
            ;;
        esac
      done
    }

    main "$@"
