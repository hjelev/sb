strip_ls_suffix() {
    local item="$1"
    local last_char
    [[ "$item" == "(Empty Directory)" ]] && { printf "%s" "$item"; return; }
    last_char="${item: -1}"
    case "$last_char" in
        '/'|'@'|'*'|'|'|'='|'>') printf "%s" "${item:0:${#item}-1}" ;;
        *) printf "%s" "$item" ;;
    esac
}
get_color() {
    local f="$1"
    local clean_f clean_no_suffix base_name base_lower
    clean_f="$f"
    case "${clean_f: -1}" in
        '/'|'@'|'*'|'|'|'='|'>') clean_f="${clean_f:0:${#clean_f}-1}" ;;
    esac
    clean_no_suffix="${clean_f%/}"
    base_name="${clean_no_suffix##*/}"
    base_lower="${base_name,,}"
    case "$base_lower" in
        .env|package.json|cargo.toml|go.mod|pom.xml|package-lock.json|cargo.lock|yarn.lock|*.conf|*.ini|*.yaml|*.toml)
            echo -n "$YELLOW"
            return
            ;;
    esac
    if [[ "$base_name" == .* ]]; then
        [[ "$f" == */ ]] && echo -n "$HIDDEN_DIR" && return
        echo -n "$HIDDEN_FILE" && return
    fi
    case "$base_lower" in
        dockerfile) echo -n "$COLOR_DOCKERFILE"; return ;;
        makefile) echo -n "$COLOR_MAKEFILE"; return ;;
        license|copying|readme.md|changelog) echo -n "$COLOR_LICENSE"; return ;;
        *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.tiff|*.ico|*.svg|*.heic|*.avif|*.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.m4v|*.ogv|*.wmv|*.mp3|*.wav|*.ogg|*.flac|*.aac|*.m4a|*.opus|*.wma|*.pdf)
            echo -n "$COLOR_MEDIA"
            return
            ;;
        *.tmp|*.bak) echo -n "$COLOR_JUNK"; return ;;
        *.html|*.htm) echo -n "$COLOR_HTML"; return ;;
    esac
    [[ "$f" == */ ]] && echo -n "$BLUE" && return
    [[ "$f" == *@ ]] && echo -n "$CYAN" && return
    [[ "$f" == *\* ]] && echo -n "$GREEN" && return
    [[ "$f" =~ \.(zip|tar|tar\.gz|tgz|bz2|xz|rar|7z|gz|zst)$ ]] && echo -n "$RED" && return
    echo -n "$STATUS_VALUE"
}
