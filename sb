                dockerfile) file_icons+=("$ICON_DOCKERFILE") ;;
                makefile) file_icons+=("$ICON_MAKEFILE") ;;
                license) file_icons+=("$ICON_LICENSE") ;;
                .env) file_icons+=("$ICON_ENV") ;;
