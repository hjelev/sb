      [[ -n "$plain_name" ]] || plain_name="decrypted"

      tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/sb-age-open.XXXXXX")" || {
        draw_status
        footer_message_auto "Open failed: cannot create temporary file."
        return 1
      }
      tmp_file="$tmp_dir/$plain_name"

      passphrase="$(read_secret_prompt "Age passphrase (open): ")"
      [[ -n "$passphrase" ]] || {
        run_rm_rf "$tmp_dir" >/dev/null 2>&1 || true
        draw_status
        footer_message_auto "Open cancelled."
        return 1
      }

      run_age_decrypt_with_passphrase "$item" "$tmp_file" "$passphrase"
