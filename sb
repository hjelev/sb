        for i in "${!files[@]}"; do
            local clean_name="${files[$i]}"
            case "${clean_name: -1}" in
                '/'|'@'|'*'|'|'|'='|'>') clean_name="${clean_name:0:${#clean_name}-1}" ;;
            esac
            if [[ "$clean_name" == "$target_file" ]]; then
                cursor=$((i + 1))
                break
            fi
        done
    else
        cursor=${dir_positions["$(pwd)"]:-1}
    fi
    (( cursor > ${#files[@]} )) && cursor=${#files[@]}
