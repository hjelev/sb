        while IFS='|' read -r perms owner size date time filename; do
            [[ -z "$owner" || -z "$perms" || -z "$size" || -z "$date" || -z "$time" || -z "$filename" ]] && continue

            # Match by filename to handle ls output being in any order
            if [[ -n "${item_to_idx[$filename]}" ]]; then
                idx=${item_to_idx[$filename]}
                metadata[$idx]="${owner}|${perms}|${size}|${date} ${time}"
