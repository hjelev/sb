        redraw_cursor
        return
    fi

    local -a items=()
    local idx f last clean_item

    # Collect items in sb-view order (maintains dirs first, then files - as sorted)
    if (( ${#selected[@]} > 0 )); then
        for (( idx=0; idx<${#files[@]}; idx++ )); do
            [[ -n "${selected[$idx]+x}" ]] || continue
            f="${files[$idx]}"
            last="${f: -1}"
            case "$last" in
                '/'|'@'|'*'|'|'|'='|'>') clean_item="${f:0:${#f}-1}" ;;
                *) clean_item="$f" ;;
            esac
            if [[ -n "$clean_item" && "$clean_item" != "(Empty Directory)" ]]; then
                items+=("$clean_item")
            fi
        done
    else
        for f in "${files[@]}"; do
            last="${f: -1}"
            case "$last" in
                '/'|'@'|'*'|'|'|'='|'>') clean_item="${f:0:${#f}-1}" ;;
                *) clean_item="$f" ;;
            esac
            if [[ -n "$clean_item" && "$clean_item" != "(Empty Directory)" ]]; then
                items+=("$clean_item")
            fi
        done
    fi

    (( ${#items[@]} > 0 )) || { redraw_cursor; return; }

    local rename_status
