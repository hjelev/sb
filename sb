        "SB_LSD_*    Configure lsd renderer"
        ""
        "Bookmarks"
        "${KEY_BOOKMARKS}            Show bookmarks screen"
        "0-9          Jump to bookmark (from bookmarks screen or main view)"
        "SB_BOOKMARK_*  Set bookmark paths in your shell profile"
