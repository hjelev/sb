                package.json) file_icons+=("$ICON_NODE") ;;
                cargo.toml) file_icons+=("$ICON_CARGO") ;;
                go.mod) file_icons+=("$ICON_GOMOD") ;;
                *.age) file_icons+=("$ICON_AGE") ;;
                *.html|*.htm) file_icons+=("$ICON_HTML") ;;
                *.jsx|*.tsx) file_icons+=("$ICON_REACT") ;;
                *.py) file_icons+=("$ICON_PY") ;;
                *.js|*.mjs|*.cjs) file_icons+=("$ICON_JS") ;;
