    zip_archive_basename() {
      local path="$1"
      local base lower
      base="$(path_basename "$path")"
      lower="$(lowercase_string "$base")"
      case "$lower" in
        *.tar.gz|*.tar.bz2|*.tar.xz|*.tar.lz4|*.tar.zst|*.tar.lz)
          base="${base%.*}"; base="${base%.*}" ;;
        *.zip|*.jar|*.apk|*.war|*.ear|*.aar|*.cbz|*.epub|*.xpi|\
        *.docx|*.xlsx|*.pptx|*.odt|*.ods|*.odp|\
        *.tgz|*.tbz2|*.txz|*.tzst|*.tar|*.7z|*.rar)
          base="${base%.*}" ;;
      esac
      printf '%s' "$base"
    }

    # Extract a single archive to out_dir. Returns 0=ok 1=error 2=no tool.
    _extract_one_archive() {
      local item="$1" out_dir="$2"
      local lower err="" unzip_item
      local -a unzip_args=()
      lower="$(lowercase_string "$item")"
      [[ -n "$SB_UNZIP_ARGS" ]] && read -r -a unzip_args <<< "$SB_UNZIP_ARGS"

      case "$lower" in
        *.zip|*.jar|*.apk|*.war|*.ear|*.aar|*.cbz|*.epub|*.xpi|\
        *.docx|*.xlsx|*.pptx|*.odt|*.ods|*.odp)
          (( HAS_UNZIP )) || return 2
          unzip_item="$item"
          [[ "$unzip_item" == -* ]] && unzip_item="./$unzip_item"
          err="$(unzip -o "${unzip_args[@]}" "$unzip_item" -d "$out_dir" 2>&1)" && return 0
          LAST_PASTE_ERR="$err"; return 1 ;;
        *.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|\
        *.tar.lz4|*.tar.zst|*.tzst|*.tar.lz|*.tar)
          (( HAS_TAR )) || return 2
          err="$(tar xf "$item" -C "$out_dir" 2>&1)" && return 0
          LAST_PASTE_ERR="$err"; return 1 ;;
        *.7z)
          (( HAS_7Z )) || return 2
          err="$(7z x "$item" -o"$out_dir" -y 2>&1)" && return 0
          LAST_PASTE_ERR="$err"; return 1 ;;
        *.rar)
          (( HAS_RAR )) || return 2
          local rar_cmd
          command -v unrar >/dev/null 2>&1 && rar_cmd=unrar || rar_cmd=rar
          err="$($rar_cmd x "$item" "$out_dir/" 2>&1)" && return 0
          LAST_PASTE_ERR="$err"; return 1 ;;
        *)
          return 2 ;;
      esac
    }

    extract_selected_zip_archives() {
      local -a items=()
      local -a archive_items=()
      local item extract_root per_archive=0
      local ok_count=0 fail_count=0 skip_count=0
      local folder_name out_dir archive_name resolved_root rc

      (( HAS_ZIP )) || {
        draw_status
        footer_message_auto "Extraction unavailable: no archive tool is enabled or installed."
        return 1
      }

      read_stdin_into_array items < <(collect_zip_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Extract failed: no valid source paths in current selection."
        return 1
      }

      for item in "${items[@]}"; do
        [[ -f "$item" ]] || continue
        if is_archive_file "$item"; then
          archive_items+=("$item")
        fi
      done

      if (( ${#archive_items[@]} == 0 )); then
        draw_status
        footer_message_auto "Extract failed: current row/selection has no supported archives."
        return 1
      fi

      if (( ${#archive_items[@]} != ${#items[@]} )); then
        draw_status
        footer_message_auto "Extract requires archive-only selection when multiple items are selected."
        return 1
      fi

      if ! read_yes_no_prompt "Extract ${#archive_items[@]} archive(s)? [y/N]: "; then
        draw_status
        footer_message_auto "Extract cancelled."
        return 1
      fi

      extract_root="$(read_line_prompt "Extract to: " "$(pwd -P)")"
      if [[ -z "$extract_root" ]]; then
        draw_status
        footer_message_auto "Extract cancelled."
        return 1
      fi

      extract_root="${extract_root/#\~/$HOME}"
      if [[ "$extract_root" != /* ]]; then
        extract_root="$(pwd -P)/$extract_root"
      fi

      run_mkdir_p "$extract_root" 2>/dev/null || {
        draw_status
        footer_message_auto "Extract failed: cannot create destination '%s'." "$extract_root"
        return 1
      }

      if (( ${#archive_items[@]} > 1 )); then
        if read_yes_no_prompt "Extract each archive into its own folder under destination? [y/N]: "; then
          per_archive=1
        fi
      fi

      for item in "${archive_items[@]}"; do
        archive_name="$(path_basename "$item")"
        if (( per_archive )); then
          folder_name="$(zip_archive_basename "$item")"
          [[ -n "$folder_name" ]] || folder_name="archive"
          out_dir="$extract_root/$folder_name"
          if [[ -e "$out_dir" ]]; then
            resolved_root="$(read_line_prompt "Destination exists for '$archive_name'. Extract to: " "$out_dir")"
            resolved_root="${resolved_root/#\~/$HOME}"
            if [[ -z "$resolved_root" ]]; then
              ((skip_count++))
              continue
            fi
            [[ "$resolved_root" != /* ]] && out_dir="$(pwd -P)/$resolved_root" || out_dir="$resolved_root"
          fi
        else
          out_dir="$extract_root"
        fi

        if ! run_mkdir_p "$out_dir" 2>/dev/null; then
          ((fail_count++))
          continue
        fi

        _extract_one_archive "$item" "$out_dir"
        rc=$?
        if (( rc == 0 )); then
          ((ok_count++))
        elif (( rc == 2 )); then
          draw_status
          footer_message_auto "Extract skipped '%s': no tool available for this format." "$archive_name"
          ((skip_count++))
        else
          ((fail_count++))
        fi
      done

      LAST_PASTE_OP="extract"
      LAST_PASTE_OK=$ok_count
      LAST_PASTE_FAIL=$fail_count
      LAST_PASTE_SKIP=$skip_count
      LAST_PASTE_RC=0
      (( fail_count > 0 )) && LAST_PASTE_RC=1

      load_data
      draw_ui
      footer_message_auto "Extract: ok:%d fail:%d skip:%d" "$ok_count" "$fail_count" "$skip_count"
      return 0
    }

    archive_selected_items_as_zip() {
      local -a items=()
      local -a zip_args=()
      local -a zip_items=()
      local item out_path out_dir default_name base err
      local ok_count=0 fail_count=0

      (( HAS_ZIPCMD )) || {
        draw_status
        footer_message_auto "Archive creation unavailable: zip is disabled or not installed."
        return 1
      }

      read_stdin_into_array items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Archive failed: no valid source paths in current selection."
        return 1
      }

      for item in "${items[@]}"; do
        [[ -e "$item" || -L "$item" ]] || continue
        zip_items+=("$item")
      done

      (( ${#zip_items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Archive failed: selected sources do not exist."
        return 1
      }

      if (( ${#zip_items[@]} == 1 )); then
        base="$(path_basename "${zip_items[0]}")"
        default_name="${base}.zip"
      else
        base="$(path_basename "$(pwd -P)")"
        [[ -n "$base" ]] || base="archive"
        default_name="${base}.zip"
      fi

      out_path="$(read_line_prompt "Archive as: " "$(pwd -P)/$default_name")"
      out_path="$(sanitize_filename_input "$out_path")"
      if [[ -z "$out_path" ]]; then
        draw_status
        footer_message_auto "Archive cancelled."
        return 1
      fi

      out_path="${out_path/#\~/$HOME}"
      if [[ "$out_path" != /* ]]; then
        out_path="$(pwd -P)/$out_path"
      fi

      out_dir="$(path_dirname "$out_path")"
      run_mkdir_p "$out_dir" 2>/dev/null || {
        draw_status
        footer_message_auto "Archive failed: cannot create destination directory '%s'." "$out_dir"
        return 1
      }

      if [[ -e "$out_path" ]]; then
        if ! read_yes_no_prompt "Archive exists. Overwrite '$out_path'? [y/N]: "; then
          draw_status
          footer_message_auto "Archive cancelled."
          return 1
        fi
        rm -f "$(safe_command_path "$out_path")" 2>/dev/null || {
          draw_status
          footer_message_auto "Archive failed: cannot overwrite '%s'." "$out_path"
          return 1
        }
      fi

      if [[ -n "$SB_ZIP_ARGS" ]]; then
        read -r -a zip_args <<< "$SB_ZIP_ARGS"
      fi

      local i zip_item
      for i in "${!zip_items[@]}"; do
        zip_item="${zip_items[$i]}"
        [[ "$zip_item" == -* ]] && zip_item="./$zip_item"
        zip_items[$i]="$zip_item"
      done

      LAST_PASTE_OP="zip"
      LAST_PASTE_ERR="-"
      if err="$(zip -r "${zip_args[@]}" "$out_path" "${zip_items[@]}" 2>&1)"; then
        ok_count=1
        LAST_PASTE_RC=0
        LAST_PASTE_OK=1
        LAST_PASTE_FAIL=0
        LAST_PASTE_SKIP=0
      else
        fail_count=1
        LAST_PASTE_RC=1
        LAST_PASTE_OK=0
        LAST_PASTE_FAIL=1
        LAST_PASTE_SKIP=0
        LAST_PASTE_ERR="$err"
      fi

      load_data
      draw_ui
      if (( ok_count )); then
        footer_message_auto "Archive created: %s" "$(path_basename "$out_path")"
        return 0
      fi

      footer_message_auto "Archive failed."
      return 1
    }

    handle_zip_action() {
      local -a items=()
      local item zip_count=0 other_count=0

      read_stdin_into_array items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        footer_message_auto "Zip action failed: no valid source paths in current selection."
        return 1
      }

      for item in "${items[@]}"; do
        [[ -e "$item" || -L "$item" ]] || continue
        if [[ -f "$item" ]] && is_archive_file "$item"; then
          ((zip_count++))
        else
          ((other_count++))
        fi
      done

      if (( zip_count > 0 && other_count == 0 )); then
        extract_selected_zip_archives
        return $?
      fi

      if (( other_count == 0 )); then
        draw_status
        footer_message_auto "Zip action failed: no existing files selected."
        return 1
      fi

      if (( ${#items[@]} > 1 )); then
        if ! read_yes_no_prompt "Create one archive from selected items? [y/N]: "; then
          draw_status
          footer_message_auto "Archive cancelled."
          return 1
        fi
      else
        item="$(path_basename "${items[0]}")"
        if ! read_yes_no_prompt "Create archive for '$item'? [y/N]: "; then
          draw_status
          footer_message_auto "Archive cancelled."
          return 1
        fi
      fi

      archive_selected_items_as_zip
    }

toggle_executable() {
