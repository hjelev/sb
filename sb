        clear_selection
        get_terminal_size
        show_loading_status
        update_files
        cursor=${dir_positions["$(pwd)"]:-1}
        (( cursor > ${#files[@]} )) && cursor=${#files[@]}
        (( cursor < 1 )) && cursor=1
