format_bytes_human() {
    local bytes="$1"
    local -a units=(B K M G T P)
    local unit_index=0
    local whole remainder decimal

    [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0

    while (( bytes >= 1024 && unit_index < ${#units[@]} - 1 )); do
        remainder=$((bytes % 1024))
        bytes=$((bytes / 1024))
        ((unit_index++))
    done

    whole=$bytes
    if (( unit_index == 0 )); then
        printf "%d%s" "$whole" "${units[$unit_index]}"
        return
    fi

    decimal=$(( (remainder * 10) / 1024 ))
    if (( whole >= 10 )); then
        printf "%d%s" "$whole" "${units[$unit_index]}"
    else
        printf "%d.%d%s" "$whole" "$decimal" "${units[$unit_index]}"
    fi
}

get_item_size_bytes() {
    local item="$1"
    [[ -e "$item" || -L "$item" ]] || { printf "0"; return; }

    if [[ -d "$item" && ! -L "$item" ]]; then
        if [[ "$OS_NAME" != "Darwin" ]]; then
            local fs_type
            fs_type=$(stat -f -c %T -- "$item" 2>/dev/null)
            case "$fs_type" in
                proc|sysfs|devtmpfs|devpts|tmpfs|cgroup|cgroup2fs|mqueue|bpf|tracefs|debugfs|configfs|securityfs|fusectl|pstore|efivarfs|autofs)
                    stat $STAT_FMT_SIZE -- "$item" 2>/dev/null || printf "0"
                    return
                    ;;
            esac
        fi

        if [[ "$OS_NAME" == "Darwin" ]]; then
            du -sk -- "$item" 2>/dev/null | awk '{print $1 * 1024}'
        else
            du -sb --apparent-size -- "$item" 2>/dev/null | awk '{print $1}'
        fi
    else
        stat $STAT_FMT_SIZE -- "$item" 2>/dev/null || printf "0"
    fi
}

update_dust_sizes() {
    dust_sizes=()
    DUST_TOTAL=""
    if ! command -v dust &>/dev/null || (( ! DUST_MODE )); then
        return
    fi

    local item clean_item bytes total_bytes=0 percent human_size
    local -A raw_sizes

    for item in "${files[@]}"; do
        [[ "$item" == "(Empty Directory)" ]] && continue
        clean_item=$(strip_ls_suffix "$item")
        [[ -n "$clean_item" ]] || continue
        bytes=$(get_item_size_bytes "$clean_item")
        [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0
        raw_sizes["$clean_item"]="$bytes"
        (( total_bytes += bytes ))
    done

    if (( total_bytes <= 0 )); then
        DUST_TOTAL="0B"
        return
    fi

    DUST_TOTAL=$(format_bytes_human "$total_bytes")

    for item in "${!raw_sizes[@]}"; do
        bytes=${raw_sizes[$item]}
        percent=$(( (bytes * 100 + total_bytes / 2) / total_bytes ))
        human_size=$(format_bytes_human "$bytes")
        dust_sizes["$item"]="$human_size|$percent"
    done
}

update_files() {
    files=()
    metadata=()
    file_icons=()
    update_git_header_suffix
    mapfile -t files < <(list_entries)
    sort_files_by_mode
    if [[ ${#files[@]} -eq 0 ]]; then
        files=("(Empty Directory)")
        metadata=("$DEFAULT_META")
        file_icons=("$ICON_DIR")
    else
        populate_display_data_bulk
    fi
    update_dust_sizes
    (( cursor > ${#files[@]} )) && cursor=${#files[@]}
}

startup_auto_name_col_width() {
    (( NAME_COL_WIDTH_AUTO )) || return

    local -a start_entries=()
    local entry clean_entry max_len=0
    local auto_floor=$(( (NAME_COL_MAX + 1) / 2 ))

    mapfile -t start_entries < <(list_entries)
    (( ${#start_entries[@]} > 0 )) || return

    for entry in "${start_entries[@]}"; do
        clean_entry=$(strip_ls_suffix "$entry")
        (( ${#clean_entry} > max_len )) && max_len=${#clean_entry}
    done

    # Keep one extra column so ls -F suffixes (like trailing '/') remain visible.
    (( max_len++ ))

    # Avoid very narrow startup layouts in folders with short names.
    (( max_len < auto_floor )) && max_len=$auto_floor

    (( max_len < NAME_COL_MIN )) && max_len=$NAME_COL_MIN
    (( max_len > NAME_COL_MAX )) && max_len=$NAME_COL_MAX
    NAME_COL_WIDTH=$max_len
}

