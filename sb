#!/usr/bin/env bash
VERSION=""

usage() {
    cat <<'EOF'
Usage: sb [--export-path FILE] [--update] [--version] [--help]

Options:
  --export-path FILE  Write the final working directory to FILE on exit.
  --update            Reinstall/update sb using the installer script.
  --version           Print the sb version and exit.
  --help              Show this help text and exit.
EOF
}

update_self() { curl -fsSL "${SB_INSTALLER_URL:-https://raw.githubusercontent.com/hjelev/sb/master/install.sh}" | bash -s -- --install-dir "$(cd "$(dirname "$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")")" && pwd -P)";}

if (( BASH_VERSINFO[0] < 4 )); then
    echo "Error: sb requires bash 4.0 or newer." >&2
    echo "macOS ships with bash 3.2. Install a newer version with: brew install bash" >&2
    exit 1
fi
EXPORT_FILE=""
while (($# > 0)); do
    case "$1" in
        --export-path)
            if [[ -z "${2-}" ]]; then
                echo "Error: --export-path requires a file path." >&2
                exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
        --version)
            printf "sb %s\n" "$VERSION"
            exit 0
            ;;
        --update)
            update_self
            exit 0
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
    esac
done
HIGHLIGHT='\033[1;44m'; BLUE='\033[1;34m'; YELLOW='\033[1;38;5;229m'; AMBER='\033[1;38;5;172m'; GREEN='\033[1;32m'; CYAN='\033[1;36m'; RED='\033[1;31m'; NC='\033[0m'
cursor=1; old_cursor=0; old_scroll=-1; scroll_offset=0; files=(); metadata=(); CLIPBOARD_PATH=""; CLIPBOARD_NAME=""; declare -A dir_positions
SHOW_HIDDEN=0
init_platform() { OS_NAME=$(uname -s 2>/dev/null); OPEN_CMD="xdg-open"; LS_CMD="ls"; LS_GROUP_DIRS=0; (( BASH_VERSINFO[0] >= 4 )) && READ_TIMEOUT="0.001" || READ_TIMEOUT="1"; [[ "$OS_NAME" == "Darwin" ]] && OPEN_CMD="open" && command -v gls &>/dev/null && LS_CMD="gls"; "$LS_CMD" -F --group-directories-first -d . >/dev/null 2>&1 && LS_GROUP_DIRS=1; }
HELP_SECTION=''; HELP_KEY=''; HELP_ACCENT=''
init_platform
orig_stty=$(stty -g)
cleanup() { echo -ne "\033[?25h"; stty "$orig_stty"; [[ -n "$EXPORT_FILE" ]] && pwd > "$EXPORT_FILE"; clear; }
handle_resize() { get_terminal_size; old_cursor=-1; old_scroll=-1; stty -echo cbreak; printf "\033[2J\033[1;1H"; draw_ui; }
trap cleanup EXIT; trap handle_resize SIGWINCH; stty -echo cbreak
get_terminal_size() { term_rows=$(tput lines); term_cols=$(tput cols); max_rows=$((term_rows - 4)); }
get_color() { local f="$1"; [[ "$f" == */ ]] && echo -n "$BLUE" && return; [[ "$f" == *@ ]] && echo -n "$CYAN" && return; [[ "$f" == *\* ]] && echo -n "$GREEN" && return; [[ "$f" =~ \.(zip|tar|gz|rar|7z)$ ]] && echo -n "$RED" && return; echo -n "$NC"; }
list_entries() { local -a ls_args=(-F); (( SHOW_HIDDEN )) && ls_args+=(-A); (( LS_GROUP_DIRS )) && ls_args+=(--group-directories-first); "$LS_CMD" "${ls_args[@]}" 2>/dev/null; }
is_gui_session() { [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" || -n "${MIR_SOCKET:-}" || "$OS_NAME" == "Darwin" ]]; }
restore_browser_ui() { stty -echo cbreak; printf "\033[2J\033[1;1H\033[?25l"; get_terminal_size; update_files; draw_ui; }
run_interactive_command() { echo -ne "\033[?25h"; stty "$orig_stty"; clear; "$@"; local status=$?; restore_browser_ui; return $status; }
show_open_error() { local item="$1"; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K%b" "${RED}Unable to open '$item'. Set \$EDITOR or install xdg-open, nano, vim, vi, or less.${NC}"; IFS= read -rsN1; echo -ne "\033[?25l"; draw_ui; }
open_in_terminal_editor() { local item="$1" editor_name; local -a editors=(); [[ -n "${VISUAL:-}" ]] && editors+=("${VISUAL%% *}"); [[ -n "${EDITOR:-}" ]] && editors+=("${EDITOR%% *}"); editors+=(sensible-editor editor nano vim vi less more); for editor_name in "${editors[@]}"; do [[ -n "$editor_name" ]] || continue; command -v "$editor_name" >/dev/null 2>&1 || continue; run_interactive_command "$editor_name" "$item" && return 0; done; return 1; }
open_external() { local item="$1"; if is_gui_session; then command -v "$OPEN_CMD" &>/dev/null && "$OPEN_CMD" "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "xdg-open" ]] && command -v xdg-open &>/dev/null && xdg-open "$item" >/dev/null 2>&1 && return 0; [[ "$OPEN_CMD" != "open" ]] && command -v open &>/dev/null && open "$item" >/dev/null 2>&1 && return 0; fi; open_in_terminal_editor "$item" && return 0; show_open_error "$item"; return 1; }
update_files() { files=(); metadata=(); mapfile -t files < <(list_entries); for f in "${files[@]}"; do clean_f=$(echo "$f" | sed 's/[$*@|=>]//g'); [[ -e "$clean_f" || -L "$clean_f" ]] && meta=$(ls -ldh "$clean_f" 2>/dev/null | awk '{printf "%s|%s|%s|%3s %2s %5s", $3, $1, $5, $6, $7, $8}') || meta="----------|----------|-----|------------"; metadata+=("$meta"); done; [[ ${#files[@]} -eq 0 ]] && files=("(Empty Directory)"); (( cursor > ${#files[@]} )) && cursor=${#files[@]}; }
ensure_cursor_visible() { local total=${#files[@]}; local max_scroll=$(( total - max_rows )); (( max_scroll < 0 )) && max_scroll=0; if (( cursor < scroll_offset + 1 )); then scroll_offset=$(( cursor - 1 )); elif (( cursor > scroll_offset + max_rows )); then scroll_offset=$(( cursor - max_rows )); fi; (( scroll_offset < 0 )) && scroll_offset=0; (( scroll_offset > max_scroll )) && scroll_offset=$max_scroll; }
draw_line() { local idx=$1; local row=$2; local f_name="${files[$idx]}"; local display_name="${f_name:0:20}"; local meta="${metadata[$idx]}"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; printf "\033[${row};1H"; if (( idx + 1 == cursor )); then printf "${HIGHLIGHT}%-20s${NC} %-12s %-11s %8s %12s" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod"; else printf "$(get_color "$f_name")%-20s${NC} %-12s %-11s %8s %12s" "$display_name" "$m_owner" "$m_perms" "$m_size" "$m_mod"; fi; }
draw_status_line() { local hidden_status="Off"; (( SHOW_HIDDEN )) && hidden_status="On"; printf "\033[%d;1H\033[K" $((max_rows + 4)); printf "Item %d/%d │ Hidden: %-3s │ Clip: %-8s │ Path: %s" "$cursor" "${#files[@]}" "$hidden_status" "${CLIPBOARD_NAME:-None}" "$(pwd)"; }
scroll_list_once() { local direction="$1"; local top=3; local bottom=$((max_rows + 2)); local old_idx=$((old_cursor - 1)); local new_idx=$((cursor - 1)); printf "\033[%d;%dr" "$top" "$bottom"; if [[ "$direction" == "down" ]]; then printf "\033[%d;1H\033[M" "$top"; if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then draw_line "$old_idx" $((bottom - 1)); printf "\033[K"; fi; if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then draw_line "$new_idx" "$bottom"; printf "\033[K"; fi; else printf "\033[%d;1H\033[L" "$top"; if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then draw_line "$new_idx" "$top"; printf "\033[K"; fi; if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then draw_line "$old_idx" $((top + 1)); printf "\033[K"; fi; fi; printf "\033[r"; draw_status_line; }
draw_ui() { local total=${#files[@]}; ensure_cursor_visible; local hidden_status="Off"; (( SHOW_HIDDEN )) && hidden_status="On"; local buffer=""; buffer+=$'\e[H\e[?25l'; buffer+=$(printf "%-20s %-12s %-11s %8s %12s\n" "FILE NAME" "OWNER" "PERMS" "SIZE" "MODIFIED"); buffer+=$'\e[2;1H'; for (( i=0; i<term_cols-1; i++ )); do buffer+="─"; done; buffer+=$'\n'; for (( i=0; i<max_rows; i++ )); do local idx=$((scroll_offset + i)); buffer+=$'\e['$((i + 3))$';1H\e[K'; if (( idx < total )); then local f_name="${files[$idx]}"; local display_name="${f_name:0:20}"; local meta="${metadata[$idx]}"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; (( idx + 1 == cursor )) && buffer+="${HIGHLIGHT}$(printf "%-20s" "$display_name")${NC}" || buffer+="$(get_color "$f_name")$(printf "%-20s" "$display_name")${NC}"; buffer+=$(printf " %-12s %-11s %8s %12s" "$m_owner" "$m_perms" "$m_size" "$m_mod"); fi; done; buffer+=$'\e['$((max_rows + 4))$';1H\e[K'; buffer+=$(printf "Item %d/%d │ Hidden: %-3s │ Clip: %-8s │ Path: %s" "$cursor" "$total" "$hidden_status" "${CLIPBOARD_NAME:-None}" "$(pwd)"); printf "%b" "$buffer"; old_cursor=$cursor; old_scroll=$scroll_offset; }
redraw_cursor() { local previous_scroll=$scroll_offset; ensure_cursor_visible; if (( scroll_offset == previous_scroll + 1 && cursor == old_cursor + 1 )); then scroll_list_once down; old_cursor=$cursor; old_scroll=$scroll_offset; return; fi; if (( scroll_offset == previous_scroll - 1 && cursor == old_cursor - 1 )); then scroll_list_once up; old_cursor=$cursor; old_scroll=$scroll_offset; return; fi; if (( scroll_offset != previous_scroll )); then draw_ui; return; fi; local buffer=""; if (( old_cursor > 0 && old_cursor != cursor )); then local old_idx=$(( old_cursor - 1 )); if (( old_idx >= scroll_offset && old_idx < scroll_offset + max_rows )); then local f_name="${files[$old_idx]}"; local display_name="${f_name:0:20}"; local meta="${metadata[$old_idx]}"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; buffer+=$'\e['$((old_idx - scroll_offset + 3))$';1H\e[K'; buffer+="$(get_color "$f_name")$(printf "%-20s" "$display_name")${NC}"; buffer+=$(printf " %-12s %-11s %8s %12s" "$m_owner" "$m_perms" "$m_size" "$m_mod"); fi; fi; local new_idx=$(( cursor - 1 )); if (( new_idx >= scroll_offset && new_idx < scroll_offset + max_rows )); then local f_name="${files[$new_idx]}"; local display_name="${f_name:0:20}"; local meta="${metadata[$new_idx]}"; IFS='|' read -r m_owner m_perms m_size m_mod <<< "$meta"; buffer+=$'\e['$((new_idx - scroll_offset + 3))$';1H\e[K'; buffer+="${HIGHLIGHT}$(printf "%-20s" "$display_name")${NC}"; buffer+=$(printf " %-12s %-11s %8s %12s" "$m_owner" "$m_perms" "$m_size" "$m_mod"); fi; printf "%b" "$buffer"; draw_status_line; old_cursor=$cursor; old_scroll=$scroll_offset; }
get_item() { [[ $cursor -gt 0 && $cursor -le ${#files[@]} ]] && echo "${files[$((cursor-1))]}" | sed 's/[$*@|=>]//g'; }
open_file() { local item="$1"; if command -v chafa &>/dev/null && [[ "$item" =~ \.(jpg|jpeg|png|gif|bmp|webp|tiff|ico)$ ]]; then echo -ne "\033[?25h"; tput smcup; printf "\033[H"; chafa "$item" | head -n $((term_rows - 2)); printf "\033[$((term_rows));1H"; read -rsn1; tput rmcup; echo -ne "\033[?25l"; redraw_cursor; else open_external "$item"; fi; }
open_with_less() { local item="$1"; [[ -f "$item" ]] && run_interactive_command less -- "$item"; }
show_help() { echo -ne "\033[?25h"; clear; printf "%b" "${HELP_ACCENT}Shell Buddy${NC} "; printf "%b" "${VERSION}\n\n"; printf "%b" "${HELP_SECTION}Navigation${NC}\n"; printf "%b" "  ${HELP_KEY}Up/Down arrows${NC}   Move selection\n"; printf "%b" "  ${HELP_KEY}PgUp/PgDn${NC}        Jump by one page\n"; printf "%b" "  ${HELP_KEY}Home/End${NC}         Jump to top/bottom\n"; printf "%b" "  ${HELP_KEY}Right/Enter${NC}      Open directory/file\n"; printf "%b" "  ${HELP_KEY}Left${NC}             Go to parent directory\n"; printf "%b" "  ${HELP_KEY}~${NC}                Go to home directory\n\n"; printf "%b" "${HELP_SECTION}File Actions${NC}\n"; printf "%b" "  ${HELP_KEY}n${NC}                Create file\n"; printf "%b" "  ${HELP_KEY}N${NC}                Create folder\n"; printf "%b" "  ${HELP_KEY}c${NC}                Copy selected item\n"; printf "%b" "  ${HELP_KEY}p${NC}                Paste copied item\n"; printf "%b" "  ${HELP_KEY}m${NC}                Move copied item\n"; printf "%b" "  ${HELP_KEY}l${NC}                Open selected file in less\n"; printf "%b" "  ${HELP_KEY}x${NC}                Toggle executable permission\n"; printf "%b" "  ${HELP_KEY}d${NC}                Delete selected item\n\n"; printf "%b" "${HELP_SECTION}View${NC}\n"; printf "%b" "  ${HELP_KEY}.${NC}                Toggle hidden files\n"; printf "%b" "  ${HELP_KEY}h${NC}                Show this help\n"; printf "%b" "  ${HELP_KEY}q${NC}                Quit\n\n"; printf "%b" "${HELP_ACCENT}Press any key to return...${NC}"; read -rsn1; draw_ui; }
create_file_item() { local name=""; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -p "New file name: " name; stty -echo cbreak; echo -ne "\033[?25l"; [[ -z "$name" ]] && { redraw_cursor; return; }; touch -- "$name" 2>/dev/null && { update_files; draw_ui; } || redraw_cursor; }
create_dir_item() { local name=""; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -p "New folder name: " name; stty -echo cbreak; echo -ne "\033[?25l"; [[ -z "$name" ]] && { redraw_cursor; return; }; mkdir -p -- "$name" 2>/dev/null && { update_files; draw_ui; } || redraw_cursor; }
move_clipboard_item() { [[ -z "$CLIPBOARD_PATH" ]] && { redraw_cursor; return; }; local dest="$CLIPBOARD_NAME"; [[ -e "$dest" ]] && { echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -i "$dest" -p "Move as: " dest; stty -echo cbreak; echo -ne "\033[?25l"; }; [[ -z "$dest" ]] && { redraw_cursor; return; }; mv -- "$CLIPBOARD_PATH" "$dest" 2>/dev/null && { CLIPBOARD_PATH=""; CLIPBOARD_NAME=""; update_files; draw_ui; } || redraw_cursor; }
toggle_executable() { local item="$1"; [[ -z "$item" || "$item" == "(Empty Directory)" ]] && return; if [[ -x "$item" ]]; then chmod a-x -- "$item" 2>/dev/null; else chmod u+x -- "$item" 2>/dev/null; fi; update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui; }
delete_item() { local item="$1"; [[ -z "$item" || "$item" == "(Empty Directory)" ]] && return; echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -r -p "Delete '$item'? [y/N]: " confirm; stty -echo cbreak; echo -ne "\033[?25l"; [[ "$confirm" =~ ^[Yy]$ ]] || { redraw_cursor; return; }; rm -rf -- "$item" 2>/dev/null && { update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui; } || redraw_cursor; }
echo -ne "\033[?25l"; get_terminal_size; update_files; draw_ui
while true; do
IFS= read -rsN1 key
if [[ $key == $'\e' ]]; then while IFS= read -rsN1 -t $READ_TIMEOUT key_rest; do key+="$key_rest"; done; fi
case "$key" in
$'\e[A') ((cursor > 1)) && ((cursor--)) && redraw_cursor ;;
$'\e[B') ((cursor < ${#files[@]})) && ((cursor++)) && redraw_cursor ;;
$'\e[5~') old_cursor=$cursor; ((cursor -= max_rows)); (( cursor < 1 )) && cursor=1; (( cursor != old_cursor )) && redraw_cursor ;;
$'\e[6~') old_cursor=$cursor; ((cursor += max_rows)); (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor != old_cursor )) && redraw_cursor ;;
$'\e[H'|$'\e[1~'|$'\e[7~'|$'\eOH') ((cursor > 1)) && cursor=1 && redraw_cursor ;;
$'\e[F'|$'\e[4~'|$'\e[8~'|$'\eOF') ((cursor < ${#files[@]})) && cursor=${#files[@]} && redraw_cursor ;;
$'\e[C'|$'\n'|$'\r') item=$(get_item); if [ -d "$item" ]; then dir_positions["$(pwd)"]=$cursor; cd "$item" 2>/dev/null; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui; elif [ -f "$item" ]; then open_file "$item"; fi ;;
$'\e[D') dir_positions["$(pwd)"]=$cursor; cd .. 2>/dev/null; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui ;;
'~') dir_positions["$(pwd)"]=$cursor; cd "$HOME" 2>/dev/null; get_terminal_size; update_files; cursor=${dir_positions["$(pwd)"]:-1}; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; draw_ui ;;
'c') item=$(get_item); [[ "$item" != "(Empty Directory)" ]] && CLIPBOARD_PATH="$(pwd)/$item" && CLIPBOARD_NAME="$item" && redraw_cursor ;;
'p') [[ -n "$CLIPBOARD_PATH" ]] && { dest="$CLIPBOARD_NAME"; [[ -e "$dest" ]] && { echo -ne "\033[?25h"; printf "\033[$((max_rows + 4));1H\033[K"; stty echo; read -e -i "$dest" -p "New name: " dest; stty -echo cbreak; echo -ne "\033[?25l"; }; cp -r "$CLIPBOARD_PATH" "$dest" 2>/dev/null && { update_files; draw_ui; } } ;;
'm') move_clipboard_item ;;
'l') item=$(get_item); open_with_less "$item" ;;
'n') create_file_item ;;
'N') create_dir_item ;;
'h') show_help ;;
'.') SHOW_HIDDEN=$((1 - SHOW_HIDDEN)); update_files; (( cursor > ${#files[@]} )) && cursor=${#files[@]}; (( cursor < 1 )) && cursor=1; draw_ui ;;
'x') item=$(get_item); toggle_executable "$item" ;;
'd') item=$(get_item); delete_item "$item" ;;
'q') break ;;
esac
done
