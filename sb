                printf "  %b\n" "${AMBER}${upload_url}${NC}"
            else
                printf "  %b\n" "${AMBER}Connection failed. Check internet or catbox.moe availability.${NC}"
            fi
            redraw_cursor
            sleep 4
        fi
    done

    draw_ui
    if [[ -n "$LAST_UPLOAD_URL" ]]; then
        printf "\033[$((max_rows + 3));1H\033[K%b" "${GREEN}✓ Upload successful${NC} - ${CYAN}URL in clipboard${NC}"
    else
        printf "\033[$((max_rows + 3));1H\033[K%b" "${AMBER}Upload process ended with errors${NC}"
    fi
    redraw_cursor
}
