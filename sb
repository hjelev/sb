sshfs_unmount_session_mounts() {
    local mp cwd
    cwd="$PWD"

    # Move out of a mounted path before unmounting.
    for mp in "${!SSHFS_SESSION_MOUNTS[@]}"; do
        if [[ "$cwd" == "$mp" || "$cwd" == "$mp/"* ]]; then
            cd "$HOME" 2>/dev/null || cd / 2>/dev/null || true
            break
        fi
    done

    for mp in "${!SSHFS_SESSION_MOUNTS[@]}"; do
        sshfs_is_mounted "$mp" || continue
        sshfs_do_unmount "$mp" >/dev/null 2>&1 || true
    done
}

zip_is_mounted() {
    grep -qs " $1 " /proc/mounts 2>/dev/null
}

zip_do_unmount() {
    local mp="$1"

    if command -v fusermount3 >/dev/null 2>&1; then
        if fusermount3 -u "$mp" 2>/dev/null || fusermount3 -uz "$mp" 2>/dev/null; then
            unset 'ZIP_SESSION_MOUNTS[$mp]'
            unset 'ZIP_MOUNT_SOURCE_DIR[$mp]'
            unset 'ZIP_MOUNT_SOURCE_FILE[$mp]'
            return 0
        fi
    fi

    if command -v fusermount >/dev/null 2>&1; then
        if fusermount -u "$mp" 2>/dev/null || fusermount -uz "$mp" 2>/dev/null; then
            unset 'ZIP_SESSION_MOUNTS[$mp]'
            unset 'ZIP_MOUNT_SOURCE_DIR[$mp]'
            unset 'ZIP_MOUNT_SOURCE_FILE[$mp]'
            return 0
        fi
    fi

    if umount "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null; then
        unset 'ZIP_SESSION_MOUNTS[$mp]'
        unset 'ZIP_MOUNT_SOURCE_DIR[$mp]'
        unset 'ZIP_MOUNT_SOURCE_FILE[$mp]'
        return 0
    fi
    return 1
}

zip_unmount_session_mounts() {
    local mp cwd
    cwd="$PWD"

    for mp in "${!ZIP_SESSION_MOUNTS[@]}"; do
        if [[ "$cwd" == "$mp" || "$cwd" == "$mp/"* ]]; then
