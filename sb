download_from_url() {
    local use_tool=""
    if command -v curl &>/dev/null; then
        use_tool="curl"
    elif command -v wget &>/dev/null; then
        use_tool="wget"
    else
        printf "\033[$((max_rows + 3));1H\033[K%b" "${AMBER}Neither curl nor wget is installed${NC}"
        redraw_cursor
        return
    fi

    local url="" download_rc=0 url_no_fragment="" url_no_query="" suggested_name="" save_as="" fallback_name="downloaded_file" renamed_to="" final_name=""
    local host_part="" host_suggest=""
    echo -ne "\033[?25h"
    printf "\033[$((max_rows + 3));1H\033[K"
    stty echo
    read -e -p "Download URL: " url
    stty -echo cbreak -ixon intr undef
    echo -ne "\033[?25l"

    [[ -z "$url" ]] && { redraw_cursor; return; }

    url_no_fragment="${url%%#*}"
    url_no_query="${url_no_fragment%%\?*}"
    suggested_name="${url_no_query##*/}"
    host_part="${url_no_query#*://}"
    host_part="${host_part%%/*}"
    host_part="${host_part##*@}"
    host_part="${host_part%%:*}"
    host_suggest=$(printf "%s" "$host_part" | tr -cs 'a-zA-Z0-9._-' '_')
    host_suggest="${host_suggest##_}"
    host_suggest="${host_suggest%%_}"
    [[ -z "$host_suggest" ]] && host_suggest="downloaded_file"

    if [[ -z "$suggested_name" || "$url_no_query" == */ ]]; then
        echo -ne "\033[?25h"
        printf "\033[$((max_rows + 3));1H\033[K"
        stty echo
        read -e -i "$host_suggest" -p "Save as: " save_as
        stty -echo cbreak -ixon intr undef
        echo -ne "\033[?25l"
        [[ -z "$save_as" ]] && save_as="$host_suggest"
    fi

    if [[ "$use_tool" == "curl" ]]; then
        if [[ -n "$save_as" ]]; then
            run_interactive_command curl -fL --show-error --progress-bar -o "$save_as" -- "$url"
        else
            run_interactive_command curl -fL --show-error --progress-bar -OJ -- "$url"
        fi
    else
        if [[ -n "$save_as" ]]; then
            run_interactive_command wget --progress=bar:force -O "$save_as" -- "$url"
        else
            run_interactive_command wget --progress=bar:force -- "$url"
        fi
    fi
    download_rc=$?

    if (( download_rc == 0 )); then
        if [[ -n "$save_as" ]]; then
            final_name="$save_as"
        fi

        if [[ -z "$save_as" && -f "$fallback_name" ]]; then
            echo -ne "\033[?25h"
            printf "\033[$((max_rows + 3));1H\033[K"
            stty echo
            read -e -i "$host_suggest" -p "Saved as $fallback_name. Rename to: " renamed_to
            stty -echo cbreak -ixon intr undef
            echo -ne "\033[?25l"

            [[ -z "$renamed_to" ]] && renamed_to="$host_suggest"
            if [[ -n "$renamed_to" && "$renamed_to" != "$fallback_name" ]]; then
                mv -- "$fallback_name" "$renamed_to" 2>/dev/null || true
                final_name="$renamed_to"
            else
                final_name="$fallback_name"
            fi
        elif [[ -z "$final_name" && -n "$suggested_name" && -f "$suggested_name" ]]; then
            final_name="$suggested_name"
        fi
        update_files
        draw_ui
        if [[ -n "$final_name" ]]; then
            printf "\033[$((max_rows + 3));1H\033[K%b" "${GREEN}Downloaded: ${final_name}${NC}"
        else
            printf "\033[$((max_rows + 3));1H\033[K%b" "${GREEN}Downloaded file successfully.${NC}"
        fi
    else
        printf "\033[$((max_rows + 3));1H\033[K%b" "${AMBER}Download failed (${use_tool} exit ${download_rc}).${NC}"
        redraw_cursor
        return
    fi
    redraw_cursor
}
