        local alias="" hostname="" user="" port="" line key val
        local def_user="${USER:-$(id -un 2>/dev/null)}"
        while IFS= read -r line; do
            line="${line#"${line%%[! ]*}"}"
            [[ "$line" == "#"* || -z "$line" ]] && continue
            key="${line%% *}"; val="${line#* }"
            case "${key,,}" in
                host)     _sshfs_emit_ssh_block "$alias" "$hostname" "$user" "$port" "$def_user"
                          alias="$val"; hostname=""; user=""; port="" ;;
                hostname) hostname="$val" ;;
                user)     user="$val" ;;
                port)     port="$val" ;;
            esac
        done < "${HOME}/.ssh/config"
        _sshfs_emit_ssh_block "$alias" "$hostname" "$user" "$port" "$def_user"
    }

    # Mount (if needed) and navigate sb into the sshfs mount point.
    sshfs_mount_and_navigate() {
