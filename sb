#!/usr/bin/env bash
VERSION=""

usage() {
    cat <<'EOF'
Usage: sb [--export-path FILE] [-w WIDTH] [--update] [-i|--int] [--version] [--help]

Options:
    --export-path FILE  Write the final working directory to FILE on exit.
        -w, --width WIDTH   Set initial name column width (10-60).
  -i, --int           Show status of available integrations and exit.
  --update            Reinstall/update sb using the installer script.
  --version           Print the sb version and exit.
  --help              Show this help text and exit.
EOF
}

update_self() { curl -fsSL "${SB_INSTALLER_URL:-https://raw.githubusercontent.com/hjelev/sb/master/install.sh}" | bash -s -- --install-dir "$(cd "$(dirname "$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")")" && pwd -P)";}
show_integrations() {
    local -a integrations=("git" "chafa" "glow" "csvlens" "jnv" "ouch" "pdftotext" "bat" "fzf" "rg" "delta" "dust")
    printf "%b" "${CYAN}Available Integrations:\n\n${NC}"
    for tool in "${integrations[@]}"; do
        if command -v "$tool" &>/dev/null; then
            local version=$("$tool" --version 2>&1 | head -n 1)
            printf "  ${GREEN}✓${NC} %-12s ${version}\n" "$tool"
        else
            printf "  ${RED}✗${NC} %-12s ${AMBER}not installed${NC}\n" "$tool"
        fi
    done
    printf "\n%b" "${CYAN}Integration Descriptions:${NC}\n"
    printf "  ${YELLOW}git${NC}         - Show current branch in header; add * for unstaged changes\n"
    printf "  ${YELLOW}chafa${NC}       - Image preview in terminal\n"
    printf "  ${YELLOW}glow${NC}        - Markdown preview\n"
    printf "  ${YELLOW}csvlens${NC}     - Delimited file preview (.csv, .tsv, .tab, .psv, .dsv)\n"
    printf "  ${YELLOW}jnv${NC}         - JSON preview (.json, .jsonl, .ndjson, .geojson)\n"
    printf "  ${YELLOW}ouch${NC}        - Archive content preview via 'ouch list'\n"
    printf "  ${YELLOW}pdftotext${NC}   - PDF text preview (uses 'bat' when available, otherwise 'less')\n"
    printf "  ${YELLOW}bat${NC}         - Syntax highlighting for code files\n"
    printf "  ${YELLOW}fzf${NC}         - Fuzzy finder for directory/file jumping\n"
    printf "  ${YELLOW}rg${NC}          - Ripgrep for fast text search\n"
    printf "  ${YELLOW}delta${NC}       - Enhanced diff viewer for file comparison\n"
    printf "  ${YELLOW}dust${NC}        - Disk usage analyzer (shows folder sizes and percentages)\n"
}
if (( BASH_VERSINFO[0] < 4 )); then
    echo "Error: sb requires bash 4.0 or newer." >&2
    echo "macOS ships with bash 3.2. Install a newer version with: brew install bash" >&2
    exit 1
fi

HIGHLIGHT='\033[1;44m'; BLUE='\033[1;34m'; YELLOW='\033[1;38;5;229m'; AMBER='\033[1;38;5;172m'; GREEN='\033[1;32m'; CYAN='\033[1;36m'; RED='\033[1;31m'; NC='\033[0m'; SELECT='\033[48;5;66m'; STATUS_LABEL='\033[38;5;244m'; STATUS_VALUE='\033[1;97m'; HIDDEN_FILE='\033[0m'; HIDDEN_DIR='\033[38;5;67m'

EXPORT_FILE=""
NAME_COL_WIDTH_OVERRIDE=""
while (($# > 0)); do
    case "$1" in
        --export-path)
            if [[ -z "${2-}" ]]; then
                echo "Error: --export-path requires a file path." >&2
                exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
        -w|--width)
            if [[ -z "${2-}" ]]; then
                echo "Error: $1 requires a width value." >&2
                exit 1
            fi
            NAME_COL_WIDTH_OVERRIDE="$2"
            shift 2
            ;;
        -i|--int)
            show_integrations
            exit 0
            ;;
        --version)
            printf "sb %s\n" "$VERSION"
            exit 0
            ;;
        --update)
            update_self
            exit 0
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
    esac
done
ICON_DIR='📁'; ICON_LINK='🔗'; ICON_FILE='📄'; ICON_EXEC='🛠'; ICON_IMAGE='🖼'; ICON_VIDEO='🎬'; ICON_AUDIO='🎵'; ICON_ARCHIVE='📦'; ICON_SCRIPT='📜'; ICON_CODE='💻'
DEFAULT_META='----------|----------|-----|----------------'
META_COL_FMT='%-12s %-11s %8s  %16s'
DUST_PCT_FMT='%6s'
DUST_META_COL_FMT='%-12s %-11s %8s %6s  %16s'
cursor=1; old_cursor=0; old_scroll=-1; scroll_offset=0; files=(); metadata=(); file_icons=(); CLIPBOARD_PATH=""; CLIPBOARD_NAME=""; CLIPBOARD_MULTI=(); CLIPBOARD_MOVE=0; declare -A dir_positions; declare -A selected
GIT_HEADER_SUFFIX=""
DUST_MODE=0
declare -A dust_sizes
SHOW_HIDDEN=0
SORT_MODE="name"
SORT_NAME_DESC=0
SORT_DATE_DESC=0
SORT_SIZE_DESC=0
