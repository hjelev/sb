    # ─────────────────────────────────────────────────────────────────────────────
    # sshfs integration
    # ─────────────────────────────────────────────────────────────────────────────

    # Parse a connection spec into _ssh_* globals.
    # Formats: [label:]user@host[:/path]  or  [label:]user@host[:port:/path]
    sshfs_parse_spec() {
        local spec="$1"
        _ssh_label=""; _ssh_user=""; _ssh_host=""; _ssh_port=""; _ssh_path="/"
        [[ "$spec" != *"@"* ]] && return 1
        local left="${spec%%@*}" right="${spec#*@}"
        if [[ "$left" == *":"* ]]; then
            _ssh_label="${left%%:*}"; _ssh_user="${left#*:}"
        else
            _ssh_label=""; _ssh_user="$left"
        fi
        # right: host[:port]:/path  or  host[:port]  or  host:/path
        if [[ "$right" == *":/"* ]]; then
            local before_path="${right%%:/*}"
            _ssh_path="/${right#*:/}"
            if [[ "$before_path" == *":"* ]]; then
                _ssh_host="${before_path%%:*}"; _ssh_port="${before_path#*:}"
            else
                _ssh_host="$before_path"; _ssh_port=""
            fi
        else
            _ssh_host="$right"; _ssh_port=""
            if [[ "$_ssh_host" == *":"* ]]; then
                _ssh_port="${_ssh_host#*:}"; _ssh_host="${_ssh_host%%:*}"
            fi
        fi
        [[ -z "$_ssh_user" || -z "$_ssh_host" ]] && return 1
        return 0
    }

    # Return the local mount directory path for a spec.
    sshfs_get_mount_point() {
        local spec="$1"
        sshfs_parse_spec "$spec" || { printf ""; return 1; }
        local safe_name
        safe_name=$(printf "%s_%s" "$_ssh_host" "$_ssh_path" | tr -cs 'a-zA-Z0-9_-' '_' | sed 's/_\+/_/g; s/^_//; s/_$//')
        printf "%s/%s" "${SSHFS_DIR}" "${safe_name:-conn}"
    }

    # Return a display-friendly connection spec without the optional label prefix.
    sshfs_format_spec_for_display() {
        local spec="$1"
        sshfs_parse_spec "$spec" || { printf "%s" "$spec"; return 0; }
        if [[ -n "$_ssh_port" ]]; then
            printf "%s@%s:%s:%s" "$_ssh_user" "$_ssh_host" "$_ssh_port" "$_ssh_path"
        else
            printf "%s@%s:%s" "$_ssh_user" "$_ssh_host" "$_ssh_path"
        fi
    }

    # Return 0 if path is a live sshfs mount.
    sshfs_is_mounted() {
        grep -qs " $1 fuse.sshfs " /proc/mounts 2>/dev/null
    }

    # Mount via sshfs; run_interactive_command lets SSH prompts appear on screen.
    sshfs_do_mount() {
        local spec="$1"
        SSHFS_LAST_ERROR=""
        sshfs_parse_spec "$spec" || {
            SSHFS_LAST_ERROR="Invalid SSH spec: ${spec}"
            return 1
        }
        if ! command -v sshfs &>/dev/null; then
            SSHFS_LAST_ERROR="sshfs is not installed"
            return 1
        fi
        local mp
        mp=$(sshfs_get_mount_point "$spec") || return 1
        sshfs_is_mounted "$mp" && return 0
        if ! mkdir -p "$mp" 2>/dev/null; then
            if [[ ! -d "$SSHFS_DIR" ]]; then
                SSHFS_LAST_ERROR="Cannot create mount base directory: ${SSHFS_DIR}. Set SB_SSHFS_DIR to a writable path (for example ${HOME}/.cache/sb_sshfs)."
            elif [[ ! -w "$SSHFS_DIR" ]]; then
                SSHFS_LAST_ERROR="Mount base directory is not writable: ${SSHFS_DIR}. Set SB_SSHFS_DIR to a writable path (for example ${HOME}/.cache/sb_sshfs)."
            else
                SSHFS_LAST_ERROR="Cannot create mount point: ${mp}"
            fi
            return 1
        fi
        local -a opts=("-o" "follow_symlinks,reconnect,ServerAliveInterval=15")
        [[ -n "$_ssh_port" ]] && opts+=("-p" "$_ssh_port")
        if ! run_interactive_command sshfs "${opts[@]}" "${_ssh_user}@${_ssh_host}:${_ssh_path}" "$mp"; then
            SSHFS_LAST_ERROR="sshfs command failed for ${_ssh_user}@${_ssh_host}:${_ssh_path} -> ${mp}."
            return 1
        fi
        SSHFS_SESSION_MOUNTS["$mp"]=1
        return 0
    }

    # Unmount an sshfs mount point.
    sshfs_do_unmount() {
        local mp="$1"
        local cwd
        cwd="$PWD"

        # Move out of the mount before unmounting to avoid "target is busy" failures.
        if [[ "$cwd" == "$mp" || "$cwd" == "$mp/"* ]]; then
            cd "$HOME" 2>/dev/null || cd / 2>/dev/null || true
        fi

        if command -v fusermount3 >/dev/null 2>&1; then
            if fusermount3 -u "$mp" 2>/dev/null || fusermount3 -uz "$mp" 2>/dev/null; then
                unset 'SSHFS_SESSION_MOUNTS[$mp]'
                return 0
            fi
        fi

        if command -v fusermount >/dev/null 2>&1; then
            if fusermount -u "$mp" 2>/dev/null || fusermount -uz "$mp" 2>/dev/null; then
                unset 'SSHFS_SESSION_MOUNTS[$mp]'
                return 0
            fi
        fi

        if umount "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null; then
            unset 'SSHFS_SESSION_MOUNTS[$mp]'
            return 0
        fi
        return 1
    }

    # Emit one SSH config host block as "alias|spec".
    _sshfs_emit_ssh_block() {
        [[ -z "$1" || "$1" == *"*"* ]] && return
        local h="${2:-$1}" u="${3:-$5}" p="$4"
        local spec="${u}@${h}:/"
        [[ -n "$p" ]] && spec="${u}@${h}:${p}:/"
        printf "%s|%s\n" "$1" "$spec"
