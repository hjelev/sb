            [[ -n "$LSY_EZA_COLOR_SCALE_MODE" ]] && eza_args+=(--color-scale-mode="$LSY_EZA_COLOR_SCALE_MODE")
            [[ "$LSY_EZA_SHOW_LINKS" == "1" ]] && eza_args+=(--links)
            [[ "$LSY_EZA_SHOW_GROUP" == "1" ]] && eza_args+=(--group)
            [[ "$LSY_EZA_NO_QUOTES" == "1" ]] && eza_args+=(--no-quotes)
