          [[ -n "$output_name" ]] || {
            draw_status
            printf "\033[%d;1H\033[K\033[2mDecrypt cancelled.\033[0m" "$rows"
            return 1
          }
          if [[ "$output_name" == */* ]]; then
            draw_status
            printf "\033[%d;1H\033[K\033[2mDecrypt failed: use a name only (no '/').\033[0m" "$rows"
            return 1
          fi
          if [[ -e "$output_name" || -L "$output_name" ]]; then
            draw_status
            printf "\033[%d;1H\033[K\033[2mDecrypt failed: target exists: %s\033[0m" "$rows" "$output_name"
            return 1
          fi
        fi

        passphrase="$(read_secret_prompt "Age passphrase (decrypt): ")"
        [[ -n "$passphrase" ]] || {
          draw_status
          printf "\033[%d;1H\033[K\033[2mDecrypt cancelled.\033[0m" "$rows"
          return 1
        }

        run_age_decrypt_with_passphrase "$item" "$output_name" "$passphrase"
        rc=$?
        passphrase=""

        if (( rc != 0 )); then
          [[ -f "$output_name" && ! -s "$output_name" ]] && rm -f -- "$output_name"
          draw_status
          printf "\033[%d;1H\033[K\033[2mDecrypt failed (exit %d).\033[0m" "$rows" "$rc"
          return 1
        fi

        rm -f -- "$item"
        load_data
        position_cursor_for_name "$output_name" >/dev/null 2>&1 || true
        draw_ui
        printf "\033[%d;1H\033[K\033[2mUnprotected with age: %s\033[0m" "$rows" "$output_name"
        return 0
      fi

      output_name="${item}.age"
      if [[ -e "$output_name" || -L "$output_name" ]]; then
        output_name="$(read_line_prompt "Encrypt as: " "$output_name")"
        output_name="$(sanitize_filename_input "$output_name")"
        output_name="$(trim_whitespace "$output_name")"
        [[ -n "$output_name" ]] || {
          draw_status
          printf "\033[%d;1H\033[K\033[2mEncrypt cancelled.\033[0m" "$rows"
          return 1
        }
        if [[ "$output_name" != *.age ]]; then
          output_name="${output_name}.age"
        fi
        if [[ "$output_name" == */* ]]; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mEncrypt failed: use a name only (no '/').\033[0m" "$rows"
          return 1
        fi
        if [[ -e "$output_name" || -L "$output_name" ]]; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mEncrypt failed: target exists: %s\033[0m" "$rows" "$output_name"
          return 1
        fi
      fi

      passphrase="$(read_secret_prompt "Age passphrase (encrypt): ")"
      [[ -n "$passphrase" ]] || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mEncrypt cancelled.\033[0m" "$rows"
        return 1
      }

      passphrase_confirm="$(read_secret_prompt "Confirm passphrase: ")"
      if [[ "$passphrase" != "$passphrase_confirm" ]]; then
        passphrase=""
        passphrase_confirm=""
        draw_status
        printf "\033[%d;1H\033[K\033[2mEncrypt cancelled: passphrases did not match.\033[0m" "$rows"
        return 1
      fi
      passphrase_confirm=""

      run_age_encrypt_with_passphrase "$item" "$output_name" "$passphrase"
      rc=$?
      passphrase=""

      if (( rc != 0 )); then
        [[ -f "$output_name" && ! -s "$output_name" ]] && rm -f -- "$output_name"
        draw_status
        printf "\033[%d;1H\033[K\033[2mEncrypt failed (exit %d).\033[0m" "$rows" "$rc"
        return 1
      fi

      rm -f -- "$item"
      load_data
      position_cursor_for_name "$output_name" >/dev/null 2>&1 || true
      draw_ui
      printf "\033[%d;1H\033[K\033[2mProtected with age: %s\033[0m" "$rows" "$output_name"
      return 0
    }

