              else
                LAST_SOURCE_FALLBACK_TO=ls
              fi
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a dust_args=() dust_compat_args=()
            dust_args=(--depth 1 --number-of-lines 100000 --reverse -R -p -C)
            (( !show_hidden )) && dust_args+=(--ignore-hidden)
            LAST_SOURCE_EXECUTED="dust"
            LAST_SOURCE_ARGS="dust ${dust_args[*]}"
            if output="$(dust "${dust_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="dust"
              break
            fi
            dust_compat_args=(-d 1 -n 100000 -r -R -p -C)
            (( !show_hidden )) && dust_compat_args+=(-i)
            LAST_SOURCE_ARGS="dust ${dust_compat_args[*]}"
            if output="$(dust "${dust_compat_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="dust"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            if (( HAS_EZA )); then
              LAST_SOURCE_FALLBACK_TO=eza
            elif (( HAS_LSD )); then
              LAST_SOURCE_FALLBACK_TO=lsd
            elif (( HAS_LOGO_LS )); then
              LAST_SOURCE_FALLBACK_TO=logo-ls
            else
              LAST_SOURCE_FALLBACK_TO=ls
            fi
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          logo-ls)
            if (( !HAS_LOGO_LS )); then
              LAST_SOURCE_EXECUTED="logo-ls"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              if (( HAS_EZA )); then
                LAST_SOURCE_FALLBACK_TO=eza
              elif (( HAS_LSD )); then
                LAST_SOURCE_FALLBACK_TO=lsd
              elif (( HAS_DUST )); then
                LAST_SOURCE_FALLBACK_TO=dust
              else
                LAST_SOURCE_FALLBACK_TO=ls
              fi
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a logols_args=() logols_extra_args=()
            # -l long listing, -h human-readable sizes. Keep logo-ls native default time style.
            logols_args=(-l -h)
            (( LSY_LOGO_LS_ICONS == 0 )) && logols_args+=(-i)
            (( LSY_LOGO_LS_COLOR == 0 )) && logols_args+=(-c)
            (( LSY_LOGO_LS_GIT_STATUS == 1 )) && logols_args+=(-D)
            if [[ -n "$LSY_LOGO_LS_EXTRA_ARGS" ]]; then
              read -r -a logols_extra_args <<< "$LSY_LOGO_LS_EXTRA_ARGS"
              logols_args+=("${logols_extra_args[@]}")
            fi
            (( show_hidden )) && logols_args+=(-A)
            LAST_SOURCE_EXECUTED="logo-ls"
            LAST_SOURCE_ARGS="logo-ls ${logols_args[*]}"
            # Force wide capture width so logo-ls does not soft-wrap rows. Wrapped
            # rows break downstream parsing by splitting one entry into multiple lines.
            if output="$(COLUMNS=4096 logo-ls "${logols_args[@]}" 2>/dev/null)"; then
              if [[ "$LSY_LOGO_LS_DIRS_FIRST" == "1" ]]; then
                output="$(printf '%s\n' "$output" | reorder_logo_ls_dirs_first)"
              fi
              LAST_SOURCE_RC=0
              LIST_SOURCE="logo-ls"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            if (( HAS_EZA )); then
              LAST_SOURCE_FALLBACK_TO=eza
            elif (( HAS_LSD )); then
              LAST_SOURCE_FALLBACK_TO=lsd
            elif (( HAS_DUST )); then
              LAST_SOURCE_FALLBACK_TO=dust
            else
              LAST_SOURCE_FALLBACK_TO=ls
            fi
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          *)
            LAST_SOURCE_EXECUTED="$source"
            LAST_SOURCE_RC=1
            ROWS_COLOR=()
            return 1
            ;;
        esac
      done

      if [[ -n "$output" ]]; then
        if [[ "$LIST_SOURCE" == "dust" ]]; then
          parse_dust_output_rows "$output"
        else
          read_stdin_into_array ROWS_COLOR <<< "$output"
        fi
      else
        ROWS_COLOR=()
      fi
      return 0
    }

    open_file_with_viewer() {
      local item="$1"
      local mime=""
      local -a chafa_args=()
      local -a glow_args=()
      local -a csvlens_args=()
      local -a jnv_args=()
      local -a play_args=()
      local -a sox_args=()

      if (( HAS_JNV )) && is_jnv_file "$item"; then
        if [[ -n "$LSY_JNV_ARGS" ]]; then
          read -r -a jnv_args <<< "$LSY_JNV_ARGS"
        fi
        run_interactive_command jnv "${jnv_args[@]}" "$item"
        return $?
      fi

      if (( HAS_CSVLENS )) && is_csvlens_file "$item"; then
        if [[ -n "$LSY_CSVLENS_ARGS" ]]; then
          read -r -a csvlens_args <<< "$LSY_CSVLENS_ARGS"
        fi
        run_interactive_command csvlens "${csvlens_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_GLOW )) && is_markdown_file "$item"; then
        if [[ -n "$LSY_GLOW_ARGS" ]]; then
          read -r -a glow_args <<< "$LSY_GLOW_ARGS"
        fi
        run_interactive_command glow -p "${glow_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_SOX )) && is_audio_file "$item"; then
          if command -v play >/dev/null 2>&1; then
            if [[ -n "$LSY_PLAY_ARGS" ]]; then
              read -r -a play_args <<< "$LSY_PLAY_ARGS"
            fi
            run_audio_preview_command play "${play_args[@]}" -- "$item"
          elif command -v sox >/dev/null 2>&1; then
            if [[ -n "$LSY_SOX_ARGS" ]]; then
              read -r -a sox_args <<< "$LSY_SOX_ARGS"
            fi
            run_audio_preview_command sox -- "$item" -d "${sox_args[@]}"
          else
            return 1
          fi
        return $?
      fi

      if (( HAS_CHAFA )); then
        if command -v file >/dev/null 2>&1; then
          mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        fi

        if [[ "$mime" == image/* ]]; then
          if [[ -n "$LSY_CHAFA_ARGS" ]]; then
            read -r -a chafa_args <<< "$LSY_CHAFA_ARGS"
          fi
          run_interactive_preview_command chafa "${chafa_args[@]}" -- "$item"
          return $?
        fi
      fi

      if (( HAS_PDFTOTEXT )) && is_pdf_file "$item"; then
        preview_pdf_with_pdftotext "$item"
        return $?
      fi

      # Only fall back to hexyl when no richer typed integration claimed the file.
      if (( HAS_HEXYL )) && should_use_hex_fallback_file "$item"; then
        open_file_with_hexyl "$item"
        return $?
      fi

      case "$FILE_VIEWER" in
        less)
          command -v less >/dev/null 2>&1 || return 1
          run_interactive_command less -- "$item"
          ;;
        bat)
          (( HAS_BAT )) || return 1
          run_interactive_command bat --paging=always -- "$item"
          ;;
        batcat)
          (( HAS_BATCAT )) || return 1
          run_interactive_command batcat --paging=always -- "$item"
          ;;
        *)
          return 1
          ;;
      esac
      return 0
    }

    is_audio_file() {
      local item="$1"
