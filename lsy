          ;;
        pdftotext)
          (( HAS_PDFTOTEXT ))
          return
          ;;
        hexyl)
          (( HAS_HEXYL ))
          return
          ;;
        hexedit)
          (( HAS_HEXEDIT ))
          return
          ;;
        rg)
          (( HAS_RG ))
          return
          ;;
        fzf)
          (( HAS_FZF ))
          return
          ;;
        wget)
          (( HAS_WGET ))
          return
          ;;
        curl)
          (( HAS_CURL ))
          return
          ;;
        age)
          (( HAS_AGE ))
          return
          ;;
        vidir)
          (( HAS_VIDIR ))
          return
          ;;
        delta)
          (( HAS_DELTA ))
          return
          ;;
        sox)
