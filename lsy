            (( show_hidden )) && lsd_args+=(-A)
            LAST_SOURCE_EXECUTED="lsd"
            LAST_SOURCE_ARGS="lsd ${lsd_args[*]}"
            if output="$(lsd "${lsd_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="lsd"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            if (( HAS_EZA )); then
              LAST_SOURCE_FALLBACK_TO=eza
            elif (( HAS_DUST )); then
              LAST_SOURCE_FALLBACK_TO=dust
            else
              LAST_SOURCE_FALLBACK_TO=ls
            fi
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          dust)
            if (( !HAS_DUST )); then
