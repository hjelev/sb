    KEY_SELECT_TOGGLE_LABEL="${LSY_KEY_SELECT_TOGGLE_LABEL:-Space/Ins}"
    KEY_SELECT_ALL="${LSY_KEY_SELECT_ALL:-*}"
    KEY_COPY="${LSY_KEY_COPY:-c}"
    KEY_MOVE="${LSY_KEY_MOVE:-m}"
    KEY_DELETE="${LSY_KEY_DELETE:-d}"
    KEY_PASTE="${LSY_KEY_PASTE:-v}"
    KEY_INTEGRATIONS="${LSY_KEY_INTEGRATIONS:-i}"
    KEY_HELP="${LSY_KEY_HELP:-h}"
    KEY_OPEN_LESS="${LSY_KEY_OPEN_LESS:-l}"
    KEY_OPEN_GUI="${LSY_KEY_OPEN_GUI:-o}"
    KEY_OPEN_EDITOR="${LSY_KEY_OPEN_EDITOR:-e}"
    KEY_FIND_FILE="${LSY_KEY_FIND_FILE:-f}"
    KEY_SEARCH="${LSY_KEY_SEARCH:-g}"
    KEY_COMPARE="${LSY_KEY_COMPARE:-C}"
    KEY_EXTRACT_ZIP="${LSY_KEY_EXTRACT_ZIP:-z}"
