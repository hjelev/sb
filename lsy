    lsd_blocks_with_required_date() {
      local blocks="$1"
      local out=()
      local part
      local has_date=0
      local has_name=0

      IFS=',' read -r -a out <<< "$blocks"
      for part in "${out[@]}"; do
        [[ "$part" == "date" ]] && has_date=1
        [[ "$part" == "name" ]] && has_name=1
      done

      (( has_date )) || out+=(date)
      (( has_name )) || out+=(name)

      local joined=""
      for part in "${out[@]}"; do
        [[ -n "$joined" ]] && joined+=","
        joined+="$part"
      done
      printf '%s' "$joined"
    }

    reorder_logo_ls_dirs_first() {
