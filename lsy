#!/usr/bin/env bash
    set -uo pipefail

    if (( BASH_VERSINFO[0] < 4 )); then
      echo "lsy requires bash 4+" >&2
      exit 1
    fi

    KEY_QUIT="${LSY_KEY_QUIT:-q}"
    KEY_RELOAD="${LSY_KEY_RELOAD:-r}"
    KEY_UP="${LSY_KEY_UP:-$'\e[A'}"
    KEY_DOWN="${LSY_KEY_DOWN:-$'\e[B'}"
    KEY_RIGHT="${LSY_KEY_RIGHT:-$'\e[C'}"
    KEY_LEFT="${LSY_KEY_LEFT:-$'\e[D'}"
    KEY_PGUP="${LSY_KEY_PGUP:-$'\e[5~'}"
    KEY_PGDN="${LSY_KEY_PGDN:-$'\e[6~'}"
    KEY_HOME="${LSY_KEY_HOME:-$'\e[H'}"
    KEY_END="${LSY_KEY_END:-$'\e[F'}"
    KEY_TOGGLE_HIDDEN="${LSY_KEY_TOGGLE_HIDDEN:-.}"
    KEY_TOGGLE_SOURCE="${LSY_KEY_TOGGLE_SOURCE:-R}"
    KEY_INTEGRATIONS="${LSY_KEY_INTEGRATIONS:-i}"
    LSY_DEBUG_SOURCE="${LSY_DEBUG_SOURCE:-1}"
    LSY_DEBUG_SHOW_CMD="${LSY_DEBUG_SHOW_CMD:-0}"
    LIST_SOURCE="${LSY_LIST_SOURCE:-}"   # empty = auto-select best available in detect_sources()
    FILE_VIEWER="${LSY_FILE_VIEWER:-}"   # empty = auto-select best available in detect_sources()
    NAME_FIRST_VIEW="${LSY_NAME_FIRST_VIEW:-1}"
    LSY_EZA_ICONS="${LSY_EZA_ICONS:-always}"
    LSY_EZA_COLOR="${LSY_EZA_COLOR:-always}"
    LSY_EZA_COLOR_SCALE="${LSY_EZA_COLOR_SCALE:-}"
    LSY_EZA_COLOR_SCALE_MODE="${LSY_EZA_COLOR_SCALE_MODE:-}"
    LSY_EZA_HYPERLINK="${LSY_EZA_HYPERLINK:-0}"
    LSY_EZA_EXTRA_ARGS="${LSY_EZA_EXTRA_ARGS:-}"
    LSY_EZA_SHOW_LINKS="${LSY_EZA_SHOW_LINKS:-0}"
    LSY_EZA_SHOW_GROUP="${LSY_EZA_SHOW_GROUP:-0}"
    LSY_EZA_NO_QUOTES="${LSY_EZA_NO_QUOTES:-1}"
    LSY_LSD_ICONS="${LSY_LSD_ICONS:-always}"
    LSY_LSD_COLOR="${LSY_LSD_COLOR:-always}"
    LSY_LSD_ICON_THEME="${LSY_LSD_ICON_THEME:-}"  # empty = auto-select in detect_sources()
    LSY_LSD_HYPERLINK="${LSY_LSD_HYPERLINK:-never}"
    LSY_LSD_BLOCKS="${LSY_LSD_BLOCKS:-permission,user,group,size,date,name}"
    LSY_LSD_EXTRA_ARGS="${LSY_LSD_EXTRA_ARGS:-}"

    declare -a ROWS_COLOR=()
    declare -a ROWS_PLAIN=()
    declare -a ROWS_SELECT_PLAIN=()
    declare -A DISABLED_INTEGRATIONS=()
    EXPORT_FILE=""

    cursor=0
    top=0
    rows=0
    cols=0
    visible_rows=0
    show_hidden=0
    HAS_EZA=0
    HAS_LSD=0
    HAS_BAT=0
    HAS_BATCAT=0
    orig_stty=""
    LAST_LOAD_MS=0
    LAST_LS_MS=0
    LAST_PARSE_MS=0
    ENTRY_COUNT=0
    LAST_SOURCE_REQUESTED="-"
    LAST_SOURCE_EXECUTED="-"
    LAST_SOURCE_RC=0
    LAST_SOURCE_FALLBACK=0
    LAST_SOURCE_FALLBACK_TO="-"
    LAST_SOURCE_ARGS="-"

    usage() {
      cat <<'EOF'
Usage: lsy [--export-path FILE] [--help]

Options:
  --export-path FILE  Write final working directory to FILE on exit.
  --help              Show this help text and exit.
EOF
    }

    parse_args() {
      while (($# > 0)); do
        case "$1" in
          --export-path)
            if [[ -z "${2-}" ]]; then
              echo "Error: --export-path requires a file path." >&2
              exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
          --help)
            usage
            exit 0
            ;;
          *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
        esac
      done
    }

    cleanup() {
      if [[ -n "$EXPORT_FILE" ]]; then
        pwd > "$EXPORT_FILE"
      fi
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      printf "\033[0m\033[2J\033[H"
    }

    run_interactive_command() {
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      stty -echo -icanon time 0 min 0
      printf "\033[?25l"
      on_resize
      return 0
    }

    on_resize() {
      rows=$(tput lines)
      cols=$(tput cols)
      visible_rows=$(( rows - 3 ))
      (( visible_rows < 1 )) && visible_rows=1
      draw_ui
    }

    detect_sources() {
      # Detect list source tools (prefer eza > lsd > ls); respect user-disabled integrations.
      if command -v eza >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[eza]+x}" ]]; then
        HAS_EZA=1
      else
        HAS_EZA=0
      fi

      if command -v lsd >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[lsd]+x}" ]]; then
        HAS_LSD=1
      else
        HAS_LSD=0
      fi

      if [[ -z "$LIST_SOURCE" ]]; then
        if (( HAS_EZA )); then
          LIST_SOURCE=eza
        elif (( HAS_LSD )); then
          LIST_SOURCE=lsd
        else
          LIST_SOURCE=ls
        fi
      else
        case "$LIST_SOURCE" in
          ls|lsd|eza) ;;
          *) LIST_SOURCE=ls ;;
        esac
        if [[ "$LIST_SOURCE" == "eza" ]] && (( !HAS_EZA )); then
          (( HAS_LSD )) && LIST_SOURCE=lsd || LIST_SOURCE=ls
        fi
        [[ "$LIST_SOURCE" == "lsd" ]] && (( !HAS_LSD )) && LIST_SOURCE=ls
      fi

      # Detect file viewer tools (prefer bat > batcat > less); respect user-disabled integrations.
      if command -v bat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]]; then
        HAS_BAT=1
      else
        HAS_BAT=0
      fi

      if command -v batcat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]] && [[ -z "${DISABLED_INTEGRATIONS[batcat]+x}" ]]; then
        HAS_BATCAT=1
      else
        HAS_BATCAT=0
      fi

      if [[ -z "$FILE_VIEWER" ]]; then
        if (( HAS_BAT )); then
          FILE_VIEWER=bat
        elif (( HAS_BATCAT )); then
          FILE_VIEWER=batcat
        else
          FILE_VIEWER=less
        fi
      fi

      if [[ -z "$LSY_LSD_ICON_THEME" ]]; then
        [[ "${NERD_FONT_ACTIVE:-0}" == "1" ]] && LSY_LSD_ICON_THEME=fancy || LSY_LSD_ICON_THEME=unicode
      fi
    }

    capture_directory_rows() {
      local requested_source="${1:-$LIST_SOURCE}"
      LAST_SOURCE_REQUESTED="$requested_source"
      LAST_SOURCE_FALLBACK=0
      LAST_SOURCE_FALLBACK_TO="-"

      case "$LIST_SOURCE" in
        ls)
          local -a ls_args=()
          ls_args=(-lh --group-directories-first --time-style=long-iso --quoting-style=literal)
          (( show_hidden )) && ls_args+=(-A)
          LAST_SOURCE_EXECUTED="ls"
          LAST_SOURCE_ARGS="ls ${ls_args[*]} --color=always"
          LC_ALL=C ls "${ls_args[@]}" --color=always 2>/dev/null | sed '1{/^total /d;}'
          LAST_SOURCE_RC=$?
          return "$LAST_SOURCE_RC"
          ;;
        eza)
          if (( !HAS_EZA )); then
            LAST_SOURCE_EXECUTED="eza"
            LAST_SOURCE_RC=127
            LAST_SOURCE_FALLBACK=1
            (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
            LIST_SOURCE="$LAST_SOURCE_FALLBACK_TO"
            capture_directory_rows "$requested_source"
            return
          fi

          local -a eza_args=() eza_extra_args=()
          eza_args=(-l --group-directories-first --time-style=long-iso --icons="$LSY_EZA_ICONS" --color="$LSY_EZA_COLOR")
          case "$LSY_EZA_HYPERLINK" in
            1|on|true|yes|always|auto)
              eza_args+=(--hyperlink)
              ;;
          esac
          [[ -n "$LSY_EZA_COLOR_SCALE" ]] && eza_args+=(--color-scale="$LSY_EZA_COLOR_SCALE")
          [[ -n "$LSY_EZA_COLOR_SCALE_MODE" ]] && eza_args+=(--color-scale-mode="$LSY_EZA_COLOR_SCALE_MODE")
          [[ "$LSY_EZA_SHOW_LINKS" == "1" ]] && eza_args+=(--links)
          [[ "$LSY_EZA_SHOW_GROUP" == "1" ]] && eza_args+=(--group)
          [[ "$LSY_EZA_NO_QUOTES" == "1" ]] && eza_args+=(--no-quotes)
          if [[ -n "$LSY_EZA_EXTRA_ARGS" ]]; then
            read -r -a eza_extra_args <<< "$LSY_EZA_EXTRA_ARGS"
            eza_args+=("${eza_extra_args[@]}")
          fi
          (( show_hidden )) && eza_args+=(--almost-all)
          LAST_SOURCE_EXECUTED="eza"
          LAST_SOURCE_ARGS="eza ${eza_args[*]}"
          eza "${eza_args[@]}" 2>/dev/null
          LAST_SOURCE_RC=$?
          if (( LAST_SOURCE_RC != 0 )); then
            LAST_SOURCE_FALLBACK=1
            (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
            LIST_SOURCE="$LAST_SOURCE_FALLBACK_TO"
            capture_directory_rows "$requested_source"
            return
          fi
          return 0
          ;;
        lsd)
          if (( !HAS_LSD )); then
            LAST_SOURCE_EXECUTED="lsd"
            LAST_SOURCE_RC=127
            LAST_SOURCE_FALLBACK=1
            (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
            LIST_SOURCE="$LAST_SOURCE_FALLBACK_TO"
            capture_directory_rows "$requested_source"
            return
          fi

          local -a lsd_args=() lsd_extra_args=()
            lsd_args=(-lh --group-dirs first --date '+%F %R' --blocks "$LSY_LSD_BLOCKS" --icon "$LSY_LSD_ICONS" --icon-theme "$LSY_LSD_ICON_THEME" --color "$LSY_LSD_COLOR" --hyperlink "$LSY_LSD_HYPERLINK")
          if [[ -n "$LSY_LSD_EXTRA_ARGS" ]]; then
            read -r -a lsd_extra_args <<< "$LSY_LSD_EXTRA_ARGS"
            lsd_args+=("${lsd_extra_args[@]}")
          fi
          (( show_hidden )) && lsd_args+=(-A)
          LAST_SOURCE_EXECUTED="lsd"
          LAST_SOURCE_ARGS="lsd ${lsd_args[*]}"
          lsd "${lsd_args[@]}" 2>/dev/null
          LAST_SOURCE_RC=$?
          if (( LAST_SOURCE_RC != 0 )); then
            LAST_SOURCE_FALLBACK=1
            (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
            LIST_SOURCE="$LAST_SOURCE_FALLBACK_TO"
            capture_directory_rows "$requested_source"
            return
          fi
          return 0
          ;;
        *)
          LAST_SOURCE_EXECUTED="$LIST_SOURCE"
          LAST_SOURCE_RC=1
          return 1
          ;;
      esac
    }

    open_file_with_viewer() {
      local item="$1"

      case "$FILE_VIEWER" in
        less)
          command -v less >/dev/null 2>&1 || return 1
          run_interactive_command less -- "$item"
          ;;
        bat)
          (( HAS_BAT )) || return 1
          run_interactive_command bat --paging=always -- "$item"
          ;;
        batcat)
          (( HAS_BATCAT )) || return 1
          run_interactive_command batcat --paging=always -- "$item"
          ;;
        *)
          return 1
          ;;
      esac
      return 0
    }
    # Reorder long-list rows to `name metadata...` using awk+column alignment.
    # Minimal modification: split on date-time anchor, reorder, let column handle alignment.
    format_name_first_aligned() {
      awk '
        BEGIN {
          esc = sprintf("%c", 27) "\\[[0-9;]*m"
          dt = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*[[:space:]]+(" esc ")*[0-9][0-9]:[0-9][0-9](" esc ")*[[:space:]]+"
        }
        {
          if (match($0, dt)) {
            name = substr($0, RSTART + RLENGTH)
            meta = substr($0, 1, RSTART - 1)
            printf "%s\t%s\n", name, meta
          } else {
            print
          }
        }
      ' | column -t -s $'\t'
    }

    load_data() {
      local t0 t1 t2

      ROWS_COLOR=()
      ROWS_PLAIN=()

      t0=$(date +%s%N)
      mapfile -t ROWS_COLOR < <(capture_directory_rows)
      t1=$(date +%s%N)
      LAST_LS_MS=$(( (t1 - t0) / 1000000 ))
      LAST_PARSE_MS=0
      LAST_LOAD_MS=$LAST_LS_MS
      ENTRY_COUNT=${#ROWS_COLOR[@]}

      if (( ${#ROWS_COLOR[@]} == 0 )); then
        ROWS_COLOR=("\033[2m(empty directory)\033[0m")
        ROWS_PLAIN=("(empty directory)")
        ROWS_SELECT_PLAIN=("(empty directory)")
        cursor=0
        top=0
        return
      fi

      # ROWS_PLAIN is needed by selected_path() so the date-anchor regex
      # works on clean text, and by draw_row() to render the reverse-video
      # selection highlight without embedded ANSI codes corrupting the output.
      mapfile -t ROWS_PLAIN < <(printf '%s\n' "${ROWS_COLOR[@]}" | sed -E $'s/\x1B\[[0-9;]*m//g')
      ROWS_SELECT_PLAIN=("${ROWS_PLAIN[@]}")

      if (( NAME_FIRST_VIEW )); then
        mapfile -t ROWS_PLAIN < <(printf '%s\n' "${ROWS_PLAIN[@]}" | format_name_first_aligned)
        mapfile -t ROWS_COLOR < <(printf '%s\n' "${ROWS_COLOR[@]}" | format_name_first_aligned)
      fi
      t2=$(date +%s%N)
      LAST_PARSE_MS=$(( (t2 - t1) / 1000000 ))
      LAST_LOAD_MS=$(( (t2 - t0) / 1000000 ))

      (( cursor >= ${#ROWS_COLOR[@]} )) && cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
      (( top < 0 )) && top=0
    }

    draw_header() {
      local user host cwd
      local separator_width
      local separator
      user="${USER:-$(id -un 2>/dev/null || printf 'user')}"
      host="${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'host')}"
      cwd="$(pwd -P 2>/dev/null || pwd)"
      separator_width=$cols
      (( separator_width < 1 )) && separator_width=1

      printf "\033[1;36m"
      printf "%s\n" "${user}@${host} » ${cwd}"
      printf "\033[0m"
      printf -v separator '%*s' "$separator_width" ''
      separator=${separator// /─}
      printf '%s\033[K\n' "$separator"
    }

    draw_row() {
      local i="$1"
      local selected="$2"
      local row

      if (( i < 0 || i >= ${#ROWS_COLOR[@]} )); then
        printf "\033[K\n"
        return
      fi

      row="${ROWS_COLOR[$i]}"

      if (( selected )); then
        printf "\033[7m%s\033[0m\033[K\n" "${ROWS_PLAIN[$i]-$row}"
        return
      fi

      printf "%s\033[K\n" "$row"
    }

    draw_status() {
      local total="$ENTRY_COUNT"
      local status_row=$rows
      local hidden_state="off"
      local source_state="$LIST_SOURCE"
      local layout_state="meta-first"
      local debug_state=""
      (( show_hidden )) && hidden_state="on"
      (( NAME_FIRST_VIEW )) && layout_state="name-first"

      if [[ "$LSY_DEBUG_SOURCE" == "1" ]]; then
        debug_state=" dbg:req:${LAST_SOURCE_REQUESTED} run:${LAST_SOURCE_EXECUTED} rc:${LAST_SOURCE_RC}"
        if (( LAST_SOURCE_FALLBACK )); then
          debug_state+=" fb:${LAST_SOURCE_FALLBACK_TO}"
        fi
        if [[ "$LSY_DEBUG_SHOW_CMD" == "1" ]]; then
          debug_state+=" cmd:${LAST_SOURCE_ARGS}"
        fi
      fi

      # Keep footer anchored regardless of current cursor location.
      printf "\033[%d;1H\033[K" "$status_row"
      printf "\033[2m[total: %d] renderer:%s layout:%s hidden:%s load:%dms (ls:%d parse:%d)%s | Up/Down PgUp/PgDn Home/End | %s source | %s hidden | %s reload | %s integrations | %s quit\033[0m\033[K" "$total" "$source_state" "$layout_state" "$hidden_state" "$LAST_LOAD_MS" "$LAST_LS_MS" "$LAST_PARSE_MS" "$debug_state" "$KEY_TOGGLE_SOURCE" "$KEY_TOGGLE_HIDDEN" "$KEY_RELOAD" "$KEY_INTEGRATIONS" "$KEY_QUIT"
    }

    scroll_list_once() {
      local direction="$1"
      local top_row=3
      local bottom_row=$((2 + visible_rows))

      printf "\033[%d;%dr" "$top_row" "$bottom_row"
      if [[ "$direction" == "down" ]]; then
        printf "\033[%d;1H\033[M" "$top_row"
      else
        printf "\033[%d;1H\033[L" "$top_row"
      fi
      printf "\033[r"
    }

    redraw_row_at_index() {
      local i="$1"
      local screen_line

      (( i >= top && i < top + visible_rows )) || return
      screen_line=$((3 + i - top))
      printf "\033[%d;1H" "$screen_line"
      if (( i == cursor )); then
        draw_row "$i" 1
      else
        draw_row "$i" 0
      fi
    }

    draw_ui() {
      printf "\033[H\033[2J"
      draw_header

      local line idx
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        if (( idx == cursor )); then
          draw_row "$idx" 1
        else
          draw_row "$idx" 0
        fi
      done

      draw_status
    }

    read_key() {
      local k
      IFS= read -rsn1 k || return 1
      if [[ "$k" == $'\e' ]]; then
        local k2 k3
        IFS= read -rsn1 -t 0.005 k2 || true
        IFS= read -rsn1 -t 0.005 k3 || true
        printf '%s' "$k$k2$k3"
      else
        printf '%s' "$k"
      fi
      return 0
    }

    move_up() {
      (( cursor > 0 )) || return
      ((cursor--))
      (( cursor < top )) && top=$cursor
    }

    move_down() {
      (( cursor + 1 < ${#ROWS_COLOR[@]} )) || return
      ((cursor++))
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    # Strip symlink target from a name string if the row represents a symlink (l*).
    strip_symlink_target() {
      local plain="$1" name="$2"
      if [[ "$plain" == l* ]]; then
        name="${name%% -> *}"
        name="${name%% ⇒ *}"
      fi
      printf '%s' "$name"
    }

    selected_path() {
      local plain name
      if (( cursor < 0 || cursor >= ${#ROWS_COLOR[@]} )); then
        return 1
      fi

      plain="${ROWS_SELECT_PLAIN[$cursor]}"
      case "$LIST_SOURCE" in
        ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi

          # Symlink rows are rendered as "name -> target"; keep only the link name.
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        lsd|eza)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi

          # lsd can prefix names with icons; drop one leading icon token for path use.
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi

          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        *)
          return 1
          ;;
      esac

      printf "%s" "$name"
      return 0
    }

    show_integrations() {
      # Each entry: role|tool|description|optional(1=toggleable, 0=required fallback)
      local -a int_entries=(
        "list source|ls|Built-in GNU/BSD ls: directory listing|0"
        "list source|eza|A modern ls replacement with rich metadata and icons|1"
        "list source|lsd|LSDeluxe: modern ls replacement with icons and colors|1"
        "view|name-first|Show file/folder name before metadata|1"
        "file viewer|less|Terminal pager for plain file viewing|0"
      )

      # batcat is a packaging alias for bat; show only one integration row.
      if command -v bat >/dev/null 2>&1; then
        int_entries+=("file viewer|bat|A cat clone with syntax highlighting and Git integration|1")
      elif command -v batcat >/dev/null 2>&1; then
        int_entries+=("file viewer|batcat|A cat clone with syntax highlighting and Git integration|1")
      else
        int_entries+=("file viewer|bat|A cat clone with syntax highlighting and Git integration|1")
      fi
      local int_count=${#int_entries[@]}
      local int_cursor=0

      # Pre-collect install state and versions once; the draw loop stays constant-time.
      local -a int_installed=() int_version=()
      local _entry _role _tool _desc _optional
      for _entry in "${int_entries[@]}"; do
        IFS='|' read -r _role _tool _desc _optional <<< "$_entry"
        if [[ "$_tool" == "name-first" ]]; then
          int_installed+=(1)
          int_version+=("built-in toggle")
        elif command -v "$_tool" >/dev/null 2>&1; then
          int_installed+=(1)
          int_version+=("$("$_tool" --version 2>&1 | head -1)")
        else
          int_installed+=(0)
          int_version+=("not installed")
        fi
      done

      _int_draw_header() {
        printf "\033[H\033[2J"
        printf "\033[1;36mIntegrations\033[0m  \033[2m↑↓ navigate | Space toggle | q return\033[0m\n"
        printf -v _sep '%*s' "$cols" ''
        printf '%s\n' "${_sep// /─}"
      }

      _int_draw_rows() {
        local i line role tool desc optional present state_tag
        local -A active_tools=(["$LIST_SOURCE"]=1 ["$FILE_VIEWER"]=1)

        for (( i=0; i<int_count; i++ )); do
          line=$((3 + i))
          IFS='|' read -r role tool desc optional <<< "${int_entries[$i]}"
          (( int_installed[i] )) && present="\033[1;32m✔\033[0m" || present="\033[2m✘\033[0m"

          if [[ "$tool" == "name-first" ]]; then
            if (( NAME_FIRST_VIEW )); then
              state_tag="\033[1;32m[on]\033[0m"
            else
              state_tag="\033[31m[off]\033[0m"
            fi
          elif (( !optional )); then
            state_tag="\033[2m[required]\033[0m"
          elif (( !int_installed[i] )); then
            state_tag="\033[2m[not installed]\033[0m"
          elif [[ -n "${DISABLED_INTEGRATIONS[$tool]+x}" ]]; then
            state_tag="\033[31m[off]\033[0m"
          elif [[ -n "${active_tools[$tool]+x}" ]]; then
            state_tag="\033[1;33m[active]\033[0m"
          else
            state_tag="\033[1;32m[on]\033[0m"
          fi

          printf "\033[%d;1H\033[K" "$line"
          if (( i == int_cursor )); then
            printf "\033[1m> %-44s  %b  %-16s  %-38s  %b\033[0m" \
              "${int_version[$i]}" "$present" "$role" "$desc" "$state_tag"
          else
            printf "  \033[2m%-44s\033[0m  %b  \033[2m%-16s\033[0m  %-38s  %b" \
              "${int_version[$i]}" "$present" "$role" "$desc" "$state_tag"
          fi
        done

        printf "\033[%d;1H\033[K\033[2mSpace toggles optional integrations; required ones cannot be disabled\033[0m" "$((int_count + 4))"
      }

      _int_draw_header
      _int_draw_rows
      while true; do
        local key
        key="$(read_key || true)"
        [[ -z "$key" ]] && continue

        case "$key" in
          "$KEY_UP")
            (( int_cursor > 0 )) && (( int_cursor-- ))
            _int_draw_rows
            ;;
          "$KEY_DOWN")
            (( int_cursor < int_count - 1 )) && (( int_cursor++ ))
            _int_draw_rows
            ;;
          ' '|$'\r')
            IFS='|' read -r _role _tool _desc _optional <<< "${int_entries[$int_cursor]}"
            if [[ "$_tool" == "name-first" ]]; then
              if (( NAME_FIRST_VIEW )); then
                NAME_FIRST_VIEW=0
              else
                NAME_FIRST_VIEW=1
              fi
              load_data
              _int_draw_rows
            elif (( _optional && int_installed[int_cursor] )); then
              if [[ -n "${DISABLED_INTEGRATIONS[$_tool]+x}" ]]; then
                unset 'DISABLED_INTEGRATIONS[$_tool]'
              else
                DISABLED_INTEGRATIONS[$_tool]=1
              fi
              LIST_SOURCE=""
              FILE_VIEWER=""
              detect_sources
              load_data
              _int_draw_rows
            fi
            ;;
          q|$'\e'|"$KEY_QUIT")
            break
            ;;
        esac
      done

      draw_ui
    }

    go_parent_dir() {
      [[ "$(pwd -P 2>/dev/null || pwd)" == "/" ]] && return 0
      cd .. 2>/dev/null || return 1
      cursor=0
      top=0
      load_data
      draw_ui
      return 0
    }

    enter_or_open_selected() {
      local item
      item="$(selected_path)" || return 1

      if [[ -d "$item" ]]; then
        cd -- "$item" || return 1
        cursor=0
        top=0
        load_data
        draw_ui
        return 0
      fi

      [[ -f "$item" ]] || return 1
      open_file_with_viewer "$item" || return 1
      draw_ui
      return 0
    }

    page_up() {
      (( cursor == 0 )) && return
      cursor=$(( cursor - visible_rows ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
    }

    page_down() {
      local max=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( max < 0 )) && return
      (( cursor == max )) && return
      cursor=$(( cursor + visible_rows ))
      (( cursor > max )) && cursor=$max
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    cycle_list_source() {
      local -a sources=(ls)
      local i current_index=-1

      (( HAS_LSD )) && sources+=(lsd)
      (( HAS_EZA )) && sources+=(eza)

      for i in "${!sources[@]}"; do
        if [[ "${sources[$i]}" == "$LIST_SOURCE" ]]; then
          current_index=$i
          break
        fi
      done

      if (( current_index < 0 )); then
        LIST_SOURCE="${sources[0]}"
        return
      fi

      current_index=$(( (current_index + 1) % ${#sources[@]} ))
      LIST_SOURCE="${sources[$current_index]}"
    }

    main() {
      parse_args "$@"
      detect_sources

      orig_stty=$(stty -g)
      trap cleanup EXIT
      trap on_resize SIGWINCH

      stty -echo -icanon time 0 min 0
      printf "\033[?25l"

      on_resize
      load_data
      draw_ui

      while true; do
        local key
        local old_cursor old_top
        key="$(read_key || true)"
        [[ -z "$key" ]] && continue

        case "$key" in
          "$KEY_QUIT")
            break
            ;;
          "$KEY_RELOAD")
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_HIDDEN")
            if (( show_hidden )); then
              show_hidden=0
            else
              show_hidden=1
            fi
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_SOURCE")
            cycle_list_source
            load_data
            draw_ui
            ;;
          "$KEY_UP")
            old_cursor=$cursor
            old_top=$top
            move_up
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top - 1 && cursor == old_cursor - 1 )); then
                scroll_list_once up
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_DOWN")
            old_cursor=$cursor
            old_top=$top
            move_down
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top + 1 && cursor == old_cursor + 1 )); then
                scroll_list_once down
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_PGUP")
            page_up
            draw_ui
            ;;
          "$KEY_PGDN")
            page_down
            draw_ui
            ;;
          "$KEY_LEFT")
            go_parent_dir || true
            ;;
          "$KEY_RIGHT")
            enter_or_open_selected || true
            ;;
          "$KEY_HOME"|$'\e[1~')
            cursor=0
            top=0
            draw_ui
            ;;
          "$KEY_INTEGRATIONS")
            show_integrations
            ;;
          "$KEY_END"|$'\e[4~')
            if (( ${#ROWS_COLOR[@]} > 0 )); then
              cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
              top=$(( cursor - visible_rows + 1 ))
              (( top < 0 )) && top=0
            fi
            draw_ui
            ;;
        esac
      done
    }

    main "$@"
