    LAST_PASTE_RC=1
  fi

  if (( ok_count > 0 )); then
    load_data
    if (( cursor >= ${#ROWS_COLOR[@]} )); then
      cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
    fi
