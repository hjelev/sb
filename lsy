        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive failed: selected sources do not exist.\033[0m" "$rows"
        return 1
      }

      if (( ${#zip_items[@]} == 1 )); then
        base="$(path_basename "${zip_items[0]}")"
        default_name="${base}.zip"
      else
        base="$(path_basename "$(pwd -P)")"
        [[ -n "$base" ]] || base="archive"
        default_name="${base}.zip"
      fi

      out_path="$(read_line_prompt "Archive as: " "$(pwd -P)/$default_name")"
      out_path="$(sanitize_filename_input "$out_path")"
      if [[ -z "$out_path" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
        return 1
      fi

      out_path="${out_path/#\~/$HOME}"
      if [[ "$out_path" != /* ]]; then
        out_path="$(pwd -P)/$out_path"
      fi

      out_dir="$(path_dirname "$out_path")"
      run_mkdir_p "$out_dir" 2>/dev/null || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive failed: cannot create destination directory '%s'.\033[0m" "$rows" "$out_dir"
        return 1
      }

      if [[ -e "$out_path" ]]; then
        if ! read_yes_no_prompt "Archive exists. Overwrite '$out_path'? [y/N]: "; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
          return 1
        fi
        rm -f "$(safe_command_path "$out_path")" 2>/dev/null || {
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive failed: cannot overwrite '%s'.\033[0m" "$rows" "$out_path"
          return 1
        }
      fi

      if [[ -n "$LSY_ZIP_ARGS" ]]; then
        read -r -a zip_args <<< "$LSY_ZIP_ARGS"
      fi

      local i zip_item
      for i in "${!zip_items[@]}"; do
        zip_item="${zip_items[$i]}"
        [[ "$zip_item" == -* ]] && zip_item="./$zip_item"
        zip_items[$i]="$zip_item"
      done

      LAST_PASTE_OP="zip"
      LAST_PASTE_ERR="-"
      if err="$(zip -r "${zip_args[@]}" "$out_path" "${zip_items[@]}" 2>&1)"; then
        ok_count=1
        LAST_PASTE_RC=0
        LAST_PASTE_OK=1
        LAST_PASTE_FAIL=0
        LAST_PASTE_SKIP=0
      else
        fail_count=1
        LAST_PASTE_RC=1
        LAST_PASTE_OK=0
        LAST_PASTE_FAIL=1
        LAST_PASTE_SKIP=0
        LAST_PASTE_ERR="$err"
      fi

      load_data
      draw_ui
      if (( ok_count )); then
        printf "\033[%d;1H\033[K\033[2mArchive created: %s\033[0m" "$rows" "$(path_basename "$out_path")"
        return 0
      fi

      printf "\033[%d;1H\033[K\033[2mArchive failed.\033[0m" "$rows"
      return 1
    }

    handle_zip_action() {
      local -a items=()
      local item zip_count=0 other_count=0

      read_stdin_into_array items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mZip action failed: no valid source paths in current selection.\033[0m" "$rows"
        return 1
      }

      for item in "${items[@]}"; do
        [[ -e "$item" || -L "$item" ]] || continue
        if [[ -f "$item" ]] && is_archive_file "$item"; then
          ((zip_count++))
        else
          ((other_count++))
        fi
      done

      if (( zip_count > 0 && other_count == 0 )); then
        extract_selected_zip_archives
        return $?
      fi

      if (( other_count == 0 )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mZip action failed: no existing files selected.\033[0m" "$rows"
        return 1
      fi

      if (( ${#items[@]} > 1 )); then
        if ! read_yes_no_prompt "Create one archive from selected items? [y/N]: "; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
