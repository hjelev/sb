#!/usr/bin/env bash
    set -uo pipefail

    if (( BASH_VERSINFO[0] < 4 )); then
      echo "lsy requires bash 4+" >&2
      exit 1
    fi

    KEY_QUIT="${LSY_KEY_QUIT:-q}"
    KEY_RELOAD="${LSY_KEY_RELOAD:-r}"
    KEY_UP="${LSY_KEY_UP:-$'\e[A'}"
    KEY_DOWN="${LSY_KEY_DOWN:-$'\e[B'}"
    KEY_RIGHT="${LSY_KEY_RIGHT:-$'\e[C'}"
    KEY_LEFT="${LSY_KEY_LEFT:-$'\e[D'}"
    KEY_PGUP="${LSY_KEY_PGUP:-$'\e[5~'}"
    KEY_PGDN="${LSY_KEY_PGDN:-$'\e[6~'}"
    KEY_HOME="${LSY_KEY_HOME:-$'\e[H'}"
    KEY_END="${LSY_KEY_END:-$'\e[F'}"
    KEY_TOGGLE_HIDDEN="${LSY_KEY_TOGGLE_HIDDEN:-.}"
    KEY_TOGGLE_SOURCE="${LSY_KEY_TOGGLE_SOURCE:-$'\e[24~'}"
    KEY_TOGGLE_SOURCE_LABEL="${LSY_KEY_TOGGLE_SOURCE_LABEL:-F12}"
    KEY_TOGGLE_NAME_FIRST="${LSY_KEY_TOGGLE_NAME_FIRST:-$'\e[20~'}"
    KEY_TOGGLE_NAME_FIRST_LABEL="${LSY_KEY_TOGGLE_NAME_FIRST_LABEL:-F9}"
    KEY_SELECT_TOGGLE="${LSY_KEY_SELECT_TOGGLE:- }"
    KEY_SELECT_TOGGLE_LABEL="${LSY_KEY_SELECT_TOGGLE_LABEL:-Space/Ins}"
    KEY_SELECT_ALL="${LSY_KEY_SELECT_ALL:-*}"
    KEY_COPY="${LSY_KEY_COPY:-c}"
    KEY_MOVE="${LSY_KEY_MOVE:-m}"
    KEY_DELETE="${LSY_KEY_DELETE:-d}"
    KEY_PASTE="${LSY_KEY_PASTE:-v}"
    KEY_INTEGRATIONS="${LSY_KEY_INTEGRATIONS:-i}"
    KEY_HELP="${LSY_KEY_HELP:-h}"
    KEY_OPEN_LESS="${LSY_KEY_OPEN_LESS:-l}"
    KEY_OPEN_GUI="${LSY_KEY_OPEN_GUI:-o}"
    KEY_OPEN_EDITOR="${LSY_KEY_OPEN_EDITOR:-e}"
    KEY_EXTRACT_ZIP="${LSY_KEY_EXTRACT_ZIP:-z}"
    KEY_HOME_DIR="${LSY_KEY_HOME_DIR:-~}"
    LSY_DEBUG_SOURCE="${LSY_DEBUG_SOURCE:-1}"
    LSY_DEBUG_SHOW_CMD="${LSY_DEBUG_SHOW_CMD:-0}"
    LSY_DEBUG_PASTE="${LSY_DEBUG_PASTE:-1}"
    LSY_GIT_DIRTY_CHECK="${LSY_GIT_DIRTY_CHECK:-1}"
    LSY_CHAFA_HOLD="${LSY_CHAFA_HOLD:-1}"
    LSY_CHAFA_ARGS="${LSY_CHAFA_ARGS:---animate=off --symbols vhalf --size 100%x60%}"
    LSY_GLOW_ARGS="${LSY_GLOW_ARGS:-}"
    LSY_CSVLENS_ARGS="${LSY_CSVLENS_ARGS:-}"
    LSY_JNV_ARGS="${LSY_JNV_ARGS:-}"
    LSY_UNZIP_ARGS="${LSY_UNZIP_ARGS:-}"
    LSY_ZIP_ARGS="${LSY_ZIP_ARGS:-}"
    LSY_EDITOR="${LSY_EDITOR:-}"
    LIST_SOURCE="${LSY_LIST_SOURCE:-}"   # empty = auto-select best available in detect_sources()
    FILE_VIEWER="${LSY_FILE_VIEWER:-}"   # empty = auto-select best available in detect_sources()
    NAME_FIRST_VIEW="${LSY_NAME_FIRST_VIEW:-1}"
    LSY_EZA_ICONS="${LSY_EZA_ICONS:-always}"
    LSY_EZA_COLOR="${LSY_EZA_COLOR:-always}"
    LSY_EZA_COLOR_SCALE="${LSY_EZA_COLOR_SCALE:-}"
    LSY_EZA_COLOR_SCALE_MODE="${LSY_EZA_COLOR_SCALE_MODE:-}"
    LSY_EZA_HYPERLINK="${LSY_EZA_HYPERLINK:-0}"
    LSY_EZA_EXTRA_ARGS="${LSY_EZA_EXTRA_ARGS:-}"
    LSY_EZA_SHOW_LINKS="${LSY_EZA_SHOW_LINKS:-0}"
    LSY_EZA_SHOW_GROUP="${LSY_EZA_SHOW_GROUP:-0}"
    LSY_EZA_NO_QUOTES="${LSY_EZA_NO_QUOTES:-1}"
    LSY_LSD_ICONS="${LSY_LSD_ICONS:-always}"
    LSY_LSD_COLOR="${LSY_LSD_COLOR:-always}"
    LSY_LSD_ICON_THEME="${LSY_LSD_ICON_THEME:-}"  # empty = auto-select in detect_sources()
    LSY_LSD_HYPERLINK="${LSY_LSD_HYPERLINK:-never}"
    LSY_LSD_BLOCKS="${LSY_LSD_BLOCKS:-permission,user,group,size,date,name}"
    LSY_LSD_EXTRA_ARGS="${LSY_LSD_EXTRA_ARGS:-}"

    declare -a ROWS_COLOR=()
    declare -a ROWS_PLAIN=()
    declare -a ROWS_SELECT_PLAIN=()
    declare -a ROWS_PATH=()
    declare -a ROWS_SELECTED=()
    declare -A DISABLED_INTEGRATIONS=()
    declare -A SELECTED_PATHS=()
    declare -a CLIPBOARD_ITEMS=()
    declare -a CLIPBOARD_MULTI=()
    EXPORT_FILE=""

    cursor=0
    top=0
    rows=0
    cols=0
    visible_rows=0
    show_hidden=0
    HAS_EZA=0
    HAS_LSD=0
    HAS_BAT=0
    HAS_BATCAT=0
    HAS_CHAFA=0
    HAS_GLOW=0
    HAS_CSVLENS=0
    HAS_JNV=0
    HAS_UNZIP=0
    HAS_ZIPCMD=0
    HAS_ZIP=0
    orig_stty=""
    LAST_LOAD_MS=0
    LAST_LS_MS=0
    LAST_PARSE_MS=0
    ENTRY_COUNT=0
    LAST_SOURCE_REQUESTED="-"
    LAST_SOURCE_EXECUTED="-"
    LAST_SOURCE_RC=0
    LAST_SOURCE_FALLBACK=0
    LAST_SOURCE_FALLBACK_TO="-"
    LAST_SOURCE_ARGS="-"
    SELECTED_COUNT=0
    CLIPBOARD_MODE="copy"
    CLIPBOARD_LABEL="none"
    CLIPBOARD_PATH=""
    CLIPBOARD_NAME=""
    CLIPBOARD_MOVE=0
    LAST_CLIP_MODE="-"
    LAST_CLIP_REQUESTED=0
    LAST_CLIP_RESOLVED=0
    LAST_CLIP_DROPPED=0
    LAST_PASTE_OP="-"
    LAST_PASTE_RC=0
    LAST_PASTE_ERR="-"
    LAST_PASTE_OK=0
    LAST_PASTE_FAIL=0
    LAST_PASTE_SKIP=0
    GIT_HEADER_SUFFIX=""
    GIT_HEADER_CACHE_PWD=""
    GIT_HEADER_CACHE_SUFFIX=""
    GIT_HEADER_CACHE_ENABLED="-1"

    usage() {
      cat <<'EOF'
Usage: lsy [--export-path FILE] [--help]

Options:
  --export-path FILE  Write final working directory to FILE on exit.
  --help              Show this help text and exit.
EOF
    }

    parse_args() {
      while (($# > 0)); do
        case "$1" in
          --export-path)
            if [[ -z "${2-}" ]]; then
              echo "Error: --export-path requires a file path." >&2
              exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
          --help)
            usage
            exit 0
            ;;
          *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
        esac
      done
    }

    cleanup() {
      if [[ -n "$EXPORT_FILE" ]]; then
        pwd > "$EXPORT_FILE"
      fi
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      printf "\033[0m\033[2J\033[H"
    }

    run_interactive_command() {
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return 0
    }

    run_interactive_preview_command() {
      local rc=0
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      rc=$?
      if [[ "$LSY_CHAFA_HOLD" == "1" ]]; then
        printf "\n\033[2mPress any key to return...\033[0m"
        IFS= read -rsn1 || true
      fi
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    read_yes_no_prompt() {
      local prompt="$1"
      local key
      local tty="/dev/tty"

      [[ -w "$tty" ]] || tty="/proc/self/fd/2"

      # Flush any queued key bytes so the confirm prompt doesn't auto-consume stale input.
      while IFS= read -rsn1 -t 0.001 key; do :; done

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"

      key="$(read_key || true)"
      printf "\033[?25l" >"$tty"
      case "$key" in
        y|Y) return 0 ;;
        *) return 1 ;;
      esac
    }

    read_line_prompt() {
      local prompt="$1"
      local initial_value="$2"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty echo <"$tty"
      IFS= read -r -e -i "$initial_value" -p "$prompt" value <"$tty" >"$tty" 2>&1
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    sanitize_filename_input() {
      local value="$1"
      # Remove non-printable control bytes that can be accidentally captured from terminal control output.
      value="$(printf '%s' "$value" | tr -d '\000-\037\177')"
      printf '%s' "$value"
    }

    on_resize() {
      rows=$(tput lines)
      cols=$(tput cols)
      visible_rows=$(( rows - 3 ))
      (( visible_rows < 1 )) && visible_rows=1
      draw_ui
    }

    detect_sources() {
      # Detect list source tools (prefer eza > lsd > ls); respect user-disabled integrations.
      if command -v eza >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[eza]+x}" ]]; then
        HAS_EZA=1
      else
        HAS_EZA=0
      fi

      if command -v lsd >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[lsd]+x}" ]]; then
        HAS_LSD=1
      else
        HAS_LSD=0
      fi

      if [[ -z "$LIST_SOURCE" ]]; then
        if (( HAS_EZA )); then
          LIST_SOURCE=eza
        elif (( HAS_LSD )); then
          LIST_SOURCE=lsd
        else
          LIST_SOURCE=ls
        fi
      else
        case "$LIST_SOURCE" in
          ls|lsd|eza) ;;
          *) LIST_SOURCE=ls ;;
        esac
        if [[ "$LIST_SOURCE" == "eza" ]] && (( !HAS_EZA )); then
          (( HAS_LSD )) && LIST_SOURCE=lsd || LIST_SOURCE=ls
        fi
        [[ "$LIST_SOURCE" == "lsd" ]] && (( !HAS_LSD )) && LIST_SOURCE=ls
      fi

      # Detect file viewer tools (prefer bat > batcat > less); respect user-disabled integrations.
      if command -v bat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]]; then
        HAS_BAT=1
      else
        HAS_BAT=0
      fi

      if command -v batcat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]] && [[ -z "${DISABLED_INTEGRATIONS[batcat]+x}" ]]; then
        HAS_BATCAT=1
      else
        HAS_BATCAT=0
      fi

      if command -v chafa >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[chafa]+x}" ]]; then
        HAS_CHAFA=1
      else
        HAS_CHAFA=0
      fi

      if command -v glow >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[glow]+x}" ]]; then
        HAS_GLOW=1
      else
        HAS_GLOW=0
      fi

      if command -v csvlens >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[csvlens]+x}" ]]; then
        HAS_CSVLENS=1
      else
        HAS_CSVLENS=0
      fi

      if command -v jnv >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[jnv]+x}" ]]; then
        HAS_JNV=1
      else
        HAS_JNV=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[zip]+x}" ]] && command -v unzip >/dev/null 2>&1; then
        HAS_UNZIP=1
      else
        HAS_UNZIP=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[zip]+x}" ]] && command -v zip >/dev/null 2>&1; then
        HAS_ZIPCMD=1
      else
        HAS_ZIPCMD=0
      fi

      if (( HAS_UNZIP || HAS_ZIPCMD )); then
        HAS_ZIP=1
      else
        HAS_ZIP=0
      fi

      if [[ -z "$FILE_VIEWER" ]]; then
        if (( HAS_BAT )); then
          FILE_VIEWER=bat
        elif (( HAS_BATCAT )); then
          FILE_VIEWER=batcat
        else
          FILE_VIEWER=less
        fi
      fi

      if [[ -z "$LSY_LSD_ICON_THEME" ]]; then
        [[ "${NERD_FONT_ACTIVE:-0}" == "1" ]] && LSY_LSD_ICON_THEME=fancy || LSY_LSD_ICON_THEME=unicode
      fi
    }

    lsd_blocks_with_required_date() {
      local blocks="$1"
      local out=()
      local part
      local has_date=0
      local has_name=0

      IFS=',' read -r -a out <<< "$blocks"
      for part in "${out[@]}"; do
        [[ "$part" == "date" ]] && has_date=1
        [[ "$part" == "name" ]] && has_name=1
      done

      (( has_date )) || out+=(date)
      (( has_name )) || out+=(name)

      local joined=""
      for part in "${out[@]}"; do
        [[ -n "$joined" ]] && joined+=","
        joined+="$part"
      done
      printf '%s' "$joined"
    }

    capture_directory_rows() {
      local requested_source="${1:-$LIST_SOURCE}"
      local source="$LIST_SOURCE"
      local output=""

      LAST_SOURCE_REQUESTED="$requested_source"
      LAST_SOURCE_FALLBACK=0
      LAST_SOURCE_FALLBACK_TO="-"

      while true; do
        case "$source" in
          ls)
            local -a ls_args=()
            ls_args=(-lh --group-directories-first --time-style=long-iso --quoting-style=literal)
            (( show_hidden )) && ls_args+=(-A)
            LAST_SOURCE_EXECUTED="ls"
            LAST_SOURCE_ARGS="ls ${ls_args[*]} --color=always"
            if output="$(LC_ALL=C ls "${ls_args[@]}" --color=always 2>/dev/null | sed '1{/^total /d;}')"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="ls"
              break
            fi
            LAST_SOURCE_RC=$?
            ROWS_COLOR=()
            return "$LAST_SOURCE_RC"
            ;;
          eza)
            if (( !HAS_EZA )); then
              LAST_SOURCE_EXECUTED="eza"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a eza_args=() eza_extra_args=()
            eza_args=(--long --modified --group-directories-first --time-style=long-iso --icons="$LSY_EZA_ICONS" --color="$LSY_EZA_COLOR")
            case "$LSY_EZA_HYPERLINK" in
              1|on|true|yes|always|auto)
                eza_args+=(--hyperlink)
                ;;
            esac
            [[ -n "$LSY_EZA_COLOR_SCALE" ]] && eza_args+=(--color-scale="$LSY_EZA_COLOR_SCALE")
            [[ -n "$LSY_EZA_COLOR_SCALE_MODE" ]] && eza_args+=(--color-scale-mode="$LSY_EZA_COLOR_SCALE_MODE")
            [[ "$LSY_EZA_SHOW_LINKS" == "1" ]] && eza_args+=(--links)
            [[ "$LSY_EZA_SHOW_GROUP" == "1" ]] && eza_args+=(--group)
            [[ "$LSY_EZA_NO_QUOTES" == "1" ]] && eza_args+=(--no-quotes)
            if [[ -n "$LSY_EZA_EXTRA_ARGS" ]]; then
              read -r -a eza_extra_args <<< "$LSY_EZA_EXTRA_ARGS"
              eza_args+=("${eza_extra_args[@]}")
            fi
            (( show_hidden )) && eza_args+=(--almost-all)
            LAST_SOURCE_EXECUTED="eza"
            LAST_SOURCE_ARGS="eza ${eza_args[*]}"
            if output="$(eza "${eza_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="eza"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          lsd)
            if (( !HAS_LSD )); then
              LAST_SOURCE_EXECUTED="lsd"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a lsd_args=() lsd_extra_args=()
            local lsd_blocks
            lsd_blocks="$(lsd_blocks_with_required_date "$LSY_LSD_BLOCKS")"
            lsd_args=(-lh --group-dirs first --date '+%F %R' --blocks "$lsd_blocks" --icon "$LSY_LSD_ICONS" --icon-theme "$LSY_LSD_ICON_THEME" --color "$LSY_LSD_COLOR" --hyperlink "$LSY_LSD_HYPERLINK")
            if [[ -n "$LSY_LSD_EXTRA_ARGS" ]]; then
              read -r -a lsd_extra_args <<< "$LSY_LSD_EXTRA_ARGS"
              lsd_args+=("${lsd_extra_args[@]}")
            fi
            (( show_hidden )) && lsd_args+=(-A)
            LAST_SOURCE_EXECUTED="lsd"
            LAST_SOURCE_ARGS="lsd ${lsd_args[*]}"
            if output="$(lsd "${lsd_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="lsd"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          *)
            LAST_SOURCE_EXECUTED="$source"
            LAST_SOURCE_RC=1
            ROWS_COLOR=()
            return 1
            ;;
        esac
      done

      if [[ -n "$output" ]]; then
        mapfile -t ROWS_COLOR <<< "$output"
      else
        ROWS_COLOR=()
      fi
      return 0
    }

    open_file_with_viewer() {
      local item="$1"
      local mime=""
      local -a chafa_args=()
      local -a glow_args=()
      local -a csvlens_args=()
      local -a jnv_args=()

      if (( HAS_JNV )) && is_jnv_file "$item"; then
        if [[ -n "$LSY_JNV_ARGS" ]]; then
          read -r -a jnv_args <<< "$LSY_JNV_ARGS"
        fi
        run_interactive_command jnv "${jnv_args[@]}" "$item"
        return $?
      fi

      if (( HAS_CSVLENS )) && is_csvlens_file "$item"; then
        if [[ -n "$LSY_CSVLENS_ARGS" ]]; then
          read -r -a csvlens_args <<< "$LSY_CSVLENS_ARGS"
        fi
        run_interactive_command csvlens "${csvlens_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_GLOW )) && is_markdown_file "$item"; then
        if [[ -n "$LSY_GLOW_ARGS" ]]; then
          read -r -a glow_args <<< "$LSY_GLOW_ARGS"
        fi
        run_interactive_command glow -p "${glow_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_CHAFA )); then
        if command -v file >/dev/null 2>&1; then
          mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        fi

        if [[ "$mime" == image/* ]]; then
          if [[ -n "$LSY_CHAFA_ARGS" ]]; then
            read -r -a chafa_args <<< "$LSY_CHAFA_ARGS"
          fi
          run_interactive_preview_command chafa "${chafa_args[@]}" -- "$item"
          return $?
        fi
      fi

      case "$FILE_VIEWER" in
        less)
          command -v less >/dev/null 2>&1 || return 1
          run_interactive_command less -- "$item"
          ;;
        bat)
          (( HAS_BAT )) || return 1
          run_interactive_command bat --paging=always -- "$item"
          ;;
        batcat)
          (( HAS_BATCAT )) || return 1
          run_interactive_command batcat --paging=always -- "$item"
          ;;
        *)
          return 1
          ;;
      esac
      return 0
    }

    is_markdown_file() {
      local item="$1"
      local lower="${item,,}"

      case "$lower" in
        *.md|*.markdown|*.mdown|*.mkd|*.mkdn|*.mdx|*.rmd|*.qmd)
          return 0
          ;;
      esac

      if command -v file >/dev/null 2>&1; then
        local mime
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        [[ "$mime" == text/markdown ]] && return 0
      fi

      return 1
    }

    is_csvlens_file() {
      local item="$1"
      local lower="${item,,}"

      case "$lower" in
        *.csv|*.tsv|*.tab|*.psv|*.dsv|*.ssv)
          return 0
          ;;
      esac

      if command -v file >/dev/null 2>&1; then
        local mime
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        case "$mime" in
          text/csv|text/tab-separated-values|application/csv|application/tab-separated-values)
            return 0
            ;;
        esac
      fi

      return 1
    }

    is_jnv_file() {
      local item="$1"
      local lower="${item,,}"

      case "$lower" in
        *.json|*.jsonl|*.ndjson|*.geojson)
          return 0
          ;;
      esac

      if command -v file >/dev/null 2>&1; then
        local mime
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        case "$mime" in
          application/json|application/geo+json|application/ld+json|application/x-ndjson|application/ndjson)
            return 0
            ;;
        esac
      fi

      return 1
    }

    open_file_with_less() {
      local item="$1"
      command -v less >/dev/null 2>&1 || return 1
      run_interactive_command less -- "$item"
      return 0
    }

    open_file_with_gui() {
      local item="$1"
      if command -v xdg-open >/dev/null 2>&1; then
        nohup xdg-open "$item" >/dev/null 2>&1 &
      elif command -v gio >/dev/null 2>&1; then
        nohup gio open "$item" >/dev/null 2>&1 &
      else
        return 1
      fi
      return 0
    }

    open_file_with_editor() {
      local item="$1"
      local editor_spec=""
      local -a editor_cmd=()
      local alt_editor_link=""

      if [[ -n "${LSY_EDITOR:-}" ]]; then
        editor_spec="$LSY_EDITOR"
      elif [[ -n "${VISUAL:-}" ]]; then
        editor_spec="$VISUAL"
      elif [[ -n "${EDITOR:-}" ]]; then
        editor_spec="$EDITOR"
      else
        alt_editor_link="$(ls -l /etc/alternatives/editor 2>/dev/null || true)"
        if [[ "$alt_editor_link" == *" -> "* ]]; then
          editor_spec="${alt_editor_link##* -> }"
        fi
      fi

      if [[ -z "$editor_spec" ]]; then
        editor_spec="nano"
      fi

      read -r -a editor_cmd <<< "$editor_spec"
      (( ${#editor_cmd[@]} > 0 )) || return 1
      command -v "${editor_cmd[0]}" >/dev/null 2>&1 || return 1

      run_interactive_command "${editor_cmd[@]}" -- "$item"
      return $?
    }

    is_zip_file() {
      local item="$1"
      local lower="${item,,}"

      case "$lower" in
        *.zip)
          return 0
          ;;
      esac

      if command -v file >/dev/null 2>&1; then
        local mime
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        [[ "$mime" == "application/zip" ]] && return 0
      fi

      return 1
    }

    collect_zip_paths_from_current_or_selection() {
      local path
      local -a paths=()

      if (( SELECTED_COUNT > 0 )); then
        mapfile -t paths < <(collect_selected_paths_in_row_order)
      else
        path="$(current_row_path)" || return 1
        paths=("$path")
      fi

      (( ${#paths[@]} > 0 )) || return 1
      printf '%s\n' "${paths[@]}"
      return 0
    }

    collect_paths_from_current_or_selection() {
      local path
      local -a paths=()

      if (( SELECTED_COUNT > 0 )); then
        mapfile -t paths < <(collect_selected_paths_in_row_order)
      else
        path="$(current_row_path)" || return 1
        paths=("$path")
      fi

      (( ${#paths[@]} > 0 )) || return 1
      printf '%s\n' "${paths[@]}"
      return 0
    }

    zip_archive_basename() {
      local path="$1"
      local base
      base="$(basename -- "$path")"
      base="${base%.[Zz][Ii][Pp]}"
      printf '%s' "$base"
    }

    extract_selected_zip_archives() {
      local -a items=()
      local -a unzip_args=()
      local -a zip_items=()
      local item extract_root per_archive=0
      local ok_count=0 fail_count=0 skip_count=0
      local folder_name out_dir err unzip_item
      local archive_name resolved_root

      (( HAS_UNZIP )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mZip extraction unavailable: unzip is disabled or not installed.\033[0m" "$rows"
        return 1
      }

      mapfile -t items < <(collect_zip_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract failed: no valid source paths in current selection.\033[0m" "$rows"
        return 1
      }

      for item in "${items[@]}"; do
        [[ -f "$item" ]] || continue
        if is_zip_file "$item"; then
          zip_items+=("$item")
        fi
      done

      if (( ${#zip_items[@]} == 0 )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract failed: current row/selection has no .zip archives.\033[0m" "$rows"
        return 1
      fi

      if (( ${#zip_items[@]} != ${#items[@]} )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract requires zip-only selection when multiple items are selected.\033[0m" "$rows"
        return 1
      fi

      if ! read_yes_no_prompt "Extract ${#zip_items[@]} archive(s)? [y/N]: "; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract cancelled.\033[0m" "$rows"
        return 1
      fi

      extract_root="$(read_line_prompt "Extract to: " "$(pwd -P)")"
      if [[ -z "$extract_root" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract cancelled.\033[0m" "$rows"
        return 1
      fi

      extract_root="${extract_root/#\~/$HOME}"
      if [[ "$extract_root" != /* ]]; then
        extract_root="$(pwd -P)/$extract_root"
      fi

      mkdir -p -- "$extract_root" 2>/dev/null || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mExtract failed: cannot create destination '%s'.\033[0m" "$rows" "$extract_root"
        return 1
      }

      if [[ -n "$LSY_UNZIP_ARGS" ]]; then
        read -r -a unzip_args <<< "$LSY_UNZIP_ARGS"
      fi

      if (( ${#zip_items[@]} > 1 )); then
        if read_yes_no_prompt "Extract each zip into its own folder under destination? [y/N]: "; then
          per_archive=1
        fi
      fi

      for item in "${zip_items[@]}"; do
        archive_name="$(basename -- "$item")"
        if (( per_archive )); then
          folder_name="$(zip_archive_basename "$item")"
          [[ -n "$folder_name" ]] || folder_name="archive"
          out_dir="$extract_root/$folder_name"
          if [[ -e "$out_dir" ]]; then
            resolved_root="$(read_line_prompt "Destination exists for '$archive_name'. Extract to: " "$out_dir")"
            resolved_root="${resolved_root/#\~/$HOME}"
            if [[ -z "$resolved_root" ]]; then
              ((skip_count++))
              continue
            fi
            if [[ "$resolved_root" != /* ]]; then
              out_dir="$(pwd -P)/$resolved_root"
            else
              out_dir="$resolved_root"
            fi
          fi
        else
          out_dir="$extract_root"
        fi

        if ! mkdir -p -- "$out_dir" 2>/dev/null; then
          ((fail_count++))
          continue
        fi

        unzip_item="$item"
        [[ "$unzip_item" == -* ]] && unzip_item="./$unzip_item"
        if err="$(unzip -o "${unzip_args[@]}" "$unzip_item" -d "$out_dir" 2>&1)"; then
          ((ok_count++))
        else
          ((fail_count++))
          LAST_PASTE_ERR="$err"
        fi
      done

      LAST_PASTE_OP="unzip"
      LAST_PASTE_OK=$ok_count
      LAST_PASTE_FAIL=$fail_count
      LAST_PASTE_SKIP=$skip_count
      LAST_PASTE_RC=0
      if (( fail_count > 0 )); then
        LAST_PASTE_RC=1
      fi

      load_data
      draw_ui
      printf "\033[%d;1H\033[K\033[2mExtract: ok:%d fail:%d skip:%d\033[0m" "$rows" "$ok_count" "$fail_count" "$skip_count"
      return 0
    }

    archive_selected_items_as_zip() {
      local -a items=()
      local -a zip_args=()
      local -a zip_items=()
      local item out_path out_dir default_name base err
      local ok_count=0 fail_count=0

      (( HAS_ZIPCMD )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive creation unavailable: zip is disabled or not installed.\033[0m" "$rows"
        return 1
      }

      mapfile -t items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive failed: no valid source paths in current selection.\033[0m" "$rows"
        return 1
      }

      for item in "${items[@]}"; do
        [[ -e "$item" || -L "$item" ]] || continue
        zip_items+=("$item")
      done

      (( ${#zip_items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive failed: selected sources do not exist.\033[0m" "$rows"
        return 1
      }

      if (( ${#zip_items[@]} == 1 )); then
        base="$(basename -- "${zip_items[0]}")"
        default_name="${base}.zip"
      else
        base="$(basename -- "$(pwd -P)")"
        [[ -n "$base" ]] || base="archive"
        default_name="${base}.zip"
      fi

      out_path="$(read_line_prompt "Archive as: " "$(pwd -P)/$default_name")"
      out_path="$(sanitize_filename_input "$out_path")"
      if [[ -z "$out_path" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
        return 1
      fi

      out_path="${out_path/#\~/$HOME}"
      if [[ "$out_path" != /* ]]; then
        out_path="$(pwd -P)/$out_path"
      fi

      out_dir="$(dirname -- "$out_path")"
      mkdir -p -- "$out_dir" 2>/dev/null || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mArchive failed: cannot create destination directory '%s'.\033[0m" "$rows" "$out_dir"
        return 1
      }

      if [[ -e "$out_path" ]]; then
        if ! read_yes_no_prompt "Archive exists. Overwrite '$out_path'? [y/N]: "; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
          return 1
        fi
        rm -f -- "$out_path" 2>/dev/null || {
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive failed: cannot overwrite '%s'.\033[0m" "$rows" "$out_path"
          return 1
        }
      fi

      if [[ -n "$LSY_ZIP_ARGS" ]]; then
        read -r -a zip_args <<< "$LSY_ZIP_ARGS"
      fi

      local i zip_item
      for i in "${!zip_items[@]}"; do
        zip_item="${zip_items[$i]}"
        [[ "$zip_item" == -* ]] && zip_item="./$zip_item"
        zip_items[$i]="$zip_item"
      done

      LAST_PASTE_OP="zip"
      LAST_PASTE_ERR="-"
      if err="$(zip -r "${zip_args[@]}" "$out_path" "${zip_items[@]}" 2>&1)"; then
        ok_count=1
        LAST_PASTE_RC=0
        LAST_PASTE_OK=1
        LAST_PASTE_FAIL=0
        LAST_PASTE_SKIP=0
      else
        fail_count=1
        LAST_PASTE_RC=1
        LAST_PASTE_OK=0
        LAST_PASTE_FAIL=1
        LAST_PASTE_SKIP=0
        LAST_PASTE_ERR="$err"
      fi

      load_data
      draw_ui
      if (( ok_count )); then
        printf "\033[%d;1H\033[K\033[2mArchive created: %s\033[0m" "$rows" "$(basename -- "$out_path")"
        return 0
      fi

      printf "\033[%d;1H\033[K\033[2mArchive failed.\033[0m" "$rows"
      return 1
    }

    handle_zip_action() {
      local -a items=()
      local item zip_count=0 other_count=0

      mapfile -t items < <(collect_paths_from_current_or_selection)
      (( ${#items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mZip action failed: no valid source paths in current selection.\033[0m" "$rows"
        return 1
      }

      for item in "${items[@]}"; do
        [[ -e "$item" || -L "$item" ]] || continue
        if [[ -f "$item" ]] && is_zip_file "$item"; then
          ((zip_count++))
        else
          ((other_count++))
        fi
      done

      if (( zip_count > 0 && other_count == 0 )); then
        extract_selected_zip_archives
        return $?
      fi

      if (( other_count == 0 )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mZip action failed: no existing files selected.\033[0m" "$rows"
        return 1
      fi

      if (( ${#items[@]} > 1 )); then
        if ! read_yes_no_prompt "Create one archive from selected items? [y/N]: "; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
          return 1
        fi
      else
        item="$(basename -- "${items[0]}")"
        if ! read_yes_no_prompt "Create archive for '$item'? [y/N]: "; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mArchive cancelled.\033[0m" "$rows"
          return 1
        fi
      fi

      archive_selected_items_as_zip
    }

delete_current_or_selected() {
  local -a items=()
  local -a existing_items=()
  local item label err
  local ok_count=0 fail_count=0 skip_count=0

  mapfile -t items < <(collect_paths_from_current_or_selection)
  (( ${#items[@]} > 0 )) || {
    draw_status
    printf "\033[%d;1H\033[K\033[2mDelete failed: no valid source paths in current selection.\033[0m" "$rows"
    return 1
  }

  for item in "${items[@]}"; do
    if [[ -e "$item" || -L "$item" ]]; then
      existing_items+=("$item")
    fi
  done

  (( ${#existing_items[@]} > 0 )) || {
    draw_status
    printf "\033[%d;1H\033[K\033[2mDelete failed: selected sources do not exist.\033[0m" "$rows"
    return 1
  }

  if (( ${#existing_items[@]} > 1 )); then
    label="Delete ${#existing_items[@]} selected item(s)? [y/N]: "
  else
    label="Delete '$(basename -- "${existing_items[0]}")'? [y/N]: "
  fi

  if ! read_yes_no_prompt "$label"; then
    draw_status
    printf "\033[%d;1H\033[K\033[2mDelete cancelled.\033[0m" "$rows"
    return 1
  fi

  for item in "${existing_items[@]}"; do
    if err="$(rm -rf -- "$item" 2>&1)"; then
      ((ok_count++))
      unset 'SELECTED_PATHS[$item]'
    else
      ((fail_count++))
      LAST_PASTE_ERR="$err"
    fi
  done

  skip_count=$(( ${#items[@]} - ${#existing_items[@]} ))
  SELECTED_COUNT=${#SELECTED_PATHS[@]}
  LAST_PASTE_OP="rm"
  LAST_PASTE_RC=0
  LAST_PASTE_OK=$ok_count
  LAST_PASTE_FAIL=$fail_count
  LAST_PASTE_SKIP=$skip_count
  if (( fail_count > 0 )); then
    LAST_PASTE_RC=1
  fi

  if (( ok_count > 0 )); then
    load_data
    if (( cursor >= ${#ROWS_COLOR[@]} )); then
      cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
    fi
    if (( cursor < top )); then
      top=$cursor
    elif (( cursor >= top + visible_rows )); then
      top=$(( cursor - visible_rows + 1 ))
    fi
  fi

  draw_ui
  printf "\033[%d;1H\033[K\033[2mDelete: ok:%d fail:%d skip:%d\033[0m" "$rows" "$ok_count" "$fail_count" "$skip_count"
  return 0
}

    # Reorder long-list rows to `name metadata...` using awk+column alignment.
    # Minimal modification: split on date-time anchor, reorder, let column handle alignment.
    format_name_first_aligned() {
      awk '
        BEGIN {
          esc = sprintf("%c", 27) "\\[[0-9;]*m"
          dt = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*[[:space:]]+(" esc ")*[0-9][0-9]:[0-9][0-9](" esc ")*[[:space:]]+"
        }
        {
          if (match($0, dt)) {
            name = substr($0, RSTART + RLENGTH)
            meta = substr($0, 1, RSTART + RLENGTH - 1)
            printf "%s\t%s\n", name, meta
          } else {
            print
          }
        }
      ' | column -t -s $'\t'
    }

    load_data() {
      local t0 t1 t2

      ROWS_COLOR=()
      ROWS_PLAIN=()
      ROWS_PATH=()
      ROWS_SELECTED=()

      t0=$(date +%s%N)
      capture_directory_rows || true
      t1=$(date +%s%N)
      LAST_LS_MS=$(( (t1 - t0) / 1000000 ))
      LAST_PARSE_MS=0
      LAST_LOAD_MS=$LAST_LS_MS
      ENTRY_COUNT=${#ROWS_COLOR[@]}

      if (( ${#ROWS_COLOR[@]} == 0 )); then
        ROWS_COLOR=("\033[2m(empty directory)\033[0m")
        ROWS_PLAIN=("(empty directory)")
        ROWS_SELECT_PLAIN=("(empty directory)")
        update_git_header_suffix
        cursor=0
        top=0
        return
      fi

      # Build plain rows once from raw renderer output.
      mapfile -t ROWS_PLAIN < <(printf '%s\n' "${ROWS_COLOR[@]}" | sed -E $'s/\x1B\[[0-9;]*m//g')

      # Keep a stable plain array for path extraction before any display reformatting.
      ROWS_SELECT_PLAIN=("${ROWS_PLAIN[@]}")

      if (( NAME_FIRST_VIEW )); then
        # Reformat only the display rows; selection rows stay in original capture order.
        mapfile -t ROWS_COLOR < <(printf '%s\n' "${ROWS_COLOR[@]}" | format_name_first_aligned)
        mapfile -t ROWS_PLAIN < <(printf '%s\n' "${ROWS_COLOR[@]}" | sed -E $'s/\x1B\[[0-9;]*m//g')
      fi
      t2=$(date +%s%N)
      LAST_PARSE_MS=$(( (t2 - t1) / 1000000 ))
      LAST_LOAD_MS=$(( (t2 - t0) / 1000000 ))

      (( cursor >= ${#ROWS_COLOR[@]} )) && cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
      (( top < 0 )) && top=0

      update_git_header_suffix
    }

    update_git_header_suffix() {
      local current_dir branch dirty="" status_output git_enabled=1
      current_dir="$(pwd -P 2>/dev/null || pwd)"
      [[ -n "${DISABLED_INTEGRATIONS[git]+x}" ]] && git_enabled=0

      if [[ "$GIT_HEADER_CACHE_PWD" == "$current_dir" && "$GIT_HEADER_CACHE_ENABLED" == "$git_enabled" ]]; then
        GIT_HEADER_SUFFIX="$GIT_HEADER_CACHE_SUFFIX"
        return
      fi

      GIT_HEADER_SUFFIX=""
      if (( !git_enabled )); then
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      fi

      command -v git >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      branch="$(git branch --show-current 2>/dev/null)"
      [[ -z "$branch" ]] && branch="$(git rev-parse --short HEAD 2>/dev/null)"
      if [[ -n "$branch" && "$LSY_GIT_DIRTY_CHECK" == "1" ]]; then
        status_output="$(git status --porcelain=v1 --untracked-files=normal 2>/dev/null)"
        [[ -n "$status_output" ]] && dirty="*"
      fi

      [[ -n "$branch" ]] && GIT_HEADER_SUFFIX=" (${branch}${dirty})"
      GIT_HEADER_CACHE_PWD="$current_dir"
      GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
      GIT_HEADER_CACHE_ENABLED="$git_enabled"
    }

    draw_header() {
      local user host cwd
      local separator_width
      local separator
      user="${USER:-$(id -un 2>/dev/null || printf 'user')}"
      host="${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'host')}"
      cwd="$(pwd -P 2>/dev/null || pwd)"
      separator_width=$cols
      (( separator_width < 1 )) && separator_width=1

      printf "\033[1;36m"
      printf "%s\n" "${user}@${host} » ${cwd}${GIT_HEADER_SUFFIX}"
      printf "\033[0m"
      printf -v separator '%*s' "$separator_width" ''
      separator=${separator// /─}
      printf '%s\033[K\n' "$separator"
    }

    draw_row() {
      local i="$1"
      local selected="$2"
      local row
      local row_plain

      if (( i < 0 || i >= ${#ROWS_COLOR[@]} )); then
        printf "\033[K\n"
        return
      fi

      row="${ROWS_COLOR[$i]}"
      row_plain="${ROWS_PLAIN[$i]-$row}"

      if (( selected )); then
        printf "\033[7m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      if [[ "${ROWS_SELECTED[$i]-0}" == "1" ]]; then
        printf "\033[48;5;24m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      printf "%s\033[K\n" "$row"
    }

    draw_status() {
      local total="$ENTRY_COUNT"
      local status_row=$rows
      local hidden_state="off"
      local source_state="$LIST_SOURCE"
      local layout_state="meta-first"
      local debug_state=""
      local selection_state="$SELECTED_COUNT"
      local clipboard_state="$CLIPBOARD_LABEL"
      (( show_hidden )) && hidden_state="on"
      (( NAME_FIRST_VIEW )) && layout_state="name-first"

      if [[ "$LSY_DEBUG_SOURCE" == "1" ]]; then
        debug_state=" dbg:req:${LAST_SOURCE_REQUESTED} run:${LAST_SOURCE_EXECUTED} rc:${LAST_SOURCE_RC}"
        if (( LAST_SOURCE_FALLBACK )); then
          debug_state+=" fb:${LAST_SOURCE_FALLBACK_TO}"
        fi
        if [[ "$LSY_DEBUG_SHOW_CMD" == "1" ]]; then
          debug_state+=" cmd:${LAST_SOURCE_ARGS}"
        fi
      fi

      if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
        debug_state+=" clip:${LAST_CLIP_MODE} req:${LAST_CLIP_REQUESTED} ok:${LAST_CLIP_RESOLVED} drop:${LAST_CLIP_DROPPED}"
        debug_state+=" paste:${LAST_PASTE_OP} rc:${LAST_PASTE_RC} ok:${LAST_PASTE_OK} fail:${LAST_PASTE_FAIL} skip:${LAST_PASTE_SKIP}"
        if [[ -n "$LAST_PASTE_ERR" && "$LAST_PASTE_ERR" != "-" ]]; then
          local err_preview="$LAST_PASTE_ERR"
          if (( ${#err_preview} > 72 )); then
            err_preview="${err_preview:0:69}..."
          fi
          debug_state+=" err:${err_preview}"
        fi
      fi

      # Keep footer anchored regardless of current cursor location.
      # Disable autowrap for the status line so long text never scrolls the screen.
      printf "\033[?7l"
      printf "\033[%d;1H\033[K" "$status_row"
      printf "\033[2m[total:%d sel:%s clip:%s] renderer:%s layout:%s hidden:%s load:%dms (ls:%d parse:%d)%s\033[0m\033[K" "$total" "$selection_state" "$clipboard_state" "$source_state" "$layout_state" "$hidden_state" "$LAST_LOAD_MS" "$LAST_LS_MS" "$LAST_PARSE_MS" "$debug_state"
      printf "\033[?7h"
    }

    scroll_list_once() {
      local direction="$1"
      local top_row=3
      local bottom_row=$((2 + visible_rows))

      printf "\033[%d;%dr" "$top_row" "$bottom_row"
      if [[ "$direction" == "down" ]]; then
        printf "\033[%d;1H\033[M" "$top_row"
      else
        printf "\033[%d;1H\033[L" "$top_row"
      fi
      printf "\033[r"
    }

    redraw_row_at_index() {
      local i="$1"
      local screen_line

      (( i >= top && i < top + visible_rows )) || return
      screen_line=$((3 + i - top))
      printf "\033[%d;1H" "$screen_line"
      if (( i == cursor )); then
        draw_row "$i" 1
      else
        draw_row "$i" 0
      fi
    }

    redraw_visible_rows_and_status() {
      local i
      for (( i=top; i<top + visible_rows; i++ )); do
        redraw_row_at_index "$i"
      done
      draw_status
    }

    draw_ui() {
      printf "\033[H\033[2J"
      draw_header

      local line idx
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        if (( idx == cursor )); then
          draw_row "$idx" 1
        else
          draw_row "$idx" 0
        fi
      done

      draw_status
    }

    read_key() {
      local k
      IFS= read -rsn1 k || return 1
      if [[ "$k" == $'\e' ]]; then
        local k2 k3 k4 k5
        IFS= read -rsn1 -t 0.005 k2 || true
        IFS= read -rsn1 -t 0.005 k3 || true
        # Extended sequences like \e[24~ (F12) or \e[5~ (PgUp) carry extra bytes
        if [[ "$k2" == '[' && "$k3" =~ [0-9] ]]; then
          IFS= read -rsn1 -t 0.005 k4 || true
          if [[ "$k4" =~ [0-9] ]]; then
            IFS= read -rsn1 -t 0.005 k5 || true
          fi
        fi
        printf '%s' "$k$k2$k3${k4-}${k5-}"
      else
        printf '%s' "$k"
      fi
      return 0
    }

    move_up() {
      (( cursor > 0 )) || return
      ((cursor--))
      (( cursor < top )) && top=$cursor
    }

    move_down() {
      (( cursor + 1 < ${#ROWS_COLOR[@]} )) || return
      ((cursor++))
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    # Strip symlink target from a name string if the row represents a symlink (l*).
    strip_symlink_target() {
      local plain="$1" name="$2"
      if [[ "$plain" == l* ]]; then
        name="${name%% -> *}"
        name="${name%% ⇒ *}"
      fi
      printf '%s' "$name"
    }

    parse_name_from_plain_row() {
      local plain="$1" name
      case "$LIST_SOURCE" in
        ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        lsd|eza)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        *)
          return 1
          ;;
      esac

      printf '%s' "$name"
      return 0
    }

    path_exists() {
      local p="$1"
      [[ -e "$p" || -L "$p" ]]
    }

    resolve_row_path_from_plain() {
      local plain="$1" name candidate
      name="$(parse_name_from_plain_row "$plain" 2>/dev/null || true)"
      [[ -n "$name" ]] || return 1

      candidate="$name"
      if path_exists "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi

      # Some renderers can leave icon tokens in plain text; peel leading tokens until path resolves.
      while [[ "$candidate" =~ ^[[:space:]]*[^[:space:]]+[[:space:]]+(.*)$ ]]; do
        candidate="${BASH_REMATCH[1]}"
        [[ -n "$candidate" ]] || break
        if path_exists "$candidate"; then
          printf '%s' "$candidate"
          return 0
        fi
      done

      return 1
    }

    build_row_paths() {
      local plain path i
      ROWS_PATH=()
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        plain="${ROWS_SELECT_PLAIN[$i]}"
        if [[ "$plain" == "(empty directory)" ]]; then
          ROWS_PATH+=("")
          continue
        fi
        path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
        ROWS_PATH+=("$path")
      done
    }

    ensure_row_path() {
      local idx="$1"
      local plain path

      if (( idx < 0 || idx >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi

      if [[ -n "${ROWS_PATH[$idx]-}" ]]; then
        printf '%s' "${ROWS_PATH[$idx]}"
        return 0
      fi

      plain="${ROWS_SELECT_PLAIN[$idx]}"
      [[ "$plain" == "(empty directory)" ]] && return 1

      path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
      [[ -n "$path" ]] || return 1
      ROWS_PATH[$idx]="$path"
      printf '%s' "$path"
      return 0
    }

    ensure_all_row_paths() {
      local i
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        ensure_row_path "$i" >/dev/null 2>&1 || true
      done
    }

    clear_selection() {
      SELECTED_PATHS=()
      SELECTED_COUNT=0
      ROWS_SELECTED=()
    }

    rebuild_row_selection_flags() {
      local -A visible=()
      local i path

      ensure_all_row_paths

      ROWS_SELECTED=()
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] && visible["$path"]=1
      done

      for path in "${!SELECTED_PATHS[@]}"; do
        [[ -n "${visible[$path]+x}" ]] || unset 'SELECTED_PATHS[$path]'
      done

      SELECTED_COUNT=${#SELECTED_PATHS[@]}
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        if [[ -n "$path" && -n "${SELECTED_PATHS[$path]+x}" ]]; then
          ROWS_SELECTED+=(1)
        else
          ROWS_SELECTED+=(0)
        fi
      done
    }

    current_row_path() {
      if (( cursor < 0 || cursor >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi
      ensure_row_path "$cursor"
    }

    toggle_selection_current() {
      local path idx
      idx=$cursor
      path="$(current_row_path)" || return 1

      if [[ -n "${SELECTED_PATHS[$path]+x}" ]]; then
        unset 'SELECTED_PATHS[$path]'
        ROWS_SELECTED[$idx]=0
      else
        SELECTED_PATHS[$path]=1
        ROWS_SELECTED[$idx]=1
      fi

      SELECTED_COUNT=${#SELECTED_PATHS[@]}
      return 0
    }

    toggle_select_all() {
      local i all_selected=1 path
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        if [[ -z "${SELECTED_PATHS[$path]+x}" ]]; then
          all_selected=0
          break
        fi
      done

      if (( all_selected )); then
        clear_selection
      else
        for i in "${!ROWS_SELECT_PLAIN[@]}"; do
          [[ -n "${ROWS_PATH[$i]-}" ]] || continue
          SELECTED_PATHS["${ROWS_PATH[$i]}"]=1
        done
        rebuild_row_selection_flags
      fi
    }

    collect_selected_paths_in_row_order() {
      local i path
      local -a collected=()
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        [[ -n "${SELECTED_PATHS[$path]+x}" ]] || continue
        collected+=("$path")
      done
      if (( ${#collected[@]} > 0 )); then
        printf '%s\n' "${collected[@]}"
      fi
    }

    update_clipboard_label() {
      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        CLIPBOARD_LABEL="${#CLIPBOARD_MULTI[@]} items"
      elif [[ -n "$CLIPBOARD_NAME" ]]; then
        CLIPBOARD_LABEL="$CLIPBOARD_NAME"
      else
        CLIPBOARD_LABEL="none"
      fi
    }

    set_clipboard_from_current_or_selection() {
      local mode="$1"
      local path
      local abs_path
      local requested_count=0
      local -a items=()
      local -a abs_items=()

      LAST_CLIP_MODE="$mode"
      LAST_CLIP_REQUESTED=0
      LAST_CLIP_RESOLVED=0
      LAST_CLIP_DROPPED=0

      if (( SELECTED_COUNT > 0 )); then
        mapfile -t items < <(collect_selected_paths_in_row_order)
      else
        path="$(current_row_path)" || return 1
        items=("$path")
      fi

      (( ${#items[@]} > 0 )) || return 1
      requested_count=${#items[@]}
      LAST_CLIP_REQUESTED=$requested_count
      for path in "${items[@]}"; do
        [[ -n "$path" ]] || continue
        abs_path="$(pwd -P)/$path"
        if path_exists "$path" || path_exists "$abs_path"; then
          abs_items+=("$abs_path")
        fi
      done
      LAST_CLIP_RESOLVED=${#abs_items[@]}
      LAST_CLIP_DROPPED=$(( requested_count - LAST_CLIP_RESOLVED ))
      (( ${#abs_items[@]} > 0 )) || return 1

      if (( ${#abs_items[@]} > 1 )) || [[ "$mode" == "move" ]]; then
        CLIPBOARD_MULTI=("${abs_items[@]}")
        CLIPBOARD_PATH=""
        CLIPBOARD_MOVE=0
        [[ "$mode" == "move" ]] && CLIPBOARD_MOVE=1
        CLIPBOARD_NAME="${#abs_items[@]} items"
      else
        CLIPBOARD_MULTI=()
        CLIPBOARD_MOVE=0
        CLIPBOARD_PATH="${abs_items[0]}"
        CLIPBOARD_NAME="$(basename -- "${abs_items[0]}")"
      fi

      CLIPBOARD_ITEMS=("${abs_items[@]}")
      CLIPBOARD_MODE="$mode"
      update_clipboard_label
      return 0
    }

    paste_clipboard_items() {
      local src dest bname err
      local ok_count=0 fail_count=0 skip_count=0

      LAST_PASTE_OP="-"
      LAST_PASTE_RC=0
      LAST_PASTE_ERR="-"
      LAST_PASTE_OK=0
      LAST_PASTE_FAIL=0
      LAST_PASTE_SKIP=0

      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        if read_yes_no_prompt "Paste ${#CLIPBOARD_MULTI[@]} item(s) here? [y/N]: "; then
          for src in "${CLIPBOARD_MULTI[@]}"; do
            bname="$(basename -- "$src")"
            dest="$bname"
            if [[ -e "$dest" ]]; then
              bname="$(sanitize_filename_input "$bname")"
              echo -ne "\033[?25h"
              printf "\033[%d;1H\033[K" "$rows"
              stty echo
              read -e -i "$dest" -p "Paste '$bname' as: " dest
              stty -echo cbreak -ixon intr undef
              echo -ne "\033[?25l"
            fi
            dest="$(sanitize_filename_input "$dest")"
            if [[ -z "$dest" ]]; then
              ((skip_count++))
              continue
            fi

            if (( CLIPBOARD_MOVE )); then
              LAST_PASTE_OP="mv"
              if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
                if err="$(mv -- "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif mv -- "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            else
              LAST_PASTE_OP="cp"
              if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
                if err="$(cp -r -- "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif cp -r -- "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            fi
          done

          LAST_PASTE_OK=$ok_count
          LAST_PASTE_FAIL=$fail_count
          LAST_PASTE_SKIP=$skip_count

          if (( CLIPBOARD_MOVE )); then
            CLIPBOARD_MULTI=()
            CLIPBOARD_MOVE=0
            CLIPBOARD_NAME=""
            clear_selection
          fi

          CLIPBOARD_ITEMS=()
          update_clipboard_label
          load_data
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste: ok:%d fail:%d skip:%d\033[0m" "$rows" "$ok_count" "$fail_count" "$skip_count"
        else
          LAST_PASTE_OP="cancel"
          draw_ui
        fi
        return 0
      fi

      if [[ -n "$CLIPBOARD_PATH" ]]; then
        dest="$CLIPBOARD_NAME"
        if [[ -e "$dest" ]]; then
          echo -ne "\033[?25h"
          printf "\033[%d;1H\033[K" "$rows"
          stty echo
          read -e -i "$dest" -p "New name: " dest
          stty -echo cbreak -ixon intr undef
          echo -ne "\033[?25l"
        fi
        dest="$(sanitize_filename_input "$dest")"

        LAST_PASTE_OP="cp"
        if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
          if err="$(cp -r -- "$CLIPBOARD_PATH" "$dest" 2>&1)"; then
            LAST_PASTE_RC=0
            LAST_PASTE_ERR="-"
            LAST_PASTE_OK=1
            LAST_PASTE_FAIL=0
            LAST_PASTE_SKIP=0
            load_data
            draw_ui
            printf "\033[%d;1H\033[K\033[2mPaste: ok:1 fail:0 skip:0\033[0m" "$rows"
          else
            LAST_PASTE_RC=$?
            LAST_PASTE_ERR="$err"
            LAST_PASTE_OK=0
            LAST_PASTE_FAIL=1
            LAST_PASTE_SKIP=0
            draw_ui
            printf "\033[%d;1H\033[K\033[2mPaste failed for: %s\033[0m" "$rows" "$dest"
          fi
          return 0
        fi

        if cp -r -- "$CLIPBOARD_PATH" "$dest" 2>/dev/null; then
          LAST_PASTE_RC=0
          LAST_PASTE_OK=1
          LAST_PASTE_FAIL=0
          LAST_PASTE_SKIP=0
          load_data
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste: ok:1 fail:0 skip:0\033[0m" "$rows"
        else
          LAST_PASTE_RC=$?
          LAST_PASTE_OK=0
          LAST_PASTE_FAIL=1
          LAST_PASTE_SKIP=0
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste failed for: %s\033[0m" "$rows" "$dest"
        fi
        return 0
      fi

      draw_ui
      printf "\033[%d;1H\033[K\033[2mClipboard is empty. Copy or move items first.\033[0m" "$rows"
      return 1
    }

    selected_path() {
      current_row_path
    }

    integration_version_label() {
      local tool="$1"
      local out version

      case "$tool" in
        eza)
          out="$(eza -v 2>&1 || eza --version 2>&1 || true)"
          version="$(printf '%s\n' "$out" | awk '/^v[0-9]/{print; exit}')"
          if [[ -n "$version" ]]; then
            printf 'eza %s' "$version"
          else
            printf '%s\n' "$out" | head -1
          fi
          ;;
        *)
          "$tool" --version 2>&1 | head -1
          ;;
      esac
    }

    show_integrations() {
      # Each entry: role|tool|description|optional(1=toggleable, 0=required fallback)
      local -a int_entries=(
        "list source|ls|Built-in GNU/BSD ls: directory listing|0"
        "list source|eza|A modern ls replacement with rich metadata and icons|1"
        "list source|lsd|LSDeluxe: modern ls replacement with icons and colors|1"
        "vcs|git|Version control integration for repo-aware workflows|1"
        "archive|zip|Zip extract/create for selected items and .zip archives|1"
        "preview|jnv|Terminal JSON preview for .json .jsonl .ndjson .geojson|1"
        "preview|csvlens|Terminal CSV/TSV preview for .csv .tsv .tab .psv .dsv .ssv|1"
        "preview|glow|Terminal markdown preview for .md, .markdown, .mdown, .mkdn (and markdown MIME)|1"
        "preview|chafa|Terminal image preview for image/* files|1"
        "view|name-first|Show file/folder name before metadata|1"
        "file viewer|less|Terminal pager for plain file viewing|0"
      )

      # batcat is a packaging alias for bat; show only one integration row.
      if command -v bat >/dev/null 2>&1; then
        int_entries+=("file viewer|bat|A cat clone with syntax highlighting and Git integration|1")
      elif command -v batcat >/dev/null 2>&1; then
        int_entries+=("file viewer|batcat|A cat clone with syntax highlighting and Git integration|1")
      else
        int_entries+=("file viewer|bat|A cat clone with syntax highlighting and Git integration|1")
      fi
      local int_count=${#int_entries[@]}
      local int_cursor=0

      # Pre-collect install state and versions once; the draw loop stays constant-time.
      local -a int_installed=() int_version=()
      local _entry _role _tool _desc _optional
      for _entry in "${int_entries[@]}"; do
        IFS='|' read -r _role _tool _desc _optional <<< "$_entry"
        if [[ "$_tool" == "name-first" ]]; then
          int_installed+=(1)
          int_version+=("built-in toggle")
        elif [[ "$_tool" == "zip" ]]; then
          local zip_ver unzip_ver
          zip_ver=""
          unzip_ver=""
          command -v zip >/dev/null 2>&1 && zip_ver="$(integration_version_label zip)"
          command -v unzip >/dev/null 2>&1 && unzip_ver="$(integration_version_label unzip)"
          if [[ -n "$zip_ver" || -n "$unzip_ver" ]]; then
            int_installed+=(1)
            if [[ -n "$zip_ver" && -n "$unzip_ver" ]]; then
              int_version+=("zip+unzip")
            elif [[ -n "$zip_ver" ]]; then
              int_version+=("$zip_ver")
            else
              int_version+=("$unzip_ver")
            fi
          else
            int_installed+=(0)
            int_version+=("not installed")
          fi
        elif command -v "$_tool" >/dev/null 2>&1; then
          int_installed+=(1)
          int_version+=("$(integration_version_label "$_tool")")
        else
          int_installed+=(0)
          int_version+=("not installed")
        fi
      done

      _int_draw_header() {
        printf "\033[H\033[2J"
        printf "\033[1;36mIntegrations\033[0m  \033[2m↑↓ navigate | Space toggle | q return\033[0m\n"
        printf -v _sep '%*s' "$cols" ''
        printf '%s\n' "${_sep// /─}"
      }

      _int_draw_rows() {
        local i line role tool desc optional present state_tag
        local -A active_tools=(["$LIST_SOURCE"]=1 ["$FILE_VIEWER"]=1)
        if [[ -z "${DISABLED_INTEGRATIONS[git]+x}" && -n "$GIT_HEADER_SUFFIX" ]]; then
          active_tools[git]=1
        fi
        if (( HAS_CHAFA )); then
          active_tools[chafa]=1
        fi
        if (( HAS_GLOW )); then
          active_tools[glow]=1
        fi
        if (( HAS_CSVLENS )); then
          active_tools[csvlens]=1
        fi
        if (( HAS_JNV )); then
          active_tools[jnv]=1
        fi
        if (( HAS_ZIP )); then
          active_tools[zip]=1
        fi

        for (( i=0; i<int_count; i++ )); do
          line=$((3 + i))
          IFS='|' read -r role tool desc optional <<< "${int_entries[$i]}"
          (( int_installed[i] )) && present="\033[1;32m✔\033[0m" || present="\033[2m✘\033[0m"

          if [[ "$tool" == "name-first" ]]; then
            if (( NAME_FIRST_VIEW )); then
              state_tag="\033[1;32m[on]\033[0m"
            else
              state_tag="\033[31m[off]\033[0m"
            fi
          elif (( !optional )); then
            state_tag="\033[2m[required]\033[0m"
          elif (( !int_installed[i] )); then
            state_tag="\033[2m[not installed]\033[0m"
          elif [[ -n "${DISABLED_INTEGRATIONS[$tool]+x}" ]]; then
            state_tag="\033[31m[off]\033[0m"
          elif [[ -n "${active_tools[$tool]+x}" ]]; then
            state_tag="\033[1;33m[active]\033[0m"
          else
            state_tag="\033[1;32m[on]\033[0m"
          fi

          printf "\033[%d;1H\033[K" "$line"
          if (( i == int_cursor )); then
            printf "\033[1m> %-44s  %b  %-16s  %-38s  %b\033[0m" \
              "${int_version[$i]}" "$present" "$role" "$desc" "$state_tag"
          else
            printf "  \033[2m%-44s\033[0m  %b  \033[2m%-16s\033[0m  %-38s  %b" \
              "${int_version[$i]}" "$present" "$role" "$desc" "$state_tag"
          fi
        done

        printf "\033[%d;1H\033[K\033[2mSpace toggles optional integrations; required ones cannot be disabled\033[0m" "$((int_count + 4))"
      }

      _int_draw_header
      _int_draw_rows
      while true; do
        local key
        key="$(read_key || true)"
        [[ -z "$key" ]] && continue

        case "$key" in
          "$KEY_UP")
            (( int_cursor > 0 )) && (( int_cursor-- ))
            _int_draw_rows
            ;;
          "$KEY_DOWN")
            (( int_cursor < int_count - 1 )) && (( int_cursor++ ))
            _int_draw_rows
            ;;
          ' '|$'\r')
            IFS='|' read -r _role _tool _desc _optional <<< "${int_entries[$int_cursor]}"
            if [[ "$_tool" == "name-first" ]]; then
              if (( NAME_FIRST_VIEW )); then
                NAME_FIRST_VIEW=0
              else
                NAME_FIRST_VIEW=1
              fi
              load_data
              _int_draw_rows
            elif (( _optional && int_installed[int_cursor] )); then
              if [[ -n "${DISABLED_INTEGRATIONS[$_tool]+x}" ]]; then
                unset 'DISABLED_INTEGRATIONS[$_tool]'
              else
                DISABLED_INTEGRATIONS[$_tool]=1
              fi
              LIST_SOURCE=""
              FILE_VIEWER=""
              detect_sources
              load_data
              _int_draw_rows
            fi
            ;;
          q|$'\e'|"$KEY_QUIT")
            break
            ;;
        esac
      done

      draw_ui
    }

    navigate_to_dir() {
      local target="$1"
      target="${target/#\~/$HOME}"
      [[ -d "$target" ]] || return 1
      cd -- "$target" 2>/dev/null || return 1
      clear_selection
      cursor=0
      top=0
      load_data
      draw_ui
    }

    jump_to_bookmark() {
      local key="$1"
      local var_name="LSY_BOOKMARK_${key}"
      local target="${!var_name-}"
      [[ -z "$target" ]] && return
      navigate_to_dir "$target"
    }

    go_parent_dir() {
      [[ "$(pwd -P 2>/dev/null || pwd)" == "/" ]] && return 0
      cd .. 2>/dev/null || return 1
      clear_selection
      cursor=0
      top=0
      load_data
      draw_ui
      return 0
    }

    enter_or_open_selected() {
      local item
      item="$(selected_path)" || return 1

      if [[ -d "$item" ]]; then
        cd -- "$item" || return 1
        cursor=0
        top=0
        load_data
        draw_ui
        return 0
      fi

      [[ -f "$item" ]] || return 1
      open_file_with_viewer "$item" || return 1
      draw_ui
      return 0
    }

    open_selected_with_less() {
      local item
      item="$(selected_path)" || return 1
      [[ -f "$item" ]] || return 1
      open_file_with_less "$item" || return 1
      draw_ui
      return 0
    }

    open_selected_with_gui() {
      local item
      item="$(selected_path)" || return 1
      [[ -e "$item" ]] || return 1
      open_file_with_gui "$item" || return 1
      draw_ui
      return 0
    }

    open_selected_with_editor() {
      local item
      item="$(selected_path)" || return 1
      [[ -f "$item" ]] || return 1
      open_file_with_editor "$item" || return 1
      draw_ui
      return 0
    }

    page_up() {
      (( cursor == 0 )) && return
      cursor=$(( cursor - visible_rows ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
    }

    page_down() {
      local max=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( max < 0 )) && return
      (( cursor == max )) && return
      cursor=$(( cursor + visible_rows ))
      (( cursor > max )) && cursor=$max
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    cycle_list_source() {
      local -a sources=(ls)
      local i current_index=-1

      (( HAS_LSD )) && sources+=(lsd)
      (( HAS_EZA )) && sources+=(eza)

      for i in "${!sources[@]}"; do
        if [[ "${sources[$i]}" == "$LIST_SOURCE" ]]; then
          current_index=$i
          break
        fi
      done

      if (( current_index < 0 )); then
        LIST_SOURCE="${sources[0]}"
        return
      fi

      current_index=$(( (current_index + 1) % ${#sources[@]} ))
      LIST_SOURCE="${sources[$current_index]}"
    }

    show_help() {
      local _rows _cols divider left_width right_width total_width junction i
      _rows=$(tput lines)
      _cols=$(tput cols)
      divider=" │ "
      left_width=38
      right_width=38
      total_width=$(( left_width + ${#divider} + right_width ))
      (( total_width > _cols )) && left_width=$(( (_cols - ${#divider}) / 2 )) && right_width=$(( _cols - left_width - ${#divider} )) && total_width=$_cols

      printf "\033[H\033[2J"
      printf "\033[1;36mlsy\033[0m  keyboard shortcuts\n"
      junction=$(( left_width + 1 ))
      for (( i=0; i<total_width; i++ )); do
        if (( i == junction )); then printf "┬"; else printf "─"; fi
      done
      printf "\n"

      # Compact fallback for very small terminals.
      if (( _rows < 15 || _cols < 70 )); then
        printf "\033[1;36mNavigation\033[0m  \033[1;33mUp/Down\033[0m move  \033[1;33mPgUp/PgDn\033[0m page  \033[1;33mHome/End\033[0m top/bottom\n"
        printf "\033[1;36mDirectory\033[0m   \033[1;33mRight\033[0m enter/open  \033[1;33mLeft\033[0m parent dir\n"
        printf "\033[1;36mSelect\033[0m      \033[1;33m%s\033[0m toggle  \033[1;33m%s\033[0m all  \033[1;33m%s\033[0m copy  \033[1;33m%s\033[0m move  \033[1;33m%s\033[0m paste  \033[1;33m%s\033[0m delete\n" "$KEY_SELECT_TOGGLE_LABEL" "$KEY_SELECT_ALL" "$KEY_COPY" "$KEY_MOVE" "$KEY_PASTE" "$KEY_DELETE"
        printf "\033[1;36mFile\033[0m        \033[1;33m%s\033[0m less viewer  \033[1;33m%s\033[0m GUI opener  \033[1;33m%s\033[0m edit  \033[1;33m%s\033[0m zip\n" "$KEY_OPEN_LESS" "$KEY_OPEN_GUI" "$KEY_OPEN_EDITOR" "$KEY_EXTRACT_ZIP"
        printf "\033[1;36mView\033[0m        \033[1;33m%s\033[0m hidden  \033[1;33m%s\033[0m renderer  \033[1;33m%s\033[0m name-first  \033[1;33m%s\033[0m integrations\n" "$KEY_TOGGLE_HIDDEN" "$KEY_TOGGLE_SOURCE_LABEL" "$KEY_TOGGLE_NAME_FIRST_LABEL" "$KEY_INTEGRATIONS"
        printf "\033[1;36mOther\033[0m       \033[1;33m%s\033[0m reload  \033[1;33m%s\033[0m help  \033[1;33m%s\033[0m quit\n\n" "$KEY_RELOAD" "$KEY_HELP" "$KEY_QUIT"
        printf "\033[2mPress any key to return...\033[0m"
        read_key >/dev/null || true
        draw_ui
        return
      fi

      local -a left_col=(
        "Navigation"
        "Up / Down    Move selection up / down"
        "PgUp / PgDn  Jump by page"
        "Home         Jump to top of list"
        "End          Jump to bottom of list"
        ""
        "Directory"
        "Right        Enter selected directory"
        "Left         Go to parent directory"
        ""
        "File"
        "Right        Open file with viewer"
        "${KEY_OPEN_LESS}            Open selected file with less"
        "${KEY_OPEN_GUI}            Open selected path in GUI app"
        "${KEY_OPEN_EDITOR}            Edit selected file in terminal editor"
        "${KEY_EXTRACT_ZIP}            Extract .zip or create archive"
        ""
        "Selection"
        "${KEY_SELECT_TOGGLE_LABEL}            Toggle current row selection"
        "${KEY_SELECT_ALL}            Select/deselect all visible rows"
        "${KEY_COPY}            Copy selected rows (or current row)"
        "${KEY_MOVE}            Move selected rows (or current row)"
        "${KEY_PASTE}            Paste clipboard items in this directory"
        "${KEY_DELETE}            Delete selected rows (or current row)"
        ""
        "View"
        "${KEY_TOGGLE_HIDDEN}            Toggle hidden files on/off"
        "${KEY_TOGGLE_SOURCE_LABEL}            Cycle list renderer (eza/lsd/ls)"
        "${KEY_TOGGLE_NAME_FIRST_LABEL}            Toggle name-first layout"
        "${KEY_INTEGRATIONS}            Show integrations screen"
      )

      local -a right_col=(
        "Shortcuts"
        "${KEY_RELOAD}            Reload current directory"
        "${KEY_HELP}            Show this help screen"
        "${KEY_QUIT}            Quit lsy"
        ""
        "Renderers"
        "eza          Rich metadata, icons, colors"
        "lsd          Modern ls with icons"
        "ls           Built-in POSIX fallback"
        ""
        "Layout"
        "${KEY_TOGGLE_NAME_FIRST_LABEL}            Toggle name-first layout"
        ""
        "Env overrides"
        "LSY_KEY_*    Override any key binding"
        "LSY_EDITOR   Optional override (else VISUAL, EDITOR, /etc/alternatives/editor, nano)"
        "LSY_UNZIP_ARGS  Extra args passed to unzip extraction"
        "LSY_ZIP_ARGS  Extra args passed to zip archive creation"
        "LSY_JNV_ARGS  Extra args passed to jnv JSON preview"
        "LSY_CSVLENS_ARGS  Extra args passed to csvlens preview"
        "LSY_GLOW_ARGS  Extra args passed to glow markdown preview"
        "LSY_EZA_*    Configure eza renderer"
        "LSY_LSD_*    Configure lsd renderer"
        ""
        "Bookmarks"
        "${KEY_HOME_DIR}            Go to home directory"
        "1-9          Jump to bookmark (LSY_BOOKMARK_1..9)"
        "LSY_BOOKMARK_*  Set bookmark paths in your shell profile"
      )

      _lsy_fmt_help_cell() {
        local cell="$1"
        local width="$2"
        local key_col=12
        (( width < 1 )) && return
        if [[ -z "$cell" ]]; then
          printf "%-*s" "$width" ""
          return
        fi
        if [[ "$cell" != *"  "* ]]; then
          printf "\033[1;36m%-*s\033[0m" "$width" "${cell:0:$width}"
          return
        fi
        local key="${cell%%  *}"
        local desc="${cell#"$key"}"
        while [[ "$desc" == ' '* ]]; do desc="${desc# }"; done
        local desc_col=$(( width - key_col - 2 ))
        (( desc_col < 0 )) && desc_col=0
        printf "\033[1;33m%-*s\033[0m  %-*s" "$key_col" "${key:0:$key_col}" "$desc_col" "${desc:0:$desc_col}"
      }

      local max_lines left_line right_line
      max_lines=${#left_col[@]}
      (( ${#right_col[@]} > max_lines )) && max_lines=${#right_col[@]}
      for (( i=0; i<max_lines; i++ )); do
        left_line="${left_col[$i]-}"
        right_line="${right_col[$i]-}"
        printf "%s%s%s\n" \
          "$(_lsy_fmt_help_cell "${left_line:0:$left_width}" "$left_width")" \
          "$divider" \
          "$(_lsy_fmt_help_cell "${right_line:0:$right_width}" "$right_width")"
      done

      printf "\n\033[2mPress any key to return...\033[0m"
      read_key >/dev/null || true
      draw_ui
    }

    main() {
      parse_args "$@"
      detect_sources

      orig_stty=$(stty -g)
      trap cleanup EXIT
      trap on_resize SIGWINCH

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"

      on_resize
      load_data
      draw_ui

      while true; do
        local key
        local old_cursor old_top
        key="$(read_key || true)"
        [[ -z "$key" ]] && continue

        case "$key" in
          "$KEY_QUIT")
            break
            ;;
          "$KEY_RELOAD")
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_HIDDEN")
            if (( show_hidden )); then
              show_hidden=0
            else
              show_hidden=1
            fi
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_SOURCE")
            cycle_list_source
            load_data
            draw_ui
            ;;
          "$KEY_TOGGLE_NAME_FIRST")
            if (( NAME_FIRST_VIEW )); then
              NAME_FIRST_VIEW=0
            else
              NAME_FIRST_VIEW=1
            fi
            load_data
            draw_ui
            ;;
          "$KEY_SELECT_TOGGLE"|$'\e[2~'|$'\e[L')
            old_cursor=$cursor
            old_top=$top
            toggle_selection_current || true
            if (( cursor + 1 < ${#ROWS_COLOR[@]} )); then
              ((cursor++))
              if (( cursor >= top + visible_rows )); then
                top=$(( cursor - visible_rows + 1 ))
              fi
            fi

            if (( top == old_top + 1 && cursor == old_cursor + 1 )); then
              scroll_list_once down
              redraw_row_at_index "$old_cursor"
              redraw_row_at_index "$cursor"
              draw_status
            elif (( top != old_top || cursor != old_cursor )); then
              redraw_row_at_index "$old_cursor"
              redraw_row_at_index "$cursor"
              draw_status
            else
              redraw_row_at_index "$old_cursor"
              draw_status
            fi
            ;;
          "$KEY_SELECT_ALL")
            toggle_select_all
            redraw_visible_rows_and_status
            ;;
          "$KEY_COPY")
            if set_clipboard_from_current_or_selection copy; then
              draw_status
            else
              draw_status
              printf "\033[%d;1H\033[K\033[2mCopy failed: no valid source paths in current selection.\033[0m" "$rows"
            fi
            ;;
          "$KEY_MOVE")
            if set_clipboard_from_current_or_selection move; then
              draw_status
            else
              draw_status
              printf "\033[%d;1H\033[K\033[2mMove failed: no valid source paths in current selection.\033[0m" "$rows"
            fi
            ;;
          "$KEY_DELETE")
            delete_current_or_selected
            ;;
          "$KEY_PASTE")
            paste_clipboard_items || true
            ;;
          "$KEY_UP")
            old_cursor=$cursor
            old_top=$top
            move_up
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top - 1 && cursor == old_cursor - 1 )); then
                scroll_list_once up
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_DOWN")
            old_cursor=$cursor
            old_top=$top
            move_down
            if (( cursor != old_cursor || top != old_top )); then
              if (( top == old_top + 1 && cursor == old_cursor + 1 )); then
                scroll_list_once down
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
                draw_status
              elif (( top != old_top )); then
                draw_ui
              else
                redraw_row_at_index "$old_cursor"
                redraw_row_at_index "$cursor"
              fi
            fi
            ;;
          "$KEY_PGUP")
            page_up
            draw_ui
            ;;
          "$KEY_PGDN")
            page_down
            draw_ui
            ;;
          "$KEY_LEFT")
            go_parent_dir || true
            ;;
          "$KEY_RIGHT")
            enter_or_open_selected || true
            ;;
          "$KEY_OPEN_LESS")
            open_selected_with_less || true
            ;;
          "$KEY_OPEN_GUI")
            open_selected_with_gui || true
            ;;
          "$KEY_OPEN_EDITOR")
            open_selected_with_editor || true
            ;;
          "$KEY_EXTRACT_ZIP")
            handle_zip_action || true
            ;;
          "$KEY_HOME"|$'\e[1~')
            cursor=0
            top=0
            draw_ui
            ;;
          "$KEY_INTEGRATIONS")
            show_integrations
            ;;
          "$KEY_HELP")
            show_help
            ;;
          "$KEY_END"|$'\e[4~')
            if (( ${#ROWS_COLOR[@]} > 0 )); then
              cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
              top=$(( cursor - visible_rows + 1 ))
              (( top < 0 )) && top=0
            fi
            draw_ui
            ;;
          "$KEY_HOME_DIR")
            navigate_to_dir "$HOME"
            ;;
          '1'|'2'|'3'|'4'|'5'|'6'|'7'|'8'|'9')
            jump_to_bookmark "$key"
            ;;
        esac
      done
    }

    main "$@"
