              if (( HAS_EZA )); then
                LAST_SOURCE_FALLBACK_TO=eza
              elif (( HAS_LSD )); then
                LAST_SOURCE_FALLBACK_TO=lsd
              elif (( HAS_LOGO_LS )); then
