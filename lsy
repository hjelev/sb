    run_age_encrypt_with_passphrase() {
      local input_file="$1"
      local output_file="$2"
      local passphrase="$3"
      local q_input q_output

      if command -v script >/dev/null 2>&1; then
        printf -v q_input '%q' "$input_file"
        printf -v q_output '%q' "$output_file"
        printf '%s\n%s\n' "$passphrase" "$passphrase" | script -q -c "age -p -o $q_output -- $q_input" /dev/null >/dev/null 2>&1
        return $?
      fi

      AGE_PASSPHRASE="$passphrase" age -p -o "$output_file" -- "$input_file" >/dev/null 2>&1
      return $?
    }

    run_age_decrypt_with_passphrase() {
      local input_file="$1"
      local output_file="$2"
      local passphrase="$3"
      local q_input q_output

      if command -v script >/dev/null 2>&1; then
        printf -v q_input '%q' "$input_file"
        printf -v q_output '%q' "$output_file"
        printf '%s\n' "$passphrase" | script -q -c "age -d -o $q_output -- $q_input" /dev/null >/dev/null 2>&1
