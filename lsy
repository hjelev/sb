    toggle_age_protection_current() {
      local item output_name rc passphrase passphrase_confirm

      if (( !HAS_AGE )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mAge unavailable: install/enable age in integrations.\033[0m" "$rows"
        return 1
      fi

      item="$(selected_path)" || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mAge action failed: no current file.\033[0m" "$rows"
        return 1
      }

      if [[ ! -f "$item" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mAge action requires a regular file.\033[0m" "$rows"
        return 1
      fi

      if is_age_file "$item"; then
        output_name="${item%.age}"
        [[ -n "$output_name" ]] || output_name="decrypted"

        if [[ -e "$output_name" || -L "$output_name" ]]; then
          output_name="$(read_line_prompt "Decrypt as: " "$output_name")"
          output_name="$(sanitize_filename_input "$output_name")"
