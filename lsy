      fi

      mount_archive="$archive_abs"
      [[ "$mount_archive" == -* ]] && mount_archive="./$mount_archive"
      if err="$(fuse-zip "${fuse_zip_args[@]}" "$mount_archive" "$mountpoint" 2>&1)"; then
        store_zip_mount "$archive_abs" "$mountpoint"
        ZIP_MOUNT_ORDER+=("$mountpoint")
      else
