    usage() {
      cat <<'EOF'
Usage: lsy [--export-path FILE] [--help]

Options:
  --export-path FILE  Write final working directory to FILE on exit.
  --help              Show this help text and exit.
EOF
    }

    parse_args() {
      while (($# > 0)); do
        case "$1" in
          --export-path)
            if [[ -z "${2-}" ]]; then
              echo "Error: --export-path requires a file path." >&2
              exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
          --help)
            usage
            exit 0
            ;;
          *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
        esac
      done
    }

    init_runtime_config() {
      if [[ "$LSY_SHOW_DEBUG_FOOTER" == "1" ]]; then
        SHOW_DEBUG_FOOTER=1
      else
        SHOW_DEBUG_FOOTER=0
      fi
    }

    detect_runtime_capabilities() {
      local uname_s now_value

      uname_s="$(uname -s 2>/dev/null || printf '')"
      [[ "$uname_s" == "Darwin" ]] && IS_DARWIN=1 || IS_DARWIN=0

      if ls --version >/dev/null 2>&1; then
        HAS_GNU_LS=1
      else
        HAS_GNU_LS=0
      fi

      now_value="$(date +%s%N 2>/dev/null || printf '')"
      if [[ "$now_value" =~ ^[0-9]+$ && "$now_value" != *N* ]]; then
        HAS_DATE_NANOSECONDS=1
      else
        HAS_DATE_NANOSECONDS=0
      fi
    }

    append_array_value() {
      local array_name="$1"
      local value="$2"
      eval "$array_name+=(\"\$value\")"
    }

    read_stdin_into_array() {
      local array_name="$1"
      local line

      eval "$array_name=()"
      while IFS= read -r line || [[ -n "$line" ]]; do
        append_array_value "$array_name" "$line"
      done
    }

    lowercase_string() {
      printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
    }

    now_epoch_ns() {
      if (( HAS_DATE_NANOSECONDS )); then
        date +%s%N
      else
        printf '%s000000000' "$(date +%s)"
      fi
    }

    safe_command_path() {
      local path="$1"
      if [[ "$path" == -* ]]; then
        printf './%s' "$path"
      else
        printf '%s' "$path"
      fi
    }

    path_basename() {
      basename "$(safe_command_path "$1")"
    }

    path_dirname() {
      dirname "$(safe_command_path "$1")"
    }

    run_mkdir_p() {
      mkdir -p "$(safe_command_path "$1")"
    }

    run_mkdir() {
      mkdir "$(safe_command_path "$1")"
    }

    run_touch_path() {
      touch "$(safe_command_path "$1")"
    }

    run_rmdir() {
      rmdir "$(safe_command_path "$1")"
    }

    run_rm_rf() {
      rm -rf "$(safe_command_path "$1")"
    }

    run_mv_path() {
      mv "$(safe_command_path "$1")" "$(safe_command_path "$2")"
    }

    run_cp_recursive() {
      cp -R "$(safe_command_path "$1")" "$(safe_command_path "$2")"
    }

    integration_is_disabled() {
      local tool="$1"
      local entry

      if (( HAS_ASSOC_ARRAYS )); then
        [[ -n "${DISABLED_INTEGRATIONS[$tool]+x}" ]]
        return
      fi

      for entry in "${DISABLED_INTEGRATIONS[@]}"; do
        [[ "$entry" == "$tool" ]] && return 0
      done
      return 1
    }

    disable_integration() {
      local tool="$1"

      integration_is_disabled "$tool" && return 0
      if (( HAS_ASSOC_ARRAYS )); then
        DISABLED_INTEGRATIONS[$tool]=1
      else
        DISABLED_INTEGRATIONS+=("$tool")
      fi
    }

    enable_integration() {
      local tool="$1"
      local i
      local -a remaining=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'DISABLED_INTEGRATIONS[$tool]'
        return 0
      fi

      for i in "${!DISABLED_INTEGRATIONS[@]}"; do
        [[ "${DISABLED_INTEGRATIONS[$i]}" == "$tool" ]] && continue
        remaining+=("${DISABLED_INTEGRATIONS[$i]}")
      done
      DISABLED_INTEGRATIONS=("${remaining[@]}")
    }

    selected_path_is_marked() {
      local path="$1"
      local entry

      if (( HAS_ASSOC_ARRAYS )); then
        [[ -n "${SELECTED_PATHS[$path]+x}" ]]
        return
      fi

      for entry in "${SELECTED_PATHS[@]}"; do
        [[ "$entry" == "$path" ]] && return 0
      done
      return 1
    }

    mark_selected_path() {
      local path="$1"

      selected_path_is_marked "$path" && return 0
      if (( HAS_ASSOC_ARRAYS )); then
        SELECTED_PATHS[$path]=1
      else
        SELECTED_PATHS+=("$path")
      fi
    }

    unmark_selected_path() {
      local path="$1"
      local i
      local -a remaining=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'SELECTED_PATHS[$path]'
        return 0
      fi

      for i in "${!SELECTED_PATHS[@]}"; do
        [[ "${SELECTED_PATHS[$i]}" == "$path" ]] && continue
        remaining+=("${SELECTED_PATHS[$i]}")
      done
      SELECTED_PATHS=("${remaining[@]}")
    }

    update_selected_count() {
