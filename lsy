  printf "\033[%d;1H\033[K\033[2mDelete: ok:%d fail:%d skip:%d\033[0m" "$rows" "$ok_count" "$fail_count" "$skip_count"
  return 0
}

    bulk_rename_selected_with_vidir() {
      local -a items=()
      local -a existing_items=()
      local -a old_names=()
      local -a new_for_old=()
      local -a mapped=()
      local -a phase_old=()
      local -a phase_new=()
      local -a phase_tmp=()
      local item old_name new_name tmp_name link_target target_base err
      local tmpdir old_count new_count=0 changed_count=0
      local i j idx found in_selected

      if (( !HAS_VIDIR )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename unavailable: vidir is not installed or disabled in integrations.\033[0m" "$rows"
        return 1
      fi

      if (( SELECTED_COUNT < 2 )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename needs at least 2 selected items.\033[0m" "$rows"
        return 1
      fi

      read_stdin_into_array items < <(collect_selected_paths_in_row_order)
      (( ${#items[@]} > 0 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename failed: no valid selected paths.\033[0m" "$rows"
        return 1
      }

      for item in "${items[@]}"; do
        if [[ -e "$item" || -L "$item" ]]; then
          existing_items+=("$item")
          old_names+=("$(path_basename "$item")")
        fi
      done

      (( ${#existing_items[@]} > 1 )) || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename needs at least 2 existing selected items.\033[0m" "$rows"
        return 1
      }

      old_count=${#old_names[@]}
      for (( i=0; i<old_count; i++ )); do
        new_for_old+=("${old_names[$i]}")
        mapped+=(0)
      done

      tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/lsy-vidir-rename.XXXXXX")" || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename failed: cannot create temporary workspace.\033[0m" "$rows"
        return 1
      }

      for old_name in "${old_names[@]}"; do
        if ! ln -s -- "$(pwd -P)/$old_name" "$tmpdir/$old_name" 2>/dev/null; then
          run_rm_rf "$tmpdir" >/dev/null 2>&1 || true
          draw_status
          printf "\033[%d;1H\033[K\033[2mBulk rename failed: cannot prepare temp entries for vidir.\033[0m" "$rows"
          return 1
        fi
      done

      run_interactive_command vidir "$tmpdir"

      while IFS= read -r -d '' item; do
        new_name="${item##*/}"
        link_target="$(readlink "$item" 2>/dev/null || true)"
        [[ -n "$link_target" ]] || continue
        target_base="$(path_basename "$link_target")"
        found=-1
        for i in "${!old_names[@]}"; do
          if [[ "${old_names[$i]}" == "$target_base" ]]; then
            found=$i
            break
          fi
        done
        (( found >= 0 )) || continue
        new_for_old[$found]="$new_name"
        mapped[$found]=1
        ((new_count++))
      done < <(find "$tmpdir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null)

      run_rm_rf "$tmpdir" >/dev/null 2>&1 || true

      if (( new_count != old_count )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename cancelled: all selected items must remain listed in vidir.\033[0m" "$rows"
        return 1
      fi

      for i in "${!mapped[@]}"; do
        if (( mapped[$i] == 0 )); then
          draw_status
          printf "\033[%d;1H\033[K\033[2mBulk rename cancelled: selection mapping became invalid.\033[0m" "$rows"
          return 1
        fi
      done

      for i in "${!new_for_old[@]}"; do
        new_name="$(sanitize_filename_input "${new_for_old[$i]}")"
        new_for_old[$i]="$new_name"
        if [[ -z "$new_name" || "$new_name" == */* ]]; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mBulk rename failed: names must be non-empty and cannot contain '/'.\033[0m" "$rows"
          return 1
        fi
      done

      for i in "${!new_for_old[@]}"; do
        for j in "${!new_for_old[@]}"; do
          (( i == j )) && continue
          if [[ "${new_for_old[$i]}" == "${new_for_old[$j]}" ]]; then
            draw_status
            printf "\033[%d;1H\033[K\033[2mBulk rename failed: duplicate target name '%s'.\033[0m" "$rows" "${new_for_old[$i]}"
            return 1
          fi
        done
      done

      for i in "${!old_names[@]}"; do
        old_name="${old_names[$i]}"
        new_name="${new_for_old[$i]}"
        [[ "$new_name" == "$old_name" ]] && continue
        ((changed_count++))
        if [[ -e "$new_name" || -L "$new_name" ]]; then
          in_selected=0
          for item in "${old_names[@]}"; do
            if [[ "$item" == "$new_name" ]]; then
              in_selected=1
              break
            fi
          done
          if (( !in_selected )); then
            draw_status
            printf "\033[%d;1H\033[K\033[2mBulk rename failed: target exists: %s\033[0m" "$rows" "$new_name"
            return 1
          fi
        fi
      done

      if (( changed_count == 0 )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mBulk rename cancelled: no name changes.\033[0m" "$rows"
        return 1
      fi

      for i in "${!old_names[@]}"; do
        old_name="${old_names[$i]}"
        new_name="${new_for_old[$i]}"
        [[ "$new_name" == "$old_name" ]] && continue
        tmp_name=".lsy-vidir-tmp.$$.$RANDOM.$i"
        while [[ -e "$tmp_name" || -L "$tmp_name" ]]; do
          tmp_name=".lsy-vidir-tmp.$$.$RANDOM.$i"
        done
        if ! err="$(run_mv_path "$old_name" "$tmp_name" 2>&1)"; then
          for (( idx=${#phase_tmp[@]}-1; idx>=0; idx-- )); do
            run_mv_path "${phase_tmp[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
          done
          draw_status
          printf "\033[%d;1H\033[K\033[2mBulk rename failed during staging: %s\033[0m" "$rows" "$err"
          return 1
        fi
        phase_old+=("$old_name")
        phase_new+=("$new_name")
        phase_tmp+=("$tmp_name")
      done

      for i in "${!phase_tmp[@]}"; do
        if ! err="$(run_mv_path "${phase_tmp[$i]}" "${phase_new[$i]}" 2>&1)"; then
          for (( idx=i; idx<${#phase_tmp[@]}; idx++ )); do
            if [[ -e "${phase_tmp[$idx]}" || -L "${phase_tmp[$idx]}" ]]; then
              run_mv_path "${phase_tmp[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
            fi
          done
          for (( idx=i-1; idx>=0; idx-- )); do
            if [[ -e "${phase_new[$idx]}" || -L "${phase_new[$idx]}" ]]; then
              run_mv_path "${phase_new[$idx]}" "${phase_old[$idx]}" >/dev/null 2>&1 || true
            fi
          done
          draw_status
          printf "\033[%d;1H\033[K\033[2mBulk rename failed during apply: %s\033[0m" "$rows" "$err"
          return 1
        fi
      done

      clear_selection
      load_data
      position_cursor_for_name "${new_for_old[0]}" >/dev/null 2>&1 || true
      draw_ui
      printf "\033[%d;1H\033[K\033[2mBulk rename complete (vidir): renamed %d selected item(s).\033[0m" "$rows" "$changed_count"
      return 0
    }

    rename_current_or_selected() {
      if (( SELECTED_COUNT > 1 )); then
        bulk_rename_selected_with_vidir
        return $?
      fi

      rename_current_entry
      return $?
    }

    rename_current_entry() {
      local src src_name parent_dir new_name dest err

      src="$(current_row_path)" || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename failed: no valid item on current row.\033[0m" "$rows"
        return 1
      }

      if [[ ! -e "$src" && ! -L "$src" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename failed: selected item no longer exists.\033[0m" "$rows"
        return 1
      fi

      src_name="$(path_basename "$src")"
      new_name="$(read_line_prompt "Rename '${src_name}' to: " "$src_name")"
      new_name="$(sanitize_filename_input "$new_name")"
      [[ -n "$new_name" ]] || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename cancelled.\033[0m" "$rows"
        return 1
      }

      if [[ "$new_name" == "$src_name" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename unchanged: %s\033[0m" "$rows" "$src_name"
        return 0
      fi

      if [[ "$new_name" == */* ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename failed: use a name only (no '/').\033[0m" "$rows"
        return 1
      fi

      parent_dir="$(path_dirname "$src")"
      dest="$parent_dir/$new_name"
      if [[ -e "$dest" || -L "$dest" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mRename failed: target exists: %s\033[0m" "$rows" "$new_name"
        return 1
      fi

      if ! err="$(run_mv_path "$src" "$dest" 2>&1)"; then
        draw_status
        if [[ -n "$err" ]]; then
          printf "\033[%d;1H\033[K\033[2mRename failed: %s\033[0m" "$rows" "$err"
        else
          printf "\033[%d;1H\033[K\033[2mRename failed: %s\033[0m" "$rows" "$src_name"
        fi
        return 1
      fi

      load_data
      position_cursor_for_name "$new_name" >/dev/null 2>&1 || true
      draw_ui
      printf "\033[%d;1H\033[K\033[2mRenamed: %s -> %s\033[0m" "$rows" "$src_name" "$new_name"
      return 0
    }

    create_entry_from_prompt() {
      local kind="$1"
      local prompt label name target display_name err

      if [[ "$kind" == "dir" ]]; then
        prompt="New folder name: "
        label="Folder"
      else
        prompt="New file name: "
        label="File"
      fi

      name="$(read_line_prompt "$prompt" "")"
      name="$(sanitize_filename_input "$name")"
      [[ -n "$name" ]] || {
        draw_status
        printf "\033[%d;1H\033[K\033[2m%s creation cancelled.\033[0m" "$rows" "$label"
        return 1
      }

      target="${name/#\~/$HOME}"
      if [[ "$target" != /* ]]; then
        target="$(pwd -P)/$target"
      fi

      if [[ -e "$target" || -L "$target" ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2m%s exists: %s\033[0m" "$rows" "$label" "$name"
        return 1
      fi

      if [[ "$kind" == "dir" ]]; then
        if ! err="$(run_mkdir "$target" 2>&1)"; then
          draw_status
          if [[ -n "$err" ]]; then
            printf "\033[%d;1H\033[K\033[2mCreate folder failed: %s\033[0m" "$rows" "$err"
          else
            printf "\033[%d;1H\033[K\033[2mCreate folder failed: %s\033[0m" "$rows" "$name"
          fi
          return 1
        fi
      else
        if ! err="$(run_touch_path "$target" 2>&1)"; then
          draw_status
          if [[ -n "$err" ]]; then
            printf "\033[%d;1H\033[K\033[2mCreate file failed: %s\033[0m" "$rows" "$err"
          else
            printf "\033[%d;1H\033[K\033[2mCreate file failed: %s\033[0m" "$rows" "$name"
          fi
          return 1
        fi
      fi

      display_name="$(path_basename "$target")"
      load_data
      position_cursor_for_name "$display_name" >/dev/null 2>&1 || true
      draw_ui
      printf "\033[%d;1H\033[K\033[2m%s created: %s\033[0m" "$rows" "$label" "$display_name"
      return 0
    }

    # Reorder long-list rows to `name metadata...` using awk+column alignment.
    # Minimal modification: split on date-time anchor, reorder, let column handle alignment.
    format_name_first_aligned() {
      local term_cols width_pct name_limit name_min_soft name_max_cap
      term_cols=$cols
      (( term_cols < 1 )) && term_cols=1

      if [[ "$LSY_NAMEFIRST_WIDTH_PCT" =~ ^[0-9]+$ ]]; then
        width_pct=$LSY_NAMEFIRST_WIDTH_PCT
      else
        width_pct=35
      fi

      if [[ "$LSY_NAMEFIRST_NAME_MIN" =~ ^[0-9]+$ ]]; then
        name_min_soft=$LSY_NAMEFIRST_NAME_MIN
      else
        name_min_soft=12
      fi

      if [[ "$LSY_NAMEFIRST_NAME_MAX" =~ ^[0-9]+$ ]]; then
        name_max_cap=$LSY_NAMEFIRST_NAME_MAX
      else
        name_max_cap=64
      fi

      (( width_pct < 1 )) && width_pct=1
      (( width_pct > 100 )) && width_pct=100
      (( name_min_soft < 1 )) && name_min_soft=1
      (( name_max_cap < 1 )) && name_max_cap=1
      (( name_max_cap < name_min_soft )) && name_max_cap=$name_min_soft

      name_limit=$(( (term_cols * width_pct) / 100 ))
      (( name_limit < name_min_soft )) && name_limit=$name_min_soft
      (( name_limit > name_max_cap )) && name_limit=$name_max_cap
      (( name_limit > term_cols )) && name_limit=$term_cols

      awk \
        -v name_limit="$name_limit" \
        -v list_source="$LIST_SOURCE" \
        -v debug_logo="$LSY_DEBUG_LOGO_NAMEFIRST" \
        -v debug_file="$LSY_DEBUG_LOGO_FILE" '
        BEGIN {
          esc = sprintf("%c", 27) "\\[[0-9;:]*m"
          dt_iso_plain = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9][[:space:]]+[0-9][0-9]:[0-9][0-9][[:space:]]+"
          dt_rfc3339_plain = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9][^ ]*[[:space:]]+"
          dt_stamp_plain = "[A-Za-z][A-Za-z][A-Za-z][[:space:]]+[0-9][0-9]?[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))[[:space:]]+"
          # Separate patterns for ISO, RFC3339, and Stamp (logo-ls default) timestamps.
          # Keeping them separate avoids complex nested alternation issues across awk implementations.
          dt_iso     = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*[[:space:]]+(" esc ")*[0-9][0-9]:[0-9][0-9](" esc ")*[[:space:]]+"
          # After the seconds, [^ ]* eats the timezone (+HH:MM, -HH:MM, Z) plus any trailing ANSI codes.
          dt_rfc3339 = "[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9](" esc ")*T[0-9][0-9]:[0-9][0-9]:[0-9][0-9][^ ]*[[:space:]]+"
          dt_stamp   = "[A-Za-z][A-Za-z][A-Za-z](" esc ")*[[:space:]]+[0-9][0-9]?(" esc ")*[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))(" esc ")*[[:space:]]+"
          ellipsis = "..."
          row_count = 0
          logo_dt_mode = 0
          dbg_rows = 0
          if (debug_logo == "1") {
            print "--- logo-namefirst-debug ---" > debug_file
            print "name_limit=" name_limit > debug_file
          }
        }
        function strip_ansi(s, tmp) {
          tmp = s
          gsub(esc, "", tmp)
          return tmp
        }
        function pad_spaces(count, out, i) {
          out = ""
          for (i = 0; i < count; i++) {
            out = out " "
          }
          return out
        }
        function truncate_plain(plain, limit, keep) {
          if (limit <= 0 || length(plain) <= limit) {
            return plain
          }
          keep = limit - length(ellipsis)
          if (keep < 1) keep = 1
          return substr(plain, 1, keep) ellipsis
        }
        function truncate_colored(s, limit, plain, has_ansi, out, keep, i, ch, rest, mlen, m) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (!has_ansi) {
            return truncate_plain(plain, limit)
          }
          if (limit <= 0 || length(plain) <= limit) {
            return s
          }
          keep = limit - length(ellipsis)
          if (keep < 1) keep = 1
          out = ""
          i = 1
          while (i <= length(s) && keep > 0) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                out = out ch m
                i += RLENGTH + 1
                continue
              }
            }
            out = out ch
            i++
            keep--
          }
          return out ellipsis sprintf("%c[0m", 27)
        }
        function take_colored_prefix(s, limit, plain, has_ansi, out, i, ch, rest, m) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (limit <= 0) {
            return ""
          }
          if (!has_ansi) {
            return substr(plain, 1, limit)
          }
          out = ""
          i = 1
          while (i <= length(s) && limit > 0) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                out = out ch m
                i += RLENGTH + 1
                continue
              }
            }
            out = out ch
            i++
            limit--
          }
          return out sprintf("%c[0m", 27)
        }
        function drop_colored_prefix(s, skip, plain, has_ansi, out, i, ch, rest, m, visible) {
          plain = strip_ansi(s)
          has_ansi = (plain != s)
          if (skip <= 0) {
            return s
          }
          if (!has_ansi) {
            return substr(plain, skip + 1)
          }
          out = ""
          i = 1
          visible = 0
          while (i <= length(s)) {
            ch = substr(s, i, 1)
            if (ch == sprintf("%c", 27)) {
              rest = substr(s, i + 1)
              if (match(rest, /^\[[0-9;:]*m/)) {
                m = substr(rest, 1, RLENGTH)
                if (visible >= skip) {
                  out = out ch m
                }
                i += RLENGTH + 1
                continue
              }
            }
            visible++
            if (visible > skip) {
              out = out ch
            }
            i++
          }
          return out
        }
        {
          row_count++
          original[row_count] = $0
          parsed[row_count] = 0

          if (list_source == "logo-ls") {
            plain_row = strip_ansi($0)
            split_mode = "none"
            matched = 0
            if (logo_dt_mode == 1 && match(plain_row, dt_iso_plain)) {
              matched = 1
            } else if (logo_dt_mode == 2 && match(plain_row, dt_rfc3339_plain)) {
              matched = 1
            } else if (logo_dt_mode == 3 && match(plain_row, dt_stamp_plain)) {
              matched = 1
            } else if (match(plain_row, dt_iso_plain)) {
              logo_dt_mode = 1
              matched = 1
            } else if (match(plain_row, dt_rfc3339_plain)) {
              logo_dt_mode = 2
              matched = 1
            } else if (match(plain_row, dt_stamp_plain)) {
              logo_dt_mode = 3
              matched = 1
            }

            if (matched) {
              split_end = RSTART + RLENGTH - 1
              meta = take_colored_prefix($0, split_end)
              name = drop_colored_prefix($0, split_end)
              split_mode = "date"
            }

            if (split_mode != "none") {

              plain_name = strip_ansi(name)
              if (match(plain_name, /^[[:space:]]+/)) {
                lead_ws = RLENGTH
                name = drop_colored_prefix(name, lead_ws)
                plain_name = substr(plain_name, lead_ws + 1)
              }

              cleaned_plain = plain_name
              sub(/[[:space:]]+\.\.\.[[:space:]]*$/, "", cleaned_plain)
              sub(/[[:space:]]+$/, "", cleaned_plain)
              if (length(cleaned_plain) < length(plain_name)) {
                name = take_colored_prefix(name, length(cleaned_plain))
              }

              if (cleaned_plain == "" || cleaned_plain ~ /^[0-9][0-9]?[[:space:]]+(([0-9][0-9]:[0-9][0-9](:[0-9][0-9])?)|((19|20)[0-9][0-9]))[[:space:]]*$/) {
                parsed[row_count] = 0
                next
              }

              if (debug_logo == "1" && dbg_rows < 12) {
                dbg_rows++
                print "row=" row_count " mode=" split_mode > debug_file
                print "plain=" plain_row > debug_file
                print "name=" cleaned_plain > debug_file
                print "meta=" strip_ansi(meta) > debug_file
              }
              name_col[row_count] = name
              meta_col[row_count] = meta
              parsed[row_count] = 1
            } else if (debug_logo == "1" && dbg_rows < 12) {
              dbg_rows++
              print "row=" row_count " mode=none" > debug_file
              print "plain=" plain_row > debug_file
            }
          } else if (match($0, dt_iso) || match($0, dt_rfc3339) || match($0, dt_stamp)) {
            name = substr($0, RSTART + RLENGTH)
            meta = substr($0, 1, RSTART + RLENGTH - 1)
            name_col[row_count] = name
            meta_col[row_count] = meta
            parsed[row_count] = 1
          }
        }
        END {
          for (i = 1; i <= row_count; i++) {
            if (!parsed[i]) {
              print original[i]
              continue
            }

            disp_name = truncate_colored(name_col[i], name_limit)
            plain_name = strip_ansi(disp_name)
            spacing = name_limit - length(plain_name) + 1
            if (spacing < 1) spacing = 1
            printf "%s%s%s\n", disp_name, pad_spaces(spacing), meta_col[i]
          }
        }
    '
    }

    load_data() {
      local t0 t1 t2

      ROWS_COLOR=()
      ROWS_PLAIN=()
      ROWS_PATH=()
      ROWS_SELECTED=()
      DUST_ROW_PATHS=()

      t0=$(now_epoch_ns)
      capture_directory_rows || true
      t1=$(now_epoch_ns)
      LAST_LS_MS=$(( (t1 - t0) / 1000000 ))
      LAST_PARSE_MS=0
      LAST_LOAD_MS=$LAST_LS_MS
      ENTRY_COUNT=${#ROWS_COLOR[@]}

      if (( ${#ROWS_COLOR[@]} == 0 )); then
        ROWS_COLOR=("\033[2m(empty directory)\033[0m")
        ROWS_PLAIN=("(empty directory)")
        ROWS_SELECT_PLAIN=("(empty directory)")
        update_git_header_suffix
        cursor=0
        top=0
        return
      fi

      # Keep a stable plain array for path extraction before any display reformatting.
      read_stdin_into_array ROWS_SELECT_PLAIN < <(printf '%s\n' "${ROWS_COLOR[@]}" | sed -E $'s/\x1B\[[0-9;:]*m//g')

      if (( NAME_FIRST_VIEW )); then
        # Reformat only the display rows; selection rows stay in original capture order.
        read_stdin_into_array ROWS_COLOR < <(printf '%s\n' "${ROWS_COLOR[@]}" | format_name_first_aligned)
      fi
      t2=$(now_epoch_ns)
      LAST_PARSE_MS=$(( (t2 - t1) / 1000000 ))
      LAST_LOAD_MS=$(( (t2 - t0) / 1000000 ))

      (( cursor >= ${#ROWS_COLOR[@]} )) && cursor=$(( ${#ROWS_COLOR[@]} - 1 ))
      (( cursor < 0 )) && cursor=0
      (( top > cursor )) && top=$cursor
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
      (( top < 0 )) && top=0

      update_git_header_suffix
    }

    update_git_header_suffix() {
      local current_dir branch dirty="" status_output git_enabled=1
      current_dir="$(pwd -P 2>/dev/null || pwd)"
      integration_is_disabled git && git_enabled=0

      if [[ "$GIT_HEADER_CACHE_PWD" == "$current_dir" && "$GIT_HEADER_CACHE_ENABLED" == "$git_enabled" ]]; then
        GIT_HEADER_SUFFIX="$GIT_HEADER_CACHE_SUFFIX"
        return
      fi

      GIT_HEADER_SUFFIX=""
      if (( !git_enabled )); then
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      fi

      command -v git >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
        GIT_HEADER_CACHE_PWD="$current_dir"
        GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
        GIT_HEADER_CACHE_ENABLED="$git_enabled"
        return
      }

      branch="$(git branch --show-current 2>/dev/null)"
      [[ -z "$branch" ]] && branch="$(git rev-parse --short HEAD 2>/dev/null)"
      if [[ -n "$branch" && "$LSY_GIT_DIRTY_CHECK" == "1" ]]; then
        status_output="$(git status --porcelain=v1 --untracked-files=normal 2>/dev/null)"
        [[ -n "$status_output" ]] && dirty="*"
      fi

      [[ -n "$branch" ]] && GIT_HEADER_SUFFIX=" (${branch}${dirty})"
      GIT_HEADER_CACHE_PWD="$current_dir"
      GIT_HEADER_CACHE_SUFFIX="$GIT_HEADER_SUFFIX"
      GIT_HEADER_CACHE_ENABLED="$git_enabled"
    }

    draw_header() {
      local user host cwd dust_segment=""
      local separator_width
      local separator
      user="${USER:-$(id -un 2>/dev/null || printf 'user')}"
      host="${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'host')}"
      cwd="$(pwd -P 2>/dev/null || pwd)"
      if [[ "$LIST_SOURCE" == "dust" && -n "$DUST_TOTAL" ]]; then
        dust_segment=" [dust:${DUST_TOTAL}]"
      fi
      separator_width=$cols
      (( separator_width < 1 )) && separator_width=1

      printf "\033[1;36m"
      printf "%s\n" "${user}@${host} » ${cwd}${GIT_HEADER_SUFFIX}${dust_segment}"
      printf "\033[0m"
      printf -v separator '%*s' "$separator_width" ''
      separator=${separator// /─}
      printf '%s\033[K\n' "$separator"
    }

    draw_row() {
      local i="$1"
      local selected="$2"
      local row
      local row_plain

      if (( i < 0 || i >= ${#ROWS_COLOR[@]} )); then
        printf "\033[K\n"
        return
      fi

      row="${ROWS_COLOR[$i]}"
      row_plain="${ROWS_PLAIN[$i]-}"
      if [[ -z "$row_plain" ]]; then
        row_plain="$(strip_ansi_for_display "$row")"
        ROWS_PLAIN[$i]="$row_plain"
      fi

      if (( selected )); then
        printf "\033[7m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      if [[ "${ROWS_SELECTED[$i]-0}" == "1" ]]; then
        printf "\033[48;5;24m%s\033[0m\033[K\n" "$row_plain"
        return
      fi

      printf "%s\033[K\n" "$row"
    }

    strip_ansi_for_display() {
      local text="$1"
      local esc=$'\033'
      local ansi_re

      ansi_re="${esc}\\[[0-9:;]*m"

      while [[ "$text" =~ $ansi_re ]]; do
        text="${text//${BASH_REMATCH[0]}/}"
      done

      printf '%s' "$text"
    }

    draw_status() {
      local total="$ENTRY_COUNT"
      local status_row=$rows
      local hidden_state="off"
      local source_state="$LIST_SOURCE"
      local layout_state="meta-first"
      local debug_state=""
      local selection_state="$SELECTED_COUNT"
      local clipboard_state="$CLIPBOARD_LABEL"
      local base_state=""
      (( show_hidden )) && hidden_state="on"
      (( NAME_FIRST_VIEW )) && layout_state="name-first"

      base_state="[total:%d sel:%s clip:%s] help:%s"

      if (( SHOW_DEBUG_FOOTER )); then
        debug_state=" renderer:${source_state} layout:${layout_state} hidden:${hidden_state} load:${LAST_LOAD_MS}ms (ls:${LAST_LS_MS} parse:${LAST_PARSE_MS})"

        if [[ "$LSY_DEBUG_SOURCE" == "1" ]]; then
          debug_state+=" dbg:req:${LAST_SOURCE_REQUESTED} run:${LAST_SOURCE_EXECUTED} rc:${LAST_SOURCE_RC}"
          if (( LAST_SOURCE_FALLBACK )); then
            debug_state+=" fb:${LAST_SOURCE_FALLBACK_TO}"
          fi
          if [[ "$LSY_DEBUG_SHOW_CMD" == "1" ]]; then
            debug_state+=" cmd:${LAST_SOURCE_ARGS}"
          fi
        fi

        if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
          debug_state+=" clip:${LAST_CLIP_MODE} req:${LAST_CLIP_REQUESTED} ok:${LAST_CLIP_RESOLVED} drop:${LAST_CLIP_DROPPED}"
          debug_state+=" paste:${LAST_PASTE_OP} rc:${LAST_PASTE_RC} ok:${LAST_PASTE_OK} fail:${LAST_PASTE_FAIL} skip:${LAST_PASTE_SKIP}"
          if [[ -n "$LAST_PASTE_ERR" && "$LAST_PASTE_ERR" != "-" ]]; then
            local err_preview="$LAST_PASTE_ERR"
            if (( ${#err_preview} > 72 )); then
              err_preview="${err_preview:0:69}..."
            fi
            debug_state+=" err:${err_preview}"
          fi
        fi
      fi

      # Keep footer anchored regardless of current cursor location.
      # Disable autowrap for the status line so long text never scrolls the screen.
      printf "\033[?7l"
      printf "\033[%d;1H\033[K" "$status_row"
      printf "\033[2m${base_state}%s\033[0m\033[K" "$total" "$selection_state" "$clipboard_state" "$KEY_HELP" "$debug_state"
      printf "\033[?7h"
    }

    scroll_list_once() {
      local direction="$1"
      local top_row=3
      local bottom_row=$((2 + visible_rows))

      printf "\033[%d;%dr" "$top_row" "$bottom_row"
      if [[ "$direction" == "down" ]]; then
        printf "\033[%d;1H\033[M" "$top_row"
      else
        printf "\033[%d;1H\033[L" "$top_row"
      fi
      printf "\033[r"
    }

    redraw_row_at_index() {
      local i="$1"
      local screen_line

      (( i >= top && i < top + visible_rows )) || return
      screen_line=$((3 + i - top))
      printf "\033[%d;1H" "$screen_line"
      if (( i == cursor )); then
        draw_row "$i" 1
      else
        draw_row "$i" 0
      fi
    }

    redraw_visible_rows_and_status() {
      local i
      for (( i=top; i<top + visible_rows; i++ )); do
        redraw_row_at_index "$i"
      done
      draw_status
    }

    draw_ui() {
      printf "\033[H\033[2J"
      draw_header

      local line idx
      for (( line=0; line<visible_rows; line++ )); do
        idx=$(( top + line ))
        if (( idx == cursor )); then
          draw_row "$idx" 1
        else
          draw_row "$idx" 0
        fi
      done

      draw_status
    }

    read_key() {
      local k
      IFS= read -rsn1 k || return 1
      if [[ "$k" == $'\e' ]]; then
        local k2 k3 k4 k5
        IFS= read -rsn1 -t 0.005 k2 || true
        IFS= read -rsn1 -t 0.005 k3 || true
        # Extended sequences like \e[24~ (F12) or \e[5~ (PgUp) carry extra bytes
        if [[ "$k2" == '[' && "$k3" =~ [0-9] ]]; then
          IFS= read -rsn1 -t 0.005 k4 || true
          if [[ "$k4" =~ [0-9] ]]; then
            IFS= read -rsn1 -t 0.005 k5 || true
          fi
        fi
        printf '%s' "$k$k2$k3${k4-}${k5-}"
      else
        printf '%s' "$k"
      fi
      return 0
    }

    move_up() {
      (( cursor > 0 )) || return
      ((cursor--))
      (( cursor < top )) && top=$cursor
    }

    move_down() {
      (( cursor + 1 < ${#ROWS_COLOR[@]} )) || return
      ((cursor++))
      if (( cursor >= top + visible_rows )); then
        top=$(( cursor - visible_rows + 1 ))
      fi
    }

    # Strip symlink target from a name string if the row represents a symlink (l*).
    strip_symlink_target() {
      local plain="$1" name="$2"
      if [[ "$plain" == l* || "$plain" == L* ]]; then
        name="${name%% -> *}"
        name="${name%% ⇒ *}"
        name="${name%% ~> *}"
      fi
      printf '%s' "$name"
    }

    parse_name_from_plain_row() {
      local plain="$1" name
      case "$LIST_SOURCE" in
        ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        lsd|eza)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]](.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          ;;
        dust)
          # Dust output prefixes rows with size and tree glyphs; resolve_row_path_from_plain
          # token-peeling logic will reduce this to an existing path candidate.
          name="$plain"
          ;;
        logo-ls)
          if [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9:]+|Z)[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[2]}"
          elif [[ "$plain" =~ [0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          elif [[ "$plain" =~ [A-Za-z][A-Za-z][A-Za-z][[:space:]]+[[:digit:]]{1,2}[[:space:]]+(([0-9]{2}:[0-9]{2}(:[0-9]{2})?)|([0-9]{4}))[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[5]}"
          elif [[ "$plain" =~ [A-Za-z][A-Za-z][A-Za-z][[:space:]]+[[:digit:]]{1,2}[[:space:]]+[0-9]{4}[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          else
            return 1
          fi
          if [[ "$name" =~ ^(.*[^[:space:]])[[:space:]]+\.\.\.[[:space:]]*$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          if [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./~+-]+[[:space:]]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          if ! path_exists "$name" && [[ "$name" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+(.*)$ ]]; then
            name="${BASH_REMATCH[1]}"
          fi
          name="$(strip_symlink_target "$plain" "$name")"
          # logo-ls appends -F classify suffixes: / (dir), @ (symlink), * (exe), = (socket), | (fifo).
          # Strip them so path resolution works; display is unaffected (drawn from ROWS_COLOR/PLAIN).
          name="${name%/}"
          name="${name%@}"
          name="${name%\*}"
          name="${name%=}"
          name="${name%|}"
          ;;
        *)
          return 1
          ;;
      esac

      printf '%s' "$name"
      return 0
    }

    path_exists() {
      local p="$1"
      [[ -e "$p" || -L "$p" ]]
    }

    normalize_candidate_path() {
      local value="$1"

      # Trim leading/trailing whitespace.
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"

      # Remove renderer symlink target tails.
      value="${value%% -> *}"
      value="${value%% ⇒ *}"
      value="${value%% ~> *}"

      # Remove logo-ls classify suffixes.
      value="${value%/}"
      value="${value%@}"
      value="${value%\*}"
      value="${value%=}"
      value="${value%|}"

      # Some icon themes glue glyphs directly to names; peel non-path glyphs.
      while [[ "$value" =~ ^[[:space:]]*[^[:alnum:][:space:]./_~+-]+(.*)$ ]]; do
        value="${BASH_REMATCH[1]}"
      done

      # Trim again after normalization.
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"

      printf '%s' "$value"
    }

    resolve_row_path_from_plain() {
      local plain="$1" name candidate
      name="$(parse_name_from_plain_row "$plain" 2>/dev/null || true)"

      if [[ -n "$name" ]]; then
        candidate="$name"
      elif [[ "$LIST_SOURCE" == "logo-ls" ]]; then
        # For logo-ls, fall back to scanning from the full row when parser patterns miss.
        candidate="$plain"
      else
        return 1
      fi

      candidate="$(normalize_candidate_path "$candidate")"
      if path_exists "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi

      # Some renderers can leave icon tokens in plain text; peel leading tokens until path resolves.
      while [[ "$candidate" =~ ^[[:space:]]*[^[:space:]]+[[:space:]]+(.*)$ ]]; do
        candidate="${BASH_REMATCH[1]}"
        candidate="$(normalize_candidate_path "$candidate")"
        [[ -n "$candidate" ]] || break
        if path_exists "$candidate"; then
          printf '%s' "$candidate"
          return 0
        fi
      done

      return 1
    }

    build_row_paths() {
      local plain path i
      ROWS_PATH=()
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        plain="${ROWS_SELECT_PLAIN[$i]}"
        if [[ "$plain" == "(empty directory)" ]]; then
          ROWS_PATH+=("")
          continue
        fi
        if [[ "$LIST_SOURCE" == "dust" && -n "${DUST_ROW_PATHS[$i]-}" ]]; then
          ROWS_PATH+=("${DUST_ROW_PATHS[$i]}")
          continue
        fi
        path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
        ROWS_PATH+=("$path")
      done
    }

    ensure_row_path() {
      local idx="$1"
      local plain path

      if (( idx < 0 || idx >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi

      if [[ -n "${ROWS_PATH[$idx]-}" ]]; then
        printf '%s' "${ROWS_PATH[$idx]}"
        return 0
      fi

      plain="${ROWS_SELECT_PLAIN[$idx]}"
      [[ "$plain" == "(empty directory)" ]] && return 1

      if [[ "$LIST_SOURCE" == "dust" && -n "${DUST_ROW_PATHS[$idx]-}" ]]; then
        ROWS_PATH[$idx]="${DUST_ROW_PATHS[$idx]}"
        printf '%s' "${ROWS_PATH[$idx]}"
        return 0
      fi

      path="$(resolve_row_path_from_plain "$plain" 2>/dev/null || true)"
      [[ -n "$path" ]] || return 1
      ROWS_PATH[$idx]="$path"
      printf '%s' "$path"
      return 0
    }

    ensure_all_row_paths() {
      local i
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        ensure_row_path "$i" >/dev/null 2>&1 || true
      done
    }

    clear_selection() {
      SELECTED_PATHS=()
      update_selected_count
      ROWS_SELECTED=()
    }

    rebuild_row_selection_flags() {
      local i path selected_path still_visible
      local -a current_selected=()

      ensure_all_row_paths
      read_stdin_into_array current_selected < <(print_selected_paths)

      ROWS_SELECTED=()
      for selected_path in "${current_selected[@]}"; do
        still_visible=0
        for i in "${!ROWS_SELECT_PLAIN[@]}"; do
          path="${ROWS_PATH[$i]-}"
          if [[ "$path" == "$selected_path" ]]; then
            still_visible=1
            break
          fi
        done
        (( still_visible )) || unmark_selected_path "$selected_path"
      done

      update_selected_count
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        if [[ -n "$path" ]] && selected_path_is_marked "$path"; then
          ROWS_SELECTED+=(1)
        else
          ROWS_SELECTED+=(0)
        fi
      done
    }

    current_row_path() {
      if (( cursor < 0 || cursor >= ${#ROWS_SELECT_PLAIN[@]} )); then
        return 1
      fi
      ensure_row_path "$cursor"
    }

    toggle_selection_current() {
      local path idx
      idx=$cursor
      path="$(current_row_path)" || return 1

      if selected_path_is_marked "$path"; then
        unmark_selected_path "$path"
        ROWS_SELECTED[$idx]=0
      else
        mark_selected_path "$path"
        ROWS_SELECTED[$idx]=1
      fi

      update_selected_count
      return 0
    }

    toggle_select_all() {
      local i all_selected=1 path
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        if ! selected_path_is_marked "$path"; then
          all_selected=0
          break
        fi
      done

      if (( all_selected )); then
        clear_selection
      else
        for i in "${!ROWS_SELECT_PLAIN[@]}"; do
          [[ -n "${ROWS_PATH[$i]-}" ]] || continue
          mark_selected_path "${ROWS_PATH[$i]}"
        done
        rebuild_row_selection_flags
      fi
    }

    collect_selected_paths_in_row_order() {
      local i path
      local -a collected=()
      ensure_all_row_paths
      for i in "${!ROWS_SELECT_PLAIN[@]}"; do
        path="${ROWS_PATH[$i]-}"
        [[ -n "$path" ]] || continue
        selected_path_is_marked "$path" || continue
        collected+=("$path")
      done
      if (( ${#collected[@]} > 0 )); then
        printf '%s\n' "${collected[@]}"
      fi
    }

    update_clipboard_label() {
      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        CLIPBOARD_LABEL="${#CLIPBOARD_MULTI[@]} items"
      elif [[ -n "$CLIPBOARD_NAME" ]]; then
        CLIPBOARD_LABEL="$CLIPBOARD_NAME"
      else
        CLIPBOARD_LABEL="none"
      fi
    }

    set_clipboard_from_current_or_selection() {
      local mode="$1"
      local path
      local abs_path
      local requested_count=0
      local -a items=()
      local -a abs_items=()

      LAST_CLIP_MODE="$mode"
      LAST_CLIP_REQUESTED=0
      LAST_CLIP_RESOLVED=0
      LAST_CLIP_DROPPED=0

      if (( SELECTED_COUNT > 0 )); then
        read_stdin_into_array items < <(collect_selected_paths_in_row_order)
      else
        path="$(current_row_path)" || return 1
        items=("$path")
      fi

      (( ${#items[@]} > 0 )) || return 1
      requested_count=${#items[@]}
      LAST_CLIP_REQUESTED=$requested_count
      for path in "${items[@]}"; do
        [[ -n "$path" ]] || continue
        abs_path="$(pwd -P)/$path"
        if path_exists "$path" || path_exists "$abs_path"; then
          abs_items+=("$abs_path")
        fi
      done
      LAST_CLIP_RESOLVED=${#abs_items[@]}
      LAST_CLIP_DROPPED=$(( requested_count - LAST_CLIP_RESOLVED ))
      (( ${#abs_items[@]} > 0 )) || return 1

      if (( ${#abs_items[@]} > 1 )) || [[ "$mode" == "move" ]]; then
        CLIPBOARD_MULTI=("${abs_items[@]}")
        CLIPBOARD_PATH=""
        CLIPBOARD_MOVE=0
        [[ "$mode" == "move" ]] && CLIPBOARD_MOVE=1
        CLIPBOARD_NAME="${#abs_items[@]} items"
      else
        CLIPBOARD_MULTI=()
        CLIPBOARD_MOVE=0
        CLIPBOARD_PATH="${abs_items[0]}"
        CLIPBOARD_NAME="$(path_basename "${abs_items[0]}")"
      fi

      CLIPBOARD_ITEMS=("${abs_items[@]}")
      CLIPBOARD_MODE="$mode"
      update_clipboard_label
      return 0
    }

    paste_clipboard_items() {
      local src dest bname err
      local ok_count=0 fail_count=0 skip_count=0

      LAST_PASTE_OP="-"
      LAST_PASTE_RC=0
      LAST_PASTE_ERR="-"
      LAST_PASTE_OK=0
      LAST_PASTE_FAIL=0
      LAST_PASTE_SKIP=0

      if (( ${#CLIPBOARD_MULTI[@]} > 0 )); then
        if read_yes_no_prompt "Paste ${#CLIPBOARD_MULTI[@]} item(s) here? [y/N]: "; then
          for src in "${CLIPBOARD_MULTI[@]}"; do
            bname="$(path_basename "$src")"
            dest="$bname"
            if [[ -e "$dest" ]]; then
              bname="$(sanitize_filename_input "$bname")"
              dest="$(read_line_prompt "Paste '$bname' as: " "$dest")"
            fi
            dest="$(sanitize_filename_input "$dest")"
            if [[ -z "$dest" ]]; then
              ((skip_count++))
              continue
            fi

            if (( CLIPBOARD_MOVE )); then
              LAST_PASTE_OP="mv"
              if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
                if err="$(run_mv_path "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif run_mv_path "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            else
              LAST_PASTE_OP="cp"
              if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
                if err="$(run_cp_recursive "$src" "$dest" 2>&1)"; then
                  LAST_PASTE_RC=0
                  LAST_PASTE_ERR="-"
                  ((ok_count++))
                else
                  LAST_PASTE_RC=$?
                  LAST_PASTE_ERR="$err"
                  ((fail_count++))
                fi
              elif run_cp_recursive "$src" "$dest" 2>/dev/null; then
                LAST_PASTE_RC=0
                ((ok_count++))
              else
                LAST_PASTE_RC=$?
                ((fail_count++))
              fi
            fi
          done

          LAST_PASTE_OK=$ok_count
          LAST_PASTE_FAIL=$fail_count
          LAST_PASTE_SKIP=$skip_count

          if (( CLIPBOARD_MOVE )); then
            CLIPBOARD_MULTI=()
            CLIPBOARD_MOVE=0
            CLIPBOARD_NAME=""
            clear_selection
          fi

          CLIPBOARD_ITEMS=()
          update_clipboard_label
          load_data
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste: ok:%d fail:%d skip:%d\033[0m" "$rows" "$ok_count" "$fail_count" "$skip_count"
        else
          LAST_PASTE_OP="cancel"
          draw_ui
        fi
        return 0
      fi

      if [[ -n "$CLIPBOARD_PATH" ]]; then
        dest="$CLIPBOARD_NAME"
        if [[ -e "$dest" ]]; then
          dest="$(read_line_prompt "New name: " "$dest")"
        fi
        dest="$(sanitize_filename_input "$dest")"

        LAST_PASTE_OP="cp"
        if [[ "$LSY_DEBUG_PASTE" == "1" ]]; then
          if err="$(run_cp_recursive "$CLIPBOARD_PATH" "$dest" 2>&1)"; then
            LAST_PASTE_RC=0
            LAST_PASTE_ERR="-"
            LAST_PASTE_OK=1
            LAST_PASTE_FAIL=0
            LAST_PASTE_SKIP=0
            load_data
            draw_ui
            printf "\033[%d;1H\033[K\033[2mPaste: ok:1 fail:0 skip:0\033[0m" "$rows"
          else
            LAST_PASTE_RC=$?
            LAST_PASTE_ERR="$err"
            LAST_PASTE_OK=0
            LAST_PASTE_FAIL=1
            LAST_PASTE_SKIP=0
            draw_ui
            printf "\033[%d;1H\033[K\033[2mPaste failed for: %s\033[0m" "$rows" "$dest"
          fi
          return 0
        fi

        if run_cp_recursive "$CLIPBOARD_PATH" "$dest" 2>/dev/null; then
          LAST_PASTE_RC=0
          LAST_PASTE_OK=1
          LAST_PASTE_FAIL=0
          LAST_PASTE_SKIP=0
          load_data
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste: ok:1 fail:0 skip:0\033[0m" "$rows"
        else
          LAST_PASTE_RC=$?
          LAST_PASTE_OK=0
          LAST_PASTE_FAIL=1
          LAST_PASTE_SKIP=0
          draw_ui
          printf "\033[%d;1H\033[K\033[2mPaste failed for: %s\033[0m" "$rows" "$dest"
        fi
        return 0
      fi

      draw_ui
      printf "\033[%d;1H\033[K\033[2mClipboard is empty. Copy or move items first.\033[0m" "$rows"
      return 1
    }

    selected_path() {
      current_row_path
    }

    integration_version_label() {
      local tool="$1"
      local out version

      case "$tool" in
        eza)
          out="$(eza -v 2>&1 || eza --version 2>&1 || true)"
          version="$(printf '%s\n' "$out" | awk '/^v[0-9]/{print; exit}')"
          if [[ -n "$version" ]]; then
            printf 'eza %s' "$version"
          else
            printf '%s\n' "$out" | head -1
          fi
          ;;
        *)
          "$tool" --version 2>&1 | head -1
          ;;
      esac
    }

    sanitize_integration_label() {
      local name="$1"
      local version_raw="$2"
      local clean_name clean_version version_token

      clean_name="$(printf '%s' "$name" | sed -E $'s/\x1B\[[0-9;]*m//g; s/[[:cntrl:]]//g; s/[[:space:]]+/ /g; s/^ //; s/ $//')"
      clean_version="$(printf '%s' "$version_raw" | sed -E $'s/\x1B\[[0-9;]*m//g; s/[[:cntrl:]]//g; s/[[:space:]]+/ /g; s/^ //; s/ $//')"

      case "$clean_version" in
        ""|"not installed")
          printf '%s' "$clean_name"
          return 0
          ;;
        "built-in toggle")
          printf '%s (built-in)' "$clean_name"
          return 0
          ;;
      esac

      version_token="$(printf '%s\n' "$clean_version" | grep -oE 'v?[0-9]+([.][0-9A-Za-z_-]+)+' | head -1 || true)"
      if [[ -n "$version_token" ]]; then
        version_token="${version_token#v}"
        printf '%s (%s)' "$clean_name" "$version_token"
        return 0
      fi

      printf '%s' "$clean_name"
    }

    integration_is_active_tool() {
      local tool="$1"

      case "$tool" in
        "$LIST_SOURCE"|"$FILE_VIEWER")
          return 0
