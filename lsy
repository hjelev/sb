    print_selected_paths() {
      local path

      if (( HAS_ASSOC_ARRAYS )); then
        for path in "${!SELECTED_PATHS[@]}"; do
          printf '%s\n' "$path"
        done
        return 0
      fi

      if (( ${#SELECTED_PATHS[@]} > 0 )); then
        printf '%s\n' "${SELECTED_PATHS[@]}"
      fi
    }

    zip_mount_for_archive() {
      local archive="$1"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        printf '%s' "${ZIP_MOUNT_BY_ARCHIVE[$archive]-}"
        return 0
      fi

      for i in "${!ZIP_MOUNT_ARCHIVES[@]}"; do
        if [[ "${ZIP_MOUNT_ARCHIVES[$i]}" == "$archive" ]]; then
          printf '%s' "${ZIP_MOUNT_POINTS[$i]}"
          return 0
        fi
      done
      return 0
    }

    zip_archive_for_mount() {
      local mountpoint="$1"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        printf '%s' "${ZIP_ARCHIVE_BY_MOUNT[$mountpoint]-}"
        return 0
      fi

      for i in "${!ZIP_ARCHIVE_MOUNTS[@]}"; do
        if [[ "${ZIP_ARCHIVE_MOUNTS[$i]}" == "$mountpoint" ]]; then
          printf '%s' "${ZIP_ARCHIVE_ARCHIVES[$i]}"
          return 0
        fi
      done
      return 0
    }

    store_zip_mount() {
      local archive="$1"
      local mountpoint="$2"
      local i

      if (( HAS_ASSOC_ARRAYS )); then
        ZIP_MOUNT_BY_ARCHIVE[$archive]="$mountpoint"
        ZIP_ARCHIVE_BY_MOUNT[$mountpoint]="$archive"
        return 0
      fi

      for i in "${!ZIP_MOUNT_ARCHIVES[@]}"; do
        if [[ "${ZIP_MOUNT_ARCHIVES[$i]}" == "$archive" ]]; then
          ZIP_MOUNT_POINTS[$i]="$mountpoint"
          return 0
        fi
      done

      ZIP_MOUNT_ARCHIVES+=("$archive")
      ZIP_MOUNT_POINTS+=("$mountpoint")
      ZIP_ARCHIVE_MOUNTS+=("$mountpoint")
      ZIP_ARCHIVE_ARCHIVES+=("$archive")
    }

    remove_zip_mount_by_archive() {
      local archive="$1"
      local i
      local -a archives=() mounts=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'ZIP_MOUNT_BY_ARCHIVE[$archive]'
        return 0
      fi

      for i in "${!ZIP_MOUNT_ARCHIVES[@]}"; do
        [[ "${ZIP_MOUNT_ARCHIVES[$i]}" == "$archive" ]] && continue
        archives+=("${ZIP_MOUNT_ARCHIVES[$i]}")
        mounts+=("${ZIP_MOUNT_POINTS[$i]}")
      done
      ZIP_MOUNT_ARCHIVES=("${archives[@]}")
      ZIP_MOUNT_POINTS=("${mounts[@]}")
    }

    remove_zip_archive_by_mount() {
      local mountpoint="$1"
      local i
      local -a mounts=() archives=()

      if (( HAS_ASSOC_ARRAYS )); then
        unset 'ZIP_ARCHIVE_BY_MOUNT[$mountpoint]'
        return 0
      fi

      for i in "${!ZIP_ARCHIVE_MOUNTS[@]}"; do
        [[ "${ZIP_ARCHIVE_MOUNTS[$i]}" == "$mountpoint" ]] && continue
        mounts+=("${ZIP_ARCHIVE_MOUNTS[$i]}")
        archives+=("${ZIP_ARCHIVE_ARCHIVES[$i]}")
      done
      ZIP_ARCHIVE_MOUNTS=("${mounts[@]}")
      ZIP_ARCHIVE_ARCHIVES=("${archives[@]}")
    }

    collect_directory_entries() {
      local had_nullglob=0
      local had_dotglob=0
      local entry
      local -a dirs=() files=()

      shopt -q nullglob && had_nullglob=1
      shopt -q dotglob && had_dotglob=1

      shopt -s nullglob
      if (( show_hidden )); then
        shopt -s dotglob
      else
        shopt -u dotglob
      fi

      for entry in */; do
        [[ -e "$entry" ]] || continue
        entry="${entry%/}"
        dirs+=("$entry")
      done

      for entry in *; do
        [[ -e "$entry" ]] || continue
        [[ -d "$entry" ]] && continue
        files+=("$entry")
      done

      (( had_nullglob )) || shopt -u nullglob
      (( had_dotglob )) && shopt -s dotglob || shopt -u dotglob

      DIRECTORY_CAPTURE_ENTRIES=("${dirs[@]}" "${files[@]}")
    }

    capture_directory_rows_bsd_ls() {
      local output=""
      local entry
      local lsy_bsd_ls_color_mode="${LSY_BSD_LS_COLOR:-auto}"
      local -a ls_args=() ls_extra_args=()
      local -a stat_args=()

      collect_directory_entries
      if (( ${#DIRECTORY_CAPTURE_ENTRIES[@]} == 0 )); then
        ROWS_COLOR=()
        return 0
      fi

      ls_args=(-ldh -D '%Y-%m-%d %H:%M')
      case "$lsy_bsd_ls_color_mode" in
        0|off|false|no|never)
          ;;
        *)
          ls_args+=(-G)
          ;;
      esac
      if [[ -n "$LSY_BSD_LS_EXTRA_ARGS" ]]; then
        read -r -a ls_extra_args <<< "$LSY_BSD_LS_EXTRA_ARGS"
        ls_args+=("${ls_extra_args[@]}")
      fi

      if output="$(LC_ALL=C CLICOLOR_FORCE=1 ls "${ls_args[@]}" -- "${DIRECTORY_CAPTURE_ENTRIES[@]}" 2>/dev/null)"; then
        read_stdin_into_array ROWS_COLOR <<< "$output"
        return 0
      fi

      for entry in "${DIRECTORY_CAPTURE_ENTRIES[@]}"; do
        stat_args+=("$(safe_command_path "$entry")")
      done

      output="$(LC_ALL=C stat -f '%Sp %Su %z %Sm %N' -t '%Y-%m-%d %H:%M' "${stat_args[@]}" 2>/dev/null)" || return 1
      read_stdin_into_array ROWS_COLOR <<< "$output"
      return 0
    }

    cleanup() {
      sshfs_unmount_session_mounts
      cleanup_fuse_zip_mounts
      if [[ -n "$EXPORT_FILE" ]]; then
        pwd > "$EXPORT_FILE"
      fi
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      printf "\033[0m\033[2J\033[H"
    }

    run_interactive_command() {
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return 0
    }

    run_interactive_command_with_status() {
      local rc=0
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      rc=$?
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    run_interactive_preview_command() {
      local rc=0
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      rc=$?
      if [[ "$LSY_CHAFA_HOLD" == "1" ]]; then
        printf "\n\033[2mPress any key to return...\033[0m"
        IFS= read -rsn1 || true
      fi
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    run_audio_preview_command() {
      local rc=0
      local key=""
      local pid=0
      local paused=0

      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear

      "$@" &
      pid=$!

      # Poll keys while playback runs; q/Esc/Ctrl+C stop, Space toggles pause/resume.
      stty -echo -icanon -ixon intr undef min 0 time 1
      while kill -0 "$pid" 2>/dev/null; do
        IFS= read -rsn1 key || true
        case "$key" in
          q|$'\e'|$'\003')
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            rc=130
            break
            ;;
          ' ')
            if (( paused )); then
              kill -CONT "$pid" 2>/dev/null || true
              paused=0
            else
              kill -STOP "$pid" 2>/dev/null || true
              paused=1
            fi
            ;;
        esac
      done

      if (( rc == 0 )); then
        wait "$pid" 2>/dev/null || rc=$?
      fi

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    read_yes_no_prompt() {
      local prompt="$1"
      local key
      local tty="/dev/tty"

      [[ -w "$tty" ]] || tty="/proc/self/fd/2"

      # Flush any queued key bytes so the confirm prompt doesn't auto-consume stale input.
      while IFS= read -rsn1 -t 0.001 key; do :; done

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"

      key="$(read_key || true)"
      printf "\033[?25l" >"$tty"
      case "$key" in
        y|Y) return 0 ;;
        *) return 1 ;;
      esac
    }

    read_line_prompt() {
      local prompt="$1"
      local initial_value="$2"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty echo <"$tty"
      if (( HAS_READLINE_DEFAULTS )); then
        IFS= read -r -e -i "$initial_value" -p "$prompt" value <"$tty" >"$tty" 2>&1
      else
        printf "%s" "$prompt" >"$tty"
        if [[ -n "$initial_value" ]]; then
          printf "%s" "$initial_value" >"$tty"
        fi
        IFS= read -r value <"$tty"
        [[ -z "$value" ]] && value="$initial_value"
      fi
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    read_secret_prompt() {
      local prompt="$1"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"
      IFS= read -r -s value <"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    sanitize_filename_input() {
      local value="$1"
      # Remove non-printable control bytes that can be accidentally captured from terminal control output.
      value="$(printf '%s' "$value" | tr -d '\000-\037\177')"
      printf '%s' "$value"
    }

    trim_whitespace() {
      local value="$1"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      printf '%s' "$value"
    }

    infer_download_name_from_url() {
      local url="$1"
      local stripped host_port host path name

      _download_name=""
      _download_used_host=0

      stripped="${url%%#*}"
      stripped="${stripped%%\?*}"

      if [[ "$stripped" == *://* ]]; then
        host_port="${stripped#*://}"
      else
        host_port="$stripped"
      fi

      host_port="${host_port%%/*}"
      host="${host_port%%:*}"

      path="${stripped#*://}"
      path="/${path#*/}"
      if [[ "$stripped" != *://* ]]; then
        path="/${stripped#*/}"
      fi

      if [[ "$path" == "/" || "$stripped" == */ ]]; then
        name=""
      else
        name="${stripped##*/}"
        [[ "$name" == "$host" ]] && name=""
      fi

      name="$(sanitize_filename_input "$name")"
      if [[ -z "$name" ]]; then
        name="$(sanitize_filename_input "$host")"
        _download_used_host=1
      fi

      if [[ -z "$name" ]]; then
        name="download"
        _download_used_host=1
      fi

      _download_name="$name"
    }

    download_file_from_url() {
      local url suggested_name target_name rc

      if (( !HAS_WGET && !HAS_CURL )); then
        draw_status
        printf "\033[%d;1H\033[K\033[2mDownload unavailable: install/enable wget or curl in integrations.\033[0m" "$rows"
        return 1
      fi

      url="$(read_line_prompt "Download URL: " "")"
      url="$(trim_whitespace "$url")"
      [[ -n "$url" ]] || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mDownload cancelled.\033[0m" "$rows"
        return 1
      }

      infer_download_name_from_url "$url"
      suggested_name="$_download_name"
      target_name="$suggested_name"

      if (( _download_used_host )); then
        target_name="$(read_line_prompt "Save as: " "$suggested_name")"
        target_name="$(sanitize_filename_input "$target_name")"
      fi

      target_name="$(trim_whitespace "$target_name")"
      [[ -n "$target_name" ]] || {
        draw_status
        printf "\033[%d;1H\033[K\033[2mDownload cancelled.\033[0m" "$rows"
        return 1
      }

      if [[ "$target_name" == */* ]]; then
        draw_status
        printf "\033[%d;1H\033[K\033[2mDownload failed: use a file name only (no '/').\033[0m" "$rows"
        return 1
      fi

      if [[ -e "$target_name" || -L "$target_name" ]]; then
        target_name="$(read_line_prompt "Target exists, save as: " "$target_name")"
        target_name="$(sanitize_filename_input "$target_name")"
        target_name="$(trim_whitespace "$target_name")"
        [[ -n "$target_name" ]] || {
          draw_status
          printf "\033[%d;1H\033[K\033[2mDownload cancelled.\033[0m" "$rows"
          return 1
        }
        if [[ "$target_name" == */* ]]; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mDownload failed: use a file name only (no '/').\033[0m" "$rows"
          return 1
        fi
        if [[ -e "$target_name" || -L "$target_name" ]]; then
          draw_status
          printf "\033[%d;1H\033[K\033[2mDownload failed: target exists: %s\033[0m" "$rows" "$target_name"
          return 1
        fi
      fi

      if (( HAS_WGET )); then
        run_interactive_command_with_status wget -O "$target_name" -- "$url"
        rc=$?
      else
        run_interactive_command_with_status curl -fL --output "$target_name" -- "$url"
        rc=$?
      fi

      if (( rc != 0 )); then
        [[ -f "$target_name" && ! -s "$target_name" ]] && rm -f -- "$target_name"
        draw_status
        printf "\033[%d;1H\033[K\033[2mDownload failed (exit %d).\033[0m" "$rows" "$rc"
        return 1
      fi

      load_data
      position_cursor_for_name "$target_name" >/dev/null 2>&1 || true
      draw_ui
      printf "\033[%d;1H\033[K\033[2mDownloaded: %s\033[0m" "$rows" "$target_name"
      return 0
    }

    is_age_file() {
