    LSY_DEBUG_SOURCE="${LSY_DEBUG_SOURCE:-1}"
    LSY_DEBUG_SHOW_CMD="${LSY_DEBUG_SHOW_CMD:-0}"
    LSY_DEBUG_PASTE="${LSY_DEBUG_PASTE:-1}"
    LSY_SHOW_DEBUG_FOOTER="${LSY_SHOW_DEBUG_FOOTER:-0}"
    LSY_GIT_DIRTY_CHECK="${LSY_GIT_DIRTY_CHECK:-1}"
    LSY_CHAFA_HOLD="${LSY_CHAFA_HOLD:-1}"
    LSY_CHAFA_ARGS="${LSY_CHAFA_ARGS:---animate=off --symbols vhalf --size 100%x60%}"
    LSY_GLOW_ARGS="${LSY_GLOW_ARGS:-}"
    LSY_CSVLENS_ARGS="${LSY_CSVLENS_ARGS:-}"
    LSY_JNV_ARGS="${LSY_JNV_ARGS:-}"
    LSY_RG_ARGS="${LSY_RG_ARGS:-}"
    LSY_FZF_ARGS="${LSY_FZF_ARGS:---ansi --reverse}"
    LSY_DELTA_ARGS="${LSY_DELTA_ARGS:---side-by-side --line-numbers}"
    LSY_SOX_ARGS="${LSY_SOX_ARGS:---stat -brief}"
      LSY_PLAY_ARGS="${LSY_PLAY_ARGS:-}"
    LSY_FUSE_ZIP_ARGS="${LSY_FUSE_ZIP_ARGS:-}"
    LSY_FUSE_ZIP_MOUNT_ROOT="${LSY_FUSE_ZIP_MOUNT_ROOT:-}"
    LSY_UNZIP_ARGS="${LSY_UNZIP_ARGS:-}"
    LSY_ZIP_ARGS="${LSY_ZIP_ARGS:-}"
    LSY_EDITOR="${LSY_EDITOR:-}"
    LIST_SOURCE="${LSY_LIST_SOURCE:-}"   # empty = auto-select best available in detect_sources()
    FILE_VIEWER="${LSY_FILE_VIEWER:-}"   # empty = auto-select best available in detect_sources()
    NAME_FIRST_VIEW="${LSY_NAME_FIRST_VIEW:-1}"
    LSY_EZA_ICONS="${LSY_EZA_ICONS:-always}"
    LSY_EZA_COLOR="${LSY_EZA_COLOR:-always}"
    LSY_EZA_COLOR_SCALE="${LSY_EZA_COLOR_SCALE:-}"
    LSY_EZA_COLOR_SCALE_MODE="${LSY_EZA_COLOR_SCALE_MODE:-}"
    LSY_EZA_HYPERLINK="${LSY_EZA_HYPERLINK:-0}"
    LSY_EZA_EXTRA_ARGS="${LSY_EZA_EXTRA_ARGS:-}"
    LSY_EZA_SHOW_LINKS="${LSY_EZA_SHOW_LINKS:-0}"
    LSY_EZA_SHOW_GROUP="${LSY_EZA_SHOW_GROUP:-0}"
    LSY_EZA_NO_QUOTES="${LSY_EZA_NO_QUOTES:-1}"
    LSY_LSD_ICONS="${LSY_LSD_ICONS:-always}"
    LSY_LSD_COLOR="${LSY_LSD_COLOR:-always}"
    LSY_LSD_ICON_THEME="${LSY_LSD_ICON_THEME:-}"  # empty = auto-select in detect_sources()
    LSY_LSD_HYPERLINK="${LSY_LSD_HYPERLINK:-never}"
    LSY_LSD_BLOCKS="${LSY_LSD_BLOCKS:-permission,user,group,size,date,name}"
    LSY_LSD_EXTRA_ARGS="${LSY_LSD_EXTRA_ARGS:-}"

    declare -a ROWS_COLOR=()
    declare -a ROWS_PLAIN=()
    declare -a ROWS_SELECT_PLAIN=()
    declare -a ROWS_PATH=()
    declare -a ROWS_SELECTED=()
    declare -A DISABLED_INTEGRATIONS=()
    declare -A SELECTED_PATHS=()
    declare -a CLIPBOARD_ITEMS=()
    declare -a CLIPBOARD_MULTI=()
    EXPORT_FILE=""

    cursor=0
    top=0
    rows=0
    cols=0
    visible_rows=0
    show_hidden=0
    SHOW_DEBUG_FOOTER=0
    HAS_EZA=0
    HAS_LSD=0
    HAS_BAT=0
    HAS_BATCAT=0
    HAS_CHAFA=0
    HAS_GLOW=0
    HAS_CSVLENS=0
    HAS_JNV=0
    HAS_RG=0
    HAS_FZF=0
    HAS_DELTA=0
    HAS_FUSE_ZIP=0
    HAS_UNZIP=0
    HAS_ZIPCMD=0
    HAS_TAR=0
    HAS_7Z=0
    HAS_RAR=0
    HAS_ZIP=0
    orig_stty=""
    LAST_LOAD_MS=0
    LAST_LS_MS=0
    LAST_PARSE_MS=0
    ENTRY_COUNT=0
    LAST_SOURCE_REQUESTED="-"
    LAST_SOURCE_EXECUTED="-"
    LAST_SOURCE_RC=0
    LAST_SOURCE_FALLBACK=0
    LAST_SOURCE_FALLBACK_TO="-"
    LAST_SOURCE_ARGS="-"
    SELECTED_COUNT=0
    CLIPBOARD_MODE="copy"
    CLIPBOARD_LABEL="none"
    CLIPBOARD_PATH=""
    CLIPBOARD_NAME=""
    CLIPBOARD_MOVE=0
    LAST_CLIP_MODE="-"
    LAST_CLIP_REQUESTED=0
    LAST_CLIP_RESOLVED=0
    LAST_CLIP_DROPPED=0
    LAST_PASTE_OP="-"
    LAST_PASTE_RC=0
    LAST_PASTE_ERR="-"
    LAST_PASTE_OK=0
    LAST_PASTE_FAIL=0
    LAST_PASTE_SKIP=0
    GIT_HEADER_SUFFIX=""
    GIT_HEADER_CACHE_PWD=""
    GIT_HEADER_CACHE_SUFFIX=""
    GIT_HEADER_CACHE_ENABLED="-1"
    FUSE_ZIP_SESSION_DIR=""
    FUSE_ZIP_MOUNT_COUNTER=0
    declare -A ZIP_MOUNT_BY_ARCHIVE=()
    declare -A ZIP_ARCHIVE_BY_MOUNT=()
    declare -a ZIP_MOUNT_ORDER=()

    usage() {
      cat <<'EOF'
Usage: lsy [--export-path FILE] [--help]

Options:
  --export-path FILE  Write final working directory to FILE on exit.
  --help              Show this help text and exit.
EOF
    }

    parse_args() {
      while (($# > 0)); do
        case "$1" in
          --export-path)
            if [[ -z "${2-}" ]]; then
              echo "Error: --export-path requires a file path." >&2
              exit 1
            fi
            EXPORT_FILE="$2"
            shift 2
            ;;
          --help)
            usage
            exit 0
            ;;
          *)
            echo "Error: unknown option '$1'." >&2
            usage >&2
            exit 1
            ;;
        esac
      done
    }

    init_runtime_config() {
      if [[ "$LSY_SHOW_DEBUG_FOOTER" == "1" ]]; then
        SHOW_DEBUG_FOOTER=1
      else
        SHOW_DEBUG_FOOTER=0
      fi
    }

    cleanup() {
      cleanup_fuse_zip_mounts
      if [[ -n "$EXPORT_FILE" ]]; then
        pwd > "$EXPORT_FILE"
      fi
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      printf "\033[0m\033[2J\033[H"
    }

    run_interactive_command() {
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return 0
    }

    run_interactive_preview_command() {
      local rc=0
      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear
      "$@"
      rc=$?
      if [[ "$LSY_CHAFA_HOLD" == "1" ]]; then
        printf "\n\033[2mPress any key to return...\033[0m"
        IFS= read -rsn1 || true
      fi
      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    run_audio_preview_command() {
      local rc=0
      local key=""
      local pid=0
      local paused=0

      printf "\033[?25h"
      stty "$orig_stty" 2>/dev/null || true
      clear

      "$@" &
      pid=$!

      # Poll keys while playback runs; q/Esc/Ctrl+C stop, Space toggles pause/resume.
      stty -echo -icanon -ixon intr undef min 0 time 1
      while kill -0 "$pid" 2>/dev/null; do
        IFS= read -rsn1 key || true
        case "$key" in
          q|$'\e'|$'\003')
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            rc=130
            break
            ;;
          ' ')
            if (( paused )); then
              kill -CONT "$pid" 2>/dev/null || true
              paused=0
            else
              kill -STOP "$pid" 2>/dev/null || true
              paused=1
            fi
            ;;
        esac
      done

      if (( rc == 0 )); then
        wait "$pid" 2>/dev/null || rc=$?
      fi

      stty -echo cbreak -ixon intr undef
      printf "\033[?25l"
      on_resize
      return $rc
    }

    read_yes_no_prompt() {
      local prompt="$1"
      local key
      local tty="/dev/tty"

      [[ -w "$tty" ]] || tty="/proc/self/fd/2"

      # Flush any queued key bytes so the confirm prompt doesn't auto-consume stale input.
      while IFS= read -rsn1 -t 0.001 key; do :; done

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      printf "%s" "$prompt" >"$tty"

      key="$(read_key || true)"
      printf "\033[?25l" >"$tty"
      case "$key" in
        y|Y) return 0 ;;
        *) return 1 ;;
      esac
    }

    read_line_prompt() {
      local prompt="$1"
      local initial_value="$2"
      local value=""
      local tty="/dev/tty"

      [[ -r "$tty" && -w "$tty" ]] || tty="/proc/self/fd/2"

      printf "\033[?25h" >"$tty"
      printf "\033[%d;1H\033[K" "$rows" >"$tty"
      stty echo <"$tty"
      IFS= read -r -e -i "$initial_value" -p "$prompt" value <"$tty" >"$tty" 2>&1
      stty -echo cbreak -ixon intr undef <"$tty"
      printf "\033[?25l" >"$tty"

      value="$(sanitize_filename_input "$value")"
      printf '%s' "$value"
    }

    sanitize_filename_input() {
      local value="$1"
      # Remove non-printable control bytes that can be accidentally captured from terminal control output.
      value="$(printf '%s' "$value" | tr -d '\000-\037\177')"
      printf '%s' "$value"
    }

    on_resize() {
      rows=$(tput lines)
      cols=$(tput cols)
      visible_rows=$(( rows - 3 ))
      (( visible_rows < 1 )) && visible_rows=1
      draw_ui
    }

    detect_sources() {
      # Detect list source tools (prefer eza > lsd > ls); respect user-disabled integrations.
      if command -v eza >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[eza]+x}" ]]; then
        HAS_EZA=1
      else
        HAS_EZA=0
      fi

      if command -v lsd >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[lsd]+x}" ]]; then
        HAS_LSD=1
      else
        HAS_LSD=0
      fi

      if [[ -z "$LIST_SOURCE" ]]; then
        if (( HAS_EZA )); then
          LIST_SOURCE=eza
        elif (( HAS_LSD )); then
          LIST_SOURCE=lsd
        else
          LIST_SOURCE=ls
        fi
      else
        case "$LIST_SOURCE" in
          ls|lsd|eza) ;;
          *) LIST_SOURCE=ls ;;
        esac
        if [[ "$LIST_SOURCE" == "eza" ]] && (( !HAS_EZA )); then
          (( HAS_LSD )) && LIST_SOURCE=lsd || LIST_SOURCE=ls
        fi
        [[ "$LIST_SOURCE" == "lsd" ]] && (( !HAS_LSD )) && LIST_SOURCE=ls
      fi

      # Detect file viewer tools (prefer bat > batcat > less); respect user-disabled integrations.
      if command -v bat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]]; then
        HAS_BAT=1
      else
        HAS_BAT=0
      fi

      if command -v batcat >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[bat]+x}" ]] && [[ -z "${DISABLED_INTEGRATIONS[batcat]+x}" ]]; then
        HAS_BATCAT=1
      else
        HAS_BATCAT=0
      fi

      if command -v chafa >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[chafa]+x}" ]]; then
        HAS_CHAFA=1
      else
        HAS_CHAFA=0
      fi

      if command -v glow >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[glow]+x}" ]]; then
        HAS_GLOW=1
      else
        HAS_GLOW=0
      fi

      if command -v csvlens >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[csvlens]+x}" ]]; then
        HAS_CSVLENS=1
      else
        HAS_CSVLENS=0
      fi

      if command -v jnv >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[jnv]+x}" ]]; then
        HAS_JNV=1
      else
        HAS_JNV=0
      fi

      if command -v rg >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[rg]+x}" ]]; then
        HAS_RG=1
      else
        HAS_RG=0
      fi

      if command -v fzf >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[fzf]+x}" ]]; then
        HAS_FZF=1
      else
        HAS_FZF=0
      fi

      if command -v delta >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[delta]+x}" ]]; then
        HAS_DELTA=1
      else
        HAS_DELTA=0
      fi

      if command -v fuse-zip >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[fuse-zip]+x}" ]]; then
        HAS_FUSE_ZIP=1
      else
        HAS_FUSE_ZIP=0
      fi

      if command -v sox >/dev/null 2>&1 && [[ -z "${DISABLED_INTEGRATIONS[sox]+x}" ]]; then
        HAS_SOX=1
      else
        HAS_SOX=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[zip]+x}" ]] && command -v unzip >/dev/null 2>&1; then
        HAS_UNZIP=1
      else
        HAS_UNZIP=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[zip]+x}" ]] && command -v zip >/dev/null 2>&1; then
        HAS_ZIPCMD=1
      else
        HAS_ZIPCMD=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[tar]+x}" ]] && command -v tar >/dev/null 2>&1; then
        HAS_TAR=1
      else
        HAS_TAR=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[7z]+x}" ]] && command -v 7z >/dev/null 2>&1; then
        HAS_7Z=1
      else
        HAS_7Z=0
      fi

      if [[ -z "${DISABLED_INTEGRATIONS[rar]+x}" ]]; then
        if command -v unrar >/dev/null 2>&1 || command -v rar >/dev/null 2>&1; then
          HAS_RAR=1
        else
          HAS_RAR=0
        fi
      else
        HAS_RAR=0
      fi

      if (( HAS_UNZIP || HAS_ZIPCMD || HAS_TAR || HAS_7Z || HAS_RAR )); then
        HAS_ZIP=1
      else
        HAS_ZIP=0
      fi

      if [[ -z "$FILE_VIEWER" ]]; then
        if (( HAS_BAT )); then
          FILE_VIEWER=bat
        elif (( HAS_BATCAT )); then
          FILE_VIEWER=batcat
        else
          FILE_VIEWER=less
        fi
      fi

      if [[ -z "$LSY_LSD_ICON_THEME" ]]; then
        [[ "${NERD_FONT_ACTIVE:-0}" == "1" ]] && LSY_LSD_ICON_THEME=fancy || LSY_LSD_ICON_THEME=unicode
      fi
    }

    lsd_blocks_with_required_date() {
      local blocks="$1"
      local out=()
      local part
      local has_date=0
      local has_name=0

      IFS=',' read -r -a out <<< "$blocks"
      for part in "${out[@]}"; do
        [[ "$part" == "date" ]] && has_date=1
        [[ "$part" == "name" ]] && has_name=1
      done

      (( has_date )) || out+=(date)
      (( has_name )) || out+=(name)

      local joined=""
      for part in "${out[@]}"; do
        [[ -n "$joined" ]] && joined+=","
        joined+="$part"
      done
      printf '%s' "$joined"
    }

    capture_directory_rows() {
      local requested_source="${1:-$LIST_SOURCE}"
      local source="$LIST_SOURCE"
      local output=""

      LAST_SOURCE_REQUESTED="$requested_source"
      LAST_SOURCE_FALLBACK=0
      LAST_SOURCE_FALLBACK_TO="-"

      while true; do
        case "$source" in
          ls)
            local -a ls_args=()
            ls_args=(-lh --group-directories-first --time-style=long-iso --quoting-style=literal)
            (( show_hidden )) && ls_args+=(-A)
            LAST_SOURCE_EXECUTED="ls"
            LAST_SOURCE_ARGS="ls ${ls_args[*]} --color=always"
            if output="$(LC_ALL=C ls "${ls_args[@]}" --color=always 2>/dev/null | sed '1{/^total /d;}')"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="ls"
              break
            fi
            LAST_SOURCE_RC=$?
            ROWS_COLOR=()
            return "$LAST_SOURCE_RC"
            ;;
          eza)
            if (( !HAS_EZA )); then
              LAST_SOURCE_EXECUTED="eza"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a eza_args=() eza_extra_args=()
            eza_args=(--long --modified --group-directories-first --time-style=long-iso --icons="$LSY_EZA_ICONS" --color="$LSY_EZA_COLOR")
            case "$LSY_EZA_HYPERLINK" in
              1|on|true|yes|always|auto)
                eza_args+=(--hyperlink)
                ;;
            esac
            [[ -n "$LSY_EZA_COLOR_SCALE" ]] && eza_args+=(--color-scale="$LSY_EZA_COLOR_SCALE")
            [[ -n "$LSY_EZA_COLOR_SCALE_MODE" ]] && eza_args+=(--color-scale-mode="$LSY_EZA_COLOR_SCALE_MODE")
            [[ "$LSY_EZA_SHOW_LINKS" == "1" ]] && eza_args+=(--links)
            [[ "$LSY_EZA_SHOW_GROUP" == "1" ]] && eza_args+=(--group)
            [[ "$LSY_EZA_NO_QUOTES" == "1" ]] && eza_args+=(--no-quotes)
            if [[ -n "$LSY_EZA_EXTRA_ARGS" ]]; then
              read -r -a eza_extra_args <<< "$LSY_EZA_EXTRA_ARGS"
              eza_args+=("${eza_extra_args[@]}")
            fi
            (( show_hidden )) && eza_args+=(--almost-all)
            LAST_SOURCE_EXECUTED="eza"
            LAST_SOURCE_ARGS="eza ${eza_args[*]}"
            if output="$(eza "${eza_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="eza"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            (( HAS_LSD )) && LAST_SOURCE_FALLBACK_TO=lsd || LAST_SOURCE_FALLBACK_TO=ls
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          lsd)
            if (( !HAS_LSD )); then
              LAST_SOURCE_EXECUTED="lsd"
              LAST_SOURCE_RC=127
              LAST_SOURCE_FALLBACK=1
              (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
              source="$LAST_SOURCE_FALLBACK_TO"
              LIST_SOURCE="$source"
              continue
            fi

            local -a lsd_args=() lsd_extra_args=()
            local lsd_blocks
            lsd_blocks="$(lsd_blocks_with_required_date "$LSY_LSD_BLOCKS")"
            lsd_args=(-lh --group-dirs first --date '+%F %R' --blocks "$lsd_blocks" --icon "$LSY_LSD_ICONS" --icon-theme "$LSY_LSD_ICON_THEME" --color "$LSY_LSD_COLOR" --hyperlink "$LSY_LSD_HYPERLINK")
            if [[ -n "$LSY_LSD_EXTRA_ARGS" ]]; then
              read -r -a lsd_extra_args <<< "$LSY_LSD_EXTRA_ARGS"
              lsd_args+=("${lsd_extra_args[@]}")
            fi
            (( show_hidden )) && lsd_args+=(-A)
            LAST_SOURCE_EXECUTED="lsd"
            LAST_SOURCE_ARGS="lsd ${lsd_args[*]}"
            if output="$(lsd "${lsd_args[@]}" 2>/dev/null)"; then
              LAST_SOURCE_RC=0
              LIST_SOURCE="lsd"
              break
            fi
            LAST_SOURCE_RC=$?
            LAST_SOURCE_FALLBACK=1
            (( HAS_EZA )) && LAST_SOURCE_FALLBACK_TO=eza || LAST_SOURCE_FALLBACK_TO=ls
            source="$LAST_SOURCE_FALLBACK_TO"
            LIST_SOURCE="$source"
            ;;
          *)
            LAST_SOURCE_EXECUTED="$source"
            LAST_SOURCE_RC=1
            ROWS_COLOR=()
            return 1
            ;;
        esac
      done

      if [[ -n "$output" ]]; then
        mapfile -t ROWS_COLOR <<< "$output"
      else
        ROWS_COLOR=()
      fi
      return 0
    }

    open_file_with_viewer() {
      local item="$1"
      local mime=""
      local -a chafa_args=()
      local -a glow_args=()
      local -a csvlens_args=()
      local -a jnv_args=()
      local -a play_args=()
      local -a sox_args=()

      if (( HAS_JNV )) && is_jnv_file "$item"; then
        if [[ -n "$LSY_JNV_ARGS" ]]; then
          read -r -a jnv_args <<< "$LSY_JNV_ARGS"
        fi
        run_interactive_command jnv "${jnv_args[@]}" "$item"
        return $?
      fi

      if (( HAS_CSVLENS )) && is_csvlens_file "$item"; then
        if [[ -n "$LSY_CSVLENS_ARGS" ]]; then
          read -r -a csvlens_args <<< "$LSY_CSVLENS_ARGS"
        fi
        run_interactive_command csvlens "${csvlens_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_GLOW )) && is_markdown_file "$item"; then
        if [[ -n "$LSY_GLOW_ARGS" ]]; then
          read -r -a glow_args <<< "$LSY_GLOW_ARGS"
        fi
        run_interactive_command glow -p "${glow_args[@]}" -- "$item"
        return $?
      fi

      if (( HAS_SOX )) && is_audio_file "$item"; then
          if command -v play >/dev/null 2>&1; then
            if [[ -n "$LSY_PLAY_ARGS" ]]; then
              read -r -a play_args <<< "$LSY_PLAY_ARGS"
            fi
            run_audio_preview_command play "${play_args[@]}" -- "$item"
          elif command -v sox >/dev/null 2>&1; then
            if [[ -n "$LSY_SOX_ARGS" ]]; then
              read -r -a sox_args <<< "$LSY_SOX_ARGS"
            fi
            run_audio_preview_command sox -- "$item" -d "${sox_args[@]}"
          else
            return 1
          fi
        return $?
      fi

      if (( HAS_CHAFA )); then
        if command -v file >/dev/null 2>&1; then
          mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        fi

        if [[ "$mime" == image/* ]]; then
          if [[ -n "$LSY_CHAFA_ARGS" ]]; then
            read -r -a chafa_args <<< "$LSY_CHAFA_ARGS"
          fi
          run_interactive_preview_command chafa "${chafa_args[@]}" -- "$item"
          return $?
        fi
      fi

      case "$FILE_VIEWER" in
        less)
          command -v less >/dev/null 2>&1 || return 1
          run_interactive_command less -- "$item"
          ;;
        bat)
          (( HAS_BAT )) || return 1
          run_interactive_command bat --paging=always -- "$item"
          ;;
        batcat)
          (( HAS_BATCAT )) || return 1
          run_interactive_command batcat --paging=always -- "$item"
          ;;
        *)
          return 1
          ;;
      esac
      return 0
    }

    is_audio_file() {
      local item="$1"
      local lower="${item,,}"

      case "$lower" in
        *.wav|*.mp3|*.flac|*.aiff|*.aif|*.opus|*.ogg|*.oga|*.wma|*.m4a|*.aac|*.alac|*.ape|*.dsf|*.dsd)
          return 0
          ;;
      esac

      if command -v file >/dev/null 2>&1; then
        local mime
        mime="$(file --brief --mime-type -- "$item" 2>/dev/null || true)"
        [[ "$mime" == audio/* ]] && return 0
      fi
      return 1
    }

    is_markdown_file() {
      local item="$1"
